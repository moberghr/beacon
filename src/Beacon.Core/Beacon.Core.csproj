<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- Package Information -->
		<Authors>Moberg</Authors>
		<Description>Beacon core library providing semantic alerts and notifications for databases. Includes domain models, services, and data access abstractions for PostgreSQL, SQL Server, and MySQL support.</Description>
		<PackageProjectUrl>https://github.com/moberghr/beacon</PackageProjectUrl>
		<RepositoryUrl>https://github.com/moberghr/beacon</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
		<PackageTags>beacon;database;alerts;notifications;postgresql;sqlserver;mysql</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<IsPackable>true</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Beacon.SampleProject" />
		<InternalsVisibleTo Include="Beacon.Api" />
		<InternalsVisibleTo Include="Beacon.Tests" />
	</ItemGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="AdaptiveCards" />
		<PackageReference Include="ClosedXML" />
		<PackageReference Include="CronExpressionDescriptor" />
		<PackageReference Include="Cronos" />
		<PackageReference Include="CsvHelper" />
		<PackageReference Include="Dapper" />
		<PackageReference Include="EFCore.BulkExtensions" />
		<PackageReference Include="MediatR" />
		<PackageReference Include="MessageCardModel" />
		<PackageReference Include="Microsoft.AspNetCore.DataProtection.EntityFrameworkCore" />
		<PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" />
		<PackageReference Include="Microsoft.EntityFrameworkCore" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
		<PackageReference Include="Microsoft.Extensions.Caching.Memory" />
		<PackageReference Include="Microsoft.Extensions.Http" />
		<!-- Pomelo 9.0.0 is the newest release and targets EF Core 9; no EF Core 10 build exists yet.
		     Pinned explicitly (was a transitive dep of EFCore.BulkExtensions 9.x before the net10/EF10
		     move) so MigrationService.Sql.cs's MySQL bulk-write path (UseMySql) still compiles on EF10.
		     It compiles and restores, but the MySQL bulk path is runtime-UNVERIFIED on EF Core 10 —
		     revisit when Pomelo ships an EF Core 10 build. -->
		<PackageReference Include="Pomelo.EntityFrameworkCore.MySql" />
		<PackageReference Include="Refit" />
		<PackageReference Include="SqlParserCS" />
		<PackageReference Include="Microsoft.Data.Sqlite" />
		<PackageReference Include="System.IdentityModel.Tokens.Jwt" />
		<PackageReference Include="Microsoft.IdentityModel.Tokens" />
	</ItemGroup>

</Project>
