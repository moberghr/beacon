<Project Sdk="Microsoft.NET.Sdk.Razor">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>

        <!-- Package Information -->
        <Authors>Moberg</Authors>
        <Description>MCP (Model Context Protocol) server for Beacon. Exposes data sources, knowledge graph, and query capabilities to AI tools via SSE transport.</Description>
        <PackageProjectUrl>https://github.com/moberghr/beacon</PackageProjectUrl>
        <RepositoryUrl>https://github.com/moberghr/beacon</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
        <PackageTags>beacon;mcp;model-context-protocol;ai;sse</PackageTags>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Beacon.Tests" />
        <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="ModelContextProtocol.AspNetCore" />
        <PackageReference Include="SqlParserCS" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Beacon.Core\Beacon.Core.csproj" />
        <ProjectReference Include="..\Beacon.AI\Beacon.AI.csproj" />
    </ItemGroup>


</Project>
