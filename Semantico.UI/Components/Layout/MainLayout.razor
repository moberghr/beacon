@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout Class="semantico-layout">
    <MudAppBar Elevation="0" Dense="false" Class="semantico-appbar">
        <div class="appbar-brand-spacer"></div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTooltip Text="@(_isDark ? "Light Mode" : "Dark Mode")" Placement="Placement.Bottom">
                <MudIconButton Icon="@(_isDark ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="@ChangeTheme"
                               Class="appbar-icon-btn" />
            </MudTooltip>
            <MudTooltip Text="Settings" Placement="Placement.Bottom">
                <MudIconButton Icon="@Icons.Material.Outlined.Settings"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               Class="appbar-icon-btn" />
            </MudTooltip>
            <MudDivider Vertical="true" FlexItem="true" Class="appbar-divider" />
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="appbar-user-chip">
                        <MudAvatar Size="Size.Small" Style="height: 22px; width: 22px; font-size: 0.7rem;" Color="Color.Secondary">A</MudAvatar>
                        <MudText Typo="Typo.body2" Class="ml-2">Admin</MudText>
                    </MudChip>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Person">Profile</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Settings">Settings</MudMenuItem>
                    <MudDivider Class="my-1" />
                    <MudMenuItem Icon="@Icons.Material.Outlined.Logout">Logout</MudMenuItem>
                </ChildContent>
            </MudMenu>
        </MudStack>
    </MudAppBar>
    <MudDrawer Open="true" ClipMode="DrawerClipMode.Never" Elevation="0" Width="250px" Class="semantico-drawer">
        <div class="drawer-header-wrapper">
            <div class="drawer-brand-header">
                <img src="../_content/Semantico.UI/favicon.svg" alt="Semantico" class="drawer-logo" />
                <div class="drawer-brand-text">
                    <span class="drawer-title">Semantico</span>
                    <span class="drawer-version">v0.99</span>
                </div>
            </div>
            <div class="drawer-gradient-fade"></div>
        </div>
        <MudNavMenu Class="drawer-nav" Bordered="false">
            <MudNavLink Href="@($"{GetBaseHref()}dashboard")" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">Home</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-sources")" Icon="@Icons.Material.Filled.Folder" IconColor="Color.Secondary">Data Sources</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}ai-actors")" Icon="@Icons.Material.Filled.SmartToy" IconColor="Color.Tertiary">AI Actors</MudNavLink>
            <MudNavGroup Title="Alerts" Icon="@Icons.Material.Filled.NotificationsActive" IconColor="Color.Info" Expanded="true" HideExpandIcon="true">
                <MudNavLink Href="@($"{GetBaseHref()}recipients")" Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">Recipients</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}queries")" Icon="@Icons.Material.Filled.Search" IconColor="Color.Info">Queries</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}subscriptions")" Icon="@Icons.Material.Filled.Subscriptions" IconColor="Color.Success">Subscriptions</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}notifications")" Icon="@Icons.Material.Filled.Notifications" IconColor="Color.Warning">Notifications</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}tasks")" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">Tasks</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="@($"{GetBaseHref()}data-migration")" Icon="@Icons.Material.Filled.SwapHoriz" IconColor="Color.Error">Data Migration</MudNavLink>
            <MudDivider Class="my-2"/>
            <MudNavLink Href="@($"{GetBaseHref()}about")" Icon="@Icons.Material.Filled.Info" IconColor="Color.Warning">About</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pb-12">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@inject IBrowserViewportService BrowserViewportService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

@code
{
    private static bool _isDark = true;
    private Breakpoint _breakpoint;

    private string GetBaseHref()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath;
        return path.EndsWith("/") ? path : $"{path}/";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            await LoadTheme();
            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task ChangeTheme()
    {
        _isDark = !_isDark;
        await LocalStorage.SetItemAsync("IsDark", _isDark.ToString()); 
        await LoadTheme();
    }
    
    private async Task LoadTheme()
    {
        // Load code highlighting CSS
        if (_isDark)
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github-dark.css");
        }
        else
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github.css");
        }

        // Update Mermaid theme
        try
        {
            var theme = _isDark ? "dark" : "default";
            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    if (typeof mermaid !== 'undefined') {{
                        mermaid.initialize({{
                            startOnLoad: false,
                            theme: '{theme}'
                        }});
                        console.log('Mermaid theme updated to: {theme}');
                    }}
                }})();
            ");
        }
        catch
        {
            // Silently ignore if mermaid is not yet loaded
        }
    }
}