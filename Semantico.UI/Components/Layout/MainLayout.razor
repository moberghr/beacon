@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@using Semantico.Core
@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout Class="@($"semantico-layout {(_isDark ? "mud-theme-dark" : "")}")">
    <MudAppBar Elevation="0" Dense="false" Class="semantico-appbar">
        <div class="appbar-brand-spacer"></div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTooltip Text="@(_isDark ? "Light Mode" : "Dark Mode")" Placement="Placement.Bottom">
                <MudIconButton Icon="@(_isDark ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="@ChangeTheme"
                               Class="appbar-icon-btn" />
            </MudTooltip>
            <MudTooltip Text="Settings" Placement="Placement.Bottom">
                <MudIconButton Icon="@Icons.Material.Outlined.Settings"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="@NavigateToSettings"
                               Class="appbar-icon-btn" />
            </MudTooltip>
            <MudDivider Vertical="true" FlexItem="true" Class="appbar-divider" />
            @if (UserContext.IsAuthenticated)
            {
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="appbar-user-chip">
                            <MudAvatar Size="Size.Small" Style="height: 22px; width: 22px; font-size: 0.7rem;" Color="Color.Secondary">@GetUserInitial()</MudAvatar>
                            <MudText Typo="Typo.body2" Class="ml-2">@(UserContext.DisplayName ?? UserContext.UserName ?? "User")</MudText>
                        </MudChip>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Settings" OnClick="NavigateToSettings">Settings</MudMenuItem>
                        <MudDivider Class="my-1" />
                        <MudMenuItem Icon="@Icons.Material.Outlined.Logout" OnClick="HandleLogout">Logout</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            }
            else
            {
                <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="appbar-user-chip">
                    <MudText Typo="Typo.body2">Guest</MudText>
                </MudChip>
            }
        </MudStack>
    </MudAppBar>
    <MudDrawer Open="true" ClipMode="DrawerClipMode.Never" Elevation="0" Width="250px" Class="semantico-drawer">
        <div class="drawer-header-wrapper">
            <div class="drawer-brand-header">
                <img src="../_content/Semantico.UI/favicon.svg" alt="Semantico" class="drawer-logo" />
                <div class="drawer-brand-text">
                    <span class="drawer-title">Semantico</span>
                    <span class="drawer-version">v0.99</span>
                </div>
            </div>
            <div class="drawer-gradient-fade"></div>
        </div>
        <MudNavMenu Class="drawer-nav" Bordered="false">
            <MudNavLink Href="@($"{GetBaseHref()}dashboard")" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">Home</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}control-tower")" Icon="@Icons.Material.Filled.Dashboard" IconColor="Color.Info">Control Tower</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}dashboards")" Icon="@Icons.Material.Filled.Widgets" IconColor="Color.Tertiary">Dashboards</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-sources")" Icon="@Icons.Material.Filled.Folder" IconColor="Color.Secondary">Data Sources</MudNavLink>
            @if (Configuration?.UseAI == true)
            {
                <MudNavLink Href="@($"{GetBaseHref()}ai-actors")" Icon="@Icons.Material.Filled.SmartToy" IconColor="Color.Tertiary">AI Actors</MudNavLink>
            }
            <MudNavGroup Title="Alerts" Icon="@Icons.Material.Filled.NotificationsActive" IconColor="Color.Info" Expanded="true" HideExpandIcon="true">
                <MudNavLink Href="@($"{GetBaseHref()}recipients")" Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">Recipients</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}queries")" Icon="@Icons.Material.Filled.Search" IconColor="Color.Info">Queries</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}subscriptions")" Icon="@Icons.Material.Filled.Subscriptions" IconColor="Color.Success">Subscriptions</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}notifications")" Icon="@Icons.Material.Filled.Notifications" IconColor="Color.Warning">Notifications</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}tasks")" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">Tasks</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="@($"{GetBaseHref()}data-quality")" Icon="@Icons.Material.Filled.VerifiedUser" IconColor="Color.Success">
                Data Quality
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Style="font-size: 0.6rem; height: 18px; margin-left: 4px;">BETA</MudChip>
            </MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}semantico/projects")" Icon="@Icons.Material.Filled.FolderSpecial" IconColor="Color.Tertiary">Projects</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-migration")" Icon="@Icons.Material.Filled.SwapHoriz" IconColor="Color.Error">Data Migration</MudNavLink>
            @if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
            {
                <MudNavLink Href="@($"{GetBaseHref()}approvals")" Icon="@Icons.Material.Filled.Approval" IconColor="Color.Warning">
                    Approvals
                    @if (_pendingApprovalCount > 0)
                    {
                        <MudBadge Content="@_pendingApprovalCount" Color="Color.Error" Overlap="true" Class="ml-2" />
                    }
                </MudNavLink>
            }
            @if (Configuration?.UserManagement.Enabled == true && HasAdminRole())
            {
                <MudDivider Class="my-2"/>
                <MudNavLink Href="@($"{GetBaseHref()}users")" Icon="@Icons.Material.Filled.AdminPanelSettings" IconColor="Color.Error">User Management</MudNavLink>
            }
            <MudNavGroup Title="MCP" Icon="@Icons.Material.Filled.SmartToy" IconColor="Color.Info" Expanded="true" HideExpandIcon="true">
                <MudNavLink Href="@($"{GetBaseHref()}semantico/data-catalog")" Icon="@Icons.Material.Filled.LibraryBooks" IconColor="Color.Info">Data Catalog</MudNavLink>
                @if (HasAdminRole())
                {
                    <MudNavLink Href="@($"{GetBaseHref()}semantico/settings/api-keys")" Icon="@Icons.Material.Filled.VpnKey" IconColor="Color.Secondary">API Keys</MudNavLink>
                    <MudNavLink Href="@($"{GetBaseHref()}semantico/settings/mcp")" Icon="@Icons.Material.Filled.SmartToy" IconColor="Color.Secondary">MCP Settings</MudNavLink>
                    <MudNavLink Href="@($"{GetBaseHref()}semantico/settings/mcp/playground")" Icon="@Icons.Material.Filled.Terminal" IconColor="Color.Secondary">MCP Playground</MudNavLink>
                    <MudNavLink Href="@($"{GetBaseHref()}semantico/settings/mcp-learning")" Icon="@Icons.Material.Filled.Psychology" IconColor="Color.Secondary">MCP Learning</MudNavLink>
                }
            </MudNavGroup>
            @if (HasAdminRole())
            {
                <MudNavLink Href="@($"{GetBaseHref()}admin/settings")" Icon="@Icons.Material.Filled.Tune" IconColor="Color.Warning">Admin Settings</MudNavLink>
            }
            <MudDivider Class="my-2"/>
            <MudNavLink Href="@($"{GetBaseHref()}about")" Icon="@Icons.Material.Filled.Info" IconColor="Color.Warning">About</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pb-12">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@inject IBrowserViewportService BrowserViewportService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject SemanticoConfiguration Configuration
@inject Semantico.Core.Authorization.ISemanticoUserContext UserContext

@inject Semantico.Core.Services.IQueryApprovalService ApprovalService

@code
{
    private bool _isDark = true;
    private Breakpoint _breakpoint;
    private int _pendingApprovalCount;

    private string GetBaseHref()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath;
        return path.EndsWith("/") ? path : $"{path}/";
    }

    private string GetUserInitial()
    {
        var name = UserContext.DisplayName ?? UserContext.UserName;
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        return name.Substring(0, 1).ToUpperInvariant();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            await LoadTheme();

            if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
            {
                _pendingApprovalCount = await ApprovalService.GetPendingCountAsync();
            }

            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task ChangeTheme()
    {
        _isDark = !_isDark;
        await LocalStorage.SetItemAsync("IsDark", _isDark.ToString()); 
        await LoadTheme();
    }
    
    private async Task LoadTheme()
    {
        // Load code highlighting CSS
        if (_isDark)
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github-dark.css");
        }
        else
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github.css");
        }

        // Update Mermaid theme
        try
        {
            var theme = _isDark ? "dark" : "default";
            await JS.InvokeVoidAsync("updateMermaidTheme", theme);
        }
        catch
        {
            // Silently ignore if mermaid is not yet loaded
        }
    }

    private void HandleLogout()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}api/auth/signout", forceLoad: true);
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}settings");
    }

    private bool HasAdminRole()
    {
        // Check if user has Admin role or is SuperAdmin
        // For now, check claims for "Admin" role
        return UserContext.HasClaim("role", "Admin") ||
               UserContext.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", "Admin");
    }
}