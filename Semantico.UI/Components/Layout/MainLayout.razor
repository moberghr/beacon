@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" ToolBarClass="px-3">
        <HomeButton />
        <MudSpacer />
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <ThemeIconButton @bind-IsDark="@_isDark" OnClick="@ChangeTheme" />
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" Size="Size.Medium" />
        </MudStack>
    </MudAppBar>
    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="2" Width="250px">
        <MudNavMenu Class="pa-2" Bordered="true">
            <div class="d-flex flex-column align-center pa-4">
                <MudText Typo="Typo.h5" Class="fw-bold">Moberg</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="mt-1">v0.8</MudChip>
            </div>
            <MudDivider Class="my-2"/>
            <MudNavLink Href="@($"{GetBaseHref()}dashboard")" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">Home</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-sources")" Icon="@Icons.Material.Filled.Folder" IconColor="Color.Secondary">Data Sources</MudNavLink>
            <MudNavGroup Title="Alerts" Icon="@Icons.Material.Filled.NotificationsActive" IconColor="Color.Info" Expanded="true" HideExpandIcon="true">
                <MudNavLink Href="@($"{GetBaseHref()}recipients")" Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">Recipients</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}queries")" Icon="@Icons.Material.Filled.Search" IconColor="Color.Info">Queries</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}subscriptions")" Icon="@Icons.Material.Filled.Subscriptions" IconColor="Color.Success">Subscriptions</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}notifications")" Icon="@Icons.Material.Filled.Notifications" IconColor="Color.Warning">Notifications</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}tasks")" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">Tasks</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="@($"{GetBaseHref()}data-migration")" Icon="@Icons.Material.Filled.SwapHoriz" IconColor="Color.Error">Data Migration</MudNavLink>
            <MudDivider Class="my-2"/>
            <MudNavLink Href="@($"{GetBaseHref()}about")" Icon="@Icons.Material.Filled.Info" IconColor="Color.Default">About</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pb-12">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@inject IBrowserViewportService BrowserViewportService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

@code
{
    private static bool _isDark = true;
    private Breakpoint _breakpoint;

    private string GetBaseHref()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath;
        return path.EndsWith("/") ? path : $"{path}/";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            await LoadTheme();
            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task ChangeTheme()
    {
        _isDark = !_isDark;
        await LocalStorage.SetItemAsync("IsDark", _isDark.ToString()); 
        await LoadTheme();
    }
    
    private async Task LoadTheme()
    {
        // Load code highlighting CSS
        if (_isDark)
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github-dark.css");
        }
        else
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Semantico.UI/highlight/styles/github.css");
        }

        // Update Mermaid theme
        try
        {
            var theme = _isDark ? "dark" : "default";
            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    if (typeof mermaid !== 'undefined') {{
                        mermaid.initialize({{
                            startOnLoad: false,
                            theme: '{theme}'
                        }});
                        console.log('Mermaid theme updated to: {theme}');
                    }}
                }})();
            ");
        }
        catch
        {
            // Silently ignore if mermaid is not yet loaded
        }
    }
}