@page "/semantico/projects/{ProjectId:int}"
@inherits BasePageComponent
@using MediatR
@using Semantico.Core.Handlers.Projects
@using Markdig
@inject IMediator Mediator
@inject IJSRuntime JS

<SemanticoPageTitle Title="@(_project?.Name ?? "Project Details")"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
    }
    else if (_project == null)
    {
        <MudAlert Severity="Severity.Error">Project not found.</MudAlert>
    }
    else
    {
        <MudStack Spacing="4">
            @* Back + Header *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => NavManager.NavigateTo("semantico/projects"))"/>
                    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Size="Size.Large" Color="Color.Primary"/>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h5" Style="font-weight: 600;">@_project.Name</MudText>
                        @if (!string.IsNullOrWhiteSpace(_project.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_project.Description</MudText>
                        }
                    </MudStack>
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="ScanAll"
                               Disabled="_scanning">
                        @(_scanning ? "Scanning..." : "Scan All")
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.MenuBook"
                               OnClick="GenerateDocumentation"
                               Disabled="_generatingDocs">
                        @(_generatingDocs ? "Generating..." : "Generate Documentation")
                    </MudButton>
                </MudStack>
            </MudStack>

            @* Overview Summary Cards *@
            <MudGrid Spacing="3">
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; text-align: center;">
                        <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Primary">@_project.TotalTables</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Tables</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; text-align: center;">
                        <MudText Typo="Typo.h4" Style="font-weight: 700;"
                                 Color="@GetScoreColor(_project.QualityScore)">
                            @(_project.QualityScore.HasValue ? $"{_project.QualityScore:F0}%" : "N/A")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Quality Score</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; text-align: center;">
                        <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Info">@_project.CodeReferenceCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Code References</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; text-align: center;">
                        <MudText Typo="Typo.body1" Style="font-weight: 600;">
                            @(_project.LastScanAt.HasValue ? _project.LastScanAt.Value.ToString("MMM dd HH:mm") : "Never")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Last Scan</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Tabs *@
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" ActivePanelIndex="_activeTab" ActivePanelIndexChanged="OnTabChanged">

                @* Overview Tab *@
                <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
                    <MudGrid Spacing="3" Class="mt-3">
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 8px;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-3">Data Sources</MudText>
                                @if (_project.DataSources.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No data sources linked.</MudText>
                                }
                                else
                                {
                                    foreach (var ds in _project.DataSources)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Color="Color.Secondary"/>
                                                <MudText Typo="Typo.body2">@ds.Name</MudText>
                                            </MudStack>
                                            <MudChip T="string" Size="Size.Small" Color="@GetScoreColor(ds.QualityScore)" Variant="Variant.Filled">
                                                @(ds.QualityScore.HasValue ? $"{ds.QualityScore:F0}%" : "N/A")
                                            </MudChip>
                                        </MudStack>
                                    }
                                }
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 8px;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-3">Repositories</MudText>
                                @if (_project.Repositories.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No repositories linked.</MudText>
                                }
                                else
                                {
                                    foreach (var repo in _project.Repositories)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Secondary"/>
                                                <MudText Typo="Typo.body2">@repo.Name</MudText>
                                            </MudStack>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@GetScanStatusColor(repo.ScanStatus)"
                                                     Variant="Variant.Outlined">
                                                @(repo.ScanStatus ?? "Not scanned")
                                            </MudChip>
                                        </MudStack>
                                    }
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* Data Sources Tab *@
                <MudTabPanel Text="Data Sources" Icon="@Icons.Material.Filled.Storage" BadgeData="@_project.DataSources.Count" BadgeColor="Color.Primary">
                    <MudStack Spacing="2" Class="mt-3">
                        @if (_project.DataSources.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">No data sources linked to this project.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@_project.DataSources" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Tables</MudTh>
                                    <MudTh>Quality Score</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd><MudText Typo="Typo.body2">@context.Name</MudText></MudTd>
                                    <MudTd><MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Storage">@context.Type</MudChip></MudTd>
                                    <MudTd><MudText Typo="Typo.body2">@context.TableCount</MudText></MudTd>
                                    <MudTd>
                                        @if (context.QualityScore.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetScoreColor(context.QualityScore)">
                                                @($"{context.QualityScore:F0}%")
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Not evaluated</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudStack>
                </MudTabPanel>

                @* Repositories Tab *@
                <MudTabPanel Text="Repositories" Icon="@Icons.Material.Filled.Code" BadgeData="@_project.Repositories.Count" BadgeColor="Color.Primary">
                    <MudStack Spacing="2" Class="mt-3">
                        @if (_project.Repositories.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">No repositories linked.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@_project.Repositories" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh>Name</MudTh>
                                    <MudTh>URL</MudTh>
                                    <MudTh>Auth</MudTh>
                                    <MudTh>Scan Status</MudTh>
                                    <MudTh>Last Scan</MudTh>
                                    <MudTh>References Found</MudTh>
                                    <MudTh Style="width: 50px;"></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd><MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Name</MudText></MudTd>
                                    <MudTd>
                                        <MudLink Href="@context.Url" Target="_blank" Typo="Typo.caption">
                                            @(context.Url.Length > 40 ? context.Url[..40] + "..." : context.Url)
                                        </MudLink>
                                    </MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.HasAccessToken ? Color.Success : Color.Default)"
                                                 Variant="Variant.Outlined">
                                            @(context.HasAccessToken ? "Token set" : "Public")
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@GetScanStatusColor(context.ScanStatus)"
                                                 Variant="Variant.Filled">
                                            @(context.ScanStatus ?? "Not scanned")
                                        </MudChip>
                                    </MudTd>
                                    <MudTd><MudText Typo="Typo.caption">@(context.LastScanAt?.ToString("MMM dd HH:mm") ?? "—")</MudText></MudTd>
                                    <MudTd><MudText Typo="Typo.body2">@context.ReferenceCount</MudText></MudTd>
                                    <MudTd>
                                        <MudIconButton Icon="@Icons.Material.Filled.Key"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Title="Set access token"
                                                       OnClick="@(() => SetRepoToken(context))"/>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudStack>
                </MudTabPanel>

                @* Documentation Tab *@
                <MudTabPanel Text="Documentation" Icon="@Icons.Material.Filled.MenuBook">
                    <MudStack Spacing="3" Class="mt-3">
                        @if (_loadingDocs)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
                        }
                        else if (_documentation?.Latest == null)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-2">
                                No documentation generated yet. Click the button below to generate comprehensive AI-powered documentation
                                covering business domains, data model, data flows, code lineage, and more.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.AutoAwesome"
                                       OnClick="GenerateDocumentation"
                                       Disabled="_generatingDocs" Size="Size.Large">
                                @(_generatingDocs ? "Generating Documentation..." : "Generate Documentation")
                            </MudButton>
                        }
                        else
                        {
                            @* Stats bar *@
                            <MudPaper Elevation="1" Class="pa-3" Style="border-radius: 8px;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Generated @_documentation.Latest.GeneratedAt.ToString("yyyy-MM-dd HH:mm") UTC
                                        </MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                            @_documentation.Latest.GeneratedByModel
                                        </MudChip>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(_documentation.Latest.DataSourcesAnalyzed) sources · @(_documentation.Latest.TablesAnalyzed) tables · @(_documentation.Latest.CodeReferencesAnalyzed) refs
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @((_documentation.Latest.InputTokens + _documentation.Latest.OutputTokens).ToString("N0")) tokens · @("$" + _documentation.Latest.EstimatedCost.ToString("F4"))
                                        </MudText>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       Title="Export as Markdown"
                                                       OnClick="@(() => ExportDocumentation(false))"/>
                                        <MudIconButton Icon="@Icons.Material.Filled.Html"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       Title="Export as HTML"
                                                       OnClick="@(() => ExportDocumentation(true))"/>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Refresh"
                                                   OnClick="GenerateDocumentation"
                                                   Disabled="_generatingDocs">
                                            Regenerate
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>

                            @* Section navigation + content *@
                            <MudGrid Spacing="3">
                                @* Left nav *@
                                <MudItem xs="12" md="3">
                                    <MudPaper Elevation="1" Class="pa-3" Style="border-radius: 8px; position: sticky; top: 80px;">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">Sections</MudText>
                                        <MudNavMenu Dense="true">
                                            @foreach (var navSection in _documentation.Latest.Sections)
                                            {
                                                <MudNavLink OnClick="@(() => ScrollToSection(navSection.SectionType.ToString()))">
                                                    @navSection.Title
                                                </MudNavLink>
                                            }
                                        </MudNavMenu>

                                        @if (_documentation.History.Count > 1)
                                        {
                                            <MudDivider Class="my-3"/>
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">History</MudText>
                                            @foreach (var entry in _documentation.History.Skip(1).Take(5))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                                    @entry.GeneratedAt.ToString("MMM dd HH:mm") — @entry.TablesAnalyzed tables
                                                </MudText>
                                            }
                                        }
                                    </MudPaper>
                                </MudItem>

                                @* Content *@
                                <MudItem xs="12" md="9">
                                    @foreach (var docSection in _documentation.Latest.Sections)
                                    {
                                        <MudPaper Elevation="1" Class="pa-4 mb-3" Style="border-radius: 8px;" id="@docSection.SectionType.ToString()">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@docSection.Title</MudText>
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               Title="Edit section"
                                                               OnClick="@(() => EditSection(docSection))"/>
                                            </MudStack>
                                            @((MarkupString)RenderMarkdown(docSection.Content))
                                        </MudPaper>
                                    }
                                </MudItem>
                            </MudGrid>
                        }
                    </MudStack>
                </MudTabPanel>

            </MudTabs>
        </MudStack>
    }
</MudContainer>

@inject ISnackbar Snackbar
@inject IDialogService DialogService

@code {
    [Parameter]
    public int ProjectId { get; set; }

    private ProjectDetailEntry? _project;
    private GetProjectDocumentationResult? _documentation;
    private bool _loading = true;
    private bool _loadingDocs;
    private int _activeTab;

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnInitializedAsync()
    {
        await LoadProject();
    }

    private async Task LoadProject()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new GetProjectDetailQuery(ProjectId));
            _project = result.Project;

            if (_project?.HasDocumentation == true)
                await LoadDocumentation();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load project: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnTabChanged(int index)
    {
        _activeTab = index;
        if (index == 3 && _documentation?.Latest != null)
        {
            await Task.Delay(300);
            await JS.InvokeVoidAsync("renderMermaidDiagrams");
        }
    }

    private async Task LoadDocumentation()
    {
        _loadingDocs = true;
        try
        {
            _documentation = await Mediator.Send(new GetProjectDocumentationQuery(ProjectId));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load documentation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingDocs = false;
        }
    }

    private bool _scanning;
    private bool _generatingDocs;

    private async Task ScanAll()
    {
        if (_project?.Repositories is not { Count: > 0 })
        {
            Snackbar.Add("No repositories to scan.", Severity.Warning);
            return;
        }

        _scanning = true;
        StateHasChanged();
        try
        {
            Snackbar.Add("Scanning all repositories...", Severity.Info);
            var result = await Mediator.Send(new ScanAllRepositoriesCommand(ProjectId));

            if (result.Errors.Count > 0)
            {
                foreach (var error in result.Errors)
                    Snackbar.Add(error, Severity.Warning);
            }

            await LoadProject();
            Snackbar.Add($"Scanned {result.ScannedCount} repositories.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Scan failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _scanning = false;
            StateHasChanged();
        }
    }

    private async Task GenerateDocumentation()
    {
        _generatingDocs = true;
        StateHasChanged();
        try
        {
            await Mediator.Send(new GenerateProjectDocumentationCommand(ProjectId, 0));
            Snackbar.Add("Documentation generation started in the background. This page will refresh when complete.", Severity.Info);
            _ = PollForDocumentationCompletion();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Documentation generation failed: {ex.Message}", Severity.Error);
            _generatingDocs = false;
            StateHasChanged();
        }
    }

    private async Task PollForDocumentationCompletion()
    {
        var existingDocId = _documentation?.Latest?.Id;
        for (var i = 0; i < 120; i++) // poll for up to 10 minutes
        {
            await Task.Delay(5000);
            try
            {
                var result = await Mediator.Send(new GetProjectDocumentationQuery(ProjectId));
                if (result.Latest != null && result.Latest.Id != existingDocId)
                {
                    _documentation = result;
                    _generatingDocs = false;
                    Snackbar.Add("Documentation generated successfully.", Severity.Success);
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(300);
                    await JS.InvokeVoidAsync("renderMermaidDiagrams");
                    return;
                }
            }
            catch
            {
                // ignore polling errors
            }
        }

        _generatingDocs = false;
        Snackbar.Add("Documentation generation is taking longer than expected. Check back later.", Severity.Warning);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExportDocumentation(bool asHtml)
    {
        if (_documentation?.Latest == null) return;
        try
        {
            var result = await Mediator.Send(new ExportProjectDocumentationCommand(_documentation.Latest.Id, asHtml));
            // TODO: Trigger file download via JS interop
            Snackbar.Add($"Export ready: {result.FileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private static string RenderMarkdown(string markdown)
    {
        return Markdig.Markdown.ToHtml(markdown, MarkdownPipeline);
    }

    private async Task ScrollToSection(string sectionId)
    {
        // Scroll to the section element by ID
        await Task.CompletedTask; // JS interop would be needed for actual scrolling
    }

    private async Task SetRepoToken(ProjectRepositoryEntry repo)
    {
        var parameters = new DialogParameters<SetRepositoryTokenDialog>
        {
            { x => x.RepositoryId, repo.Id },
            { x => x.RepositoryName, repo.Name },
            { x => x.HasExistingToken, repo.HasAccessToken }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SetRepositoryTokenDialog>("Set Access Token", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadProject();
    }

    private async Task EditSection(ProjectDocSectionEntry section)
    {
        var parameters = new DialogParameters<EditDocumentationSectionDialog>
        {
            { x => x.SectionId, section.Id },
            { x => x.SectionTitle, section.Title },
            { x => x.InitialContent, section.Content }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<EditDocumentationSectionDialog>(
            $"Edit: {section.Title}", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadDocumentation();
            StateHasChanged();
        }
    }

    private static Color GetScoreColor(double? score) => score switch
    {
        >= 90 => Color.Success,
        >= 70 => Color.Warning,
        < 70 => Color.Error,
        _ => Color.Default
    };

    private static Color GetScanStatusColor(string? status) => status switch
    {
        "Completed" => Color.Success,
        "InProgress" => Color.Info,
        "Failed" => Color.Error,
        _ => Color.Default
    };

}
