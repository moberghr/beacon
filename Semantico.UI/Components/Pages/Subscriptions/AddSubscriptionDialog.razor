@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Subscriptions
@using Semantico.Core.Services
<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1 mb-n1" />
            Add subscription
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1" @bind-Errors="@errors" @bind-IsValid="_isFormValid">
            <MudTextField
                OnlyValidateIfDirty="true"
                Margin="Margin.Normal"
                Variant="Variant.Text"
                Class="mb-2"
                @bind-Value="@Subscription.Recipient"
                T="String"
                Label="Recipient"
                Required="true"
            />
            <MudTextField
                OnlyValidateIfDirty="true"
                Immediate="true"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Class="mb-2"
                @bind-Value="@Subscription.CronExpression"
                Placeholder="* * * * *"
                Validation="@(new Func<string, string>(ValidateCron))"
                T="String"
                Label="Cron"
                Required="true"
            />
            <MudSelect T="NotificationType" Label="Notification Type" @bind-Value="@Subscription.NotificationType" Required="true">
    <MudSelectItem Value="NotificationType.Email">Email</MudSelectItem>
    <MudSelectItem Value="NotificationType.Teams">Teams</MudSelectItem>
    <MudSelectItem Value="NotificationType.Jira">Jira</MudSelectItem>
</MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton
            Class="ml-4"
            OnClick="@Cancel"
            Variant="Variant.Filled"
        >
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="!_isFormValid" OnClick="@Submit"/>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject ISubscriptionService Service

@code
{
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public SubscriptionData Subscription { get; set; } = new SubscriptionData();

    private MudForm _form;
    private bool _loading;
    bool _isFormValid = false;
    string[] errors = { };

    async Task Submit()
    {
        if (_loading)
        {
            return;
        }

        await _form.Validate();
        
        if (!_form.IsValid)
        {
            return;
        }

        _loading = true;
        var response = await Service.CreateSubscriptionAsync(Subscription, CancellationToken.None);
        
        if (response.Success)
        {
            MudDialog.Close(DialogResult.Ok(true));
            Snackbar.Add(response.Message, Severity.Success);
        }
        else
        {
            Snackbar.Add(response.Message, Severity.Error);
        }
        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();

    private string ValidateCron(string cron)
    {
        // todo: let's see how to validate best
        if (NCrontab.Advanced.CrontabSchedule.TryParse(cron) == null)
        {
            return "Invalid cron expression";
        }

        return string.Empty;
    }
}