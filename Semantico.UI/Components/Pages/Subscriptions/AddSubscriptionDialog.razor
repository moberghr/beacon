@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Subscriptions
@using Semantico.Core.Models.Recipients
@using Semantico.Core.Services
<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1 mb-n1" />
            Add subscription
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1" @bind-Errors="@errors" @bind-IsValid="_isFormValid">
            <MudTextField OnlyValidateIfDirty="true"
            Immediate="true"
            Margin="Margin.Dense"
            Variant="Variant.Outlined"
            Class="mb-2"
            @bind-Value="@Subscription.CronExpression"
            Placeholder="* * * * *"
            Validation="@(new Func<string, Task<string>>(ValidateCron))"
            T="String"
            HelperText="@_cronDescription"
            Label="Cron"
            Required="true" />
            <MudSelect T="string" Label="Recipient" MultiSelection="true" @bind-SelectedValues="_selectedRecipientIds" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                @{
                    foreach (var recipient in _recipients)
                    {
                        <MudSelectItem T="string" Value="@recipient.RecipientId.ToString()">@recipient.Name</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton
        Class="ml-4"
        OnClick="@Cancel"
        Variant="Variant.Filled"
        >
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="!_isFormValid" OnClick="@Submit"/>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject ISubscriptionService Service
@inject IRecipientService RecipientService
@inject IJSRuntime JSRuntime

@code
{
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public SubscriptionData Subscription { get; set; } = new SubscriptionData();

    private List<RecipientData> _recipients { get; set; } = [];

    private string _cronDescription { get; set; } = "";

    private IEnumerable<string> _selectedRecipientIds { get; set; } = [];

    private MudForm _form;
    private bool _loading;
    bool _isFormValid = false;
    string[] errors = { };

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        _recipients = await RecipientService.GetRecipients(null, default);

        _loading = false;
    }

    async Task Submit()
    {
        if (_loading)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        _loading = true;

        Subscription.Recipients = _recipients.Where(x => _selectedRecipientIds.Contains(x.RecipientId.ToString())).ToList();

        var response = await Service.CreateSubscription(Subscription, CancellationToken.None);

        if (response.Success)
        {
            MudDialog.Close(DialogResult.Ok(true));
            Snackbar.Add(response.Message, Severity.Success);
        }
        else
        {
            Snackbar.Add(response.Message, Severity.Error);
        }
        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();

    private async Task<string> ValidateCron(string cron)
    {
        if (!Cronos.CronExpression.TryParse(cron, out Cronos.CronExpression? expression))
        {
            _cronDescription = "";

            return "Invalid cron expression";
        }

        _cronDescription = cron.GetCronDescription();

        var cronNextAt = cron.GetCronNextAt();
        var localNextAt = await JSRuntime.InvokeAsync<string>("toLocalTime", cronNextAt);

        _cronDescription += $" -> next at: {localNextAt}";

        return string.Empty;
    }
}