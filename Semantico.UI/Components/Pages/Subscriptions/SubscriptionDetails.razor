@page "/subscriptions/details/{id:int}"
@inherits BasePageComponent
@using Semantico.Core.Models.QueryExecutionHistory
@using Semantico.Core.Models.Subscriptions
@using Semantico.Core.Models.Recipients
@using Semantico.Core.Services
@using Semantico.Core.Worker
@using SortDirection = MudBlazor.SortDirection

<SemanticoPageTitle Title="Query"/>

<MudContainer Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Subscriptions" Title="Subscription details" Alert="@Model?.Status" AlertSeverity="@(isSubscriptionActive ? Severity.Success : Severity.Error)" ButtonIcon="@Icons.Material.Outlined.Archive" ButtonText="Archive" ButtonDisabled="@(!isSubscriptionActive)" OnClick="@ArchiveSubscription">
        <MudItem xs="6" sm="2" md="2" lg="2" Class="d-flex justify-end">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(async () => await TestSubscription())">Test</MudButton>
        </MudItem>
    </SemanticoPageHeader>
    <MudCard Class="my-4 px-2">
        <MudCardContent>
            @if (_loading)
            {
                <MudSkeleton />
            }
            else
            {
                <MudGrid Justify="Justify.FlexStart" Spacing="1">
                    <MudItem xs="12" sm="12" md="5" lg="5">
                        <MudStack Spacing="5">
                            <MudText>
                                <strong>Query:</strong> @Model?.QueryName <br />
                                <strong>Query ID:</strong> @Model?.QueryId
                            </MudText>
                            <MudText>
                                <strong>Cron:</strong> @Model?.CronExpression <br />
                                @_cronDescription <br />
                                @_cronNextAt
                            </MudText>
                            <MudText>
                                <strong>Max Rows:</strong> @(Model?.MaxRows.HasValue == true ? Model.MaxRows.ToString() : "All") <br />
                                <strong>Include Attachment:</strong> @(Model?.IncludeAttachment == true ? "Yes" : "No") <br />
                                <strong>Show Query in Notification:</strong> @(Model?.ShowQuery == true ? "Yes" : "No") <br />
                                <strong>Query timeout:</strong> @Model?.TimeoutSeconds
                            </MudText>
                            <MudText>
                                <strong>Parameters:</strong> @Model?.Parameters.ToJson()
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="12" md="7" lg="7">
                        <MudStack Spacing="1">
                            <MudTable Items="@Model?.Recipients" Hover="true">
                                <ToolBarContent>
                                    <MudText Typo="Typo.h6">Recipients</MudText>
                                    <MudSpacer />
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(async () => await AddRecipientsAsync())">Add Recipients</MudButton>
                                </ToolBarContent>
                                <HeaderContent>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Destination</MudTh>
                                    <MudTh>Notification Type</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Name">@context.Name</MudTd>
                                    <MudTd DataLabel="Destination">@(context.Destination.Length <= 30 ? context.Destination : context.Destination.Substring(0, 30) + " ...")</MudTd>
                                    <MudTd DataLabel="Notification Type">@context.NotificationType</MudTd>
                                    <MudTd><MudIconButton Size="Size.Small" Disabled="@(Model?.Recipients?.Count <= 1)" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(async () => await RemoveRecipientAsync(context))"></MudIconButton></MudTd>
                                </RowTemplate>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new int[] { 4 }"
                                    HorizontalAlignment="HorizontalAlignment.Center"
                                    HideRowsPerPage="true"
                                    HidePageNumber="true" />
                                </PagerContent>
                            </MudTable>
                        </MudStack>
                    </MudItem>
                    <MudItem>
                        <MudStack Spacing="1">
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>
        <MudCardContent>
            <MudItem xs="12">
                <MudContainer Class="my-4 px-4">
                    <MudDataGrid @ref="_notificationsDataGrid" ServerData="NotificationsServerReload" T="QueryExecutionHistoryData" Hover="true" Filterable="false">
                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Execution history</MudText>
                        </ToolBarContent>
                        <Columns>
                            <PropertyColumn InitialDirection="SortDirection.Descending" Property="x => x.CreatedTime" Title="Created"/>
                            <PropertyColumn Property="x => x.QueryExecutionHistoryId" Title="Id"/>
                            <TemplateColumn Title="Recipients">
                                <CellTemplate>
                                    @($"[{context.Item.Notifications.Count}] {string.Join(", ", context.Item.Notifications.Select(x => x.RecipientName).ToList()).GetSubstring(50)}")
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.ResultCount"/>
                            <PropertyColumn Property="x => x.NotificationStatus"/>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="QueryExecutionHistoryData" />
                        </PagerContent>
                    </MudDataGrid>
                </MudContainer>
            </MudItem>

        </MudCardContent>
    </MudCard>
</MudContainer>

@inject ISubscriptionService Service
@inject IQueryService QueryService
@inject IJobService JobService
@inject INotificationService NotificationsService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

@code
{
    [Parameter]
    public int Id { get; set; }

    public SubscriptionDetailsData? Model;

    private bool _loading;

    private QueryExecutionHistoryListData List { get; set; } = new();

    MudDataGrid<QueryExecutionHistoryData>? _notificationsDataGrid;

    private bool isSubscriptionActive;

    private string? _cronDescription;
    private string? _cronNextAt;

    private async Task<GridData<QueryExecutionHistoryData>> NotificationsServerReload(GridState<QueryExecutionHistoryData> state)
    {
        var gridRequest = DataGridHelper.BuildSortedRequest<GetQueryExecutionHistoryRequest, QueryExecutionHistoryData>(state);

        gridRequest.SubscriptionId = Id;

        List = await NotificationsService.GetQueryExecutionHistory(gridRequest, CancellationToken.None);

        return new GridData<QueryExecutionHistoryData> {
            TotalItems = List.Data.Count,
            Items = List.Data
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _cronDescription = Model?.CronExpression?.GetCronDescription();

        var cronNextAt = Model?.CronExpression?.GetCronNextAt();
        var localNextAt = await JSRuntime.InvokeAsync<string>("toLocalTime", cronNextAt);

        _cronNextAt = $"next at: {localNextAt}";

    }

    private async Task Load()
    {
        _loading = true;

        Model = await Service.GetSubscriptionDetails(Id, CancellationToken.None);

        isSubscriptionActive = Model?.Status == "Active";
        
        await _notificationsDataGrid!.ReloadServerData();
        
        _loading = false;
    }

    private async Task ArchiveSubscription()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning", 
            "Do you want to archive this subscription?",
            yesText: "Yes",
            cancelText: "No");

        if (result == null || !result.Value)
        {
            return;
        }

        await Service.DeleteSubscription(Id, CancellationToken.None);

        await Load();
    }
    
    private async Task TestSubscription()
    {
        await JobService.ExecuteQuery(Id);

        await Load();
    }

    private async Task AddRecipientsAsync()
    {
        var parameters = new DialogParameters<AddRecipientsDialog> { { x => x.Subscription, Model }};

        var dialog = await DialogService.ShowAsync<AddRecipientsDialog>("", parameters);
        var result = await dialog.Result;

        if (!result?.Canceled ?? false)
        {
            await Load();
        }
    }

    private async Task RemoveRecipientAsync(RecipientData recipientData)
    {
        await Service.RemoveRecipient(Model!.SubscriptionId, recipientData!.RecipientId!.Value, CancellationToken.None);

        await Load();
    }
}