@page "/semantico/subscriptions/details/{id:int}"
@inherits BasePageComponent
@using Semantico.Core.Models.QueryExecutionHistory
@using Semantico.Core.Models.Subscriptions
@using Semantico.Core.Services

<SemanticoPageTitle Title="Query"/>

<MudContainer Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Subscriptions" Title="Subscription details" Alert="@Model?.Status" AlertSeverity="@(isSubscriptionActive ? Severity.Success : Severity.Error)" ButtonIcon="@Icons.Material.Outlined.Archive" ButtonText="Archive" ButtonDisabled="@(!isSubscriptionActive)" OnClick="@ArchiveSubscription"/>
    <MudCard Class="my-4 px-2">
        <MudCardContent>
            @if (_loading)
            {
                <MudSkeleton />
            }
            else
            {
                <MudGrid Justify="Justify.FlexStart" Spacing="1">
                    <MudItem xs="12" sm="12" md="5" lg="5">
                        <MudStack Spacing="5">
                            <MudText>
                                <strong>Query:</strong> @Model?.QueryName
                            </MudText>
                            <MudText>
                                <strong>Cron:</strong> @Model?.CronExpression <br />
                                @_cronDescription
                            </MudText>
                            <MudText>
                                <strong>Parameters:</strong> @Model?.Parameters.ToJson()
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="12" md="7" lg="7">
                        <MudStack Spacing="1">
                            <MudTable Items="@Model?.Recipients" Hover="true">
                                <ToolBarContent>
                                    <MudText Typo="Typo.h6">Recipients</MudText>
                                </ToolBarContent>
                                <HeaderContent>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Destination</MudTh>
                                    <MudTh>Notification Type</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Name">@context.Name</MudTd>
                                    <MudTd DataLabel="Destination">@(context.Destination.Length <= 30 ? context.Destination : context.Destination.Substring(0, 30) + " ...")</MudTd>
                                    <MudTd DataLabel="Notification Type">@context.NotificationType</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudStack>
                    </MudItem>
                    <MudItem>
                        <MudStack Spacing="1">
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>
        <MudCardContent>
            <MudItem xs="12">
                <MudContainer Class="my-4 px-4">
                    <SemanticoPageAlert Text="List of executions." />
                    <MudDataGrid @ref="_notificationsDataGrid" ServerData="NotificationsServerReload" T="QueryExecutionHistoryData" Hover="true" Filterable="false">
                        <Columns>
                            <PropertyColumn Property="x => x.CreatedTime" Title="Created"/>
                            <PropertyColumn Property="x => x.QueryExecutionHistoryId" Title="Id"/>
                            <PropertyColumn Property="x => x.RecipientName"/>
                            <PropertyColumn Property="x => x.NotificationType"/>
                            <PropertyColumn Property="x => x.ResultCount"/>
                            <PropertyColumn Property="x => x.NotificationSent"/>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="QueryExecutionHistoryData" />
                        </PagerContent>
                    </MudDataGrid>
                </MudContainer>
            </MudItem>

        </MudCardContent>
    </MudCard>
</MudContainer>

@inject ISubscriptionService Service
@inject INotificationService NotificationsService
@inject IDialogService DialogService

@code
{
    [Parameter]
    public int Id { get; set; }

    public SubscriptionDetailsData? Model;

    private bool _loading;
    
    private QueryExecutionHistoryListData List { get; set; }
    
    MudDataGrid<QueryExecutionHistoryData>? _notificationsDataGrid;

    private bool isSubscriptionActive;

    private string _cronDescription;
                
    private async Task<GridData<QueryExecutionHistoryData>> NotificationsServerReload(GridState<QueryExecutionHistoryData> state)
    {
        var gridRequest = DataGridHelper.BuildSortedRequest<GetQueryExecutionHistoryRequest, QueryExecutionHistoryData>(state);

        // var request = new GetQueryExecutionHistoryRequest
        // {
        //     SubscriptionId = Id,
        //     Page = gridRequest.Page,
        //     PageSize = gridRequest.PageSize,
        //     SortCriteria = gridRequest.SortCriteria,
        //     NotificationSent = null,
        //     LastQueryExecutionHistoryId = null
        // };
        
        gridRequest.SubscriptionId = Id;
        
        List = await NotificationsService.GetQueryExecutionHistory(gridRequest, new CancellationToken());

        return new GridData<QueryExecutionHistoryData> {
            TotalItems = List.Data.Count,
            Items = List.Data
        };
    }
    
    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;

        Model = await Service.GetSubscriptionDetails(Id, new CancellationToken());

        isSubscriptionActive = Model?.Status == "Active";

        _cronDescription = Model?.CronExpression?.GetCronDescription();

        _loading = false;
    }

    private async Task ArchiveSubscription()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning", 
            "Do you want to archive this subscription?",
            yesText: "Yes",
            cancelText: "No");

        if (result == null || !result.Value)
        {
            return;
        }

        await Service.DeleteSubscription(Id, new CancellationToken());
        
        await Load();
    }
}