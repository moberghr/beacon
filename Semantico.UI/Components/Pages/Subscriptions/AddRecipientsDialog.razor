@using Semantico.Core.Models.Recipients
@using Semantico.Core.Models.Subscriptions
@using Semantico.Core.Services

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
            Add Recipients
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudList T="int" @bind-SelectedValues="_selectedRecipientIds" SelectionMode="SelectionMode.MultiSelection" ReadOnly="false" CheckBoxColor="Color.Primary">
            @{
                foreach (var recipient in _availableRecipients)
                {
                    <MudListItem T="int" Text="@recipient.Name" Value="recipient.RecipientId!.Value" />
                }
            }
        </MudList>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Success" OnClick="@(async () => await AddRecipientsAsync())">Add</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject ISubscriptionService Service
@inject IRecipientService RecipientService

@code {
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public required SubscriptionDetailsData Subscription { get; set; }

    private List<RecipientData> _availableRecipients { get; set; } = [];

    private IReadOnlyCollection<int> _selectedRecipientIds { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        var recipients = await RecipientService.GetRecipients(null, null, default);

        _availableRecipients = recipients.ExceptBy(Subscription.Recipients.Select(x => x.RecipientId), x => x.RecipientId).ToList();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task AddRecipientsAsync()
    {
        await Service.AddRecipients(Subscription.SubscriptionId, _selectedRecipientIds.ToList(), default);

        Snackbar.Add("Added recipients to subscription", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
