@page "/query-execution-history/{id:int}"
@inherits BasePageComponent
@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.QueryExecutionHistory
@using Semantico.Core.Services
@using System.Text.Json

<SemanticoPageTitle Title="Query Execution Details"/>

<MudContainer Class="my-4 px-4"  MaxWidth="MaxWidth.ExtraExtraLarge">
    @if (_loading)
    {
        <MudCard>
            <MudCardContent>
                <MudSkeleton Animation="Animation.Wave"/>
            </MudCardContent>
        </MudCard>
    }
    else if (Model == null)
    {
        <MudAlert Severity="Severity.Error">Query execution history not found.</MudAlert>
    }
    else
    {
        var status = Model.NotificationStatus;
        var statusColor = status switch
        {
            NotificationStatus.NotificationSent => Color.Success,
            NotificationStatus.Timeout => Color.Error,
            NotificationStatus.Failed => Color.Error,
            NotificationStatus.NoResults => Color.Secondary,
            _ => Color.Default
        };

        <!-- Page Header -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h3" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.QueryStats" Class="mr-2" />
                    Query Execution #@Model.Id
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Executed @Model.CreatedTime.ToString("MMM dd, yyyy HH:mm:ss")
                </MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudChip T="string" Color="@statusColor" Size="Size.Large">@status</MudChip>
            </MudStack>
        </MudStack>

        <!-- Hero Statistics Cards -->
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <HeroStatCard CardClass="hero-stat-card" Icon="@Icons.Material.Filled.Timer" Badge="Time"
                              Value="@Model.ExecutionTimeMs.ToString("N0")" Label="Execution Time (ms)" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <HeroStatCard CardClass="hero-stat-card-success" Icon="@Icons.Material.Filled.DataObject" Badge="Results"
                              Value="@Model.ResultCount.ToString()" Label="Result Count" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <HeroStatCard CardClass="hero-stat-card-info" Icon="@Icons.Material.Filled.Notifications" Badge="Sent"
                              Value="@Model.Notifications.Count.ToString()" Label="Notifications" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <HeroStatCard CardClass="hero-stat-card-warning" Icon="@Icons.Material.Filled.Task" Badge="Created"
                              Value="@Model.Tasks.Count.ToString()" Label="Tasks" />
            </MudItem>
        </MudGrid>

        <!-- Execution Information -->
        <MudPaper Class="detail-card pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="section-title">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Execution Information
            </MudText>

            <MudGrid Justify="Justify.FlexStart" Spacing="3">
                <MudItem xs="12" md="6">
                    <MudStack Spacing="2">
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Execution ID</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">@Model.Id</MudText>
                        </div>
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Executed At</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">@Model.CreatedTime.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                        </div>
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Execution Time</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">@Model.ExecutionTimeMs.ToString("N2") ms</MudText>
                        </div>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudStack Spacing="2">
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Query</MudText>
                            <MudLink Href="@($"queries/{Model.QueryId}")" Typo="Typo.body1" Style="font-weight: 600;">
                                @Model.QueryName
                            </MudLink>
                        </div>
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Subscription</MudText>
                            <MudLink Href="@($"subscriptions/{Model.SubscriptionId}")" Typo="Typo.body1" Style="font-weight: 600;">
                                ID @Model.SubscriptionId
                            </MudLink>
                        </div>
                        <div class="info-row">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Color="@statusColor" Size="Size.Small">@status</MudChip>
                        </div>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (Model.Notifications.Any())
        {
            <MudPaper Class="detail-card pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="mr-2" />
                    Notifications (@Model.Notifications.Count)
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Recipient</th>
                            <th>Type</th>
                            <th>Sent At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var notification in Model.Notifications)
                        {
                            <tr>
                                <td>
                                    <MudLink Href="@($"notifications/{notification.Id}")">
                                        @notification.Id
                                    </MudLink>
                                </td>
                                <td>@notification.RecipientName</td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@notification.Type</MudChip>
                                </td>
                                <td>@notification.SentAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }

        @if (Model.Tasks.Any())
        {
            <MudPaper Class="detail-card pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Task" Class="mr-2" />
                    Tasks (@Model.Tasks.Count)
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Result Count</th>
                            <th>Created At</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.Tasks)
                        {
                            <tr>
                                <td>
                                    <MudLink Href="@($"tasks/{task.Id}")">
                                        @task.Id
                                    </MudLink>
                                </td>
                                <td>@task.LatestResultCount</td>
                                <td>@task.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>
                                    @if (task.Resolved)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Resolved</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Open</MudChip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(Model.Results))
        {
            <MudPaper Class="detail-card pa-4 mb-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6" Class="section-title mb-0">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
                        Query Results
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="@CopyResults">
                        Copy Results
                    </MudButton>
                </MudStack>
                @if (_formattedResults != null)
                {
                    @if (_formattedResults.Count > 100)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3">
                            <strong>Results Truncated:</strong> This execution returned @_formattedResults.Count total rows. Only 100 rows (maximum) are displayed to prevent memory issues.
                        </MudAlert>
                    }
                    <MudDataGrid T="Dictionary<string, object?>"
                                 Items="@_formattedResults.Take(100)"
                                 Dense="true"
                                 Hover="true"
                                 Filterable="false"
                                 SortMode="SortMode.Multiple">
                        <Columns>
                            @if (_columns != null)
                            {
                                @foreach (var column in _columns)
                                {
                                    var columnName = column;
                                    <TemplateColumn Title="@columnName">
                                        <CellTemplate>
                                            @(context.Item.GetValueOrDefault(columnName)?.ToString() ?? "")
                                        </CellTemplate>
                                    </TemplateColumn>
                                }
                            }
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="Dictionary<string, object?>" PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                        </PagerContent>
                    </MudDataGrid>
                }
                else
                {
                    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Raw Results:</strong></MudText>
                    <MudPaper Class="pa-3" Style="background-color: #f8f9fa; max-height: 400px; overflow-y: auto;">
                        <pre>@Model.Results</pre>
                    </MudPaper>
                }
            </MudPaper>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">No results were stored for this query execution.</MudAlert>
        }
    }
</MudContainer>

@inject INotificationService Service
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

@code
{
    [Parameter]
    public int Id { get; set; }

    public QueryExecutionHistoryDetailsData? Model;

    private bool _loading;
    private List<Dictionary<string, object?>>? _formattedResults;
    private List<string>? _columns;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;

        Model = await Service.GetQueryExecutionHistoryDetails(Id, new CancellationToken());

        if (Model != null && !string.IsNullOrEmpty(Model.Results))
        {
            TryParseResults();
        }

        _loading = false;
    }

    private void TryParseResults()
    {
        if (string.IsNullOrEmpty(Model?.Results)) return;

        try
        {
            var jsonResults = JsonSerializer.Deserialize<List<Dictionary<string, object?>>>(Model.Results);
            if (jsonResults != null && jsonResults.Any())
            {
                _formattedResults = jsonResults;
                _columns = jsonResults.First().Keys.ToList();
            }
        }
        catch
        {
            // If parsing fails, we'll show raw results
            _formattedResults = null;
            _columns = null;
        }
    }

    private async Task CopyResults()
    {
        if (!string.IsNullOrEmpty(Model?.Results))
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Model.Results);
            Snackbar.Add("Results copied to clipboard", Severity.Success);
        }
    }
}
