@using Semantico.Core.Models.Ai.MultiAgent
@using Semantico.Core.Handlers.Ai.DocumentationAgent
@using MediatR

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Class="mr-1 mb-n1" />
            Multi-Agent Documentation
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_generating)
        {
            <div class="d-flex flex-column align-center py-8">
                <MudProgressLinear Value="_progressPercent" Color="Color.Primary" Size="Size.Large" Class="mb-4" Style="width: 100%;" />
                <MudText Typo="Typo.body1">@_progressMessage</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_progressPercent% complete</MudText>
            </div>
        }
        else if (_result != null)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Documentation generated successfully!
            </MudAlert>

            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tables Analyzed</MudText>
                        <MudText Typo="Typo.h6">@_result.TablesAnalyzed</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Generation Time</MudText>
                        <MudText Typo="Typo.h6">@_result.GenerationTime.TotalSeconds.ToString("F1")s</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tokens Used</MudText>
                        <MudText Typo="Typo.h6">@_result.TokensUsed.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Estimated Cost</MudText>
                        <MudText Typo="Typo.h6">$@_result.EstimatedCost.ToString("F4")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Model</MudText>
                        <MudText Typo="Typo.body2">@_result.GeneratedByModel</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Multi-agent workflow: Orchestrator identifies domains → Parallel agents document each → Aggregator synthesizes
            </MudAlert>

            <MudForm @ref="@_form" Class="pt-1" @bind-IsValid="_isFormValid">
                <MudTextField
                    Margin="Margin.Normal"
                    Variant="Variant.Text"
                    Class="mb-2"
                    @bind-Value="@_title"
                    T="String"
                    Label="Documentation Title"
                    Placeholder="Leave empty for auto-generated title"
                />

                <MudNumericField
                    Margin="Margin.Normal"
                    Variant="Variant.Text"
                    Class="mb-2"
                    @bind-Value="@_maxTables"
                    T="int"
                    Label="Maximum Tables to Analyze"
                    Min="1"
                    Max="200"
                    HelperText="Limit the number of tables to analyze (1-200)"
                />

                <MudNumericField
                    Margin="Margin.Normal"
                    Variant="Variant.Text"
                    Class="mb-2"
                    @bind-Value="@_maxConcurrentAgents"
                    T="int"
                    Label="Concurrent Agents"
                    Min="1"
                    Max="10"
                    HelperText="Number of domain agents to run in parallel (1-10)"
                />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        @if (_result != null)
        {
            <MudButton
                OnClick="@Close"
                Variant="Variant.Filled"
                Color="Color.Primary"
            >
                Close
            </MudButton>
        }
        else
        {
            <MudButton
                Class="ml-4"
                OnClick="@Cancel"
                Variant="Variant.Filled"
                Disabled="@_generating"
            >
                Cancel
            </MudButton>

            <MudButton
                OnClick="@Generate"
                Variant="Variant.Filled"
                Color="Color.Primary"
                Disabled="@(!_isFormValid || _generating)"
                StartIcon="@Icons.Material.Filled.RocketLaunch"
            >
                @(_generating ? "Generating..." : "Start Multi-Agent")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IMediator Mediator

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int DataSourceId { get; set; }

    [Parameter]
    public int UserId { get; set; } = 1; // TODO: Get from auth context

    private MudForm _form;
    private bool _generating;
    private bool _isFormValid = true;
    private string? _title;
    private int _maxTables = 100;
    private int _maxConcurrentAgents = 5;
    private GenerationResult? _result;
    private string? _progressMessage = "Starting...";
    private int _progressPercent;

    async Task Generate()
    {
        if (_generating) return;

        await _form.Validate();
        if (!_form.IsValid) return;

        _generating = true;
        _progressPercent = 0;
        _progressMessage = "Initializing multi-agent workflow...";
        StateHasChanged();

        var stopwatch = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            var progress = new Progress<DocumentationProgress>(p =>
            {
                _progressPercent = p.PercentComplete;
                _progressMessage = p.StatusMessage;
                InvokeAsync(StateHasChanged);
            });

            var command = new GenerateMultiAgentDocumentationCommand
            {
                DataSourceId = DataSourceId,
                UserId = UserId,
                MaxConcurrentAgents = _maxConcurrentAgents,
                Title = _title,
                MaxTables = _maxTables,
                Progress = progress
            };

            var documentation = await Mediator.Send(command);
            stopwatch.Stop();

            _result = new GenerationResult
            {
                TablesAnalyzed = documentation.TablesAnalyzed,
                GeneratedByModel = documentation.GeneratedByModel ?? "Unknown",
                TokensUsed = documentation.TokensUsed,
                EstimatedCost = documentation.EstimatedCost,
                GenerationTime = stopwatch.Elapsed
            };

            Snackbar.Add($"Documentation generated successfully! ({_result.TablesAnalyzed} tables analyzed)", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to generate documentation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generating = false;
            StateHasChanged();
        }
    }

    void Cancel() => MudDialog.Cancel();
    void Close() => MudDialog.Close(DialogResult.Ok(_result));

    private record GenerationResult
    {
        public int TablesAnalyzed { get; init; }
        public string GeneratedByModel { get; init; } = null!;
        public int TokensUsed { get; init; }
        public decimal EstimatedCost { get; init; }
        public TimeSpan GenerationTime { get; init; }
    }
}
