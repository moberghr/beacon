@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.DataSources
@using Semantico.Core.Services
<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1 mb-n1" />
            Add data source
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1" @bind-Errors="@errors" @bind-IsValid="_isFormValid">
            <MudTextField
                OnlyValidateIfDirty="true"
                Margin="Margin.Normal"
                Variant="Variant.Text"
                Class="mb-2"
                @bind-Value="@DataSource.Name"
                T="String"
                Label="Name"
                Required="true"
            />
            <MudTextField
                OnlyValidateIfDirty="true"
                Immediate="true"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Class="mb-2"
                @bind-Value="@DataSource.ConnectionString"
                T="string"
                Label="Connection string"
                Required="true"
                InputType="InputType.Password"
                Adornment="Adornment.End"
                AdornmentIcon="@Icons.Material.Filled.Lock"
            />
            <MudSelect T="DatabaseEngineType" Label="Database Engine Type" @bind-Value="@DataSource.DatabaseEngineType" Required="true">
    <MudSelectItem Value="DatabaseEngineType.PostgreSQL">PostgreSQL</MudSelectItem>
    <MudSelectItem Value="DatabaseEngineType.MSSQL">MSSQL</MudSelectItem>
    <MudSelectItem Value="DatabaseEngineType.MySQL">MySQL</MudSelectItem>
</MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton
            Class="ml-4"
            OnClick="@Cancel"
            Variant="Variant.Filled"
        >
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="!_isFormValid" OnClick="@Submit"/>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IDataSourceService Service

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DataSourceData DataSource { get; set; }

    private MudForm _form;
    private bool _loading;
    bool _isFormValid = false;
    string[] errors = { };

    async Task Submit()
    {
        if (_loading)
        {
            return;
        }

        await _form.Validate();
        
        if (!_form.IsValid)
        {
            return;
        }

        _loading = true;
        var response = await Service.CreateDataSource(DataSource, CancellationToken.None);

        if (response.Success)
        {
            MudDialog.Close(DialogResult.Ok(true));
            Snackbar.Add(response.Message, Severity.Success);
        }
        else
        {
            Snackbar.Add(response.Message, Severity.Error);
        }
        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();
}