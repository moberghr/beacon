@using Semantico.Core.Services.Ai.DocumentationAgent.Models
@using Semantico.Core.Handlers.Ai.DocumentationAgent
@using Semantico.Core.Handlers.DataSources.GetDataSourceSchemas
@using MediatR

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-1 mb-n1" />
            Start Documentation Agent
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_starting)
        {
            <div class="d-flex flex-column align-center py-8">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.body1" Class="mt-4">Starting documentation agent...</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">This will run in the background</MudText>
            </div>
        }
        else if (_result != null)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Documentation agent started successfully!
            </MudAlert>

            <MudText Typo="Typo.body2" Class="mb-2">
                The agent is now running in the background and will document your database schema in parallel.
                You can track progress on the data source page.
            </MudText>

            <MudPaper Elevation="0" Class="pa-3 mt-4">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Agent Run ID</MudText>
                <MudText Typo="Typo.h6">@_result.AgentRunId</MudText>
            </MudPaper>
        }
        else
        {
            <MudForm @ref="@_form" Class="pt-1" @bind-IsValid="_isFormValid">
                <MudTextField
                    Margin="Margin.Normal"
                    Variant="Variant.Text"
                    Class="mb-2"
                    @bind-Value="@_options.Title"
                    T="String"
                    Label="Documentation Title"
                    Placeholder="Leave empty for auto-generated title"
                />

                @if (_loadingSchemas)
                {
                    <div class="d-flex align-center mb-4">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <MudText Typo="Typo.caption">Loading schemas...</MudText>
                    </div>
                }
                else if (_availableSchemas.Any())
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2 mt-3">Select Schemas to Document</MudText>
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-3">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @(_selectedSchemas.Count == _availableSchemas.Count ? "All schemas selected" : $"{_selectedSchemas.Count} of {_availableSchemas.Count} selected")
                            </MudText>
                            <MudButton Size="Size.Small" OnClick="@ToggleAllSchemas" Variant="Variant.Text">
                                @(_selectedSchemas.Count == _availableSchemas.Count ? "Deselect All" : "Select All")
                            </MudButton>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var schema in _availableSchemas)
                            {
                                <MudChip T="string"
                                    Color="@(_selectedSchemas.Contains(schema) ? Color.Primary : Color.Default)"
                                    Variant="@(_selectedSchemas.Contains(schema) ? Variant.Filled : Variant.Outlined)"
                                    OnClick="@(() => ToggleSchema(schema))"
                                    Class="cursor-pointer"
                                >
                                    @if (_selectedSchemas.Contains(schema))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                                    }
                                    @schema
                                </MudChip>
                            }
                        </div>
                        @if (_selectedSchemas.Count == 0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                Please select at least one schema to document
                            </MudAlert>
                        }
                    </MudPaper>
                }

                <MudNumericField
                    Margin="Margin.Normal"
                    Variant="Variant.Text"
                    Class="mb-2"
                    @bind-Value="@_options.MaxParallelTables"
                    T="int"
                    Label="Parallel Tables"
                    Min="1"
                    Max="10"
                    HelperText="Number of tables to document concurrently (1-10)"
                />

                <MudSwitch
                    @bind-Checked="@_options.IncludeSampleData"
                    T="bool"
                    Color="Color.Primary"
                    Label="Include Sample Data"
                    Class="mb-2"
                />

                <MudSwitch
                    @bind-Checked="@_options.IncludeRelationships"
                    T="bool"
                    Color="Color.Primary"
                    Label="Include Relationships"
                    Class="mb-2"
                />

                <MudExpansionPanels Class="mt-4">
                    <MudExpansionPanel Text="Advanced Options">
                        <MudNumericField
                            Margin="Margin.Normal"
                            Variant="Variant.Text"
                            @bind-Value="@_options.MaxRetries"
                            T="int"
                            Label="Max Retries per Table"
                            Min="1"
                            Max="5"
                            HelperText="Number of retry attempts for failed tables"
                        />

                        <MudNumericField
                            Margin="Margin.Normal"
                            Variant="Variant.Text"
                            @bind-Value="@_options.MaxSampleRows"
                            T="int"
                            Label="Max Sample Rows"
                            Min="1"
                            Max="10"
                            HelperText="Number of sample rows to fetch per table"
                        />

                        <MudSlider
                            @bind-Value="@_options.Temperature"
                            Min="0"
                            Max="1"
                            Step="0.1m"
                            TickMarks="true"
                            TickMarkLabels="@(new string[] { "0", "0.5", "1" })"
                            Class="mb-4"
                        >
                            Temperature: @_options.Temperature.ToString("F1")
                        </MudSlider>

                        <MudNumericField
                            Margin="Margin.Normal"
                            Variant="Variant.Text"
                            @bind-Value="@_options.MaxTokens"
                            T="int"
                            Label="Max Tokens"
                            Min="1024"
                            Max="16384"
                        />
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
                    The documentation agent uses a 3-phase workflow: Discovery → Parallel Documentation → Synthesis.
                    Progress can be tracked in real-time, and the workflow is resumable if interrupted.
                </MudAlert>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        @if (_result != null)
        {
            <MudButton
                OnClick="@Close"
                Variant="Variant.Filled"
                Color="Color.Primary"
            >
                Close
            </MudButton>
        }
        else
        {
            <MudButton
                Class="ml-4"
                OnClick="@Cancel"
                Variant="Variant.Filled"
                Disabled="@_starting"
            >
                Cancel
            </MudButton>

            <MudButton
                OnClick="@Start"
                Variant="Variant.Filled"
                Color="Color.Primary"
                Disabled="@(!_isFormValid || _starting)"
                StartIcon="@Icons.Material.Filled.RocketLaunch"
            >
                @(_starting ? "Starting..." : "Start Agent")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IMediator Mediator

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int DataSourceId { get; set; }

    [Parameter]
    public int UserId { get; set; } = 1; // TODO: Get from auth context

    private MudForm _form;
    private bool _starting;
    private bool _isFormValid = true;
    private DocumentationAgentOptions _options = new() { MaxParallelTables = 5, MaxRetries = 3 };
    private StartDocumentationAgentResult? _result;

    private bool _loadingSchemas;
    private List<string> _availableSchemas = new();
    private HashSet<string> _selectedSchemas = new();

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        await LoadSchemasAsync();
    }

    async Task LoadSchemasAsync()
    {
        _loadingSchemas = true;
        StateHasChanged();

        try
        {
            var query = new GetDataSourceSchemasQuery(DataSourceId);
            var result = await Mediator.Send(query);

            _availableSchemas = result.Schemas;
            // Select all schemas by default
            _selectedSchemas = new HashSet<string>(_availableSchemas);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load schemas: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingSchemas = false;
            StateHasChanged();
        }
    }

    void ToggleSchema(string schema)
    {
        if (_selectedSchemas.Contains(schema))
        {
            _selectedSchemas.Remove(schema);
        }
        else
        {
            _selectedSchemas.Add(schema);
        }
        StateHasChanged();
    }

    void ToggleAllSchemas()
    {
        if (_selectedSchemas.Count == _availableSchemas.Count)
        {
            _selectedSchemas.Clear();
        }
        else
        {
            _selectedSchemas = new HashSet<string>(_availableSchemas);
        }
        StateHasChanged();
    }

    async Task Start()
    {
        if (_starting)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        // Validate that at least one schema is selected
        if (_selectedSchemas.Count == 0)
        {
            Snackbar.Add("Please select at least one schema to document", Severity.Warning);
            return;
        }

        _starting = true;
        StateHasChanged();

        try
        {
            // Pass selected schemas to options
            _options.SelectedSchemas = _selectedSchemas.ToList();

            var command = new StartDocumentationAgentCommand
            {
                DataSourceId = DataSourceId,
                UserId = UserId,
                Options = _options
            };

            _result = await Mediator.Send(command);

            Snackbar.Add($"Documentation agent started! Run ID: {_result.AgentRunId}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to start agent: {ex.Message}", Severity.Error);
        }
        finally
        {
            _starting = false;
            StateHasChanged();
        }
    }

    void Cancel() => MudDialog.Cancel();

    void Close() => MudDialog.Close(DialogResult.Ok(_result));
}
