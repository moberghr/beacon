@page "/data-sources/{DataSourceId:int}"
@inherits BasePageComponent
@using Semantico.Core
@using Semantico.Core.Services
@using Semantico.Core.Data.Entities
@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Metadata
@using Semantico.Core.Models.DataSources
@using Semantico.Core.Models.Providers.CloudWatch
@using BlazorMonaco
@using BlazorMonaco.Editor
@using System.Text.Json

<style>
    .sql-editor-container {
        height: 100% !important;
    }

    .sql-editor-container > div {
        height: 100% !important;
    }
</style>

<SemanticoPageTitle Title="@_dataSourceName"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Storage" Title="@_dataSourceName"/>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4"/>
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="my-4">@_error</MudAlert>
    }
    else
    {
        <!-- Data Source Statistics -->
        <MudCard Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Overview</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@(_dataSourceInfo?.DataSourceType == DataSourceType.CloudWatch ? Icons.Material.Filled.Cloud : Icons.Material.Filled.Storage)" Color="Color.Primary" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">
                                @if (_dataSourceInfo?.DataSourceType == DataSourceType.CloudWatch)
                                {
                                    <text>CloudWatch</text>
                                }
                                else
                                {
                                    @_dataSourceInfo?.DatabaseEngineType
                                }
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Data Source Type</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Success" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@_queriesCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Queries</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Info" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@_migrationsCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Migration Jobs</MudText>
                        </MudPaper>
                    </MudItem>
                    @if (_dataSourceInfo?.DataSourceType == DataSourceType.Database)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                                <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Warning" Size="Size.Large" Class="mb-2"/>
                                <MudText Typo="Typo.h4">@(_metadata?.Tables.Count ?? 0)</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Tables</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                @if (_configuration?.UseAI == true && _dataSourceInfo?.DataSourceType == DataSourceType.Database)
                {
                    <MudDivider Class="my-4" />
                    <div class="d-flex flex-column align-center gap-2">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Generate Documentation</MudText>
                        <div class="d-flex justify-center gap-4">
                            <MudButton Variant="Variant.Filled"
                                      Color="Color.Primary"
                                      StartIcon="@Icons.Material.Filled.Hub"
                                      OnClick="GenerateDocumentation"
                                      Size="Size.Large">
                                Multi-Agent Workflow
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                      Color="Color.Default"
                                      StartIcon="@Icons.Material.Filled.SmartToy"
                                      OnClick="StartDocumentationAgent"
                                      Size="Size.Large">
                                Background Agent
                            </MudButton>
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Multi-Agent: Orchestrator identifies domains → Parallel agents document each → Aggregator synthesizes
                        </MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>

        <!-- Active Agent Runs -->
        @if (_configuration?.UseAI == true && _dataSourceInfo?.DataSourceType == DataSourceType.Database && _activeAgentRuns?.Count > 0)
        {
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-2" />
                            Active Documentation Agent Runs
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @foreach (var agentRun in _activeAgentRuns)
                    {
                        <DocumentationAgentProgress
                            AgentRunId="@agentRun.Id"
                            OnCompleted="@OnAgentCompleted" />
                    }
                </MudCardContent>
            </MudCard>
        }

        <!-- AI Documentation History -->
        @if (_configuration?.UseAI == true && _dataSourceInfo?.DataSourceType == DataSourceType.Database && _documentations?.Count > 0)
        {
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-2" />
                            AI Documentation History
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudTable Items="@_documentations" Hover="true" Dense="true" Striped="true">
                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Generated</MudTh>
                            <MudTh>Tables</MudTh>
                            <MudTh>Model</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Title">@context.Title</MudTd>
                            <MudTd DataLabel="Generated">@context.GeneratedAt.ToString("g")</MudTd>
                            <MudTd DataLabel="Tables">@context.TablesAnalyzed</MudTd>
                            <MudTd DataLabel="Model">@context.GeneratedByModel</MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                              Color="Color.Primary"
                                              Size="Size.Small"
                                              Href="@($"data-sources/{DataSourceId}/documentation/{context.Id}")"
                                              Title="View Documentation"/>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileDownload" OnClick="@(() => ExportMarkdown(context.Id))">
                                        Export Markdown
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileDownload" OnClick="@(() => ExportHtml(context.Id))">
                                        Export HTML
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf" OnClick="@(() => ExportPdf(context.Id))">
                                        Export PDF
                                    </MudMenuItem>
                                </MudMenu>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        }

        <!-- Query Editor - conditional based on data source type -->
        @if (_dataSourceInfo?.DataSourceType == DataSourceType.CloudWatch)
        {
            <CloudWatchQueryEditor DataSourceId="@DataSourceId"
                                  Config="@_cloudWatchConfig"
                                  ExecuteAdHocQuery="@ExecuteAdHocQueryWrapper" />
        }
        else
        {
            <!-- Database Query Editor -->
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Ad-Hoc Query Editor</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        <strong>Results Limited:</strong> Ad-hoc queries are automatically limited to 100 rows to prevent memory issues.
                        A LIMIT/TOP clause will be added if your query doesn't have one.
                    </MudAlert>

                    <div class="d-flex align-center gap-2 mb-2">
                        <MudButton Variant="Variant.Filled"
                                  Color="Color.Primary"
                                  StartIcon="@Icons.Material.Filled.PlayArrow"
                                  OnClick="ExecuteQuery"
                                  Disabled="@_executing">
                            @(_executing ? "Executing..." : "Execute Query")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                  Color="Color.Secondary"
                                  StartIcon="@Icons.Material.Filled.Refresh"
                                  OnClick="RefreshMetadata"
                                  Disabled="@_refreshingMetadata">
                            @(_refreshingMetadata ? "Refreshing..." : "Refresh Metadata")
                        </MudButton>
                        @if (_metadata != null)
                        {
                            <MudText Typo="Typo.caption" Class="ml-auto">
                                Last refreshed: @_metadata.RefreshedAt.ToString("g")
                            </MudText>
                        }
                    </div>

                    <div style="display: flex; gap: 0; height: 600px; border: 1px solid #ddd;">
                        <div style="width: 300px; min-width: 300px; height: 100%; overflow: hidden;">
                            <DatabaseExplorer Metadata="@_metadata"
                                             OnTableSelected="@OnTableSelected"
                                             OnColumnSelected="@OnColumnSelected" />
                        </div>
                        <div style="flex: 1; height: 100%; border-left: 1px solid #ddd;">
                            @if (_monacoReady)
                            {
                                <StandaloneCodeEditor @ref="_editor"
                                                     Id="query-editor"
                                                     ConstructionOptions="EditorConstructionOptions"
                                                     OnDidInit="OnEditorInit"
                                                     OnDidChangeModelContent="OnEditorContentChanged"
                                                     CssClass="sql-editor-container"/>
                            }
                            else
                            {
                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; background-color: #f5f5f5;">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                </div>
                            }
                        </div>
                    </div>
                </MudCardContent>
            </MudCard>

            @if (_queryResult != null)
            {
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Query Results</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Executed in @_queryResult.ExecutionTime.TotalMilliseconds.ToString("F2") ms | @_queryResult.RowCount rows
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                          Color="Color.Default"
                                          OnClick="@(() => _queryResult = null)"/>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_queryResult.Success)
                        {
                            @if (_queryResult.RowCount > 0)
                            {
                                @if (_queryResult.RowCount > _queryResult.Rows.Count)
                                {
                                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                                        <strong>Results Truncated:</strong> Query returned @_queryResult.RowCount total rows, but only 100 rows (maximum) are displayed.
                                        Consider adding a WHERE clause or LIMIT to reduce the result set.
                                    </MudAlert>
                                }
                                <div style="overflow-x: auto;">
                                    <MudDataGrid T="Dictionary<string, object?>"
                                                 Items="@_queryResult.Rows"
                                                 Hover="true"
                                                 Dense="true"
                                                 Filterable="false"
                                                 SortMode="SortMode.Multiple">
                                        <Columns>
                                            @foreach (var column in _queryResult.Columns)
                                            {
                                                var columnName = column;
                                                <TemplateColumn Title="@columnName">
                                                    <CellTemplate>
                                                        @(context.Item.GetValueOrDefault(columnName)?.ToString() ?? "NULL")
                                                    </CellTemplate>
                                                </TemplateColumn>
                                            }
                                        </Columns>
                                        <PagerContent>
                                            <MudDataGridPager T="Dictionary<string, object?>" PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                                        </PagerContent>
                                    </MudDataGrid>
                                </div>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">Query executed successfully but returned no rows.</MudAlert>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Error">@_queryResult.Error</MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            }
        }
    }
</MudContainer>

@inject IDatabaseMetadataService MetadataService
@inject IDataSourceService DataSourceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject SemanticoConfiguration _configuration
@inject MediatR.IMediator Mediator

@code {
    [Parameter]
    public int DataSourceId { get; set; }

    private StandaloneCodeEditor? _editor;
    private DatabaseMetadataSnapshot? _metadata;
    private DataSourceListData? _dataSourceInfo;
    private string _dataSourceName = "";
    private int _queriesCount = 0;
    private int _migrationsCount = 0;
    private bool _loading = true;
    private bool _executing = false;
    private bool _refreshingMetadata = false;
    private string? _error;
    private AdHocQueryResult? _queryResult;
    private string _currentQuery = "";
    private bool _completionProviderRegistered = false;
    private bool _monacoReady = false;
    private List<DataSourceDocumentation>? _documentations;
    private List<Semantico.Core.Data.Entities.DocumentationAgentRun>? _activeAgentRuns;
    private CloudWatchConfiguration? _cloudWatchConfig;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;

            // Load data source information
            var dataSources = await DataSourceService.GetDataSources(DataSourceId, CancellationToken.None);
            _dataSourceInfo = dataSources.FirstOrDefault();

            if (_dataSourceInfo != null)
            {
                _dataSourceName = _dataSourceInfo.Name;
                _queriesCount = _dataSourceInfo.Queries.Count;
                _migrationsCount = _dataSourceInfo.MigrationJobsCount;
            }
            else
            {
                _dataSourceName = $"Data Source {DataSourceId}";
            }

            // Load metadata only for database types
            if (_dataSourceInfo?.DataSourceType == DataSourceType.Database)
            {
                _metadata = await MetadataService.GetMetadataAsync(DataSourceId);
            }
            else if (_dataSourceInfo?.DataSourceType == DataSourceType.CloudWatch)
            {
                // Parse CloudWatch configuration from encrypted connection data
                try
                {
                    var decryptedConnectionData = await DataSourceService.GetDecryptedConnectionData(DataSourceId, CancellationToken.None);
                    _cloudWatchConfig = JsonSerializer.Deserialize<CloudWatchConfiguration>(decryptedConnectionData);
                }
                catch (Exception ex)
                {
                    // If we can't load config, set a default
                    _cloudWatchConfig = new CloudWatchConfiguration
                    {
                        Region = "Error loading configuration",
                        LogGroups = new List<string> { ex.Message }
                    };
                }
            }

            // Load AI documentation history if AI is enabled (only for database sources)
            if (_configuration?.UseAI == true && _dataSourceInfo?.DataSourceType == DataSourceType.Database)
            {
                _documentations = await Mediator.Send(new GetDocumentationsCommand { DataSourceId = DataSourceId });

                // Load active agent runs
                await LoadActiveAgentRuns();
            }

            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load data source: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wait for Monaco to be ready after first render (JS interop is now available)
            _monacoReady = await WaitForMonacoAsync();
            StateHasChanged(); // Re-render to show the editor
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "sql",
            Theme = "vs",
            Value = "-- Write your SQL query here\nSELECT * FROM ",
            FontSize = 14,
            LineNumbers = "on",
            RenderLineHighlight = "all",
            ScrollBeyondLastLine = false,
            ReadOnly = false
        };
    }

    private async Task OnEditorInit()
    {
        if (_editor != null && _metadata != null)
        {
            await RegisterCompletionProvider();
            await EnableDropOnEditor();
        }
    }

    private async Task<bool> WaitForMonacoAsync(int maxAttempts = 50, int delayMs = 100)
    {
        for (int i = 0; i < maxAttempts; i++)
        {
            try
            {
                // Check if both monaco and blazorMonaco are available
                var isReady = await JSRuntime.InvokeAsync<bool>("eval",
                    "typeof monaco !== 'undefined' && typeof blazorMonaco !== 'undefined' && typeof blazorMonaco.editor !== 'undefined' && typeof blazorMonaco.editor.create !== 'undefined'");
                if (isReady)
                    return true;
            }
            catch (Exception)
            {
                // Suppress individual attempt errors during initialization
            }

            await Task.Delay(delayMs);
        }

        return false;
    }

    private async Task EnableDropOnEditor()
    {
        try
        {
            await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.enableDropOnEditor",
                "query-editor"
            );
        }
        catch
        {
            // Silently fail if drop functionality cannot be enabled
        }
    }

    private Task OnEditorContentChanged(ModelContentChangedEvent e)
    {
        // Update current query when content changes
        return Task.CompletedTask;
    }

    private async Task RegisterCompletionProvider()
    {
        if (_editor == null || _metadata == null || _completionProviderRegistered) return;

        try
        {
            _completionProviderRegistered = true;

            // Convert metadata to a serializable format for JavaScript
            var metadataForJs = new
            {
                tables = _metadata.Tables.Select(t => new
                {
                    schemaName = t.SchemaName,
                    tableName = t.TableName,
                    description = t.Description,
                    columns = t.Columns.Select(c => new
                    {
                        columnName = c.ColumnName,
                        dataType = c.DataType,
                        isNullable = c.IsNullable,
                        isPrimaryKey = c.IsPrimaryKey,
                        isForeignKey = c.IsForeignKey,
                        foreignKeyTable = c.ForeignKeyTable,
                        foreignKeyColumn = c.ForeignKeyColumn,
                        ordinalPosition = c.OrdinalPosition
                    }).ToList()
                }).ToList()
            };

            // Determine SQL dialect based on data source type
            string sqlDialect = "sql"; // Default, could be enhanced to detect PostgreSQL, SQL Server, etc.

            // Register context-aware completion provider using the helper
            var success = await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.registerSqlCompletionProvider",
                "query-editor",
                sqlDialect,
                metadataForJs
            );

            if (success)
            {
                // Register Ctrl+Space for trigger suggest
                await _editor.AddCommand((int)KeyMod.CtrlCmd | (int)KeyCode.Space, async (args) =>
                {
                    await _editor.Trigger("editor", "editor.action.triggerSuggest", null);
                });

                var totalItems = _metadata.Tables.Count + _metadata.Tables.Sum(t => t.Columns.Count);
                Snackbar.Add($"Context-aware intellisense enabled with {totalItems} database objects", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to register SQL completion provider", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to register completion provider: {ex.Message}", Severity.Warning);
        }
    }

    private async Task ExecuteQuery()
    {
        if (_editor == null) return;

        try
        {
            _executing = true;
            _currentQuery = await _editor.GetValue();

            if (string.IsNullOrWhiteSpace(_currentQuery))
            {
                Snackbar.Add("Please enter a query", Severity.Warning);
                return;
            }

            _queryResult = await DataSourceService.ExecuteAdHocQuery(DataSourceId, _currentQuery, CancellationToken.None);

            if (_queryResult.Success)
            {
                Snackbar.Add($"Query executed successfully - {_queryResult.RowCount} rows returned", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Query execution failed", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Query execution failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _executing = false;
        }
    }

    private async Task RefreshMetadata()
    {
        try
        {
            _refreshingMetadata = true;

            // Dispose old completion provider first
            try
            {
                await JSRuntime.InvokeVoidAsync("semanticoSqlEditor.disposeCompletionProvider", "query-editor");
            }
            catch
            {
                // Ignore errors if provider doesn't exist
            }

            _completionProviderRegistered = false; // Reset flag to allow re-registration
            _metadata = await MetadataService.RefreshMetadataAsync(DataSourceId);

            // Re-register completion provider with new metadata
            if (_editor != null)
            {
                await RegisterCompletionProvider();
            }

            Snackbar.Add($"Metadata refreshed: {_metadata.Tables.Count} tables", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to refresh metadata: {ex.Message}", Severity.Error);
        }
        finally
        {
            _refreshingMetadata = false;
        }
    }

    private async Task OnTableSelected(string tableName)
    {
        if (_editor != null)
        {
            try
            {
                // Get current value and cursor position
                var currentValue = await _editor.GetValue();
                var position = await _editor.GetPosition();

                // Calculate the character offset
                var lines = currentValue.Split('\n');
                var offset = 0;
                for (int i = 0; i < position.LineNumber - 1; i++)
                {
                    offset += lines[i].Length + 1; // +1 for newline
                }
                offset += position.Column - 1;

                // Insert table name at cursor position
                var newValue = currentValue.Insert(offset, tableName);
                await _editor.SetValue(newValue);
                await _editor.Focus();
            }
            catch
            {
                // Silently ignore insert errors
            }
        }
    }

    private async Task OnColumnSelected((string TableName, string ColumnName) selection)
    {
        if (_editor != null)
        {
            try
            {
                var textToInsert = $"{selection.TableName}.{selection.ColumnName}";

                // Get current value and cursor position
                var currentValue = await _editor.GetValue();
                var position = await _editor.GetPosition();

                // Calculate the character offset
                var lines = currentValue.Split('\n');
                var offset = 0;
                for (int i = 0; i < position.LineNumber - 1; i++)
                {
                    offset += lines[i].Length + 1; // +1 for newline
                }
                offset += position.Column - 1;

                // Insert column name at cursor position
                var newValue = currentValue.Insert(offset, textToInsert);
                await _editor.SetValue(newValue);
                await _editor.Focus();
            }
            catch
            {
                // Silently ignore insert errors
            }
        }
    }

    private async Task GenerateDocumentation()
    {

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var parameters = new DialogParameters<GenerateDocumentationDialog>
        {
            { x => x.DataSourceId, DataSourceId }
        };

        var dialog = await DialogService.ShowAsync<GenerateDocumentationDialog>("", parameters, options);

        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            // Reload documentations
            if (_configuration?.UseAI == true)
            {
                _documentations = await Mediator.Send(new GetDocumentationsCommand { DataSourceId = DataSourceId });
            }
            Snackbar.Add("Documentation generated successfully!", Severity.Success);
        }
    }

    private Color GetStatusColor(DocumentationStatus status)
    {
        return status switch
        {
            DocumentationStatus.Draft => Color.Default,
            DocumentationStatus.Published => Color.Success,
            _ => Color.Default
        };
    }

    private async Task ExportMarkdown(int documentationId)
    {

        try
        {
            var markdown = await Mediator.Send(new ExportDocumentationToMarkdownCommand { DocumentationId = documentationId });
            await DownloadFile($"documentation-{documentationId}.md", markdown, "text/markdown");
            Snackbar.Add("Markdown exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export markdown: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportHtml(int documentationId)
    {

        try
        {
            var html = await Mediator.Send(new ExportDocumentationToHtmlCommand { DocumentationId = documentationId });
            await DownloadFile($"documentation-{documentationId}.html", html, "text/html");
            Snackbar.Add("HTML exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export HTML: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportPdf(int documentationId)
    {

        try
        {
            var pdf = await Mediator.Send(new ExportDocumentationToPdfCommand { DocumentationId = documentationId });
            await DownloadFile($"documentation-{documentationId}.pdf", pdf, "application/pdf");
            Snackbar.Add("PDF exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadFile(string fileName, string content, string contentType)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        await DownloadFile(fileName, bytes, contentType);
    }

    private async Task DownloadFile(string fileName, byte[] bytes, string contentType)
    {
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, contentType);
    }

    private async Task StartDocumentationAgent()
    {

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var parameters = new DialogParameters<StartDocumentationAgentDialog>
        {
            { x => x.DataSourceId, DataSourceId },
            { x => x.UserId, 1 } // TODO: Get from auth context
        };

        var dialog = await DialogService.ShowAsync<StartDocumentationAgentDialog>("", parameters, options);

        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is Semantico.Core.Handlers.Ai.DocumentationAgent.StartDocumentationAgentResult agentResult)
        {
            // Reload active agent runs
            await LoadActiveAgentRuns();
            Snackbar.Add($"Documentation agent started! Run ID: {agentResult.AgentRunId}", Severity.Success);
        }
    }

    private async Task LoadActiveAgentRuns()
    {
        try
        {
            var query = new Semantico.Core.Handlers.Ai.DocumentationAgent.GetActiveAgentRunsQuery
            {
                DataSourceId = DataSourceId
            };
            _activeAgentRuns = await Mediator.Send(query);
        }
        catch (Exception ex)
        {
            // Silently fail - agent runs are optional
            _activeAgentRuns = null;
        }
    }

    private async Task OnAgentCompleted()
    {
        // Reload documentation history
        if (_configuration?.UseAI == true)
        {
            _documentations = await Mediator.Send(new GetDocumentationsCommand { DataSourceId = DataSourceId });
        }

        // Reload active runs
        await LoadActiveAgentRuns();

        StateHasChanged();
    }

    private async Task<AdHocQueryResult> ExecuteAdHocQueryWrapper(int dataSourceId, string query, CancellationToken cancellationToken)
    {
        return await DataSourceService.ExecuteAdHocQuery(dataSourceId, query, cancellationToken);
    }
}
