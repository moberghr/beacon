@page "/data-sources/{DataSourceId:int}"
@inherits BasePageComponent
@using Semantico.Core.Services
@using Semantico.Core.Models.Metadata
@using Semantico.Core.Models.DataSources
@using BlazorMonaco
@using BlazorMonaco.Editor

<style>
    .sql-editor-container {
        height: 100% !important;
    }

    .sql-editor-container > div {
        height: 100% !important;
    }
</style>

<SemanticoPageTitle Title="@_dataSourceName"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Storage" Title="@_dataSourceName"/>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4"/>
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="my-4">@_error</MudAlert>
    }
    else
    {
        <!-- Data Source Statistics -->
        <MudCard Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Overview</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@_dataSourceInfo?.DatabaseEngineType</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Database Type</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Success" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@_queriesCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Queries</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Info" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@_migrationsCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Migration Jobs</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center">
                            <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Warning" Size="Size.Large" Class="mb-2"/>
                            <MudText Typo="Typo.h4">@(_metadata?.Tables.Count ?? 0)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tables</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        <!-- Query Editor -->
        <MudCard Elevation="2" Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Ad-Hoc Query Editor</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex align-center gap-2 mb-2">
                    <MudButton Variant="Variant.Filled"
                              Color="Color.Primary"
                              StartIcon="@Icons.Material.Filled.PlayArrow"
                              OnClick="ExecuteQuery"
                              Disabled="@_executing">
                        @(_executing ? "Executing..." : "Execute Query")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                              Color="Color.Secondary"
                              StartIcon="@Icons.Material.Filled.Refresh"
                              OnClick="RefreshMetadata"
                              Disabled="@_refreshingMetadata">
                        @(_refreshingMetadata ? "Refreshing..." : "Refresh Metadata")
                    </MudButton>
                    @if (_metadata != null)
                    {
                        <MudText Typo="Typo.caption" Class="ml-auto">
                            Last refreshed: @_metadata.RefreshedAt.ToString("g")
                        </MudText>
                    }
                </div>

                <div style="display: flex; gap: 0; height: 600px; border: 1px solid #ddd;">
                    <div style="width: 300px; min-width: 300px; height: 100%; overflow: hidden;">
                        <DatabaseExplorer Metadata="@_metadata"
                                         OnTableSelected="@OnTableSelected"
                                         OnColumnSelected="@OnColumnSelected" />
                    </div>
                    <div style="flex: 1; height: 100%; border-left: 1px solid #ddd;">
                        @if (_monacoReady)
                        {
                            <StandaloneCodeEditor @ref="_editor"
                                                 Id="query-editor"
                                                 ConstructionOptions="EditorConstructionOptions"
                                                 OnDidInit="OnEditorInit"
                                                 OnDidChangeModelContent="OnEditorContentChanged"
                                                 CssClass="sql-editor-container"/>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; background-color: #f5f5f5;">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </div>
                        }
                    </div>
                </div>
            </MudCardContent>
        </MudCard>

        @if (_queryResult != null)
        {
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Query Results</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Executed in @_queryResult.ExecutionTime.TotalMilliseconds.ToString("F2") ms | @_queryResult.RowCount rows
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                      Color="Color.Default"
                                      OnClick="@(() => _queryResult = null)"/>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_queryResult.Success)
                    {
                        @if (_queryResult.RowCount > 0)
                        {
                            <div style="overflow-x: auto;">
                                <MudTable Items="@_queryResult.Rows" Hover="true" Dense="true" Striped="true" Bordered="true">
                                    <HeaderContent>
                                        @foreach (var column in _queryResult.Columns)
                                        {
                                            <MudTh>@column</MudTh>
                                        }
                                    </HeaderContent>
                                    <RowTemplate>
                                        @foreach (var column in _queryResult.Columns)
                                        {
                                            <MudTd DataLabel="@column">
                                                @(context.ContainsKey(column) ? (context[column]?.ToString() ?? "NULL") : "")
                                            </MudTd>
                                        }
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">Query executed successfully but returned no rows.</MudAlert>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error">@_queryResult.Error</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        }
    }
</MudContainer>

@inject IDatabaseMetadataService MetadataService
@inject IDataSourceService DataSourceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

@code {
    [Parameter]
    public int DataSourceId { get; set; }

    private StandaloneCodeEditor? _editor;
    private DatabaseMetadataSnapshot? _metadata;
    private DataSourceListData? _dataSourceInfo;
    private string _dataSourceName = "";
    private int _queriesCount = 0;
    private int _migrationsCount = 0;
    private bool _loading = true;
    private bool _executing = false;
    private bool _refreshingMetadata = false;
    private string? _error;
    private AdHocQueryResult? _queryResult;
    private string _currentQuery = "";
    private bool _completionProviderRegistered = false;
    private bool _monacoReady = false;

    protected override async Task OnInitializedAsync()
    {
        // Wait for Monaco to be ready before rendering the editor
        _monacoReady = await WaitForMonacoAsync();

        try
        {
            _loading = true;

            // Load data source information
            var dataSources = await DataSourceService.GetDataSources(DataSourceId, CancellationToken.None);
            _dataSourceInfo = dataSources.FirstOrDefault();

            if (_dataSourceInfo != null)
            {
                _dataSourceName = _dataSourceInfo.Name;
                _queriesCount = _dataSourceInfo.Queries.Count;
                _migrationsCount = _dataSourceInfo.MigrationJobsCount;
            }
            else
            {
                _dataSourceName = $"Data Source {DataSourceId}";
            }

            // Load metadata
            _metadata = await MetadataService.GetMetadataAsync(DataSourceId);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load data source: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "sql",
            Theme = "vs",
            Value = "-- Write your SQL query here\nSELECT * FROM ",
            FontSize = 14,
            LineNumbers = "on",
            RenderLineHighlight = "all",
            ScrollBeyondLastLine = false,
            ReadOnly = false
        };
    }

    private async Task OnEditorInit()
    {
        if (_editor != null && _metadata != null)
        {
            await RegisterCompletionProvider();
            await EnableDropOnEditor();
        }
    }

    private async Task<bool> WaitForMonacoAsync(int maxAttempts = 50, int delayMs = 100)
    {
        for (int i = 0; i < maxAttempts; i++)
        {
            try
            {
                // Check if both monaco and blazorMonaco are available
                var isReady = await JSRuntime.InvokeAsync<bool>("eval",
                    "typeof monaco !== 'undefined' && typeof blazorMonaco !== 'undefined' && typeof blazorMonaco.editor !== 'undefined' && typeof blazorMonaco.editor.create !== 'undefined'");
                if (isReady)
                {
                    Console.WriteLine($"QueryEditor: BlazorMonaco is ready (attempt {i + 1})");
                    return true;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"QueryEditor: BlazorMonaco check failed (attempt {i + 1}): {ex.Message}");
            }

            await Task.Delay(delayMs);
        }

        Console.WriteLine($"QueryEditor: BlazorMonaco not ready after {maxAttempts} attempts");
        return false;
    }

    private async Task EnableDropOnEditor()
    {
        try
        {
            var success = await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.enableDropOnEditor",
                "query-editor"
            );

            if (success)
            {
                Console.WriteLine("Drop enabled on Monaco editor");
            }
            else
            {
                Console.WriteLine("Failed to enable drop on Monaco editor");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error enabling drop on editor: {ex.Message}");
        }
    }

    private Task OnEditorContentChanged(ModelContentChangedEvent e)
    {
        // Update current query when content changes
        return Task.CompletedTask;
    }

    private async Task RegisterCompletionProvider()
    {
        if (_editor == null || _metadata == null || _completionProviderRegistered) return;

        try
        {
            _completionProviderRegistered = true;

            // Convert metadata to a serializable format for JavaScript
            var metadataForJs = new
            {
                tables = _metadata.Tables.Select(t => new
                {
                    schemaName = t.SchemaName,
                    tableName = t.TableName,
                    description = t.Description,
                    columns = t.Columns.Select(c => new
                    {
                        columnName = c.ColumnName,
                        dataType = c.DataType,
                        isNullable = c.IsNullable,
                        isPrimaryKey = c.IsPrimaryKey,
                        isForeignKey = c.IsForeignKey,
                        foreignKeyTable = c.ForeignKeyTable,
                        foreignKeyColumn = c.ForeignKeyColumn,
                        ordinalPosition = c.OrdinalPosition
                    }).ToList()
                }).ToList()
            };

            // Determine SQL dialect based on data source type
            string sqlDialect = "sql"; // Default, could be enhanced to detect PostgreSQL, SQL Server, etc.

            // Register context-aware completion provider using the helper
            var success = await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.registerSqlCompletionProvider",
                "query-editor",
                sqlDialect,
                metadataForJs
            );

            if (success)
            {
                // Register Ctrl+Space for trigger suggest
                await _editor.AddCommand((int)KeyMod.CtrlCmd | (int)KeyCode.Space, async (args) =>
                {
                    await _editor.Trigger("editor", "editor.action.triggerSuggest", null);
                });

                var totalItems = _metadata.Tables.Count + _metadata.Tables.Sum(t => t.Columns.Count);
                Snackbar.Add($"Context-aware intellisense enabled with {totalItems} database objects", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to register SQL completion provider", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to register completion provider: {ex.Message}", Severity.Warning);
        }
    }

    private async Task ExecuteQuery()
    {
        if (_editor == null) return;

        try
        {
            _executing = true;
            _currentQuery = await _editor.GetValue();

            if (string.IsNullOrWhiteSpace(_currentQuery))
            {
                Snackbar.Add("Please enter a query", Severity.Warning);
                return;
            }

            _queryResult = await DataSourceService.ExecuteAdHocQuery(DataSourceId, _currentQuery, CancellationToken.None);

            if (_queryResult.Success)
            {
                Snackbar.Add($"Query executed successfully - {_queryResult.RowCount} rows returned", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Query execution failed", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Query execution failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _executing = false;
        }
    }

    private async Task RefreshMetadata()
    {
        try
        {
            _refreshingMetadata = true;

            // Dispose old completion provider first
            try
            {
                await JSRuntime.InvokeVoidAsync("semanticoSqlEditor.disposeCompletionProvider", "query-editor");
            }
            catch
            {
                // Ignore errors if provider doesn't exist
            }

            _completionProviderRegistered = false; // Reset flag to allow re-registration
            _metadata = await MetadataService.RefreshMetadataAsync(DataSourceId);

            // Re-register completion provider with new metadata
            if (_editor != null)
            {
                await RegisterCompletionProvider();
            }

            Snackbar.Add($"Metadata refreshed: {_metadata.Tables.Count} tables", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to refresh metadata: {ex.Message}", Severity.Error);
        }
        finally
        {
            _refreshingMetadata = false;
        }
    }

    private async Task OnTableSelected(string tableName)
    {
        if (_editor != null)
        {
            try
            {
                // Get current value and cursor position
                var currentValue = await _editor.GetValue();
                var position = await _editor.GetPosition();

                // Calculate the character offset
                var lines = currentValue.Split('\n');
                var offset = 0;
                for (int i = 0; i < position.LineNumber - 1; i++)
                {
                    offset += lines[i].Length + 1; // +1 for newline
                }
                offset += position.Column - 1;

                // Insert table name at cursor position
                var newValue = currentValue.Insert(offset, tableName);
                await _editor.SetValue(newValue);
                await _editor.Focus();
            }
            catch
            {
                // Silently ignore insert errors
            }
        }
    }

    private async Task OnColumnSelected((string TableName, string ColumnName) selection)
    {
        if (_editor != null)
        {
            try
            {
                var textToInsert = $"{selection.TableName}.{selection.ColumnName}";

                // Get current value and cursor position
                var currentValue = await _editor.GetValue();
                var position = await _editor.GetPosition();

                // Calculate the character offset
                var lines = currentValue.Split('\n');
                var offset = 0;
                for (int i = 0; i < position.LineNumber - 1; i++)
                {
                    offset += lines[i].Length + 1; // +1 for newline
                }
                offset += position.Column - 1;

                // Insert column name at cursor position
                var newValue = currentValue.Insert(offset, textToInsert);
                await _editor.SetValue(newValue);
                await _editor.Focus();
            }
            catch
            {
                // Silently ignore insert errors
            }
        }
    }
}
