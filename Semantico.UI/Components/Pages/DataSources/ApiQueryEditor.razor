@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.DataSources
@using Semantico.Core.Services
@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@using Semantico.Core.Data

<MudCard Elevation="2" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Api" Class="mr-2"/>
                API Query Editor
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Select an endpoint from the list, configure parameters and result mapping, then preview the response.
        </MudAlert>

        <div style="display: flex; gap: 16px; min-height: 500px;">
            @* Left: Endpoint Explorer *@
            <div style="width: 320px; min-width: 320px; overflow-y: auto; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; padding: 8px;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Endpoints</MudText>

                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                }
                else if (_endpointGroups.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No endpoints found. Try refreshing metadata.</MudText>
                }
                else
                {
                    <MudTreeView T="string" Dense="true">
                        @foreach (var group in _endpointGroups)
                        {
                            <MudTreeViewItem T="string" Value="@group.Key" Text="@group.Key" Icon="@Icons.Material.Filled.Folder">
                                @foreach (var ep in group.Value)
                                {
                                    <MudTreeViewItem T="string"
                                                     Value="@ep.TableName"
                                                     Text="@ep.TableName"
                                                     Icon="@GetMethodIcon(ep.TableName)"
                                                     IconColor="@GetMethodColor(ep.TableName)"
                                                     OnClick="@(() => SelectEndpoint(ep))"/>
                                }
                            </MudTreeViewItem>
                        }
                    </MudTreeView>
                }

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="RefreshEndpoints"
                           Disabled="_refreshing"
                           Class="mt-2">
                    @(_refreshing ? "Refreshing..." : "Refresh Endpoints")
                </MudButton>
            </div>

            @* Right: Request Builder *@
            <div style="flex: 1; overflow-y: auto;">
                @if (_selectedEndpoint == null)
                {
                    <MudPaper Elevation="0" Class="pa-8 text-center" Style="border: 2px dashed var(--mud-palette-lines-default); border-radius: 8px; height: 100%; display: flex; align-items: center; justify-content: center;">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary"/>
                            <MudText Typo="Typo.body1" Color="Color.Secondary">Select an endpoint from the list</MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudStack Spacing="3">
                        @* Endpoint info *@
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Color="@GetMethodColor(_selectedEndpoint.TableName)" Size="Size.Small" Variant="Variant.Filled">
                                    @GetMethod(_selectedEndpoint.TableName)
                                </MudChip>
                                <MudText Typo="Typo.subtitle1" Style="font-family: monospace;">@GetPath(_selectedEndpoint.TableName)</MudText>
                            </MudStack>
                            @if (!string.IsNullOrEmpty(_selectedEndpoint.TableDescription))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">@_selectedEndpoint.TableDescription</MudText>
                            }
                        </MudPaper>

                        @* Parameters *@
                        @if (_parameterValues.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2">Parameters</MudText>
                            <MudGrid Spacing="2">
                                @foreach (var param in _parameterValues)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="param.Value"
                                                      Label="@($"{param.Name} ({param.In})")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      HelperText="@param.Description"
                                                      Required="@param.Required"/>
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        @* Result Mapping *@
                        <MudText Typo="Typo.subtitle2">Result Mapping</MudText>
                        <MudTextField @bind-Value="_arrayPath"
                                      Label="Array Path (JSONPath)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      HelperText="JSONPath to the array in the response, e.g. $.data or $"/>

                        <MudSwitch @bind-Value="_autoDetectColumns" Label="Auto-detect columns" Color="Color.Primary"/>

                        @* Execute *@
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       OnClick="ExecuteQuery"
                                       Disabled="@_executing">
                                @(_executing ? "Executing..." : "Preview")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.Code"
                                       OnClick="@(() => _showRawJson = !_showRawJson)">
                                @(_showRawJson ? "Hide JSON" : "Show JSON")
                            </MudButton>
                        </div>

                        @if (_showRawJson)
                        {
                            <MudTextField Value="@BuildQueryJson()"
                                          Label="Query Definition (JSON)"
                                          Variant="Variant.Outlined"
                                          Lines="10"
                                          ReadOnly="true"
                                          Style="font-family: monospace; font-size: 0.85rem;"/>
                        }
                    </MudStack>
                }
            </div>
        </div>
    </MudCardContent>
</MudCard>

@if (_queryResult is { Success: true, RowCount: > 0 })
{
    <MudCard Elevation="2">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Query Results</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_queryResult.RowCount rows in @_queryResult.ExecutionTime.TotalMilliseconds.ToString("F0") ms
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <div style="overflow-x: auto;">
                <MudDataGrid T="Dictionary<string, object?>"
                             Items="@_queryResult.Rows"
                             Hover="true"
                             Dense="true"
                             Filterable="false">
                    <Columns>
                        @foreach (var column in _queryResult.Columns)
                        {
                            var columnName = column;
                            <TemplateColumn Title="@columnName">
                                <CellTemplate>
                                    @(context.Item.GetValueOrDefault(columnName)?.ToString() ?? "NULL")
                                </CellTemplate>
                            </TemplateColumn>
                        }
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="Dictionary<string, object?>" PageSizeOptions="new int[] { 10, 25, 50, 100 }"/>
                    </PagerContent>
                </MudDataGrid>
            </div>
        </MudCardContent>
    </MudCard>
}

@inject IDbContextFactory<SemanticoContext> ContextFactory
@inject ISnackbar Snackbar

@code {
    [Parameter] public int DataSourceId { get; set; }
    [Parameter] public Func<int, string, CancellationToken, Task<AdHocQueryResult>>? ExecuteAdHocQuery { get; set; }

    private bool _loading = true;
    private bool _refreshing;
    private bool _executing;
    private bool _showRawJson;
    private bool _autoDetectColumns = true;
    private string _arrayPath = "$";

    private Dictionary<string, List<EndpointInfo>> _endpointGroups = new();
    private EndpointInfo? _selectedEndpoint;
    private List<ParameterInput> _parameterValues = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEndpoints();
    }

    private async Task LoadEndpoints()
    {
        _loading = true;
        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var metadata = await context.DatabaseMetadata
                .Where(m => m.DataSourceId == DataSourceId && m.ArchivedTime == null)
                .Select(m => new EndpointInfo
                {
                    SchemaName = m.SchemaName,
                    TableName = m.TableName,
                    TableDescription = m.TableDescription,
                    Columns = m.Columns.Select(c => new ColumnInfo { Name = c.ColumnName, Type = c.DataType, Description = c.Description }).ToList()
                })
                .ToListAsync();

            _endpointGroups = metadata
                .GroupBy(e => e.SchemaName)
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.OrderBy(e => e.TableName).ToList());
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshEndpoints()
    {
        _refreshing = true;
        try
        {
            // TODO: call metadata refresh service
            await LoadEndpoints();
            Snackbar.Add("Endpoints refreshed", Severity.Success);
        }
        finally
        {
            _refreshing = false;
        }
    }

    private void SelectEndpoint(EndpointInfo endpoint)
    {
        _selectedEndpoint = endpoint;

        // Parse parameters from column metadata (stored as description hints)
        // For now, extract from the endpoint name pattern
        _parameterValues.Clear();

        var path = GetPath(endpoint.TableName);
        // Extract path parameters like {id}
        var pathParams = System.Text.RegularExpressions.Regex.Matches(path, @"\{(\w+)\}");
        foreach (System.Text.RegularExpressions.Match match in pathParams)
        {
            _parameterValues.Add(new ParameterInput
            {
                Name = match.Groups[1].Value,
                In = "path",
                Required = true
            });
        }

        // Try to guess a good default array path
        _arrayPath = "$";
    }

    private AdHocQueryResult? _queryResult;

    private async Task ExecuteQuery()
    {
        if (_selectedEndpoint == null || ExecuteAdHocQuery == null) return;

        _executing = true;
        _queryResult = null;
        try
        {
            var json = BuildQueryJson();
            _queryResult = await ExecuteAdHocQuery(DataSourceId, json, CancellationToken.None);
            if (_queryResult.Success)
                Snackbar.Add($"Returned {_queryResult.RowCount} rows in {_queryResult.ExecutionTime.TotalMilliseconds:F0}ms", Severity.Success);
            else
                Snackbar.Add($"Error: {_queryResult.Error}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _executing = false;
        }
    }

    private string BuildQueryJson()
    {
        var method = _selectedEndpoint == null ? "GET" : GetMethod(_selectedEndpoint.TableName);
        var path = _selectedEndpoint == null ? "/" : GetPath(_selectedEndpoint.TableName);

        var queryParams = _parameterValues.Where(p => p.In == "query" && !string.IsNullOrEmpty(p.Value)).ToDictionary(p => p.Name, p => p.Value!);
        var pathParams = _parameterValues.Where(p => p.In == "path" && !string.IsNullOrEmpty(p.Value)).ToDictionary(p => p.Name, p => p.Value!);
        var headerParams = _parameterValues.Where(p => p.In == "header" && !string.IsNullOrEmpty(p.Value)).ToDictionary(p => p.Name, p => p.Value!);

        var query = new
        {
            Method = method,
            Path = path,
            Parameters = new
            {
                Query = queryParams,
                Path = pathParams,
                Header = headerParams
            },
            ResultMapping = new
            {
                ArrayPath = _arrayPath,
                Columns = _autoDetectColumns ? (object?)null : new object[] { }
            }
        };

        return JsonSerializer.Serialize(query, new JsonSerializerOptions { WriteIndented = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    }

    private static string GetMethod(string tableName)
    {
        var spaceIndex = tableName.IndexOf(' ');
        return spaceIndex > 0 ? tableName[..spaceIndex] : "GET";
    }

    private static string GetPath(string tableName)
    {
        var spaceIndex = tableName.IndexOf(' ');
        return spaceIndex > 0 ? tableName[(spaceIndex + 1)..] : tableName;
    }

    private static string GetMethodIcon(string tableName)
    {
        var method = GetMethod(tableName);
        return method switch
        {
            "GET" => Icons.Material.Filled.Download,
            "POST" => Icons.Material.Filled.Upload,
            "PUT" => Icons.Material.Filled.Edit,
            "DELETE" => Icons.Material.Filled.Delete,
            "PATCH" => Icons.Material.Filled.BuildCircle,
            _ => Icons.Material.Filled.Http
        };
    }

    private static Color GetMethodColor(string tableName)
    {
        var method = GetMethod(tableName);
        return method switch
        {
            "GET" => Color.Success,
            "POST" => Color.Warning,
            "PUT" => Color.Info,
            "DELETE" => Color.Error,
            "PATCH" => Color.Secondary,
            _ => Color.Default
        };
    }

    private class EndpointInfo
    {
        public string SchemaName { get; set; } = "";
        public string TableName { get; set; } = "";
        public string? TableDescription { get; set; }
        public List<ColumnInfo> Columns { get; set; } = new();
    }

    private class ColumnInfo
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string? Description { get; set; }
    }

    private class ParameterInput
    {
        public string Name { get; set; } = "";
        public string In { get; set; } = "query";
        public bool Required { get; set; }
        public string? Description { get; set; }
        public string? Value { get; set; }
    }
}
