@page "/setup"
@layout SetupLayout
@using Semantico.Core
@using Semantico.Core.Models.UserManagement
@using Semantico.Core.Services
@using System.ComponentModel.DataAnnotations

<SemanticoPageTitle Title="Setup"/>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-8">
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <img src="../_content/Semantico.UI/favicon.svg" alt="Semantico" style="height: 48px; width: 48px;" />
                <MudText Typo="Typo.h4" Style="font-weight: bold">Semantico</MudText>
            </MudStack>

            <MudDivider />

            @if (_setupComplete)
            {
                <MudAlert Severity="Severity.Success" Class="my-4">
                    <MudText Typo="Typo.body1"><strong>Setup Complete!</strong></MudText>
                    <MudText Typo="Typo.body2">Your super admin account has been created. You can now log in.</MudText>
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="GoToLogin">
                    Go to Login
                </MudButton>
            }
            else if (_alreadySetup)
            {
                <MudAlert Severity="Severity.Info" Class="my-4">
                    <MudText Typo="Typo.body1"><strong>Setup Already Complete</strong></MudText>
                    <MudText Typo="Typo.body2">This Semantico installation has already been configured.</MudText>
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="GoToLogin">
                    Go to Login
                </MudButton>
            }
            else
            {
                <MudText Typo="Typo.h6" Align="Align.Center">Initial Setup</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">
                    Create your super admin account to get started.
                </MudText>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                }

                <MudForm @ref="_form" @bind-IsValid="_isFormValid">
                    <MudTextField @bind-Value="_model.UserName"
                                  Label="Username"
                                  Required="true"
                                  RequiredError="Username is required"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email (optional)"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="_model.DisplayName"
                                  Label="Display Name (optional)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="_model.Password"
                                  Label="Password"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Validation="@(new Func<string, string?>(ValidatePassword))"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-3"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showPassword = !_showPassword)" />

                    <MudTextField @bind-Value="_model.ConfirmPassword"
                                  Label="Confirm Password"
                                  InputType="@(_showConfirmPassword ? InputType.Text : InputType.Password)"
                                  Required="true"
                                  RequiredError="Please confirm your password"
                                  Validation="@(new Func<string, string?>(ValidateConfirmPassword))"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-4"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showConfirmPassword = !_showConfirmPassword)" />

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                        <MudText Typo="Typo.caption">
                            Password must be at least @_configuration.UserManagement.MinimumPasswordLength characters
                            @if (_configuration.UserManagement.RequirePasswordComplexity)
                            {
                                <text> and include uppercase, lowercase, number, and special character</text>
                            }
                        </MudText>
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@(!_isFormValid || _isSubmitting)"
                               OnClick="HandleSubmit">
                        @if (_isSubmitting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Creating Account...</text>
                        }
                        else
                        {
                            <text>Create Super Admin Account</text>
                        }
                    </MudButton>
                </MudForm>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@inject IUserManagementService UserService
@inject IRoleService RoleService
@inject SemanticoConfiguration _configuration
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@code {
    private MudForm _form = null!;
    private CreateSuperAdminRequest _model = new();
    private bool _isFormValid;
    private bool _isSubmitting;
    private bool _showPassword;
    private bool _showConfirmPassword;
    private bool _setupComplete;
    private bool _alreadySetup;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Check if setup is needed
        var isFirstRun = await UserService.IsFirstRunAsync();
        _alreadySetup = !isFirstRun;
    }

    private string? ValidatePassword(string password)
    {
        if (string.IsNullOrEmpty(password))
            return null; // Required validation handles this

        if (password.Length < _configuration.UserManagement.MinimumPasswordLength)
            return $"Password must be at least {_configuration.UserManagement.MinimumPasswordLength} characters";

        if (_configuration.UserManagement.RequirePasswordComplexity)
        {
            if (!password.Any(char.IsUpper))
                return "Password must contain at least one uppercase letter";
            if (!password.Any(char.IsLower))
                return "Password must contain at least one lowercase letter";
            if (!password.Any(char.IsDigit))
                return "Password must contain at least one digit";
            if (!password.Any(c => !char.IsLetterOrDigit(c)))
                return "Password must contain at least one special character";
        }

        return null;
    }

    private string? ValidateConfirmPassword(string confirmPassword)
    {
        if (string.IsNullOrEmpty(confirmPassword))
            return null; // Required validation handles this

        if (confirmPassword != _model.Password)
            return "Passwords do not match";

        return null;
    }

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            // Ensure system roles exist
            await RoleService.SeedSystemRolesAsync();

            // Create super admin
            await UserService.CreateSuperAdminAsync(_model);

            _setupComplete = true;
            Snackbar.Add("Super admin account created successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void GoToLogin()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath.TrimEnd('/');
        NavigationManager.NavigateTo($"{path}/login", forceLoad: true);
    }
}
