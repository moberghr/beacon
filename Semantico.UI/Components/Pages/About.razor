@page "/about"
@inherits BasePageComponent

<SemanticoPageTitle Title="About"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Info" Title="About Semantico"/>

    @* Overview Section *@
    <MudCard Class="my-4">
        <MudCardContent>
            <MudStack Spacing="3">
                <MudText Typo="Typo.h4" Color="Color.Primary" Class="fw-bold">
                    Semantic Database Monitoring & Orchestration
                </MudText>
                <MudText Typo="Typo.h6" Color="Color.Secondary">
                    Transform your database monitoring through intelligent queries, flexible alerting, and cross-database orchestration
                </MudText>
                <MudText Typo="Typo.body1">
                    <strong>Semantico</strong> is a powerful .NET library that enables semantic alerts and notifications for databases with robust data orchestration capabilities.
                    Monitor data quality, enforce business rules, automate reporting, and orchestrate complex ETL workflows across PostgreSQL, SQL Server, and MySQL databases.
                </MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @* Core Capabilities *@
    <MudCard Class="my-4">
        <MudCardContent>
            <MudText Typo="Typo.h5" Class="mb-4 fw-bold">Core Capabilities</MudText>
