                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="pa-4" Elevation="0" Style="height: 100%; border: 1px solid var(--mud-palette-divider);">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Color="Color.Primary">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Large" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6" Align="Align.Center" Class="fw-bold">Query Monitoring</MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center">
                                Create semantic SQL queries to monitor data quality, business rules, and database health with multi-step execution
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="pa-4" Elevation="0" Style="height: 100%; border: 1px solid var(--mud-palette-divider);">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Color="Color.Secondary">
                                <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6" Align="Align.Center" Class="fw-bold">Smart Alerting</MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center">
                                Deliver notifications via Email, Microsoft Teams, or Jira with rich formatting and complete result attachments
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
