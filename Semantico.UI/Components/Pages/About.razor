                            <MudText Typo="Typo.body2">
                                Schedule daily sales reports, weekly performance summaries, and monthly analytics.
                                Delivered as Excel/CSV attachments via email.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4" Elevation="0" Style="height: 100%; border-left: 4px solid var(--mud-palette-tertiary);">
