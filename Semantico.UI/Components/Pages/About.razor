@inject IJSRuntime JS

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("mermaid.run", new { querySelector = ".mermaid" });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error rendering Mermaid diagrams: {ex.Message}");
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }
}
