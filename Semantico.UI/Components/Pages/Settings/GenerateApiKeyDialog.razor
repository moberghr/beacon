@namespace Semantico.UI.Components.Pages.ApiKeys
@using MediatR
@using Semantico.Core.Handlers.ApiKeys
@inject IMediator Mediator

<MudDialog>
    <DialogContent>
        @if (_generatedKey == null)
        {
            @* --- Step 1: Configure the key --- *@
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_name"
                                  Label="Key Name"
                                  Required="true"
                                  RequiredError="Name is required"
                                  MaxLength="100"
                                  Variant="Variant.Outlined"
                                  HelperText="A memorable name for this key, e.g. 'CI Pipeline' or 'Monitoring Bot'"/>

                    <MudTextField @bind-Value="_description"
                                  Label="Description (optional)"
                                  Lines="2"
                                  MaxLength="500"
                                  Variant="Variant.Outlined"/>

                    @* Scopes *@
                    <MudDivider Class="my-1"/>
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Scopes</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Grant only the permissions this key requires.
                    </MudText>
                    <MudStack Spacing="1">
                        <MudCheckBox @bind-Value="_scopeRead" Color="Color.Info" Dense="true">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">Read</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Query data, read configurations and reports</MudText>
                            </MudStack>
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_scopeExecute" Color="Color.Warning" Dense="true">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">Execute</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Trigger scans, run queries and execute jobs</MudText>
                            </MudStack>
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_scopeAdmin" Color="Color.Error" Dense="true">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">Admin</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Full access including user management and settings</MudText>
                            </MudStack>
                        </MudCheckBox>
                    </MudStack>

                    @if (!_scopeRead && !_scopeExecute && !_scopeAdmin)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">Select at least one scope.</MudAlert>
                    }

                    @* Project Restrictions *@
                    <MudDivider Class="my-1"/>
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Project Restrictions</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        Select which projects this API key can access via MCP.
                    </MudText>
                    @if (_projects.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">No projects found. Create a project first.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="int" MultiSelection="true" @bind-SelectedValues="_selectedProjectIds"
                                   Label="Projects"
                                   MultiSelectionTextFunc="@(ids => $"{ids.Count()} project(s) selected")"
                                   Variant="Variant.Outlined"
                                   HelperText="Select at least one project for MCP access.">
                            @foreach (var project in _projects)
                            {
                                <MudSelectItem T="int" Value="@project.Id">@project.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    @* Expiration *@
                    <MudDivider Class="my-1"/>
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Expiration (optional)</MudText>
                    <MudDatePicker @bind-Date="_expiresAt"
                                   Label="Expiration Date"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   HelperText="Leave empty for a non-expiring key"
                                   MinDate="@DateTime.Today.AddDays(1)"/>
                </MudStack>
            </MudForm>
        }
        else
        {
            @* --- Step 2: Display the generated key --- *@
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle">
                    API key generated successfully!
                </MudAlert>

                <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Warning">
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">This key will not be shown again.</MudText>
                    <MudText Typo="Typo.caption">
                        Copy it now and store it securely. Once you close this dialog, you will not be able to retrieve the full key.
                    </MudText>
                </MudAlert>

                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Your new API key</MudText>
                    <MudPaper Elevation="0" Class="pa-3" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Style="font-family: monospace; font-size: 0.9rem; word-break: break-all;">
                                @_generatedKey
                            </MudText>
                            <MudIconButton Icon="@(_copied ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.ContentCopy)"
                                           Color="@(_copied ? Color.Success : Color.Primary)"
                                           Size="Size.Small"
                                           OnClick="CopyKey"
                                           Title="Copy to clipboard"/>
                        </MudStack>
                    </MudPaper>
                    @if (_copied)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">Copied to clipboard!</MudText>
                    }
                </MudStack>

                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Key Details</MudText>
                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        @foreach (var scope in GetSelectedScopes())
                        {
                            <MudChip T="string" Size="Size.Small" Color="@GetScopeColor(scope)" Variant="Variant.Filled">@scope</MudChip>
                        }
                    </MudStack>
                    @if (_expiresAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Expires: @_expiresAt.Value.ToString("yyyy-MM-dd")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No expiration date set.</MudText>
                    }
                </MudStack>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_generatedKey == null)
        {
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="Generate"
                       Disabled="@(!_isValid || !HasScope() || _submitting)">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                    <span class="ml-2">Generating...</span>
                }
                else
                {
                    <text>Generate Key</text>
                }
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Done">
                Done — I've copied the key
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject IJSRuntime JS
@inject ISnackbar Snackbar

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _submitting;
    private bool _copied;

    private string _name = string.Empty;
    private string? _description;
    private bool _scopeRead = true;
    private bool _scopeExecute;
    private bool _scopeAdmin;
    private IEnumerable<int> _selectedProjectIds = [];
    private List<ProjectEntry> _projects = [];
    private DateTime? _expiresAt;

    private string? _generatedKey;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        var result = await Mediator.Send(new Semantico.Core.Handlers.Projects.GetProjectsQuery());
        _projects = result.Entries.Select(p => new ProjectEntry(p.Id, p.Name)).ToList();
    }

    private bool HasScope() => _scopeRead || _scopeExecute || _scopeAdmin;

    private List<string> GetSelectedScopes()
    {
        var scopes = new List<string>();
        if (_scopeRead) scopes.Add("Read");
        if (_scopeExecute) scopes.Add("Execute");
        if (_scopeAdmin) scopes.Add("Admin");
        return scopes;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Generate()
    {
        if (!_isValid || !HasScope()) return;

        _submitting = true;
        try
        {
            var projectIds = _selectedProjectIds.ToArray();

            var result = await Mediator.Send(new CreateApiKeyCommand(
                _name,
                GetSelectedScopes().ToArray(),
                projectIds.Length > 0 ? projectIds : null,
                _expiresAt));

            _generatedKey = result.PlainTextKey;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task CopyKey()
    {
        if (_generatedKey == null) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _generatedKey);
            _copied = true;
            StateHasChanged();
        }
        catch
        {
            Snackbar.Add("Could not copy to clipboard automatically. Please select and copy manually.", Severity.Warning);
        }
    }

    private void Done()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }

    private static Color GetScopeColor(string scope) => scope switch
    {
        "Admin" => Color.Error,
        "Execute" => Color.Warning,
        "Read" => Color.Info,
        _ => Color.Default
    };

    private record ProjectEntry(int Id, string Name);
}
