@page "/semantico/settings/mcp/playground"
@namespace Semantico.UI.Components.Pages.McpConfig
@inherits BasePageComponent
@using Markdig
@using MediatR
@using Semantico.Core.Services
@inject IMediator Mediator
@inject IMcpPlaygroundService PlaygroundService
@inject ISnackbar Snackbar

<SemanticoPageTitle Title="MCP Playground"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4" Style="height: calc(100vh - 100px); display: flex; flex-direction: column;">
    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">MCP Playground</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Test MCP tools interactively. Select a project and start asking questions.
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="int?" @bind-Value="_selectedProjectId"
                       Label="Project"
                       Variant="Variant.Outlined"
                       Placeholder="Select a project"
                       Style="min-width: 250px;"
                       Dense="true"
                       Margin="Margin.Dense">
                @foreach (var p in _projects)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_selectedTool"
                       Label="Tool"
                       Variant="Variant.Outlined"
                       Style="min-width: 180px;"
                       Dense="true"
                       Margin="Margin.Dense">
                @foreach (var tool in _toolNames)
                {
                    <MudSelectItem T="string" Value="@tool">@tool</MudSelectItem>
                }
            </MudSelect>
            <MudTooltip Text="Clear conversation">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearMessages" Disabled="@(_messages.Count == 0)"/>
            </MudTooltip>
        </MudStack>
    </MudStack>

    @* Chat area *@
    <MudPaper Elevation="0" Class="flex-grow-1 pa-4" Style="overflow-y: auto; background: var(--mud-palette-background-grey); border-radius: 12px 12px 0 0;" @ref="_chatPanel">
        @if (_messages.Count == 0)
        {
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; opacity: 0.5;">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" Color="Color.Default"/>
                    <MudText Typo="Typo.body1" Align="Align.Center">Select a project and ask a question to get started.</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Use <strong>ask</strong> for natural language queries, <strong>search</strong> to find tables, or <strong>get_context</strong> for a project overview.
                    </MudText>
                </MudStack>
            </div>
        }
        else
        {
            <MudStack Spacing="3">
                @foreach (var msg in _messages)
                {
                    @if (msg.IsUser)
                    {
                        @* User message *@
                        <div style="display: flex; justify-content: flex-end;">
                            <MudPaper Elevation="1" Class="pa-3" Style="max-width: 75%; border-radius: 12px 12px 0 12px; background: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@msg.Text</MudText>
                                <MudText Typo="Typo.caption" Style="opacity: 0.7; margin-top: 4px;">@msg.ToolName</MudText>
                            </MudPaper>
                        </div>
                    }
                    else
                    {
                        @* System response *@
                        <div style="display: flex; justify-content: flex-start;">
                            <MudPaper Elevation="0" Class="pa-3" Style="max-width: 85%; border-radius: 12px 12px 12px 0; background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default);">
                                @if (msg.IsError)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true" NoIcon="false" Class="mb-2">Error</MudAlert>
                                }
                                <div class="mcp-markdown" style="font-size: 0.85rem;">@((MarkupString)RenderMarkdown(msg.Text))</div>
                                @if (msg.DurationMs.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 4px;">@msg.DurationMs ms</MudText>
                                }
                            </MudPaper>
                        </div>
                    }
                }
                @if (_executing)
                {
                    <div style="display: flex; justify-content: flex-start;">
                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 12px 12px 12px 0; background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default);">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="width: 200px;"/>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Executing @_selectedTool...</MudText>
                        </MudPaper>
                    </div>
                }
            </MudStack>
        }
    </MudPaper>

    @* Input area *@
    <MudPaper Elevation="2" Class="pa-3" Style="border-radius: 0 0 12px 12px;">
        @if (_selectedTool == "ask")
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_inputText"
                              Placeholder="Ask a question about your data..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              Immediate="true"
                              OnKeyDown="HandleKeyDown"
                              Disabled="_executing"/>
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@(_executing || string.IsNullOrWhiteSpace(_inputText) || _selectedProjectId == null)"/>
            </MudStack>
        }
        else if (_selectedTool == "search")
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_inputText"
                              Placeholder="Search keyword (e.g. customer, revenue, order_date)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              Immediate="true"
                              OnKeyDown="HandleKeyDown"
                              Disabled="_executing"/>
                <MudNumericField T="int" @bind-Value="_maxResults"
                                 Label="Max"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="1" Max="50"
                                 Style="width: 90px;"
                                 Disabled="_executing"/>
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@(_executing || string.IsNullOrWhiteSpace(_inputText) || _selectedProjectId == null)"/>
            </MudStack>
        }
        else if (_selectedTool == "query")
        {
            <MudStack Spacing="2">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudTextField @bind-Value="_datasourceName"
                                  Placeholder="Data source name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Style="max-width: 250px;"
                                  Disabled="_executing"/>
                    <MudNumericField T="int" @bind-Value="_maxRows"
                                     Label="Max rows"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="1" Max="1000"
                                     Style="width: 120px;"
                                     Disabled="_executing"/>
                    <MudSpacer/>
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Color="Color.Primary"
                                   OnClick="SendMessage"
                                   Disabled="@(_executing || string.IsNullOrWhiteSpace(_inputText) || _selectedProjectId == null)"/>
                </MudStack>
                <MudTextField @bind-Value="_inputText"
                              Placeholder="SELECT * FROM ..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3"
                              FullWidth="true"
                              Disabled="_executing"/>
            </MudStack>
        }
        else if (_selectedTool == "get_documentation")
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_datasourceName"
                              Placeholder="Data source name (optional)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="max-width: 200px;"
                              Disabled="_executing"/>
                <MudTextField @bind-Value="_tableName"
                              Placeholder="Table name (optional)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="max-width: 200px;"
                              Disabled="_executing"/>
                <MudTextField @bind-Value="_schemaName"
                              Placeholder="Schema (optional)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="max-width: 150px;"
                              Disabled="_executing"/>
                <MudSpacer/>
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@(_executing || _selectedProjectId == null)"/>
            </MudStack>
        }
        else
        {
            @* get_context — no params needed *@
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2" Color="Color.Secondary">No parameters needed — click send to get the project overview.</MudText>
                <MudSpacer/>
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@(_executing || _selectedProjectId == null)"/>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<ProjectEntry> _projects = [];
    private IReadOnlyList<string> _toolNames = [];
    private int? _selectedProjectId;
    private string _selectedTool = "ask";
    private string _inputText = "";
    private string _datasourceName = "";
    private string _tableName = "";
    private string _schemaName = "";
    private int _maxResults = 20;
    private int _maxRows = 100;
    private bool _executing;
    private readonly List<ChatMessage> _messages = [];
    private MudPaper? _chatPanel;

    protected override async Task OnInitializedAsync()
    {
        _toolNames = PlaygroundService.ToolNames;

        var result = await Mediator.Send(new Semantico.Core.Handlers.Projects.GetProjectsQuery());
        _projects = result.Entries.Select(p => new ProjectEntry(p.Id, p.Name)).ToList();

        if (_projects.Count == 1)
            _selectedProjectId = _projects[0].Id;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (_selectedProjectId == null)
        {
            Snackbar.Add("Select a project first.", Severity.Warning);
            return;
        }

        var args = BuildArguments();
        var displayText = GetDisplayText();

        _messages.Add(new ChatMessage(true, displayText, _selectedTool, false, null));
        _executing = true;
        StateHasChanged();

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var result = await PlaygroundService.ExecuteToolAsync(_selectedTool, args, _selectedProjectId.Value, CancellationToken.None);
            sw.Stop();

            _messages.Add(new ChatMessage(false, result.Text, _selectedTool, result.IsError, (int)sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage(false, $"Exception: {ex.Message}", _selectedTool, true, null));
        }
        finally
        {
            _executing = false;
            _inputText = "";
            StateHasChanged();
        }
    }

    private Dictionary<string, object?> BuildArguments() => _selectedTool switch
    {
        "ask" => new()
        {
            ["question"] = _inputText,
            ["execute"] = true
        },
        "search" => new()
        {
            ["query"] = _inputText,
            ["max_results"] = _maxResults
        },
        "query" => BuildQueryArgs(),
        "get_documentation" => BuildDocArgs(),
        _ => new() // get_context
    };

    private Dictionary<string, object?> BuildQueryArgs()
    {
        var args = new Dictionary<string, object?> { ["sql"] = _inputText, ["max_rows"] = _maxRows };
        if (!string.IsNullOrWhiteSpace(_datasourceName))
            args["datasource_name"] = _datasourceName;
        return args;
    }

    private Dictionary<string, object?> BuildDocArgs()
    {
        var args = new Dictionary<string, object?>();
        if (!string.IsNullOrWhiteSpace(_datasourceName))
            args["datasource_name"] = _datasourceName;
        if (!string.IsNullOrWhiteSpace(_tableName))
            args["table_name"] = _tableName;
        if (!string.IsNullOrWhiteSpace(_schemaName))
            args["schema_name"] = _schemaName;
        return args;
    }

    private string GetDisplayText() => _selectedTool switch
    {
        "ask" => _inputText,
        "search" => $"search: {_inputText}",
        "query" => $"{(string.IsNullOrWhiteSpace(_datasourceName) ? "" : $"[{_datasourceName}] ")}{_inputText}",
        "get_documentation" => GetDocDisplayText(),
        _ => "get_context"
    };

    private string GetDocDisplayText()
    {
        var parts = new[] { _datasourceName, _tableName, _schemaName }.Where(s => !string.IsNullOrWhiteSpace(s)).ToList();
        return parts.Count > 0 ? string.Join(" / ", parts) : "Project documentation";
    }

    private void ClearMessages() => _messages.Clear();

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static string RenderMarkdown(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        return Markdown.ToHtml(text, MarkdownPipeline);
    }

    private record ProjectEntry(int Id, string Name);
    private record ChatMessage(bool IsUser, string Text, string ToolName, bool IsError, int? DurationMs);
}

<style>
    .mcp-markdown h1 { font-size: 1.3rem; font-weight: 600; margin: 0.5rem 0 0.3rem; }
    .mcp-markdown h2 { font-size: 1.1rem; font-weight: 600; margin: 0.5rem 0 0.3rem; }
    .mcp-markdown h3 { font-size: 0.95rem; font-weight: 600; margin: 0.4rem 0 0.2rem; }
    .mcp-markdown p { margin: 0.3rem 0; }
    .mcp-markdown ul, .mcp-markdown ol { margin: 0.3rem 0; padding-left: 1.5rem; }
    .mcp-markdown li { margin: 0.15rem 0; }
    .mcp-markdown pre {
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 6px;
        padding: 0.6rem 0.8rem;
        overflow-x: auto;
        font-size: 0.8rem;
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
        margin: 0.4rem 0;
    }
    .mcp-markdown code {
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
        font-size: 0.82rem;
    }
    .mcp-markdown :not(pre) > code {
        background: var(--mud-palette-background-grey);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
    }
    .mcp-markdown table {
        border-collapse: collapse;
        width: 100%;
        margin: 0.4rem 0;
        font-size: 0.8rem;
    }
    .mcp-markdown th, .mcp-markdown td {
        border: 1px solid var(--mud-palette-lines-default);
        padding: 0.3rem 0.6rem;
        text-align: left;
    }
    .mcp-markdown th {
        background: var(--mud-palette-background-grey);
        font-weight: 600;
    }
    .mcp-markdown strong { font-weight: 600; }
    .mcp-markdown hr { border: none; border-top: 1px solid var(--mud-palette-lines-default); margin: 0.5rem 0; }
</style>
