@page "/semantico/queries"
@inherits BasePageComponent
@using Semantico.Core.Models.Queries
@using Semantico.Core.Services
@using SortDirection = MudBlazor.SortDirection


<SemanticoPageTitle Title="Queries"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.Search" Title="Queries" ButtonText="New Query" OnClick="@NewQuery"/>
    <SemanticoPageAlert Text="Manage your queries and subscriptions. Click on a row to view details and configure subscriptions."/>
    <MudCard Elevation="2">
        <MudDataGrid @ref="_dataGrid" ServerData="ServerReload" T="QueryData" RowClick="OnRowClick" Hover="true" Filterable="false" Bordered="false">
        <Columns>
            <PropertyColumn Property="x => x.QueryId" Title="Id"/>
            <PropertyColumn InitialDirection="SortDirection.Ascending" Property="x => x.Name" Title="Name"/>
            <PropertyColumn Property="x => x.Description" Title="Description"/>
            <PropertyColumn Property="x => x.CreatedTime" Title="Created"/>
            <PropertyColumn Property="x => x.ProjectName"/>
            <PropertyColumn Property="x => x.SubscriptionsCount" Title="Subscriptions Count"/>
            <PropertyColumn Property="x => x.Parameters.ToJson()" Title="Parameters"/>
        </Columns>
            <PagerContent>
                <MudDataGridPager T="QueryData"/>
            </PagerContent>
        </MudDataGrid>
    </MudCard>
</MudContainer>


@inject Semantico.Core.Services.IQueryService service;
@inject IDialogService DialogService

@code {
    private PagedList<QueryData> QueriesList { get; set; }
    MudDataGrid<QueryData>? _dataGrid;
    private bool _loading;
    private string _searchString;

    private async Task<GridData<QueryData>> ServerReload(GridState<QueryData> state)
    {
        var request = DataGridHelper.BuildSortedRequest<GetQueriesRequest, QueryData>(state);
        QueriesList = await service.GetQueries(request, CancellationToken.None);

        return new GridData<QueryData>
        {
            TotalItems = QueriesList.TotalCount ?? 0,
            Items = QueriesList.Items
        };
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        _dataGrid?.ReloadServerData();
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<QueryData> args)
    {
        NavManager.NavigateTo($"/semantico/queries/details/{args.Item.QueryId}");
    }

    private void NewQuery()
    {
        NavManager.NavigateTo("/semantico/queries/add");
    }
}