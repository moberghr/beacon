@using Semantico.Core.Handlers.QueryFolders
@using MediatR

<MudPaper Elevation="2" Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h6">Folders</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@(() => CreateFolder(null))"
                       Title="Create Root Folder" />
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else
    {
        <MudTreeView T="QueryFolderData"
                     Items="_treeItems"
                     Dense="true"
                     Hover="true"
                     ExpandOnClick="true"
                     @bind-SelectedValue="_selectedFolder">
            <ItemTemplate Context="context">
                <MudTreeViewItem @bind-Expanded="@context.Expanded"
                                 Items="@context.Children"
                                 Value="@context.Value"
                                 Icon="@(context.Expanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder)"
                                 Text="@context.Text"
                                 OnClick="@(() => OnNodeSelected(context.Value))">
                    <BodyContent Context="folder">
                        <div class="d-flex align-center justify-space-between" style="width: 100%;">
                            <div class="d-flex align-center">
                                <MudText>@context.Value?.Name</MudText>
                                <MudChip T="int" Size="Size.Small" Variant="Variant.Text">@(context.Value?.QueryCount ?? 0)</MudChip>
                            </div>
                            <div class="d-flex" @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                                               Size="Size.Small"
                                               OnClick="@(() => CreateFolder(context.Value?.Id))"
                                               Title="Create Subfolder" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               OnClick="@(() => EditFolder(context.Value))"
                                               Title="Edit Folder" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteFolder(context.Value))"
                                               Title="Delete Folder" />
                            </div>
                        </div>
                    </BodyContent>
                </MudTreeViewItem>
            </ItemTemplate>
        </MudTreeView>

        <MudDivider Class="my-2" />

        <MudList T="string" Dense="true">
            <MudListItem T="string"
                         OnClick="@(() => OnRootLevelSelected())"
                         Class="@(_selectedFolderId == -1 ? "mud-selected-item" : "")">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOff" Class="mr-2" />
                    <MudText>Root Level (No Folder)</MudText>
                    <MudChip T="int" Size="Size.Small" Variant="Variant.Text">@_rootQueryCount</MudChip>
                </div>
            </MudListItem>

            <MudListItem T="string"
                         OnClick="@(() => OnShowAllQueries())"
                         Class="@(_selectedFolderId == null ? "mud-selected-item" : "")">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                    <MudText>All Queries</MudText>
                    <MudChip T="int" Size="Size.Small" Variant="Variant.Text">@_totalQueryCount</MudChip>
                </div>
            </MudListItem>
        </MudList>
    }
</MudPaper>

@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@code {
    [Parameter]
    public EventCallback<int?> OnFolderSelected { get; set; }

    private bool _loading = true;
    private List<QueryFolderData> _folders = new();
    private List<TreeItemData<QueryFolderData>> _treeItems = new();
    private QueryFolderData? _selectedFolder;
    private int? _selectedFolderId;
    private int _rootQueryCount;
    private int _totalQueryCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadFolders();
    }

    private async Task LoadFolders()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new GetQueryFoldersQuery());
            _folders = result.Folders;
            _rootQueryCount = result.RootLevelQueryCount;
            _totalQueryCount = result.TotalQueryCount;
            BuildTreeStructure();
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildTreeStructure()
    {
        _treeItems = new List<TreeItemData<QueryFolderData>>();

        var folderDict = _folders.ToDictionary(
            f => f.Id,
            f => new TreeItemData<QueryFolderData>
            {
                Value = f,
                Text = $"{f.Name} ({f.QueryCount})",
                Icon = Icons.Material.Filled.Folder,
                Children = new List<TreeItemData<QueryFolderData>>()
            });

        foreach (var folder in _folders)
        {
            var node = folderDict[folder.Id];

            if (folder.ParentFolderId.HasValue && folderDict.TryGetValue(folder.ParentFolderId.Value, out var parentNode))
            {
                ((List<TreeItemData<QueryFolderData>>)parentNode.Children!).Add(node);
            }
            else
            {
                _treeItems.Add(node);
            }
        }
    }

    private async Task OnNodeSelected(QueryFolderData? folder)
    {
        _selectedFolder = folder;
        _selectedFolderId = folder?.Id;
        await OnFolderSelected.InvokeAsync(_selectedFolderId);
    }

    private async Task OnRootLevelSelected()
    {
        _selectedFolder = null;
        _selectedFolderId = -1; // -1 indicates root level (no folder)
        await OnFolderSelected.InvokeAsync(_selectedFolderId);
    }

    private async Task OnShowAllQueries()
    {
        _selectedFolder = null;
        _selectedFolderId = null; // null indicates show all
        await OnFolderSelected.InvokeAsync(null);
    }

    private async Task CreateFolder(int? parentFolderId)
    {
        var parameters = new DialogParameters<CreateFolderDialog>
        {
            { x => x.ParentFolderId, parentFolderId }
        };

        var dialog = await DialogService.ShowAsync<CreateFolderDialog>("Create Folder", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadFolders();
            await OnFolderSelected.InvokeAsync(_selectedFolderId);
        }
    }

    private async Task EditFolder(QueryFolderData? folder)
    {
        if (folder == null) return;

        var parameters = new DialogParameters<UpdateFolderDialog>
        {
            { x => x.Folder, folder }
        };

        var dialog = await DialogService.ShowAsync<UpdateFolderDialog>("Edit Folder", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadFolders();
            await OnFolderSelected.InvokeAsync(_selectedFolderId);
        }
    }

    private async Task DeleteFolder(QueryFolderData? folder)
    {
        if (folder == null) return;

        var parameters = new DialogParameters<DeleteFolderDialog>
        {
            { x => x.Folder, folder }
        };

        var dialog = await DialogService.ShowAsync<DeleteFolderDialog>("Delete Folder", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadFolders();

            // If the deleted folder was selected, clear selection
            if (_selectedFolderId == folder.Id)
            {
                _selectedFolderId = null;
                await OnFolderSelected.InvokeAsync(null);
            }
        }
    }
}
