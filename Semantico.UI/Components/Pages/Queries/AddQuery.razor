@page "/queries/add"
@using Semantico.Core.Models.Queries
@using Semantico.Core.Services
@using Semantico.UI.Components.Custom
@using Semantico.Core.Data.Enums
@using Semantico.Core.Adapters
@using QueryParameterValue = Semantico.Core.Models.Queries.ParameterValue

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
    <MudStack Spacing="4">
        <MudPaper Class="pa-6">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
                <MudText Typo="Typo.h4">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3" />
                    Add New Query
                </MudText>
                <MudStack Row Spacing="2">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="@GoBack">
                        Back
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="!IsFormValid"
                               OnClick="@Submit">
                        Save Query
                    </MudButton>
                </MudStack>
            </MudStack>

            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="@Query.Name"
                                      Label="Query Name"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      HelperText="Enter a descriptive name for your query" />
                        
                        <MudTextField @bind-Value="@Query.Description"
                                      Label="Description"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      AutoGrow
                                      Required="true"
                                      HelperText="Describe what this query does and its purpose" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-2">Query Info</MudText>
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                <strong>Steps:</strong> @(Query?.Steps?.Count ?? 0)
                            </MudText>
                            @if (Query?.IsMultiStep == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Multi-Step</MudChip>
                            }
                            @if (Query?.IsCrossDataSource == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Cross-Data-Source</MudChip>
                            }
                            @if (Query?.IsCrossDatabase == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Cross-Database</MudChip>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <QueryStepBuilder Query="@Query"
                          AvailableProjects="@_availableProjects"
                          OnQueryChanged="@OnQueryChanged"
                          OnPreviewStep="@OnPreviewStep"
                          OnPreviewStepWithParameters="@OnPreviewStepWithParameters"
                          OnExecuteQuery="@OnExecuteQuery"
                          OnSaveQuery="@OnSaveQuery" />

        @if (Query?.Steps?.Any() == true)
        {
            <QueryFlowDiagram Query="@Query" />
        }

        @if (_currentQueryResult != null)
        {
            <QueryExecutionResultsPreview ExecutionResult="@_currentQueryResult"
                                          OnClose="@ClosePreview" />
        }
    </MudStack>
</MudContainer>

@inject ISnackbar Snackbar
@inject IQueryService QueryService
@inject IQueryExecutionPreviewService PreviewService
@inject IDataSourceService DataSourceService
@inject NavigationManager NavigationManager

@code
{
    public QueryData Query { get; set; } = new();

    private Dictionary<int, QueryStepBuilder.ProjectInfo> _availableProjects { get; set; } = [];
    private bool _loading;
    private QueryExecutionResult? _currentQueryResult;

    protected override async Task OnInitializedAsync()
    {
        var dataSources = await DataSourceService.GetDataSources(null, default);

        // Only include database type data sources for queries (for now)
        _availableProjects = dataSources
            .Where(x => x.DatabaseEngineType.HasValue)
            .ToDictionary(x => x.Id, x => new QueryStepBuilder.ProjectInfo
            {
                Name = x.Name,
                DatabaseEngine = x.DatabaseEngineType!.Value.ToString(),
                DatabaseEngineType = x.DatabaseEngineType.Value
            });

        // Initialize query with empty steps collection
        Query = new QueryData { Name = "", Description = "", Steps = new() };
    }

    private async Task Submit()
    {
        if (_loading || !IsFormValid)
        {
            return;
        }

        _loading = true;

        try
        {
            var response = await QueryService.CreateQuery(Query, CancellationToken.None);

            if (response.Success)
            {
                Snackbar.Add(response.Message, Severity.Success);
                NavigationManager.NavigateTo("queries");
            }
            else
            {
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }

        _loading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("queries");
    }

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Query?.Name) &&
        !string.IsNullOrWhiteSpace(Query?.Description) &&
        Query?.Steps?.Any() == true &&
        Query.Steps.All(s => !string.IsNullOrWhiteSpace(s.SqlValue) && s.DataSourceId > 0);

    private void OnQueryChanged(QueryData updatedQuery)
    {
        Query = updatedQuery;
        StateHasChanged();
    }

    private async Task OnPreviewStep(int stepOrder)
    {
        await OnPreviewStepWithParameters((stepOrder, new List<QueryParameterValue>()));
    }

    private async Task OnPreviewStepWithParameters((int stepOrder, List<QueryParameterValue> parameters) args)
    {
        var step = Query.Steps.FirstOrDefault(s => s.StepOrder == args.stepOrder);
        if (step == null) 
        {
            Snackbar.Add($"Step {args.stepOrder} not found", Severity.Error);
            return;
        }

        try
        {
            Snackbar.Add($"Executing step {args.stepOrder}...", Severity.Info);
            
            // Use the preview service to execute the temporary step
            var executionResult = await PreviewService.ExecuteTemporaryStepPreview(Query, args.stepOrder, args.parameters, CancellationToken.None);

            if (executionResult != null)
            {
                // Convert step result to full query result for compatibility with QueryExecutionResultsPreview
                _currentQueryResult = new QueryExecutionResult
                {
                    Success = executionResult.Success,
                    ErrorMessage = executionResult.ErrorMessage,
                    TotalExecutionTimeMs = executionResult.ExecutionTimeMs,
                    IsMultiStep = Query.Steps.Count > 1,
                    IsCrossDataSource = Query.Steps.Select(s => s.DataSourceId).Distinct().Count() > 1,
                    IsCrossDatabase = Query.Steps.Where(s => s.DatabaseEngineType.HasValue).Select(s => s.DatabaseEngineType!.Value).Distinct().Count() > 1,
                    DataSourcesInvolved = Query.Steps.Select(s => s.DataSourceName).Distinct().ToList(),
                    DatabaseEnginesUsed = Query.Steps.Where(s => s.DatabaseEngineType.HasValue).Select(s => s.DatabaseEngineType!.Value).Distinct().ToList(),
                    StepResults = new List<QueryStepResult> { executionResult },
                    FinalResult = executionResult.Success && executionResult.PreviewResults != null ? new QueryResult
                    {
                        QueryResults = "Step preview results",
                        TotalRecords = executionResult.TotalRows,
                        DataSourceName = executionResult.DataSourceName,
                        SqlQuery = executionResult.StepName,
                        SubscriptionName = "Step Preview",
                        SubscriptionId = null,
                        ExecutionTimeMs = executionResult.ExecutionTimeMs,
                        AllRecords = executionResult.PreviewResults,
                        TopRecords = executionResult.PreviewResults?.Take(20).ToList() ?? new()
                    } : null
                };

                if (executionResult.Success)
                {
                    Snackbar.Add($"Step {args.stepOrder} executed successfully! Returned {executionResult.TotalRows} rows in {executionResult.ExecutionTimeMs:F0}ms", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Step {args.stepOrder} execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add($"Step {args.stepOrder} execution failed", Severity.Error);
            }
            
            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing step {args.stepOrder}: {e.Message}", Severity.Error);
        }
    }

    private void ClosePreview()
    {
        _currentQueryResult = null;
        StateHasChanged();
    }

    private async Task OnExecuteQuery()
    {
        if (!Query.Steps.Any())
        {
            Snackbar.Add("Add at least one step before executing the query", Severity.Warning);
            return;
        }

        try
        {
            Snackbar.Add("Executing full query...", Severity.Info);
            
            var executionResult = await PreviewService.ExecuteTemporaryQueryPreview(Query, CancellationToken.None);

            if (executionResult != null)
            {
                _currentQueryResult = executionResult;
                
                if (executionResult.Success)
                {
                    var message = executionResult.IsMultiStep 
                        ? $"Query executed successfully! {executionResult.StepResults.Count} steps completed in {executionResult.TotalExecutionTimeMs:F0}ms"
                        : $"Query executed successfully! Returned {executionResult.FinalResult?.TotalRecords ?? 0} rows in {executionResult.TotalExecutionTimeMs:F0}ms";
                        
                    Snackbar.Add(message, Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Query execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add("Query execution failed", Severity.Error);
            }
            
            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing query: {e.Message}", Severity.Error);
        }
    }

    private async Task OnSaveQuery()
    {
        await Submit();
    }
}