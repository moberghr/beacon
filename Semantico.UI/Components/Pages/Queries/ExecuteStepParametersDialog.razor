@using MudBlazor
@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Queries
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-1 mb-n1" />
            Step Parameters
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">Provide values for the query parameters before executing the step.</MudText>
        <MudForm @ref="@_form" @bind-IsValid="_isFormValid">
            @foreach (var param in Parameters)
            {
                @if (!string.IsNullOrEmpty(param.Placeholder))
                {
                    @if (param.Type == ParameterType.String)
                    {
                        <MudTextField T="string"
                            Label="@param.Name"
                            @bind-Value="_parameterValues[param.Placeholder]"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            HelperText="@($"{param.Description} (Placeholder: {param.Placeholder})")"
                            Class="mb-2" />
                    }
                    else if (param.Type == ParameterType.Number)
                    {
                        <MudTextField T="string"
                            Label="@param.Name"
                            @bind-Value="_parameterValues[param.Placeholder]"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            HelperText="@($"{param.Description} (Placeholder: {param.Placeholder})")"
                            Validation="@(new Func<string, string?>(value => ValidateNumber(value)))"
                            Class="mb-2" />
                    }
                    else if (param.Type == ParameterType.DateTime)
                    {
                        <MudTextField T="string"
                            Label="@param.Name"
                            @bind-Value="_parameterValues[param.Placeholder]"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            HelperText="@($"{param.Description} (Format: yyyy-MM-dd HH:mm:ss) (Placeholder: {param.Placeholder})")"
                            Validation="@(new Func<string, string?>(value => ValidateDateTime(value)))"
                            Class="mb-2" />
                    }
                }
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Disabled="!_isFormValid"
                   OnClick="Submit"
                   Variant="Variant.Filled">
            Execute
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public List<QueryStepParameterData> Parameters { get; set; } = new();

    private MudForm _form = null!;
    private bool _isFormValid = false;
    private Dictionary<string, string> _parameterValues = new();

    protected override void OnInitialized()
    {
        // Initialize parameter values dictionary with empty strings
        foreach (var param in Parameters.Where(p => !string.IsNullOrEmpty(p.Placeholder)))
        {
            _parameterValues[param.Placeholder!] = string.Empty;
        }
    }

    void Submit()
    {
        // Convert to ParameterValue list
        var parameterValues = _parameterValues
            .Where(kvp => !string.IsNullOrWhiteSpace(kvp.Key))
            .Select(kvp => new Semantico.Core.Models.Queries.ParameterValue
            {
                Name = Parameters.First(p => p.Placeholder == kvp.Key).Name,
                Value = kvp.Value
            })
            .ToList();

        MudDialog.Close(DialogResult.Ok(parameterValues));
    }

    void Cancel() => MudDialog.Cancel();

    string? ValidateNumber(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Value is required";
        }

        if (!double.TryParse(value, out _))
        {
            return "Value must be a valid number";
        }

        return null;
    }

    string? ValidateDateTime(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Value is required";
        }

        if (!DateTime.TryParse(value, out _))
        {
            return "Value must be a valid date/time (e.g., 2024-01-01 12:00:00)";
        }

        return null;
    }
}
