@using Semantico.Core.Handlers.QueryFolders
@using MediatR

<MudDialog>
    <DialogContent>
        <MudText>Are you sure you want to delete the folder <strong>@Folder.Name</strong>?</MudText>

        @if (Folder.ChildFolderCount > 0)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">
                This folder contains @Folder.ChildFolderCount subfolder(s). Please delete or move the subfolders first.
            </MudAlert>
        }
        else if (Folder.QueryCount > 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-3">
                This folder contains @Folder.QueryCount query(ies).
            </MudAlert>

            <MudCheckBox @bind-Value="_moveQueriesToParent"
                         Label="Move queries to parent folder"
                         Color="Color.Primary"
                         Class="mt-2" />

            @if (_moveQueriesToParent)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2">
                    Queries will be moved to @(Folder.ParentFolderId.HasValue ? "the parent folder" : "root level (no folder)").
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">
                    You must check the option above to delete a folder that contains queries.
                </MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(_deleting || (Folder.QueryCount > 0 && !_moveQueriesToParent) || Folder.ChildFolderCount > 0)">
            @if (_deleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Delete</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@inject IMediator Mediator
@inject ISnackbar Snackbar

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public QueryFolderData Folder { get; set; } = null!;

    private bool _moveQueriesToParent;
    private bool _deleting;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        _deleting = true;
        try
        {
            var command = new DeleteQueryFolderCommand(
                FolderId: Folder.Id,
                MoveQueriesToParent: _moveQueriesToParent
            );

            await Mediator.Send(command);

            Snackbar.Add($"Folder '{Folder.Name}' deleted successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting folder: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleting = false;
        }
    }
}
