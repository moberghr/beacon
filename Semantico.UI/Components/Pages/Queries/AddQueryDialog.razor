@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Projects
@using Semantico.Core.Models.Queries
@using Semantico.Core.Services

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1 mb-n1" />
            Add query
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1" @bind-Errors="@errors" @bind-IsValid="_isFormValid">
            <MudTextField OnlyValidateIfDirty="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Class="mb-2"
                          @bind-Value="@Query.Name"
                          T="String"
                          Label="Name"
                          Required="true" />
            <MudTextField OnlyValidateIfDirty="true"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Class="mb-2"
                          @bind-Value="@Query.Description"
                          T="string"
                          Label="Description"
                          Required="true"
                          AutoGrow />
            <MudSelect T="int" Label="Project" @bind-Value="@Query.ProjectId" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                @{
                    foreach (var project in _projects)
                    {
                        <MudSelectItem Value="project.Key">@project.Value</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudTextField OnlyValidateIfDirty="true"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Lines="5"
                          Class="mb-2"
                          @bind-Value="@Query.SqlValue"
                          T="string"
                          Label="SQL"
                          Required="true"
                          AutoGrow />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Class="ml-4"
                   OnClick="@Cancel"
                   Variant="Variant.Filled">
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="!_isFormValid" OnClick="@Submit" />
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IQueryService QueryService
@inject IProjectService ProjectService
@inject IJSRuntime JS

@code
{
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public QueryData Query { get; set; }

    private Dictionary<int, string> _projects { get; set; } = [];

    private MudForm _form;
    private bool _loading;
    bool _isFormValid = false;
    string[] errors = { };

    protected override async Task OnInitializedAsync()
    {
        var projects = await ProjectService.GetProjectsAsync(null, default);

        _projects = projects.ToDictionary(x => x.Id, x => x.Name);
    }

    async Task Submit()
    {
        if (_loading)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        _loading = true;

        try
        {
            var response = await QueryService.CreateQueryAsync(Query, CancellationToken.None);

            if (response.Success)
            {
                MudDialog.Close(DialogResult.Ok(true));
                Snackbar.Add(response.Message, Severity.Success);
            }
            else
            {
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }

        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();
}