@page "/dashboards/view/{DashboardId:int}"
@using Semantico.Core.Handlers.Dashboards.GetDashboard
@using Semantico.Core.Models.Dashboards
@using Semantico.Core.Data.Enums
@using Semantico.UI.Components.Pages.Dashboards.Widgets
@using MediatR
@inject IMediator Mediator
@inject NavigationManager NavManager
@inherits BasePageComponent
@implements IDisposable

<SemanticoPageTitle Title="@(_dashboard != null ? _dashboard.Name : "Dashboard")"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large"/>
            <MudText Typo="Typo.h6">Loading dashboard...</MudText>
        </MudStack>
    }
    else if (_dashboard == null)
    {
        <MudAlert Severity="Severity.Error">Dashboard not found or you don't have permission to access it.</MudAlert>
    }
    else
    {
        <MudStack Spacing="4">
            @* Header *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h4">@_dashboard.Name</MudText>
                    @if (!string.IsNullOrWhiteSpace(_dashboard.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_dashboard.Description</MudText>
                    }
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    @if (_dashboard.RefreshIntervalSeconds.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Refresh">
                            Auto-refresh: @_dashboard.RefreshIntervalSeconds.Value s
                        </MudChip>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Primary"
                                   OnClick="RefreshDashboard"
                                   Title="Refresh now"/>
                    @if (_dashboard.UserPermissionLevel >= DashboardPermissionLevel.Edit)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Color="Color.Info"
                                   Href="@($"/semantico/dashboards/builder/{DashboardId}")">
                            Edit
                        </MudButton>
                    }
                </MudStack>
            </MudStack>

            @* Dashboard Content *@
            @if (!_dashboard.Widgets.Any())
            {
                <MudPaper Elevation="2" Class="pa-8" Style="min-height: 400px;">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" Style="min-height: 350px;">
                        <MudIcon Icon="@Icons.Material.Filled.Widgets" Size="Size.Large" Color="Color.Secondary"/>
                        <MudText Typo="Typo.h5" Color="Color.Secondary">No widgets configured</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            This dashboard doesn't have any widgets yet
                        </MudText>
                        @if (_dashboard.UserPermissionLevel >= DashboardPermissionLevel.Edit)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       Href="@($"/semantico/dashboards/builder/{DashboardId}")">
                                Edit Dashboard
                            </MudButton>
                        }
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var widget in _dashboard.Widgets.OrderBy(w => w.SortOrder))
                    {
                        <MudItem xs="12" sm="@widget.Width">
                            @RenderWidget(widget)
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int DashboardId { get; set; }

    private DashboardDetailsData? _dashboard;
    private bool _loading = true;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        SetupAutoRefresh();
    }

    private async Task LoadDashboard()
    {
        _loading = true;
        try
        {
            _dashboard = await Mediator.Send(new GetDashboardQuery(DashboardId));
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetupAutoRefresh()
    {
        if (_dashboard?.RefreshIntervalSeconds.HasValue == true)
        {
            _refreshTimer = new System.Threading.Timer(
                async _ => await RefreshDashboardCallback(),
                null,
                TimeSpan.FromSeconds(_dashboard.RefreshIntervalSeconds.Value),
                TimeSpan.FromSeconds(_dashboard.RefreshIntervalSeconds.Value));
        }
    }

    private async Task RefreshDashboard()
    {
        await LoadDashboard();
        StateHasChanged();
    }

    private async Task RefreshDashboardCallback()
    {
        await InvokeAsync(async () =>
        {
            await LoadDashboard();
            StateHasChanged();
        });
    }

    private RenderFragment RenderWidget(DashboardWidgetData widget) => builder =>
    {
        switch (widget.WidgetType)
        {
            case WidgetType.KpiCard:
                builder.OpenComponent<KpiCardWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.AddAttribute(2, "DashboardRefreshInterval", _dashboard?.RefreshIntervalSeconds);
                builder.CloseComponent();
                break;

            case WidgetType.LineChart:
            case WidgetType.BarChart:
                builder.OpenComponent<ChartWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            case WidgetType.Table:
                builder.OpenComponent<TableWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            case WidgetType.Gauge:
                builder.OpenComponent<GaugeWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            default:
                builder.OpenElement(0, "div");
                builder.AddContent(1, $"Widget type {widget.WidgetType} not yet implemented");
                builder.CloseElement();
                break;
        }
    };

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
