@using Semantico.Core.Handlers.Dashboards.CloneDashboard
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Info">
                    Clone dashboard <strong>@SourceDashboardName</strong> with all its widgets
                </MudAlert>

                <MudTextField @bind-Value="_newName"
                              Label="New Dashboard Name"
                              Required="true"
                              RequiredError="Name is required"
                              MaxLength="200"
                              Variant="Variant.Outlined"/>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Clone"
                   Disabled="@(!_isValid || _isCloning)">
            @if (_isCloning)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Cloning...</span>
            }
            else
            {
                <text>Clone Dashboard</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int SourceDashboardId { get; set; }
    [Parameter] public string SourceDashboardName { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isCloning;

    private string _newName = string.Empty;

    protected override void OnInitialized()
    {
        _newName = $"{SourceDashboardName} (Copy)";
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Clone()
    {
        if (!_isValid)
        {
            return;
        }

        _isCloning = true;

        try
        {
            var command = new CloneDashboardCommand(
                SourceDashboardId: SourceDashboardId,
                NewName: _newName
            );

            var result = await Mediator.Send(command);
            MudDialog.Close(DialogResult.Ok(result.DashboardId));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cloning dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCloning = false;
        }
    }
}
