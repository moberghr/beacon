@page "/"
@page "/dashboard"
@using Semantico.Core.Models.QueryExecutionHistory
@using Semantico.Core.Data.Enums
@using Semantico.UI.Helpers
@inherits BasePageComponent
@inject Semantico.Core.Services.INotificationService notificationService
@inject Semantico.Core.Services.IStatisticsService statisticsService

<SemanticoPageTitle Title="Dashboard"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <!-- Page Header -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h3" Style="font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Dashboard
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Real-time overview of your monitoring system performance and activity
            </MudText>
        </MudStack>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="RefreshDashboard" />
    </MudStack>

    <!-- Hero Metrics -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" lg="3">
            <HeroStatCard CardClass="hero-stat-card" Icon="@Icons.Material.Filled.Subscriptions" Badge="Active"
                          Value="@((dashboardStatistics?.ActiveSubscriptions ?? 0).ToString())" Label="Active Subscriptions"
                          Trend="@($"{dashboardStatistics?.TotalSubscriptions ?? 0} total configured")" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <HeroStatCard CardClass="hero-stat-card-success" Icon="@Icons.Material.Filled.PlayArrow" Badge="Executed"
                          Value="@FormatNumber(dashboardStatistics?.TotalQueriesExecuted ?? 0)" Label="Query Executions"
                          Trend="@($"{dashboardStatistics?.TotalQueries ?? 0} queries configured")" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <HeroStatCard CardClass="hero-stat-card-warning" Icon="@Icons.Material.Filled.Notifications" Badge="Sent"
                          Value="@FormatNumber(dashboardStatistics?.TotalNotificationsSent ?? 0)" Label="Notifications Sent"
                          Trend="@($"{dashboardStatistics?.TotalRecipients ?? 0} recipients configured")" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <HeroStatCard CardClass="hero-stat-card-warning" Icon="@Icons.Material.Filled.Warning" Badge="24h"
                          Value="@((dashboardStatistics?.AnomaliesLast24Hours ?? 0).ToString())" Label="Anomalies Detected"
                          Trend="@($"{dashboardStatistics?.TotalAnomaliesDetected ?? 0} total detected")" />
        </MudItem>
    </MudGrid>

    <!-- Execution Time Metrics -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" lg="4">
            <HeroStatCard CardClass="hero-metric-card-primary" Icon="@Icons.Material.Filled.Speed" Badge="Average"
                          Value="@FormatExecutionTime(dashboardStatistics?.AvgExecutionTimeMs ?? 0)" Label="Avg Execution Time"
                          Trend="Across all queries" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="4">
            <HeroStatCard CardClass="hero-metric-card-success" Icon="@Icons.Material.Filled.FlashOn" Badge="Fastest"
                          Value="@FormatExecutionTime(dashboardStatistics?.MinExecutionTimeMs ?? 0)" Label="Fastest Query"
                          Trend="Best performance recorded" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="4">
            <HeroStatCard CardClass="hero-metric-card-error" Icon="@Icons.Material.Filled.HourglassTop" Badge="Slowest"
                          Value="@FormatExecutionTime(dashboardStatistics?.MaxExecutionTimeMs ?? 0)" Label="Slowest Query"
                          Trend="Needs optimization attention" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <!-- Main Content Area -->
        <MudItem xs="12" lg="8">
            <!-- Activity Trends Chart -->
            <MudPaper Class="detail-card pa-4 mb-3" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="mr-2" />
                    Activity Trends - Last 30 Days
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@chartSeries"
                          XAxisLabels="@xAxisLabels"
                          Width="100%"
                          Height="350px"
                          ChartOptions="@chartOptions"
                          AxisChartOptions="@axisChartOptions"/>
            </MudPaper>

            <!-- Execution Time Chart -->
            <MudPaper Class="detail-card pa-4 mb-3" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Class="mr-2" />
                    Query Execution Performance - Last 30 Days
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@executionTimeChartSeries"
                          XAxisLabels="@executionTimeXAxisLabels"
                          Width="@ChartHelper.DefaultChartWidth"
                          Height="@ChartHelper.DefaultChartHeight"
                          ChartOptions="@executionTimeChartOptions"
                          AxisChartOptions="@executionTimeAxisChartOptions"/>
            </MudPaper>

            <!-- Notification Channel Breakdown -->
            @if (dashboardStatistics?.NotificationsByChannel?.Any() == true)
            {
                <MudPaper Class="detail-card pa-4 mb-3" Elevation="2">
                    <MudText Typo="Typo.h6" Class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-2" />
                        Notification Channels
                    </MudText>
                    <MudGrid Spacing="2">
                        @foreach (var channel in dashboardStatistics.NotificationsByChannel)
                        {
                            <MudItem xs="12" sm="6" md="3">
                                <MudPaper Class="pa-3 text-center" Style="@GetChannelStyle(channel.Key)">
                                    <MudIcon Icon="@GetChannelIcon(channel.Key)" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h5">@channel.Value</MudText>
                                    <MudText Typo="Typo.body2">@channel.Key</MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }

            <!-- Top Subscriptions -->
            @if (dashboardStatistics?.TopSubscriptions?.Any() == true)
            {
                <MudPaper Class="detail-card pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                        Top Subscriptions (Last 30 Days)
                    </MudText>
                    <MudStack Spacing="2">
                        @foreach (var subscription in dashboardStatistics.TopSubscriptions)
                        {
                            <div class="top-subscription-item">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Spacing="1">
                                        <MudLink Href="@($"subscriptions/{subscription.SubscriptionId}")" Typo="Typo.body1" Style="font-weight: 600;">
                                            @subscription.SubscriptionName
                                        </MudLink>
                                        <MudStack Row="true" Spacing="3">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                                @subscription.ExecutionCount executions
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" />
                                                @subscription.NotificationCount notifications
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Last: @subscription.LastExecuted?.ToString("g")
                                    </MudText>
                                </MudStack>
                            </div>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudItem>

        <!-- Sidebar -->
        <MudItem xs="12" lg="4">
            <!-- System Overview -->
            <MudPaper Class="detail-card pa-4" Elevation="2" Style="margin-bottom: 1rem;">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Class="mr-2" />
                    System Overview
                </MudText>
                <MudStack Spacing="2">
                    <div class="info-row">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Data Sources</MudText>
                                <MudText Typo="Typo.h6">@(dashboardStatistics?.TotalDataSources ?? 0)</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" />
                        </MudStack>
                    </div>

                    <div class="info-row" style="border-left-color: var(--mud-palette-success);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Recipients</MudText>
                                <MudText Typo="Typo.h6">@(dashboardStatistics?.TotalRecipients ?? 0)</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Success" />
                        </MudStack>
                    </div>

                    <div class="info-row" style="border-left-color: var(--mud-palette-warning);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Unresolved Tasks</MudText>
                                <MudText Typo="Typo.h6">@(dashboardStatistics?.UnresolvedTasks ?? 0)</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.Task" Color="Color.Warning" />
                        </MudStack>
                    </div>

                    <div class="info-row" style="border-left-color: var(--mud-palette-info);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Active Anomaly Detection</MudText>
                                <MudText Typo="Typo.h6">@(dashboardStatistics?.ActiveAnomalyConfigs ?? 0)</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Info" />
                        </MudStack>
                    </div>
                </MudStack>
            </MudPaper>

            <!-- Recent Activity -->
            @if (dashboardStatistics?.RecentActivities?.Any() == true)
            {
                <MudPaper Class="detail-card pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
                        Recent Activity
                    </MudText>
                    <MudStack Spacing="1">
                        @foreach (var activity in dashboardStatistics.RecentActivities.Take(8))
                        {
                            <div class="activity-item">
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@GetActivityIcon(activity.Icon)" Size="Size.Small" Color="@GetActivityColor(activity.Type)" />
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@activity.Type</MudText>
                                        </MudStack>
                                        @if (!string.IsNullOrEmpty(activity.Status))
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(activity.Status)">@activity.Status</MudChip>
                                        }
                                    </MudStack>
                                    @if (!string.IsNullOrEmpty(activity.Link))
                                    {
                                        <MudLink Href="@activity.Link" Typo="Typo.caption">
                                            @activity.Description
                                        </MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @activity.Description
                                        </MudText>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                        @activity.Timestamp.ToString("g")
                                    </MudText>
                                </MudStack>
                            </div>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>

    <!-- Additional Statistics Row -->
    <MudGrid Spacing="3" Class="mt-3">
        <!-- Migration Statistics -->
        <MudItem xs="12" md="6">
            <MudPaper Class="detail-card pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-2" />
                    Data Migration Overview
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-error-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Error">@(dashboardStatistics?.TotalMigrationJobs ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Total Jobs</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-success-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Success">@(dashboardStatistics?.EnabledMigrationJobs ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Enabled</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-info-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Info">@(dashboardStatistics?.TotalMigrationExecutions ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Executions</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-success-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Success">@(dashboardStatistics?.SuccessfulMigrationExecutions ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Successful</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Task Statistics -->
        <MudItem xs="12" md="6">
            <MudPaper Class="detail-card pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-2" />
                    Task Management
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="4">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-primary-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Primary">@(dashboardStatistics?.TotalTasks ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Total Tasks</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-warning-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Warning">@(dashboardStatistics?.UnresolvedTasks ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Open</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="pa-3 text-center" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-success-rgb), 0.1), transparent);">
                            <MudText Typo="Typo.h5" Color="Color.Success">@(dashboardStatistics?.ResolvedTasks ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Resolved</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private DashboardStatisticsData? dashboardStatistics;
    private List<ChartSeries> chartSeries = new();
    private string[] xAxisLabels = Array.Empty<string>();
    private ChartOptions chartOptions = new();
    private AxisChartOptions axisChartOptions = new();

    // Execution time chart fields
    private List<ChartSeries> executionTimeChartSeries = new();
    private string[] executionTimeXAxisLabels = Array.Empty<string>();
    private ChartOptions executionTimeChartOptions = new();
    private AxisChartOptions executionTimeAxisChartOptions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        var notificationStatisticsData = await notificationService.GetNotificationStatistics(CancellationToken.None);
        dashboardStatistics = await statisticsService.GetDashboardStatistics(CancellationToken.None);

        PrepareChartData(notificationStatisticsData);
        ConfigureChartOptions();
        PrepareExecutionTimeChart();
    }

    private async Task RefreshDashboard()
    {
        await LoadDashboardData();
        StateHasChanged();
    }

    private void PrepareChartData(NotificationStatisticsData? notificationStatisticsData)
    {
        if (notificationStatisticsData?.NotificationDateStatistics == null)
            return;

        var data = notificationStatisticsData.NotificationDateStatistics.OrderBy(x => x.Date).ToList();

        xAxisLabels = data.Select(x => x.Date.ToShortDateWithoutYear()).ToArray();

        chartSeries = new List<ChartSeries>
        {
            new()
            {
                Name = "Queries executed",
                Data = data.Select(x => (double)x.TotalQueries).ToArray()
            },
            new()
            {
                Name = "Notifications sent",
                Data = data.Select(x => (double)x.NotificationsSent).ToArray()
            }
        };
    }

    private void ConfigureChartOptions()
    {
        chartOptions.YAxisTicks = 10;
        chartOptions.ChartPalette = new[] { "#1f77b4", "#ff7f0e", "#2ca02c", "#d62728" };
        chartOptions.YAxisLines = true;
        chartOptions.XAxisLines = true;
        chartOptions.InterpolationOption = InterpolationOption.Straight;

        axisChartOptions.XAxisLabelRotation = 45;
    }

    private string FormatNumber(int number)
    {
        if (number >= 1000000)
            return $"{number / 1000000.0:0.#}M";
        if (number >= 1000)
            return $"{number / 1000.0:0.#}K";
        return number.ToString();
    }

    private string GetChannelIcon(string channel)
    {
        return channel switch
        {
            "Email" => Icons.Material.Filled.Email,
            "Teams" => Icons.Material.Filled.Groups,
            "Slack" => Icons.Material.Filled.Chat,
            "Jira" => Icons.Material.Filled.BugReport,
            _ => Icons.Material.Filled.Notifications
        };
    }

    private string GetChannelStyle(string channel)
    {
        var color = channel switch
        {
            "Email" => "var(--mud-palette-primary)",
            "Teams" => "var(--mud-palette-info)",
            "Slack" => "var(--mud-palette-success)",
            "Jira" => "var(--mud-palette-warning)",
            _ => "var(--mud-palette-secondary)"
        };
        return $"background: linear-gradient(135deg, rgba({GetColorRgb(color)}, 0.1), transparent); border-left: 4px solid {color};";
    }

    private string GetColorRgb(string color)
    {
        return color switch
        {
            "var(--mud-palette-primary)" => "var(--mud-palette-primary-rgb)",
            "var(--mud-palette-info)" => "var(--mud-palette-info-rgb)",
            "var(--mud-palette-success)" => "var(--mud-palette-success-rgb)",
            "var(--mud-palette-warning)" => "var(--mud-palette-warning-rgb)",
            _ => "var(--mud-palette-secondary-rgb)"
        };
    }

    private string GetActivityIcon(string? icon)
    {
        return icon switch
        {
            "Search" => Icons.Material.Filled.Search,
            "Warning" => Icons.Material.Filled.Warning,
            "Task" => Icons.Material.Filled.Task,
            "Migration" => Icons.Material.Filled.SwapHoriz,
            _ => Icons.Material.Filled.Circle
        };
    }

    private Color GetActivityColor(string type)
    {
        return type switch
        {
            "Query Execution" => Color.Primary,
            "Anomaly Detected" => Color.Error,
            "Task Created" => Color.Warning,
            "Migration" => Color.Info,
            _ => Color.Default
        };
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Notification Sent" => Color.Success,
            "High" => Color.Error,
            "Medium" => Color.Warning,
            "Low" => Color.Info,
            _ => Color.Default
        };
    }

    private void PrepareExecutionTimeChart()
    {
        if (dashboardStatistics?.ExecutionTimeHistory == null || !dashboardStatistics.ExecutionTimeHistory.Any())
            return;

        var chart = ChartHelper.BuildExecutionTimeChart(dashboardStatistics.ExecutionTimeHistory);
        executionTimeChartSeries = chart.Series;
        executionTimeXAxisLabels = chart.Labels;
        executionTimeChartOptions = chart.Options;
        executionTimeAxisChartOptions = chart.AxisOptions;
    }

    private string FormatExecutionTime(double milliseconds) => UiHelpers.FormatExecutionTime(milliseconds);
}
