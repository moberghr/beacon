@using Semantico.Core.Data.Enums
@using Semantico.Core.Models.Recipients
@using Semantico.Core.Services

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-1 mb-n1" />
            Update recipient
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1" @bind-Errors="@errors" @bind-IsValid="_isFormValid">
            <MudTextField OnlyValidateIfDirty="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Class="mb-2"
                          @bind-Value="@Recipient.Name"
                          T="String"
                          Label="Name"
                          Required="true" />
            <MudTextField OnlyValidateIfDirty="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Class="mb-2"
                          @bind-Value="@_displayedDestination"
                          T="String"
                          Label="Destination"
                          HelperText="@(_isDestinationMasked ? "Leave as-is to keep current value, or enter new value to update" : "")"
                          Required="true" />
            <MudTextField OnlyValidateIfDirty="true"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Class="mb-2"
                          @bind-Value="@Recipient.Description"
                          Placeholder="Description (optional)"
                          T="String"
                          Label="Description"
                          Required="false" />
            <MudSelect T="NotificationType" Label="Notification Type" @bind-Value="@Recipient.NotificationType" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                <MudSelectItem Value="NotificationType.Email">Email</MudSelectItem>
                <MudSelectItem Value="NotificationType.Teams">Teams</MudSelectItem>
                <MudSelectItem Value="NotificationType.Slack">Slack</MudSelectItem>
                <MudSelectItem Value="NotificationType.Jira">Jira</MudSelectItem>
                <MudSelectItem Value="NotificationType.Webhook">Webhook</MudSelectItem>
            </MudSelect>

            @if (Recipient.NotificationType == NotificationType.Webhook)
            {
                <MudTextField @bind-Value="@Recipient.HeadersJson"
                              T="String"
                              Label="Custom Headers (JSON)"
                              HelperText="Optional JSON object of custom HTTP headers, e.g. {&quot;Authorization&quot;: &quot;Bearer token&quot;}"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mt-2"
                              Lines="3" />

                <MudTextField @bind-Value="@Recipient.BodyTemplate"
                              T="String"
                              Label="Body Template (Optional)"
                              HelperText="Use placeholders like {{Timestamp}}, {{SubscriptionName}}, {{TotalRecords}}, {{Records}}. Leave empty for default payload."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mt-2"
                              Lines="10"
                              Placeholder='Example: { "alert": "{{SubscriptionName}}", "count": {{TotalRecords}}, "data": {{Records}} }' />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Class="ml-4"
                   OnClick="@Cancel"
                   Variant="Variant.Filled">
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="!_isFormValid" OnClick="@Submit" />
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IRecipientService Service

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public RecipientData Recipient { get; set; } = new RecipientData();

    private MudForm _form;
    private bool _loading;
    bool _isFormValid = false;
    string[] errors = { };

    private string _originalDestination = null!;
    private string _displayedDestination = null!;
    private bool _isDestinationMasked;

    protected override void OnInitialized()
    {
        _originalDestination = Recipient.Destination;
        _displayedDestination = Components.UiHelpers.MaskedDestinationValue;
        _isDestinationMasked = true;
    }

    async Task Submit()
    {
        if (_loading)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        // If destination is still masked, restore original value (no change)
        // Otherwise, use the new value entered by the user
        if (_displayedDestination == Components.UiHelpers.MaskedDestinationValue)
        {
            Recipient.Destination = _originalDestination;
        }
        else
        {
            Recipient.Destination = _displayedDestination;
        }

        _loading = true;

        var response = await Service.UpdateRecipient(Recipient, CancellationToken.None);

        if (response.Success)
        {
            MudDialog.Close(DialogResult.Ok(true));
            Snackbar.Add(response.Message, Severity.Success);
        }
        else
        {
            Snackbar.Add(response.Message, Severity.Error);
        }
        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();
}