@using Semantico.Core.Handlers.Ai.AiActor
@using MediatR

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Class="mr-1 mb-n1" />
            Refine AI Actor
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_refining)
        {
            <div class="d-flex flex-column align-center py-8">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.body1" Class="mt-4">Processing feedback...</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">The actor is analyzing your feedback</MudText>
            </div>
        }
        else if (_result != null)
        {
            <MudAlert Severity="@(_result.Success ? Severity.Success : Severity.Error)" Class="mb-4">
                @(_result.Success ? "Feedback processed successfully!" : _result.ErrorMessage)
            </MudAlert>

            @if (_result.Success)
            {
                <MudPaper Elevation="0" Class="pa-3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Decision Summary</MudText>
                    <MudText Typo="Typo.body2">@_result.DecisionSummary</MudText>

                    <MudDivider Class="my-3" />

                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-2">
                        <MudText Typo="Typo.caption">Queries Created:</MudText>
                        <MudText Typo="Typo.caption">@_result.QueriesCreated</MudText>
                    </MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">Queries Refined:</MudText>
                        <MudText Typo="Typo.caption">@_result.QueriesRefined</MudText>
                    </MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">Subscriptions Created:</MudText>
                        <MudText Typo="Typo.caption">@_result.SubscriptionsCreated</MudText>
                    </MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">Tokens Used:</MudText>
                        <MudText Typo="Typo.caption">@_result.TokensUsed.ToString("N0")</MudText>
                    </MudStack>
                </MudPaper>
            }
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-4">
                Provide feedback to adjust how the actor monitors your data source. You can request new queries,
                modifications to existing ones, or changes to monitoring schedules.
            </MudText>

            <MudForm @ref="@_form" Class="pt-1" @bind-IsValid="_isFormValid">
                <MudTextField
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    @bind-Value="@_feedback"
                    T="String"
                    Label="Your Feedback"
                    Required="true"
                    RequiredError="Feedback is required"
                    Lines="5"
                    Placeholder="e.g., 'Add monitoring for user login failures' or 'Check for transactions more frequently'"
                />
            </MudForm>

            <MudExpansionPanels Class="mt-4">
                <MudExpansionPanel Text="Example Feedback">
                    <MudList T="string" Dense="true">
                        <MudListItem>"Add a query to monitor failed login attempts"</MudListItem>
                        <MudListItem>"Check for payment failures every 15 minutes instead of hourly"</MudListItem>
                        <MudListItem>"Stop monitoring the users table, focus on transactions"</MudListItem>
                        <MudListItem>"The current queries are returning too many results, add filters for last 24 hours only"</MudListItem>
                    </MudList>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions>
        @if (_result != null)
        {
            <MudButton OnClick="@Close" Variant="Variant.Filled" Color="Color.Primary">
                Close
            </MudButton>
        }
        else
        {
            <MudButton Class="ml-4" OnClick="@Cancel" Variant="Variant.Filled" Disabled="@_refining">
                Cancel
            </MudButton>
            <MudButton
                OnClick="@Refine"
                Variant="Variant.Filled"
                Color="Color.Primary"
                Disabled="@(!_isFormValid || _refining)"
                StartIcon="@Icons.Material.Filled.Send"
            >
                @(_refining ? "Processing..." : "Submit Feedback")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IMediator Mediator

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int ActorId { get; set; }

    private MudForm _form;
    private bool _refining;
    private bool _isFormValid;
    private RefineAiActorResult? _result;

    private string _feedback = "";

    async Task Refine()
    {
        if (_refining) return;

        await _form.Validate();
        if (!_form.IsValid) return;

        _refining = true;
        StateHasChanged();

        try
        {
            var command = new RefineAiActorCommand
            {
                ActorId = ActorId,
                Feedback = _feedback
            };

            _result = await Mediator.Send(command);

            if (_result.Success)
            {
                Snackbar.Add("Feedback processed successfully!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Failed to process feedback: {_result.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            _result = new RefineAiActorResult { Success = false, ErrorMessage = ex.Message };
        }
        finally
        {
            _refining = false;
            StateHasChanged();
        }
    }

    void Cancel() => MudDialog.Cancel();
    void Close() => MudDialog.Close(DialogResult.Ok(_result));
}
