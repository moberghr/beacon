@page "/semantico/data-migration"
@inherits BasePageComponent
@using Semantico.Core.Models.DataMigration
@using Semantico.Core.Services
@using Semantico.Core.Data.Enums
@using Semantico.Core.Helpers

<SemanticoPageTitle Title="Data Migration"/>

<MudContainer Class="my-4 px-4">
    <SemanticoPageHeader Icon="@Icons.Material.Filled.SwapHoriz" Title="Data Migration" ButtonText="New Migration Job" OnClick="@AddMigrationJob"/>
    <SemanticoPageAlert Text="Manage data migration jobs and view execution history."/>

    <MudDataGrid @ref="_dataGrid" ServerData="@ServerReload" T="MigrationJobDto" Hover="true" Filterable="false" SortMode="SortMode.None">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <CellTemplate>
                    <MudLink Href="@($"/semantico/data-migration/edit/{context.Item.Id}")">
                        @context.Item.Name
                    </MudLink>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProjectName" Title="Source Project"/>
            <PropertyColumn Property="x => x.DestinationProjectName" Title="Destination Project"/>
            <PropertyColumn Property="x => x.DestinationTable" Title="Destination Table"/>
            <PropertyColumn Property="x => x.Schedule" Title="Schedule">
                <CellTemplate>
                    @if (string.IsNullOrEmpty(context.Item.Schedule))
                    {
                        <MudText>Manual</MudText>
                    }
                    else
                    {
                        <MudText>@context.Item.Schedule</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.IsEnabled" Title="Status">
                <CellTemplate>
                    <MudChip Size="Size.Small" Color="@(context.Item.IsEnabled ? Color.Success : Color.Default)">
                        @(context.Item.IsEnabled ? "Enabled" : "Disabled")
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LastExecuted" Title="Last Execution">
                <CellTemplate>
                    @if (context.Item.LastExecuted.HasValue)
                    {
                        <div>
                            <MudText Typo="Typo.body2">@context.Item.LastExecuted.Value.ToString("yyyy-MM-dd HH:mm")</MudText>
                            @if (context.Item.LastExecutionStatus.HasValue)
                            {
                                <ExecutionStatusChip Status="@context.Item.LastExecutionStatus.Value"/>
                            }
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">Never</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TotalExecutions" Title="Executions">
                <CellTemplate>
                    <MudText>@context.Item.SuccessfulExecutions / @context.Item.TotalExecutions</MudText>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                <CellTemplate>
                    <MudButtonGroup Size="Size.Small" Variant="Variant.Text">
                        <MudButton StartIcon="@Icons.Material.Filled.PlayArrow" 
                                  Color="Color.Primary" 
                                  OnClick="@(() => ExecuteJob(context.Item))"
                                  Disabled="@(!context.Item.IsEnabled)">
                            Execute
                        </MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Edit" 
                                  Color="Color.Info" 
                                  Href="@($"/semantico/data-migration/edit/{context.Item.Id}")">
                            Edit
                        </MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.History" 
                                  Color="Color.Info" 
                                  Href="@($"/semantico/data-migration/history/{context.Item.Id}")">
                            History
                        </MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Delete" 
                                  Color="Color.Error" 
                                  OnClick="@(() => DeleteJob(context.Item))">
                            Delete
                        </MudButton>
                    </MudButtonGroup>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="MigrationJobDto"/>
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@inject IMigrationService _service
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@code {
    private PagedList<MigrationJobDto>? _list = null;
    MudDataGrid<MigrationJobDto>? _dataGrid;
    private bool _loading = false;

    private async Task<GridData<MigrationJobDto>> ServerReload(GridState<MigrationJobDto> state)
    {
        try
        {
            Console.WriteLine($"ServerReload called - Page: {state.Page}, PageSize: {state.PageSize}");

            var request = DataGridHelper.BuildSortedRequest<GetMigrationJobsRequest, MigrationJobDto>(state);
            _list = await _service.GetMigrationJobs(request, CancellationToken.None);

            Console.WriteLine($"ServerReload completed - Total: {_list.TotalCount}, Jobs: {_list.Items.Count}");

            return new GridData<MigrationJobDto>
            {
                TotalItems = _list.TotalCount ?? 0,
                Items = _list.Items
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ServerReload error: {ex.Message}");
            Snackbar.Add($"Error loading migration jobs: {ex.Message}", Severity.Error);
            return new GridData<MigrationJobDto>
            {
                TotalItems = 0,
                Items = new List<MigrationJobDto>()
            };
        }
    }
    
    private async Task AddMigrationJob()
    {
        NavManager.NavigateTo("/semantico/data-migration/create");
    }
    
    private async Task ExecuteJob(MigrationJobDto job)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Execute Migration Job", 
            $"Are you sure you want to execute '{job.Name}'?", 
            yesText:"Execute", cancelText:"Cancel");
            
        if (confirmed == true)
        {
            _loading = true;
            
            try
            {
                var request = new ExecuteMigrationJobRequest(job.Id);
                var response = await _service.ExecuteMigrationJob(request, CancellationToken.None);
                
                if (response.Status == MigrationStatus.Completed)
                {
                    Snackbar.Add($"Migration job '{job.Name}' completed successfully. Processed {response.SourceRowsRead} rows.", Severity.Success);
                }
                else if (response.Status == MigrationStatus.Failed)
                {
                    Snackbar.Add($"Migration job '{job.Name}' failed: {response.ErrorMessage}", Severity.Error);
                }
                else
                {
                    Snackbar.Add($"Migration job '{job.Name}' status: {response.Status}", Severity.Info);
                }
                
                await _dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error executing migration job: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }
    
    private async Task DeleteJob(MigrationJobDto job)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete Migration Job", 
            $"Are you sure you want to delete '{job.Name}'? This action cannot be undone.", 
            yesText:"Delete", cancelText:"Cancel");
            
        if (confirmed == true)
        {
            _loading = true;
            
            try
            {
                var response = await _service.DeleteMigrationJob(job.Id, CancellationToken.None, false);
                
                if (response.Success)
                {
                    Snackbar.Add($"Migration job '{job.Name}' deleted successfully.", Severity.Success);
                    await _dataGrid.ReloadServerData();
                }
                else
                {
                    Snackbar.Add($"Error deleting migration job: {response.Message}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting migration job: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }
}