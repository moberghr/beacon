<MudPaper Class="@($"{CardClass} pa-4")" Elevation="@Elevation">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudIcon Icon="@Icon" Size="Size.Large" />
            <MudChip T="string" Size="Size.Small" Style="background: rgba(255,255,255,0.2); color: white;">@Badge</MudChip>
        </MudStack>
        <MudText Class="hero-stat-number">@Value</MudText>
        <MudText Class="hero-stat-label">@Label</MudText>
        @if (!string.IsNullOrEmpty(Trend))
        {
            <MudText Typo="Typo.caption" Class="metric-trend">@Trend</MudText>
        }
    </MudStack>
</MudPaper>

@code
{
    [Parameter, EditorRequired]
    public string CardClass { get; set; } = "hero-stat-card";

    [Parameter, EditorRequired]
    public string Icon { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Badge { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Label { get; set; } = null!;

    [Parameter]
    public string? Trend { get; set; }

    [Parameter]
    public int Elevation { get; set; } = 4;
}
