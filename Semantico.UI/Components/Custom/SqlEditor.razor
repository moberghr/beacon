@using Semantico.Core.Services
@using Semantico.Core.Models.Metadata
@using BlazorMonaco
@using BlazorMonaco.Editor

<style>
    .sql-editor-container {
        height: 100% !important;
    }

    .sql-editor-container > div {
        height: 100% !important;
    }
</style>

<div style="height: @Height; border: 1px solid #ddd;">
    @if (_monacoReady)
    {
        <StandaloneCodeEditor @ref="_editor"
                             Id="@EditorId"
                             ConstructionOptions="EditorConstructionOptions"
                             OnDidInit="OnEditorInit"
                             OnDidChangeModelContent="OnEditorContentChanged"
                             CssClass="sql-editor-container" />
    }
    else
    {
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; background-color: #f5f5f5;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
        </div>
    }
</div>

@inject IDatabaseMetadataService MetadataService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public int? DataSourceId { get; set; }
    [Parameter] public string Height { get; set; } = "200px";
    [Parameter] public bool ReadOnly { get; set; } = false;
    [Parameter] public string EditorId { get; set; } = $"sql-editor-{Guid.NewGuid()}";
    [Parameter] public string Placeholder { get; set; } = "-- Write your SQL query here\nSELECT * FROM ";

    private StandaloneCodeEditor? _editor;
    private DatabaseMetadataSnapshot? _metadata;
    private bool _initialized = false;
    private string _lastValue = "";
    private bool _completionProviderRegistered = false;
    private bool _monacoReady = false;

    protected override async Task OnInitializedAsync()
    {
        _monacoReady = await WaitForMonacoAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Load metadata if DataSourceId is provided, valid (not 0), and changed
        if (DataSourceId.HasValue && DataSourceId.Value > 0 && _metadata == null)
        {
            await LoadMetadata();

            // Register completion provider if editor is already initialized
            if (_initialized && _editor != null && !ReadOnly && _metadata != null)
            {
                await RegisterCompletionProvider();
            }
        }
        else if (DataSourceId.HasValue && DataSourceId.Value > 0 && _metadata != null && _metadata.DataSourceId != DataSourceId.Value)
        {
            // Project changed, reload metadata
            _metadata = null;
            _completionProviderRegistered = false; // Reset flag to allow re-registration
            await LoadMetadata();

            // Re-register completion provider with new metadata if editor is initialized
            if (_initialized && _editor != null && !ReadOnly)
            {
                await RegisterCompletionProvider();
            }
        }

        // Update editor value if it changed externally
        if (_initialized && _editor != null && Value != _lastValue)
        {
            await _editor.SetValue(Value ?? "");
            _lastValue = Value ?? "";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _editor != null)
        {
            try
            {
                await _editor.Layout();
            }
            catch
            {
                // Silently ignore layout errors
            }
        }
    }

    private async Task LoadMetadata()
    {
        if (!DataSourceId.HasValue || DataSourceId.Value <= 0) return;

        try
        {
            _metadata = await MetadataService.GetMetadataAsync(DataSourceId.Value);
        }
        catch (Exception ex)
        {
            // Silently fail - editor will work without intellisense
            Console.WriteLine($"Failed to load metadata: {ex.Message}");
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        // Start with actual value or empty string (not placeholder)
        // We'll set placeholder-like text as a comment if value is empty
        var initialValue = Value;
        if (string.IsNullOrEmpty(initialValue))
        {
            initialValue = ""; // Start completely empty, user can start typing immediately
        }
        _lastValue = Value ?? "";

        Console.WriteLine($"SqlEditor {EditorId}: Constructing with ReadOnly={ReadOnly}, Value length={Value?.Length ?? 0}, Initial='{initialValue?.Substring(0, Math.Min(20, initialValue?.Length ?? 0))}'");

        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "sql",
            Theme = "vs",
            Value = initialValue,
            FontSize = 14,
            LineNumbers = "on",
            RenderLineHighlight = "all",
            ScrollBeyondLastLine = false,
            ReadOnly = false, // Always start as editable
            Minimap = new EditorMinimapOptions { Enabled = false },
            WordWrap = "on",
            DomReadOnly = false
        };
    }

    private async Task OnEditorInit()
    {
        _initialized = true;

        if (_editor != null)
        {
            try
            {
                await _editor.Layout();

                if (!ReadOnly)
                {
                    await _editor.UpdateOptions(new EditorUpdateOptions
                    {
                        ReadOnly = false,
                        DomReadOnly = false
                    });

                    try
                    {
                        await _editor.Focus();
                    }
                    catch
                    {
                        // Silently ignore focus errors
                    }
                }

                if (_metadata != null && !ReadOnly)
                {
                    await RegisterCompletionProvider();
                }

                await EnableDropOnEditor();
            }
            catch
            {
                // Silently ignore initialization errors
            }
        }
    }

    private async Task EnableDropOnEditor()
    {
        try
        {
            var success = await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.enableDropOnEditor",
                EditorId
            );

            if (success)
            {
                Console.WriteLine($"SqlEditor {EditorId}: Drop enabled on Monaco editor");
            }
            else
            {
                Console.WriteLine($"SqlEditor {EditorId}: Failed to enable drop on Monaco editor");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SqlEditor {EditorId}: Error enabling drop on editor: {ex.Message}");
        }
    }

    private async Task OnEditorContentChanged(ModelContentChangedEvent e)
    {
        if (_editor != null)
        {
            var newValue = await _editor.GetValue();

            // Don't send placeholder text as actual value
            if (newValue == Placeholder)
            {
                newValue = "";
            }

            _lastValue = newValue;
            await ValueChanged.InvokeAsync(newValue);
        }
    }

    private async Task RegisterCompletionProvider()
    {
        if (_editor == null || _metadata == null || _completionProviderRegistered) return;

        try
        {
            _completionProviderRegistered = true;

            // Use the JS helper to register context-aware completion
            var success = await JSRuntime.InvokeAsync<bool>(
                "semanticoSqlEditor.registerSqlCompletionProvider",
                EditorId,
                "sql",
                _metadata
            );

            if (success)
            {
                // Register Ctrl+Space for trigger suggest
                await _editor.AddCommand((int)KeyMod.CtrlCmd | (int)KeyCode.Space, async (args) =>
                {
                    await _editor.Trigger("editor", "editor.action.triggerSuggest", null);
                });

                Console.WriteLine($"SqlEditor {EditorId}: Registered completion provider via helper");
            }
            else
            {
                Console.WriteLine($"SqlEditor {EditorId}: Failed to register completion provider via helper");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SqlEditor {EditorId}: Failed to register completion provider: {ex.Message}");
        }
    }

    public async Task<string> GetValue()
    {
        if (_editor != null)
        {
            return await _editor.GetValue();
        }
        return Value ?? "";
    }

    public async Task SetValue(string value)
    {
        if (_editor != null)
        {
            await _editor.SetValue(value ?? "");
            _lastValue = value ?? "";
        }
    }

    public async Task RefreshMetadata()
    {
        if (!DataSourceId.HasValue) return;

        try
        {
            _completionProviderRegistered = false; // Reset flag to allow re-registration
            _metadata = await MetadataService.RefreshMetadataAsync(DataSourceId.Value);

            if (_editor != null && !ReadOnly)
            {
                await RegisterCompletionProvider();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to refresh metadata: {ex.Message}", Severity.Error);
        }
    }

    private async Task<bool> WaitForMonacoAsync(int maxAttempts = 50, int delayMs = 100)
    {
        for (int i = 0; i < maxAttempts; i++)
        {
            try
            {
                var isReady = await JSRuntime.InvokeAsync<bool>("eval",
                    "typeof monaco !== 'undefined' && typeof blazorMonaco !== 'undefined' && typeof blazorMonaco.editor !== 'undefined' && typeof blazorMonaco.editor.create !== 'undefined'");
                if (isReady)
                {
                    return true;
                }
            }
            catch
            {
                // Silently continue
            }

            await Task.Delay(delayMs);
        }

        return false;
    }

}
