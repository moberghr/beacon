@using Semantico.Core.Models.Queries
@using Semantico.Core.Data.Enums
@using QueryParameterValue = Semantico.Core.Models.Queries.ParameterValue

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
            Set Parameter Values for Step @StepOrder Preview
        </MudText>
        
        @if (Parameters?.Any() == true)
        {
            <MudStack Spacing="3">
                @foreach (var param in Parameters)
                {
                    <MudPaper Class="pa-3" Outlined="true">
                        <MudStack Spacing="2">
                            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.subtitle1">
                                    <strong>{@param.Name}</strong>
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">
                                    @param.Type
                                </MudChip>
                            </MudStack>
                            
                            @if (!string.IsNullOrEmpty(param.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @param.Description
                                </MudText>
                            }
                            
                            @switch (param.Type)
                            {
                                case ParameterType.String:
                                    <MudTextField @bind-Value="ParameterValues[param.Name]"
                                                  Label="Value"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="@(param.Placeholder ?? "Enter string value")"
                                                  Required="true" />
                                    break;
                                    
                                case ParameterType.Number:
                                    <MudTextField @bind-Value="ParameterValues[param.Name]"
                                                  Label="Value"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="@(param.Placeholder ?? "Enter number value")"
                                                  Required="true"
                                                  InputType="InputType.Number" />
                                    break;
                                    
                                case ParameterType.DateTime:
                                    <MudTextField @bind-Value="ParameterValues[param.Name]"
                                                  Label="Value"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="@(param.Placeholder ?? "Enter date/time value")"
                                                  Required="true"
                                                  HelperText="Format: YYYY-MM-DD HH:MM:SS or YYYY-MM-DD" />
                                    break;
                            }
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Info">
                This step has no parameters to configure.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Secondary">
            Cancel
        </MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(!IsFormValid)" StartIcon="@Icons.Material.Filled.PlayArrow">
            Preview with Parameters
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public List<QueryStepParameterData>? Parameters { get; set; }
    [Parameter] public int StepOrder { get; set; }
    
    public Dictionary<string, string> ParameterValues { get; set; } = new();
    
    protected override void OnParametersSet()
    {
        // Initialize parameter values dictionary
        if (Parameters?.Any() == true)
        {
            foreach (var param in Parameters)
            {
                if (!ParameterValues.ContainsKey(param.Name))
                {
                    ParameterValues[param.Name] = "";
                }
            }
        }
    }
    
    private bool IsFormValid =>
        Parameters?.All(p => !string.IsNullOrWhiteSpace(ParameterValues.GetValueOrDefault(p.Name))) == true ||
        Parameters?.Any() != true;
    
    private void Submit()
    {
        if (IsFormValid)
        {
            var result = Parameters?.Select(p => new QueryParameterValue
            {
                Name = p.Name,
                Value = ParameterValues[p.Name]
            }).ToList() ?? new List<QueryParameterValue>();
            
            MudDialog.Close(DialogResult.Ok(result));
        }
    }
    
    private void Cancel() => MudDialog.Cancel();
}