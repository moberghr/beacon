@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@using Beacon.Core
@using Beacon.UI.Components.Helpers
@inherits LayoutComponentBase
@implements IDisposable

@* Required *@
<MudThemeProvider Theme="BeaconTheme.Theme" IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout Class="@($"beacon-layout {(_isDark ? "mud-theme-dark" : "")}")">
    <MudAppBar Elevation="0" Dense="false" Class="beacon-appbar beacon-topbar">
        <div class="bx-topbar">
            <nav class="bx-breadcrumb" aria-label="Breadcrumb">
                <a class="bx-breadcrumb__crumb" href="@($"{GetBaseHref()}dashboard")">Workspace</a>
                @foreach (var crumb in _breadcrumbs)
                {
                    <span class="bx-breadcrumb__sep">/</span>
                    @if (!string.IsNullOrEmpty(crumb.Href) && crumb != _breadcrumbs.Last())
                    {
                        <a class="bx-breadcrumb__crumb" href="@crumb.Href">@crumb.Label</a>
                    }
                    else
                    {
                        <span class="bx-breadcrumb__current">@crumb.Label</span>
                    }
                }
            </nav>
            <button type="button" class="bx-topbar__search" @onclick="NavigateToSearch">
                <MudIcon Icon="@Icons.Material.Rounded.Search" Size="Size.Small" />
                <span class="bx-topbar__search-text">Search queries, sources, recipients…</span>
                <span class="bx-topbar__search-kbd">
                    <span class="bx-kbd">⌘</span><span class="bx-kbd">K</span>
                </span>
            </button>
            <div class="bx-topbar__right">
                <MudTooltip Text="@(_isDark ? "Light Mode" : "Dark Mode")" Placement="Placement.Bottom">
                    <button type="button" class="bx-icon-btn" @onclick="@ChangeTheme">
                        <MudIcon Icon="@(_isDark ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)" Size="Size.Small" />
                    </button>
                </MudTooltip>
                <MudTooltip Text="Notifications" Placement="Placement.Bottom">
                    <button type="button" class="bx-icon-btn" @onclick="NavigateToNotifications">
                        <MudIcon Icon="@Icons.Material.Rounded.Notifications" Size="Size.Small" />
                        @if (_pendingApprovalCount > 0 || _hasUnreadNotifications)
                        {
                            <span class="bx-icon-btn__dot"></span>
                        }
                    </button>
                </MudTooltip>
                <MudTooltip Text="Settings" Placement="Placement.Bottom">
                    <button type="button" class="bx-icon-btn" @onclick="@NavigateToSettings">
                        <MudIcon Icon="@Icons.Material.Rounded.Settings" Size="Size.Small" />
                    </button>
                </MudTooltip>
                <span class="bx-topbar__divider"></span>
                @if (UserContext.IsAuthenticated)
                {
                    <button type="button" class="bx-user-chip" @onclick="NavigateToSettings">
                        <span class="bx-user-chip__avatar">@GetUserInitial()</span>
                        <span class="bx-user-chip__name">@(UserContext.DisplayName ?? UserContext.UserName ?? "User")</span>
                    </button>
                    <MudTooltip Text="Logout" Placement="Placement.Bottom">
                        <button type="button" class="bx-icon-btn" @onclick="HandleLogout">
                            <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                }
                else
                {
                    <span class="bx-user-chip bx-user-chip--guest">
                        <span class="bx-user-chip__avatar">?</span>
                        <span class="bx-user-chip__name">Guest</span>
                    </span>
                }
            </div>
        </div>
    </MudAppBar>
    <MudDrawer Open="@_drawerOpen" OpenChanged="@(v => _drawerOpen = v)" ClipMode="DrawerClipMode.Never" Elevation="0" Width="280px" Class="beacon-drawer">
        <div class="drawer-header-wrapper">
            <div class="drawer-brand-header">
                <img src="../_content/Beacon.UI/logo.svg?v=20260423e" alt="Beacon" class="drawer-logo" />
                <span class="drawer-version">v0.99</span>
            </div>
        </div>
        <MudNavMenu Class="drawer-nav" Bordered="false">
            <div class="nav-section-label">Overview</div>
            <MudNavLink Href="@($"{GetBaseHref()}dashboard")" Icon="@Icons.Material.Rounded.SpaceDashboard" IconColor="Color.Default">Home</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}control-tower")" Icon="@Icons.Material.Rounded.MonitorHeart" IconColor="Color.Default">Control Tower</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}dashboards")" Icon="@Icons.Material.Rounded.Widgets" IconColor="Color.Default">Dashboards</MudNavLink>

            <div class="nav-section-label">Data</div>
            <MudNavLink Href="@($"{GetBaseHref()}data-sources")" Icon="@Icons.Material.Rounded.Storage" IconColor="Color.Default">Data Sources</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}beacon/projects")" Icon="@Icons.Material.Rounded.FolderSpecial" IconColor="Color.Default">Projects</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-quality")" Icon="@Icons.Material.Rounded.VerifiedUser" IconColor="Color.Default">
                Data Quality
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Style="font-size: 0.55rem; height: 16px; margin-left: 4px; border-radius: 4px;">BETA</MudChip>
            </MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}data-migration")" Icon="@Icons.Material.Rounded.SwapHoriz" IconColor="Color.Default">Data Migration</MudNavLink>
            @if (Configuration?.UseAI == true)
            {
                <MudNavLink Href="@($"{GetBaseHref()}ai-actors")" Icon="@Icons.Material.Rounded.SmartToy" IconColor="Color.Default">AI Actors</MudNavLink>
            }

            <div class="nav-section-label">Alerts</div>
            <MudNavLink Href="@($"{GetBaseHref()}queries")" Icon="@Icons.Material.Rounded.ManageSearch" IconColor="Color.Default">Queries</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}subscriptions")" Icon="@Icons.Material.Rounded.Schedule" IconColor="Color.Default">Subscriptions</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}notifications")" Icon="@Icons.Material.Rounded.Notifications" IconColor="Color.Default">Notifications</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}recipients")" Icon="@Icons.Material.Rounded.People" IconColor="Color.Default">Recipients</MudNavLink>
            <MudNavLink Href="@($"{GetBaseHref()}tasks")" Icon="@Icons.Material.Rounded.TaskAlt" IconColor="Color.Default">Tasks</MudNavLink>

            <div class="nav-section-label">MCP</div>
            <MudNavLink Href="@($"{GetBaseHref()}beacon/data-catalog")" Icon="@Icons.Material.Rounded.MenuBook" IconColor="Color.Default">Data Catalog</MudNavLink>
            @if (HasAdminRole())
            {
                <MudNavLink Href="@($"{GetBaseHref()}beacon/settings/api-keys")" Icon="@Icons.Material.Rounded.Key" IconColor="Color.Default">API Keys</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}beacon/settings/mcp")" Icon="@Icons.Material.Rounded.Tune" IconColor="Color.Default">MCP Settings</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}beacon/settings/mcp/playground")" Icon="@Icons.Material.Rounded.Terminal" IconColor="Color.Default">MCP Playground</MudNavLink>
                <MudNavLink Href="@($"{GetBaseHref()}beacon/settings/mcp-learning")" Icon="@Icons.Material.Rounded.Psychology" IconColor="Color.Default">MCP Learning</MudNavLink>
            }

            @if (HasAdminRole() || (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole()))
            {
                <div class="nav-section-label">Admin</div>
                @if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
                {
                    <MudNavLink Href="@($"{GetBaseHref()}approvals")" Icon="@Icons.Material.Rounded.Approval" IconColor="Color.Default">
                        Approvals
                        @if (_pendingApprovalCount > 0)
                        {
                            <MudBadge Content="@_pendingApprovalCount" Color="Color.Error" Overlap="true" Class="ml-2" />
                        }
                    </MudNavLink>
                }
                @if (Configuration?.UserManagement.Enabled == true && HasAdminRole())
                {
                    <MudNavLink Href="@($"{GetBaseHref()}users")" Icon="@Icons.Material.Rounded.AdminPanelSettings" IconColor="Color.Default">User Management</MudNavLink>
                }
                @if (HasAdminRole())
                {
                    <MudNavLink Href="@($"{GetBaseHref()}admin/settings")" Icon="@Icons.Material.Rounded.Settings" IconColor="Color.Default">Admin Settings</MudNavLink>
                }
            }

            <div class="drawer-footer">
                <MudNavLink Href="@($"{GetBaseHref()}about")" Icon="@Icons.Material.Rounded.Info" IconColor="Color.Default">About</MudNavLink>
            </div>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="bx-main pb-12">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            <div class="bx-content">
                @Body
            </div>
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@inject IBrowserViewportService BrowserViewportService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject BeaconConfiguration Configuration
@inject Beacon.Core.Authorization.IBeaconUserContext UserContext

@inject Beacon.Core.Services.IQueryApprovalService ApprovalService

@code
{
    private bool _isDark = true;
    private Breakpoint _breakpoint;
    private bool _drawerOpen = true;
    private int _pendingApprovalCount;
    private bool _hasUnreadNotifications;
    private List<Crumb> _breadcrumbs = new();

    private record Crumb(string Label, string? Href);

    private static readonly Dictionary<string, (string Section, string Label)> _routeMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["dashboard"] = ("Overview", "Mission Control"),
        ["control-tower"] = ("Overview", "Control Tower"),
        ["dashboards"] = ("Overview", "Dashboards"),
        ["data-sources"] = ("Data", "Data Sources"),
        ["data-quality"] = ("Data", "Data Quality"),
        ["data-migration"] = ("Data", "Data Migration"),
        ["beacon/projects"] = ("Data", "Projects"),
        ["beacon/data-catalog"] = ("MCP", "Data Catalog"),
        ["ai-actors"] = ("Data", "AI Actors"),
        ["queries"] = ("Alerts", "Queries"),
        ["queries/add"] = ("Alerts", "New query"),
        ["subscriptions"] = ("Alerts", "Subscriptions"),
        ["notifications"] = ("Alerts", "Notifications"),
        ["recipients"] = ("Alerts", "Recipients"),
        ["tasks"] = ("Alerts", "Tasks"),
        ["beacon/settings/api-keys"] = ("MCP", "API Keys"),
        ["beacon/settings/mcp"] = ("MCP", "MCP Settings"),
        ["beacon/settings/mcp/playground"] = ("MCP", "MCP Playground"),
        ["beacon/settings/mcp-learning"] = ("MCP", "MCP Learning"),
        ["users"] = ("Admin", "User Management"),
        ["admin/settings"] = ("Admin", "Admin Settings"),
        ["approvals"] = ("Admin", "Approvals"),
        ["settings"] = ("You", "Settings"),
        ["about"] = ("You", "About"),
    };

    private string GetBaseHref()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath;
        return path.EndsWith("/") ? path : $"{path}/";
    }

    private string GetUserInitial()
    {
        var name = UserContext.DisplayName ?? UserContext.UserName;
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        return name.Substring(0, 1).ToUpperInvariant();
    }

    protected override void OnInitialized()
    {
        UpdateBreadcrumbs(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateBreadcrumbs(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateBreadcrumbs(string uri)
    {
        var basePath = new Uri(NavigationManager.BaseUri).AbsolutePath.TrimEnd('/');
        var path = new Uri(uri).AbsolutePath;
        if (basePath.Length > 0 && path.StartsWith(basePath, StringComparison.OrdinalIgnoreCase))
        {
            path = path.Substring(basePath.Length);
        }
        path = path.Trim('/');

        var crumbs = new List<Crumb>();
        if (string.IsNullOrEmpty(path) || path.Equals("dashboard", StringComparison.OrdinalIgnoreCase))
        {
            crumbs.Add(new Crumb("Overview", null));
            crumbs.Add(new Crumb("Mission Control", null));
        }
        else
        {
            var matchKey = _routeMap.Keys
                .Where(k => path.Equals(k, StringComparison.OrdinalIgnoreCase) || path.StartsWith(k + "/", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(k => k.Length)
                .FirstOrDefault();

            if (matchKey != null)
            {
                var (section, label) = _routeMap[matchKey];
                crumbs.Add(new Crumb(section, null));
                crumbs.Add(new Crumb(label, $"{GetBaseHref()}{matchKey}"));
                if (!path.Equals(matchKey, StringComparison.OrdinalIgnoreCase))
                {
                    var rest = path.Substring(matchKey.Length).Trim('/');
                    if (!string.IsNullOrEmpty(rest))
                    {
                        crumbs.Add(new Crumb(rest, null));
                    }
                }
            }
            else
            {
                var segments = path.Split('/');
                foreach (var seg in segments)
                {
                    if (!string.IsNullOrEmpty(seg))
                    {
                        crumbs.Add(new Crumb(seg, null));
                    }
                }
            }
        }
        _breadcrumbs = crumbs;
    }

    private void NavigateToSearch()
    {
        // Search command palette not yet implemented — link to queries for now.
        NavigationManager.NavigateTo($"{GetBaseHref()}queries");
    }

    private void NavigateToNotifications()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}notifications");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            _drawerOpen = _breakpoint >= Breakpoint.Lg;
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            await LoadTheme();

            if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
            {
                _pendingApprovalCount = await ApprovalService.GetPendingCountAsync();
            }

            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task ChangeTheme()
    {
        _isDark = !_isDark;
        await LocalStorage.SetItemAsync("IsDark", _isDark.ToString());
        await LoadTheme();
    }

    private async Task LoadTheme()
    {
        // Load code highlighting CSS
        if (_isDark)
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Beacon.UI/highlight/styles/github-dark.css");
        }
        else
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Beacon.UI/highlight/styles/github.css");
        }

        // Update Mermaid theme
        try
        {
            var theme = _isDark ? "dark" : "default";
            await JS.InvokeVoidAsync("updateMermaidTheme", theme);
        }
        catch
        {
            // Silently ignore if mermaid is not yet loaded
        }
    }

    private void HandleLogout()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}api/auth/signout", forceLoad: true);
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}settings");
    }

    private bool HasAdminRole()
    {
        // Check if user has Admin role or is SuperAdmin
        // For now, check claims for "Admin" role
        return UserContext.HasClaim("role", "Admin") ||
               UserContext.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", "Admin");
    }
}
