@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@using Beacon.Core
@using Beacon.UI.Components.Helpers
@inherits LayoutComponentBase
@implements IDisposable

@* Required *@
<MudThemeProvider Theme="BeaconTheme.Theme" IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout Class="@($"beacon-layout {(_isDark ? "mud-theme-dark" : "")}")">
    <MudAppBar Elevation="0" Dense="false" Class="beacon-appbar beacon-topbar">
        <div class="topbar">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a class="breadcrumb__crumb" href="@($"{GetBaseHref()}dashboard")">Workspace</a>
                @foreach (var crumb in _breadcrumbs)
                {
                    <span class="breadcrumb__sep">/</span>
                    @if (!string.IsNullOrEmpty(crumb.Href) && crumb != _breadcrumbs.Last())
                    {
                        <a class="breadcrumb__crumb" href="@crumb.Href">@crumb.Label</a>
                    }
                    else
                    {
                        <span class="breadcrumb__current">@crumb.Label</span>
                    }
                }
            </nav>
            <button type="button" class="topbar__search" @onclick="NavigateToSearch">
                <MudIcon Icon="@Icons.Material.Rounded.Search" Size="Size.Small" />
                <span>Search queries, sources, recipients…</span>
                <span class="topbar__search-kbd">
                    <span class="kbd">⌘</span><span class="kbd">K</span>
                </span>
            </button>
            <div class="topbar__right">
                <MudTooltip Text="@(_isDark ? "Light Mode" : "Dark Mode")" Placement="Placement.Bottom">
                    <button type="button" class="icon-btn" @onclick="@ChangeTheme">
                        <MudIcon Icon="@(_isDark ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)" Size="Size.Small" />
                    </button>
                </MudTooltip>
                <MudTooltip Text="Notifications" Placement="Placement.Bottom">
                    <button type="button" class="icon-btn" @onclick="NavigateToNotifications">
                        <MudIcon Icon="@Icons.Material.Rounded.Notifications" Size="Size.Small" />
                        @if (_pendingApprovalCount > 0 || _hasUnreadNotifications)
                        {
                            <span class="icon-btn__dot"></span>
                        }
                    </button>
                </MudTooltip>
                <MudTooltip Text="Settings" Placement="Placement.Bottom">
                    <button type="button" class="icon-btn" @onclick="@NavigateToSettings">
                        <MudIcon Icon="@Icons.Material.Rounded.Settings" Size="Size.Small" />
                    </button>
                </MudTooltip>
                <span class="divider-v"></span>
                @if (UserContext.IsAuthenticated)
                {
                    <button type="button" class="user-chip" @onclick="NavigateToSettings">
                        <span class="user-chip__avatar">@GetUserInitial()</span>
                        <span class="user-chip__name">@(UserContext.DisplayName ?? UserContext.UserName ?? "User")</span>
                    </button>
                    <MudTooltip Text="Logout" Placement="Placement.Bottom">
                        <button type="button" class="icon-btn" @onclick="HandleLogout">
                            <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                }
                else
                {
                    <span class="user-chip">
                        <span class="user-chip__avatar">?</span>
                        <span class="user-chip__name">Guest</span>
                    </span>
                }
            </div>
        </div>
    </MudAppBar>
    <MudDrawer Open="@_drawerOpen" OpenChanged="@(v => _drawerOpen = v)" ClipMode="DrawerClipMode.Never" Elevation="0" Width="232px" Class="beacon-drawer">
        <aside class="sidebar">
            <div class="sidebar__brand">
                <div class="sidebar__logo">
                    <div class="sidebar__logo-dot" aria-hidden="true"></div>
                    <span>Beacon</span>
                </div>
                <span class="sidebar__version">v0.99</span>
            </div>

            <nav class="sidebar__nav">
                <div class="sidebar__section">
                    <div class="sidebar__section-label">Overview</div>
                    <NavLink href="@($"{GetBaseHref()}dashboard")" class="nav-item" ActiveClass="active" Match="NavLinkMatch.All">
                        <MudIcon Icon="@Icons.Material.Rounded.SpaceDashboard" Class="nav-item__icon" />
                        <span>Home</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}control-tower")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.MonitorHeart" Class="nav-item__icon" />
                        <span>Control Tower</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}dashboards")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.Widgets" Class="nav-item__icon" />
                        <span>Dashboards</span>
                    </NavLink>
                </div>

                <div class="sidebar__section">
                    <div class="sidebar__section-label">Data</div>
                    <NavLink href="@($"{GetBaseHref()}data-sources")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.Storage" Class="nav-item__icon" />
                        <span>Data Sources</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}beacon/projects")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.FolderSpecial" Class="nav-item__icon" />
                        <span>Projects</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}data-quality")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.VerifiedUser" Class="nav-item__icon" />
                        <span>Data Quality</span>
                        <span class="nav-item__badge">BETA</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}data-migration")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.SwapHoriz" Class="nav-item__icon" />
                        <span>Data Migration</span>
                    </NavLink>
                    @if (Configuration?.UseAI == true)
                    {
                        <NavLink href="@($"{GetBaseHref()}ai-actors")" class="nav-item" ActiveClass="active">
                            <MudIcon Icon="@Icons.Material.Rounded.SmartToy" Class="nav-item__icon" />
                            <span>AI Actors</span>
                        </NavLink>
                    }
                </div>

                <div class="sidebar__section">
                    <div class="sidebar__section-label">Alerts</div>
                    <NavLink href="@($"{GetBaseHref()}queries")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.ManageSearch" Class="nav-item__icon" />
                        <span>Queries</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}subscriptions")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.Schedule" Class="nav-item__icon" />
                        <span>Subscriptions</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}notifications")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.Notifications" Class="nav-item__icon" />
                        <span>Notifications</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}recipients")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.People" Class="nav-item__icon" />
                        <span>Recipients</span>
                    </NavLink>
                    <NavLink href="@($"{GetBaseHref()}tasks")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Class="nav-item__icon" />
                        <span>Tasks</span>
                    </NavLink>
                </div>

                <div class="sidebar__section">
                    <div class="sidebar__section-label">MCP</div>
                    <NavLink href="@($"{GetBaseHref()}beacon/data-catalog")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.MenuBook" Class="nav-item__icon" />
                        <span>Data Catalog</span>
                    </NavLink>
                    @if (HasAdminRole())
                    {
                        <NavLink href="@($"{GetBaseHref()}beacon/settings/api-keys")" class="nav-item" ActiveClass="active">
                            <MudIcon Icon="@Icons.Material.Rounded.Key" Class="nav-item__icon" />
                            <span>API Keys</span>
                        </NavLink>
                        <NavLink href="@($"{GetBaseHref()}beacon/settings/mcp")" class="nav-item" ActiveClass="active" Match="NavLinkMatch.All">
                            <MudIcon Icon="@Icons.Material.Rounded.Tune" Class="nav-item__icon" />
                            <span>MCP Settings</span>
                        </NavLink>
                        <NavLink href="@($"{GetBaseHref()}beacon/settings/mcp/playground")" class="nav-item" ActiveClass="active">
                            <MudIcon Icon="@Icons.Material.Rounded.Terminal" Class="nav-item__icon" />
                            <span>MCP Playground</span>
                        </NavLink>
                        <NavLink href="@($"{GetBaseHref()}beacon/settings/mcp-learning")" class="nav-item" ActiveClass="active">
                            <MudIcon Icon="@Icons.Material.Rounded.Psychology" Class="nav-item__icon" />
                            <span>MCP Learning</span>
                        </NavLink>
                    }
                </div>

                @if (HasAdminRole() || (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole()))
                {
                    <div class="sidebar__section">
                        <div class="sidebar__section-label">Admin</div>
                        @if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
                        {
                            <NavLink href="@($"{GetBaseHref()}approvals")" class="nav-item" ActiveClass="active">
                                <MudIcon Icon="@Icons.Material.Rounded.Approval" Class="nav-item__icon" />
                                <span>Approvals</span>
                                @if (_pendingApprovalCount > 0)
                                {
                                    <span class="nav-item__count">@_pendingApprovalCount</span>
                                }
                            </NavLink>
                        }
                        @if (Configuration?.UserManagement.Enabled == true && HasAdminRole())
                        {
                            <NavLink href="@($"{GetBaseHref()}users")" class="nav-item" ActiveClass="active">
                                <MudIcon Icon="@Icons.Material.Rounded.AdminPanelSettings" Class="nav-item__icon" />
                                <span>User Management</span>
                            </NavLink>
                        }
                        @if (HasAdminRole())
                        {
                            <NavLink href="@($"{GetBaseHref()}admin/settings")" class="nav-item" ActiveClass="active">
                                <MudIcon Icon="@Icons.Material.Rounded.Settings" Class="nav-item__icon" />
                                <span>Admin Settings</span>
                            </NavLink>
                        }
                    </div>
                }

                <div class="sidebar__section" style="margin-top: 18px;">
                    <NavLink href="@($"{GetBaseHref()}about")" class="nav-item" ActiveClass="active">
                        <MudIcon Icon="@Icons.Material.Rounded.Info" Class="nav-item__icon" />
                        <span>About</span>
                    </NavLink>
                </div>
            </nav>
        </aside>
    </MudDrawer>
    <MudMainContent Class="main pb-12">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            <div class="@($"page beacon-page{(_isDark ? " beacon-page--dark" : "")}")">
                @Body
            </div>
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@inject IBrowserViewportService BrowserViewportService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject BeaconConfiguration Configuration
@inject Beacon.Core.Authorization.IBeaconUserContext UserContext

@inject Beacon.Core.Services.IQueryApprovalService ApprovalService

@code
{
    private bool _isDark = true;
    private Breakpoint _breakpoint;
    private bool _drawerOpen = true;
    private int _pendingApprovalCount;
    private bool _hasUnreadNotifications;
    private List<Crumb> _breadcrumbs = new();

    private record Crumb(string Label, string? Href);

    private static readonly Dictionary<string, (string Section, string Label)> _routeMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["dashboard"] = ("Overview", "Mission Control"),
        ["control-tower"] = ("Overview", "Control Tower"),
        ["dashboards"] = ("Overview", "Dashboards"),
        ["data-sources"] = ("Data", "Data Sources"),
        ["data-quality"] = ("Data", "Data Quality"),
        ["data-migration"] = ("Data", "Data Migration"),
        ["beacon/projects"] = ("Data", "Projects"),
        ["beacon/data-catalog"] = ("MCP", "Data Catalog"),
        ["ai-actors"] = ("Data", "AI Actors"),
        ["queries"] = ("Alerts", "Queries"),
        ["queries/add"] = ("Alerts", "New query"),
        ["subscriptions"] = ("Alerts", "Subscriptions"),
        ["notifications"] = ("Alerts", "Notifications"),
        ["recipients"] = ("Alerts", "Recipients"),
        ["tasks"] = ("Alerts", "Tasks"),
        ["beacon/settings/api-keys"] = ("MCP", "API Keys"),
        ["beacon/settings/mcp"] = ("MCP", "MCP Settings"),
        ["beacon/settings/mcp/playground"] = ("MCP", "MCP Playground"),
        ["beacon/settings/mcp-learning"] = ("MCP", "MCP Learning"),
        ["users"] = ("Admin", "User Management"),
        ["admin/settings"] = ("Admin", "Admin Settings"),
        ["approvals"] = ("Admin", "Approvals"),
        ["settings"] = ("You", "Settings"),
        ["about"] = ("You", "About"),
    };

    private string GetBaseHref()
    {
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath;
        return path.EndsWith("/") ? path : $"{path}/";
    }

    private string GetUserInitial()
    {
        var name = UserContext.DisplayName ?? UserContext.UserName;
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        return name.Substring(0, 1).ToUpperInvariant();
    }

    protected override void OnInitialized()
    {
        UpdateBreadcrumbs(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateBreadcrumbs(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateBreadcrumbs(string uri)
    {
        var basePath = new Uri(NavigationManager.BaseUri).AbsolutePath.TrimEnd('/');
        var path = new Uri(uri).AbsolutePath;
        if (basePath.Length > 0 && path.StartsWith(basePath, StringComparison.OrdinalIgnoreCase))
        {
            path = path.Substring(basePath.Length);
        }
        path = path.Trim('/');

        var crumbs = new List<Crumb>();
        if (string.IsNullOrEmpty(path) || path.Equals("dashboard", StringComparison.OrdinalIgnoreCase))
        {
            crumbs.Add(new Crumb("Overview", null));
            crumbs.Add(new Crumb("Mission Control", null));
        }
        else
        {
            var matchKey = _routeMap.Keys
                .Where(k => path.Equals(k, StringComparison.OrdinalIgnoreCase) || path.StartsWith(k + "/", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(k => k.Length)
                .FirstOrDefault();

            if (matchKey != null)
            {
                var (section, label) = _routeMap[matchKey];
                crumbs.Add(new Crumb(section, null));
                crumbs.Add(new Crumb(label, $"{GetBaseHref()}{matchKey}"));
                if (!path.Equals(matchKey, StringComparison.OrdinalIgnoreCase))
                {
                    var rest = path.Substring(matchKey.Length).Trim('/');
                    if (!string.IsNullOrEmpty(rest))
                    {
                        crumbs.Add(new Crumb(rest, null));
                    }
                }
            }
            else
            {
                var segments = path.Split('/');
                foreach (var seg in segments)
                {
                    if (!string.IsNullOrEmpty(seg))
                    {
                        crumbs.Add(new Crumb(seg, null));
                    }
                }
            }
        }
        _breadcrumbs = crumbs;
    }

    private void NavigateToSearch()
    {
        // Search command palette not yet implemented — link to queries for now.
        NavigationManager.NavigateTo($"{GetBaseHref()}queries");
    }

    private void NavigateToNotifications()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}notifications");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            _drawerOpen = _breakpoint >= Breakpoint.Lg;
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            await LoadTheme();

            if (Configuration?.ApprovalWorkflow.Enabled == true && HasAdminRole())
            {
                _pendingApprovalCount = await ApprovalService.GetPendingCountAsync();
            }

            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task ChangeTheme()
    {
        _isDark = !_isDark;
        await LocalStorage.SetItemAsync("IsDark", _isDark.ToString());
        await LoadTheme();
    }

    private async Task LoadTheme()
    {
        // Load code highlighting CSS
        if (_isDark)
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Beacon.UI/highlight/styles/github-dark.css");
        }
        else
        {
            await JS.InvokeVoidAsync("loadCss", "../_content/Beacon.UI/highlight/styles/github.css");
        }

        // Update Mermaid theme
        try
        {
            var theme = _isDark ? "dark" : "default";
            await JS.InvokeVoidAsync("updateMermaidTheme", theme);
        }
        catch
        {
            // Silently ignore if mermaid is not yet loaded
        }
    }

    private void HandleLogout()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}api/auth/signout", forceLoad: true);
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo($"{GetBaseHref()}settings");
    }

    private bool HasAdminRole()
    {
        // Check if user has Admin role or is SuperAdmin
        // For now, check claims for "Admin" role
        return UserContext.HasClaim("role", "Admin") ||
               UserContext.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", "Admin");
    }
}
