@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@using Beacon.UI.Components.Helpers
@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider Theme="BeaconTheme.Theme" IsDarkMode="@_isDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout Class="@($"beacon-layout beacon-login-layout {(_isDark ? "mud-theme-dark" : "")}")">
    <MudMainContent Class="login-main-content">
        <CascadingValue Value="@_isDark" Name="IsDarkMode">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<style>
    .beacon-login-layout {
        min-height: 100vh;
        background: #0a0e1a;
        overflow: hidden;
        position: relative;
    }

    .beacon-login-layout::before {
        content: '';
        position: absolute;
        top: -40%;
        left: -20%;
        width: 70%;
        height: 70%;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 70%);
        animation: float-orb-1 20s ease-in-out infinite;
        pointer-events: none;
    }

    .beacon-login-layout::after {
        content: '';
        position: absolute;
        bottom: -30%;
        right: -15%;
        width: 60%;
        height: 60%;
        background: radial-gradient(circle, rgba(168, 85, 247, 0.12) 0%, transparent 70%);
        animation: float-orb-2 25s ease-in-out infinite;
        pointer-events: none;
    }

    .login-main-content {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 24px;
        position: relative;
        z-index: 1;
    }

    /* Subtle middle orb */
    .login-main-content::before {
        content: '';
        position: absolute;
        top: 30%;
        right: 20%;
        width: 40%;
        height: 40%;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
        animation: float-orb-3 18s ease-in-out infinite;
        pointer-events: none;
        z-index: -1;
    }

    @@keyframes float-orb-1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(10%, 8%) scale(1.05); }
        66% { transform: translate(-5%, -3%) scale(0.95); }
    }

    @@keyframes float-orb-2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-8%, -6%) scale(1.08); }
        66% { transform: translate(5%, 4%) scale(0.92); }
    }

    @@keyframes float-orb-3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-6%, 8%) scale(1.1); }
    }
</style>

@inject ILocalStorageService LocalStorage

@code
{
    private static bool _isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await LocalStorage.GetItemAsync<string>("IsDark") == "True";
            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }
}
