@using Blazored.LocalStorage
@using Color = MudBlazor.Color
@using Beacon.UI.Components.Helpers
@inherits LayoutComponentBase

<MudThemeProvider Theme="BeaconTheme.Theme" IsDarkMode="@_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@($"beacon-layout {(_isDark ? "mud-theme-dark" : "")}")">
    <MudMainContent Class="d-flex align-center justify-center" Style="min-height: 100vh; background: linear-gradient(135deg, #022c22 0%, #064e3b 45%, #065f46 100%);">
        @Body
    </MudMainContent>
</MudLayout>

@inject ILocalStorageService LocalStorage

@code {
    private bool _isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var darkSetting = await LocalStorage.GetItemAsync<string>("IsDark");
            _isDark = darkSetting == "True" || string.IsNullOrEmpty(darkSetting);
            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }
}
