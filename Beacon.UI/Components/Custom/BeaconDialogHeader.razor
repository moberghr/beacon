@* Dialog header with Beacon visual language.
   Place inside MudDialog <TitleContent> to replace the default title bar.
   Variants: signal (default), nodes, grid *@

<div class="@($"bx-dialog-head{(IsDarkMode ? " bx-dialog-head--dark" : "")}")">
    <svg class="bx-dialog-head__bg" viewBox="0 0 600 100" preserveAspectRatio="none" aria-hidden="true">
        <defs>
            <pattern id="@GridId" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="currentColor" stroke-width="0.5" />
            </pattern>
            @if (Variant == "signal")
            {
                <linearGradient id="@ScanGradId" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="var(--brand-500)" stop-opacity="0" />
                    <stop offset="60%" stop-color="var(--brand-500)" stop-opacity="0.18" />
                    <stop offset="100%" stop-color="var(--brand-500)" stop-opacity="0" />
                </linearGradient>
            }
        </defs>

        <rect class="bx-dialog-head__grid" width="600" height="100" fill="url(#@GridId)" />

        @if (Variant == "signal")
        {
            <g class="bx-dialog-head__arcs" fill="none" transform="translate(0, 0)">
                <path d="M 560 0 A 180 180 0 0 0 540 60"
                      stroke="var(--brand-500)" stroke-opacity="0.30" stroke-width="1" />
                <path d="M 560 0 A 120 120 0 0 0 546 40"
                      stroke="var(--brand-500)" stroke-opacity="0.40" stroke-width="1" />
                <path d="M 560 0 A 60 60 0 0 0 554 22"
                      stroke="var(--brand-500)" stroke-opacity="0.55" stroke-width="1" />
                <circle cx="560" cy="0" r="4" fill="var(--brand-500)" />
            </g>
            <rect class="bx-dialog-head__scan" x="0" y="0" width="100" height="100"
                  fill="url(#@ScanGradId)" />
        }
        else if (Variant == "nodes")
        {
            <g class="bx-dialog-head__nodes" stroke="var(--brand-500)" fill="var(--brand-500)">
                <circle cx="480" cy="25" r="3" opacity="0.85" />
                <circle cx="520" cy="55" r="3" opacity="0.85" />
                <circle cx="440" cy="65" r="3" opacity="0.85" />
                <circle cx="560" cy="35" r="3" opacity="0.85" />
                <circle cx="400" cy="40" r="3" opacity="0.85" />
                <circle cx="470" cy="82" r="3" opacity="0.85" />
                <path d="M400 40 L480 25 L520 55 L440 65 L470 82 M480 25 L560 35 M520 55 L560 35"
                      stroke-opacity="0.4" fill="none" />
            </g>
        }
    </svg>

    <div class="bx-dialog-head__inner">
        <div class="bx-dialog-head__main">
            @if (!string.IsNullOrEmpty(Eyebrow))
            {
                <div class="bx-dialog-head__eyebrow">
                    <span class="bx-dialog-head__pin" aria-hidden="true"></span>
                    @((MarkupString)Eyebrow)
                </div>
            }
            <h2 class="bx-dialog-head__title">
                @if (!string.IsNullOrEmpty(Prefix))
                {
                    <span>@Prefix </span>
                }
                @if (!string.IsNullOrEmpty(Emphasis))
                {
                    <span class="bx-dialog-head__word">
                        @Emphasis
                        <svg class="bx-dialog-head__underline" viewBox="0 0 220 14"
                             preserveAspectRatio="none" aria-hidden="true">
                            <path d="M2 9 Q 40 2, 80 7 T 160 7 T 218 5"
                                  fill="none" stroke="var(--brand-500)"
                                  stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                    </span>
                }
                @if (!string.IsNullOrEmpty(Suffix))
                {
                    <span> @Suffix</span>
                }
                @if (string.IsNullOrEmpty(Prefix) && string.IsNullOrEmpty(Emphasis) && !string.IsNullOrEmpty(Title))
                {
                    <span>@Title</span>
                }
            </h2>
            @if (!string.IsNullOrEmpty(Sub))
            {
                <p class="bx-dialog-head__sub">@Sub</p>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "IsDarkMode")]
    public bool IsDarkMode { get; set; }

    /// <summary>Visual variant: signal (default), nodes, grid</summary>
    [Parameter] public string Variant { get; set; } = "signal";

    /// <summary>Uppercase breadcrumb eyebrow. Supports simple HTML (e.g. span separators).</summary>
    [Parameter] public string Eyebrow { get; set; } = "";

    /// <summary>Text before the italic emphasis word.</summary>
    [Parameter] public string Prefix { get; set; } = "";

    /// <summary>The italic word with the hand-drawn underline animation.</summary>
    [Parameter] public string Emphasis { get; set; } = "";

    /// <summary>Text after the italic emphasis word (e.g. ".").</summary>
    [Parameter] public string Suffix { get; set; } = "";

    /// <summary>Fallback plain title when Prefix/Emphasis are not used.</summary>
    [Parameter] public string Title { get; set; } = "";

    /// <summary>Sub-line description below the title.</summary>
    [Parameter] public string Sub { get; set; } = "";

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private string GridId     => $"dh-grid-{_id}";
    private string ScanGradId => $"dh-scan-{_id}";
}
