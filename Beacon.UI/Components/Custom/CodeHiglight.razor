@* Code Highlight Component - Read-only code display with syntax highlighting *@
<div class="code-highlight-container" style="background-color: @(IsDarkMode ? "#1e1e1e" : "#f5f5f5"); border: 1px solid @(IsDarkMode ? "#444" : "#ddd"); border-radius: 4px; padding: 12px; overflow-x: auto;">
    <pre style="margin: 0; font-family: 'Courier New', monospace; font-size: 14px; white-space: pre-wrap; word-wrap: break-word; color: @(IsDarkMode ? "#d4d4d4" : "inherit");"><code class="language-sql">@Code</code></pre>
</div>

@code {
    [Parameter]
    public string Code { get; set; } = string.Empty;

    [Parameter]
    public string Language { get; set; } = "sql";

    [CascadingParameter(Name = "IsDarkMode")]
    public bool IsDarkMode { get; set; }
}

