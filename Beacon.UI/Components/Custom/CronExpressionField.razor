@inject IJSRuntime JSRuntime

@* TODO: Beacon migration — uses MudForm Validation=. Leave as MudTextField. *@
<MudTextField OnlyValidateIfDirty="@OnlyValidateIfDirty"
              Immediate="@Immediate"
              Margin="@Margin"
              Variant="@Variant"
              Class="@Class"
              Value="@Value"
              ValueChanged="@OnValueChanged"
              Placeholder="@Placeholder"
              Validation="@(new Func<string, Task<string>>(ValidateCron))"
              T="String"
              HelperText="@_cronDescription"
              Label="@Label"
              Required="@Required"
              Disabled="@Disabled" />

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Cron Expression";
    [Parameter] public string Placeholder { get; set; } = "* * * * *";
    [Parameter] public bool Required { get; set; } = false;
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool OnlyValidateIfDirty { get; set; } = true;
    [Parameter] public bool Immediate { get; set; } = true;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public string Class { get; set; } = "mb-2";

    private string _cronDescription = "";

    private async Task OnValueChanged(string? value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    private async Task<string> ValidateCron(string? cron)
    {
        if (string.IsNullOrWhiteSpace(cron))
        {
            _cronDescription = "";
            return Required ? "Cron expression is required" : string.Empty;
        }

        if (!Cronos.CronExpression.TryParse(cron, out Cronos.CronExpression? expression))
        {
            _cronDescription = "";
            return "Invalid cron expression";
        }

        _cronDescription = cron.GetCronDescription();

        var cronNextAt = cron.GetCronNextAt();
        var localNextAt = await JSRuntime.InvokeAsync<string>("toLocalTime", cronNextAt);

        _cronDescription += $" -> next at: {localNextAt}";

        return string.Empty;
    }
}