@* Single row in the Pre-flight checks list. Tone: ok | warn | pending. *@

<div class="check">
    <div class="check__icon @($"check__icon--{Tone}")">
        @switch (Tone)
        {
            case "ok":
                <MudIcon Icon="@Icons.Material.Rounded.Check" Size="Size.Small" Style="font-size: 12px;" />
                break;
            case "warn":
                <MudIcon Icon="@Icons.Material.Rounded.PriorityHigh" Size="Size.Small" Style="font-size: 12px;" />
                break;
            default:
                <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="Size.Small" Style="font-size: 12px;" />
                break;
        }
    </div>
    <div>
        <div class="check__main">@Title</div>
        @if (!string.IsNullOrEmpty(Detail))
        {
            <div class="check__detail">@Detail</div>
        }
    </div>
    @if (!string.IsNullOrEmpty(Time))
    {
        <div class="check__time">@Time</div>
    }
</div>

@code {
    [Parameter] public string Tone { get; set; } = "pending";
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Detail { get; set; }
    [Parameter] public string? Time { get; set; }
}
