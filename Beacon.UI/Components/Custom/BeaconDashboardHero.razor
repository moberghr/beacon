@* Mission-control hero for the dashboard.
   Animated radar grid + sweep beam + concentric ping rings,
   time-of-day greeting, italic emphasis word with hand-drawn underline,
   live UTC clock and 24h system status mini-rail. *@

@implements IDisposable
@inject NavigationManager NavigationManager

<div class="beacon-hero">
    <div class="beacon-hero__sweep" aria-hidden="true">
        <svg viewBox="0 0 600 200" preserveAspectRatio="none" width="100%" height="100%">
            <defs>
                <radialGradient id="bh-radial" cx="0%" cy="50%" r="60%">
                    <stop offset="0%" stop-color="var(--brand-500)" stop-opacity="0.35" />
                    <stop offset="55%" stop-color="var(--brand-500)" stop-opacity="0.08" />
                    <stop offset="100%" stop-color="var(--brand-500)" stop-opacity="0" />
                </radialGradient>
                <pattern id="bh-grid" width="24" height="24" patternUnits="userSpaceOnUse">
                    <path d="M24 0H0V24" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.6" />
                </pattern>
            </defs>
            <rect width="600" height="200" fill="url(#bh-grid)" class="beacon-hero__grid" />
            <rect width="600" height="200" fill="url(#bh-radial)" />
            <g class="beacon-hero__rings">
                <circle cx="0" cy="100" r="60" fill="none" stroke="var(--brand-500)" stroke-opacity="0.18" />
                <circle cx="0" cy="100" r="120" fill="none" stroke="var(--brand-500)" stroke-opacity="0.13" />
                <circle cx="0" cy="100" r="180" fill="none" stroke="var(--brand-500)" stroke-opacity="0.08" />
            </g>
        </svg>
        <div class="beacon-hero__beam"></div>
    </div>

    <div class="beacon-hero__inner">
        <div class="beacon-hero__left">
            <div class="beacon-hero__eyebrow">
                <span class="mono">@_dateLabel</span>
                <span class="beacon-hero__sep">·</span>
                <span class="mono">@_timeLabel UTC</span>
                <span class="beacon-hero__sep">·</span>
                <span class="live-pip"><span class="live-pip__dot"></span>BEACON ACTIVE</span>
            </div>
            <h1 class="beacon-hero__title">
                <span class="beacon-hero__greet">@_greeting@(string.IsNullOrEmpty(UserName) ? "" : $", {UserName}").</span>
                <span class="beacon-hero__headline">
                    <span>@HeadlinePrefix</span>
                    <span class="beacon-hero__word">
                        @HeadlineEmphasis
                        <svg class="beacon-hero__underline" viewBox="0 0 220 14" preserveAspectRatio="none" aria-hidden="true">
                            <path d="M2 9 Q 40 2, 80 7 T 160 7 T 218 5"
                                  fill="none" stroke="var(--brand-500)" stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                    </span>
                </span>
            </h1>
            @if (Sub != null)
            {
                <p class="beacon-hero__sub">@Sub</p>
            }
        </div>

        <div class="beacon-hero__right">
            <div class="beacon-hero__rail" title="Last 24 hours of system status">
                <div class="beacon-hero__rail-label">
                    <span>SYSTEM · LAST 24H</span>
                    <span class="mono">@(_tickedSec.ToString("D2"))s</span>
                </div>
                <div class="beacon-hero__rail-bars">
                    @for (int i = 0; i < _ticks.Length; i++)
                    {
                        var tone = _ticks[i];
                        var delay = (i * 30) + "ms";
                        <span class="beacon-hero__tick beacon-hero__tick--@tone" style="animation-delay: @delay"></span>
                    }
                </div>
                <div class="beacon-hero__rail-axis">
                    <span class="mono subtle">−24h</span>
                    <span class="mono subtle">now</span>
                </div>
            </div>
            @if (Actions != null)
            {
                <div class="beacon-hero__actions">@Actions</div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? UserName { get; set; }
    [Parameter] public string HeadlinePrefix { get; set; } = "Everything is";
    [Parameter] public string HeadlineEmphasis { get; set; } = "nominal";
    [Parameter] public RenderFragment? Sub { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    private System.Threading.Timer? _timer;
    private string _dateLabel = "";
    private string _timeLabel = "";
    private string _greeting = "Hello";
    private int _tickedSec = 12;
    private string[] _ticks = Array.Empty<string>();

    protected override void OnInitialized()
    {
        _ticks = BuildTicks();
        UpdateClock();

        _timer = new System.Threading.Timer(_ =>
        {
            UpdateClock();
            _tickedSec = _tickedSec >= 60 ? 1 : _tickedSec + 1;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void UpdateClock()
    {
        var now = DateTime.UtcNow;
        _dateLabel = now.ToString("ddd, dd MMM").ToUpperInvariant();
        _timeLabel = now.ToString("HH:mm:ss");

        var hour = DateTime.Now.Hour;
        _greeting = hour < 5 ? "Late shift"
                   : hour < 12 ? "Good morning"
                   : hour < 17 ? "Good afternoon"
                   : hour < 21 ? "Good evening"
                   : "Late shift";
    }

    private static string[] BuildTicks()
    {
        var rnd = new Random();
        var arr = new string[24];
        for (var i = 0; i < arr.Length; i++)
        {
            var r = rnd.NextDouble();
            arr[i] = r < 0.04 ? "crit" : r < 0.12 ? "warn" : "ok";
        }
        return arr;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
