@* Single entry in the Recent activity feed. Tone: ok | warn | crit | info | brand. *@

<div class="feed__item">
    <div class="feed__icon feed__icon--@Tone">
        <MudIcon Icon="@Icon" Size="Size.Small" Style="font-size: 12px;" />
    </div>
    <div class="feed__main">
        <div class="feed__title">@Title</div>
        @if (!string.IsNullOrEmpty(Meta))
        {
            <div class="feed__meta">@Meta</div>
        }
    </div>
    @if (!string.IsNullOrEmpty(Time))
    {
        <div class="feed__time">@Time</div>
    }
</div>

@code {
    [Parameter] public string Tone { get; set; } = "info";
    [Parameter] public string Icon { get; set; } = Icons.Material.Rounded.Circle;
    [Parameter] public RenderFragment? Title { get; set; }
    [Parameter] public string? Meta { get; set; }
    [Parameter] public string? Time { get; set; }
}
