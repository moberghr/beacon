@* Small count tile used in the bottom mini-grid (data migration, tasks). *@

<div class="mini">
    <div class="mini__label">
        <span class="mini__dot" style="background: @DotColor;"></span>
        @Label
    </div>
    <div class="mini__value">@Value</div>
    <div class="mini__bar">
        <span style="width: @Bar; background: @BarColor;"></span>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Bar { get; set; } = "0%";
    [Parameter] public string DotColor { get; set; } = "var(--brand-500)";
    [Parameter] public string BarColor { get; set; } = "var(--brand-500)";
}
