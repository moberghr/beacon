@using Beacon.Core.Models.Queries
@using Beacon.Core.Adapters

<MudCard Class="mt-4" Style="position: relative; bottom: 0; background-color: #fafafa;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.TableView" />
                <MudText Typo="Typo.h6">
                    @if (IsStepResult)
                    {
                        <text>Step @StepOrder Results</text>
                    }
                    else
                    {
                        <text>Query Results</text>
                    }
                </MudText>
                @if (TotalRows > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                        @TotalRows rows
                    </MudChip>
                }
                @if (ExecutionTimeMs > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">
                        @($"{ExecutionTimeMs:F0}ms")
                    </MudChip>
                }
            </MudStack>
        </CardHeaderContent>
        <CardHeaderActions>
            <BeaconIconButton Icon="@Icons.Material.Filled.Close"
                              Size="sm"
                              OnClick="OnClose" />
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (!Success)
        {
            <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Error">
                <strong>Execution Error:</strong> @ErrorMessage
            </MudAlert>
        }
        else if (Results?.Any() != true)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                No results returned from the query.
            </MudAlert>
        }
        else
        {
            <MudPaper Style="max-height: 300px; overflow-y: auto;" Elevation="0">
                <MudTable T="IDictionary<string, object?>" Items="@Results" Dense="true" Hover="true" 
                          Style="font-size: 0.8rem;">
                    <HeaderContent>
                        @if (Results.FirstOrDefault() is { } firstRow)
                        {
                            @foreach (var column in firstRow.Keys)
                            {
                                <MudTh Style="font-weight: bold; background-color: #e3f2fd;">@column</MudTh>
                            }
                        }
                    </HeaderContent>
                    <RowTemplate>
                        @foreach (var kvp in context)
                        {
                            <MudTd Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" 
                                   Title="@(kvp.Value?.ToString() ?? "")">
                                @if (kvp.Value == null)
                                {
                                    <span style="color: #999; font-style: italic;">NULL</span>
                                }
                                else
                                {
                                    @kvp.Value.ToString()
                                }
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            </MudPaper>
            
            @if (TotalRows > Results.Count)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2">
                    Showing @Results.Count of @TotalRows total rows (preview limited)
                </MudAlert>
            }
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public List<IDictionary<string, object?>>? Results { get; set; }
    [Parameter] public int TotalRows { get; set; }
    [Parameter] public double ExecutionTimeMs { get; set; }
    [Parameter] public bool Success { get; set; } = true;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool IsStepResult { get; set; }
    [Parameter] public int StepOrder { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}