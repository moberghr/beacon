@using Beacon.Core.Models.ControlTower
@using MudBlazor

<MudTooltip Text="@GetSparklineTooltip()">
    <div style="width: 80px; height: 30px;">
        @if (Data?.Any() == true)
        {
            <MudChart ChartType="ChartType.Line"
                      ChartSeries="@_series"
                      ChartLabels="@_labels"
                      Width="80px"
                      Height="30px"
                      ChartOptions="@_options" />
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No data</MudText>
        }
    </div>
</MudTooltip>

@code {
    [Parameter] public List<AnomalySparklinePoint>? Data { get; set; }

    private List<ChartSeries<double>> _series = new();
    private string[] _labels = Array.Empty<string>();
    private LineChartOptions _options = new()
    {
        YAxisTicks = 0,
        XAxisLines = false,
        YAxisLines = false,
        InterpolationOption = InterpolationOption.Straight
    };

    protected override void OnParametersSet()
    {
        if (Data?.Any() == true)
        {
            _labels = Data.Select(d => "").ToArray(); // No labels for compact view
            _series = new List<ChartSeries<double>>
            {
                new()
                {
                    Name = "Anomalies",
                    Data = Data.Select(d => (double)d.AnomalyCount).ToArray()
                }
            };
        }
    }

    private string GetSparklineTooltip()
    {
        if (Data?.Any() != true) return "No anomalies detected";
        var total = Data.Sum(d => d.AnomalyCount);
        return $"{total} anomalies in last 30 days";
    }
}
