@using Beacon.Core.Models.Queries
@using BlazorMonaco
@using BlazorMonaco.Editor
@using Beacon.Core.Data.Enums

<style>
    .final-query-editor-container {
        height: 100% !important;
    }

    .final-query-editor-container > div {
        height: 100% !important;
    }
</style>

<div style="height: @Height; border: 1px solid #ddd;">
    @if (_monacoReady)
    {
        <StandaloneCodeEditor @ref="_editor"
                             Id="@EditorId"
                             ConstructionOptions="EditorConstructionOptions"
                             OnDidInit="OnEditorInit"
                             OnDidChangeModelContent="OnEditorContentChanged"
                             CssClass="final-query-editor-container" />
    }
    else
    {
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; background-color: #f5f5f5;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
</div>

@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public QueryData? Query { get; set; }
    [Parameter] public string Height { get; set; } = "300px";
    [Parameter] public string EditorId { get; set; } = $"final-query-editor-{Guid.NewGuid()}";
    [Parameter] public string Placeholder { get; set; } = "-- Optional: Combine results from previous steps using @result1, @result2, etc.";

    [CascadingParameter(Name = "IsDarkMode")]
    public bool IsDarkMode { get; set; }

    private StandaloneCodeEditor? _editor;
    private bool _initialized = false;
    private bool _completionProviderRegistered = false;
    private string _lastValue = "";
    private bool _monacoReady = false;
    private bool _lastDarkMode = false;

    protected override async Task OnInitializedAsync()
    {
        // Wait for Monaco to be ready before rendering the editor
        _monacoReady = await WaitForMonacoAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Update theme if dark mode changed
        if (_initialized && _editor != null && IsDarkMode != _lastDarkMode)
        {
            _lastDarkMode = IsDarkMode;
            await UpdateEditorTheme();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _editor != null)
        {
            await Task.Delay(100);
            try
            {
                await _editor.Layout();
            }
            catch
            {
                // Silently ignore layout errors
            }
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        var initialValue = Value;
        if (string.IsNullOrEmpty(initialValue))
        {
            initialValue = "";
        }
        _lastValue = Value ?? "";

        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "sql",
            Theme = IsDarkMode ? "vs-dark" : "vs",
            Value = initialValue,
            FontSize = 14,
            LineNumbers = "on",
            RenderLineHighlight = "all",
            ScrollBeyondLastLine = false,
            ReadOnly = false,
            Minimap = new EditorMinimapOptions { Enabled = false },
            WordWrap = "on"
        };
    }

    private async Task OnEditorInit()
    {
        _initialized = true;
        _lastDarkMode = IsDarkMode;

        if (_editor != null)
        {
            try
            {
                await _editor.Layout();

                await _editor.UpdateOptions(new EditorUpdateOptions
                {
                    ReadOnly = false
                });

                await Task.Delay(100);

                try
                {
                    await _editor.Focus();
                }
                catch
                {
                    // Silently ignore focus errors
                }

                // Register completion provider with SQLite and virtual table context
                await RegisterCompletionProvider();
            }
            catch
            {
                // Silently ignore initialization errors
            }
        }
    }

    private async Task<bool> WaitForMonacoAsync(int maxAttempts = 50, int delayMs = 100)
    {
        for (int i = 0; i < maxAttempts; i++)
        {
            try
            {
                // Check if both monaco and blazorMonaco are available
                var isReady = await JSRuntime.InvokeAsync<bool>("eval",
                    "typeof monaco !== 'undefined' && typeof blazorMonaco !== 'undefined' && typeof blazorMonaco.editor !== 'undefined' && typeof blazorMonaco.editor.create !== 'undefined'");
                if (isReady)
                {
                    Console.WriteLine($"FinalQueryEditor {EditorId}: BlazorMonaco is ready (attempt {i + 1})");
                    return true;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"FinalQueryEditor {EditorId}: BlazorMonaco check failed (attempt {i + 1}): {ex.Message}");
            }

            await Task.Delay(delayMs);
        }

        Console.WriteLine($"FinalQueryEditor {EditorId}: BlazorMonaco not ready after {maxAttempts} attempts");
        return false;
    }

    private async Task OnEditorContentChanged(ModelContentChangedEvent e)
    {
        if (_editor != null)
        {
            var newValue = await _editor.GetValue();

            if (newValue != _lastValue)
            {
                _lastValue = newValue;
                await ValueChanged.InvokeAsync(newValue);
            }
        }
    }

    private async Task RegisterCompletionProvider()
    {
        if (_editor == null || _completionProviderRegistered) return;

        try
        {
            _completionProviderRegistered = true;

            var completionItems = new List<object>();

            // Add SQLite-specific keywords
            var sqliteKeywords = new[] {
                "SELECT", "FROM", "WHERE", "JOIN", "INNER", "LEFT", "RIGHT", "OUTER", "ON",
                "GROUP", "BY", "HAVING", "ORDER", "ASC", "DESC", "LIMIT", "OFFSET",
                "UNION", "UNION ALL", "INTERSECT", "EXCEPT", "CASE", "WHEN", "THEN", "ELSE", "END",
                "AND", "OR", "NOT", "NULL", "IS", "IN", "LIKE", "BETWEEN", "EXISTS",
                "DISTINCT", "COUNT", "SUM", "AVG", "MAX", "MIN", "CAST", "COALESCE",
                "AS", "WITH", "OVER", "PARTITION", "ROW_NUMBER", "RANK", "DENSE_RANK"
            };

            foreach (var keyword in sqliteKeywords)
            {
                completionItems.Add(new
                {
                    label = keyword,
                    kind = 14, // Keyword
                    insertText = keyword,
                    detail = "SQLite Keyword"
                });
            }

            // Add virtual table references from query steps
            if (Query?.Steps != null)
            {
                foreach (var step in Query.Steps.OrderBy(s => s.StepOrder))
                {
                    var tableName = $"@result{step.StepOrder}";
                    completionItems.Add(new
                    {
                        label = tableName,
                        kind = 7, // Class/Table
                        insertText = tableName,
                        detail = $"Virtual Table - {step.DataSourceName}",
                        documentation = $"Results from Step {step.StepOrder}: {step.Name ?? $"Step {step.StepOrder}"} ({step.DatabaseEngineDescription})"
                    });

                    // If step has a name, also suggest it
                    if (!string.IsNullOrWhiteSpace(step.Name) && step.Name != $"Step {step.StepOrder}")
                    {
                        completionItems.Add(new
                        {
                            label = $"-- {step.Name}",
                            kind = 9, // Property
                            insertText = tableName,
                            detail = $"Step {step.StepOrder}",
                            documentation = step.Description ?? $"Results from {step.Name}"
                        });
                    }
                }
            }

            // Add common SQLite functions
            var sqliteFunctions = new[] {
                "LENGTH", "SUBSTR", "REPLACE", "TRIM", "LTRIM", "RTRIM", "UPPER", "LOWER",
                "ROUND", "ABS", "RANDOM", "DATETIME", "DATE", "TIME", "STRFTIME",
                "NULLIF", "IFNULL", "TYPEOF", "CAST", "PRINTF"
            };

            foreach (var func in sqliteFunctions)
            {
                completionItems.Add(new
                {
                    label = func,
                    kind = 3, // Function
                    insertText = $"{func}()",
                    detail = "SQLite Function"
                });
            }

            // Register completion provider via JavaScript
            await JSRuntime.InvokeVoidAsync("eval", $@"
                (function() {{
                    const completionItems = {System.Text.Json.JsonSerializer.Serialize(completionItems)};
                    const targetEditorId = '{EditorId}';

                    monaco.languages.registerCompletionItemProvider('sql', {{
                        provideCompletionItems: function(model, position) {{
                            // Find the editor for this specific FinalQueryEditor instance
                            let editor = null;
                            if (window.monaco && window.monaco.editor) {{
                                 const editors = window.monaco.editor.getEditors();
                                 editor = editors.find(e => {{
                                     const domNode = e.getContainerDomNode();
                                     return domNode && domNode.id === targetEditorId;
                                 }});
                            }}
                            
                            // Only provide completions if the model belongs to this editor
                            if (!editor || editor.getModel() !== model) {{
                                return {{ suggestions: [] }};
                            }}

                            // Filter to only show virtual tables and SQLite-specific items
                            const virtualTableItems = completionItems.filter(item =>
                                item.label.startsWith('@result') ||
                                item.detail === 'SQLite Keyword' ||
                                item.detail === 'SQLite Function' ||
                                item.detail.startsWith('Step ') ||
                                item.detail.startsWith('Virtual Table')
                            );

                            return {{
                                suggestions: virtualTableItems.map(item => ({{
                                    label: item.label,
                                    kind: item.kind,
                                    insertText: item.insertText,
                                    detail: item.detail,
                                    documentation: item.documentation
                                }}))
                            }};
                        }}
                    }});
                }})();
            ");

            // Register Ctrl+Space for trigger suggest
            await _editor.AddCommand((int)KeyMod.CtrlCmd | (int)KeyCode.Space, async (args) =>
            {
                await _editor.Trigger("editor", "editor.action.triggerSuggest", null);
            });
        }
        catch
        {
            // Silently ignore completion provider registration errors
        }
    }

    public async Task<string> GetValue()
    {
        if (_editor != null)
        {
            return await _editor.GetValue();
        }
        return Value;
    }

    public async Task SetValue(string value)
    {
        if (_editor != null)
        {
            await _editor.SetValue(value);
            _lastValue = value;
        }
    }

    public async Task Focus()
    {
        if (_editor != null)
        {
            try
            {
                await _editor.Focus();
            }
            catch
            {
                // Silently ignore focus errors
            }
        }
    }

    private async Task UpdateEditorTheme()
    {
        if (_editor == null) return;

        try
        {
            var theme = IsDarkMode ? "vs-dark" : "vs";
            await JSRuntime.InvokeVoidAsync("eval", $@"
                (function() {{
                    const editors = monaco.editor.getEditors();
                    const targetEditor = editors.find(e => {{
                        const domNode = e.getContainerDomNode();
                        return domNode && domNode.id === '{EditorId}';
                    }});
                    if (targetEditor) {{
                        monaco.editor.setTheme('{theme}');
                    }}
                }})();
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"FinalQueryEditor {EditorId}: Failed to update theme: {ex.Message}");
        }
    }
}
