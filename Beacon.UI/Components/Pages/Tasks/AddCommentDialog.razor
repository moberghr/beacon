@using Beacon.Core.Services

<MudDialog Class="pb-2">
    <TitleContent>
        <BeaconDialogHeader Variant="grid"
            Eyebrow="TASKS"
            Prefix="Add a"
            Emphasis="comment"
            Suffix="." />
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" Class="pt-1">
            <BeaconTextField @bind-Value="@CommentContent"
                             Label="Comment"
                             Multiline="true"
                             Rows="5"
                             MaxLength="4000"
                             Placeholder="Add your comment..."
                             Required="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton
            Class="ml-4"
            OnClick="@Cancel"
            Variant="Variant.Filled"
        >
            Cancel
        </MudButton>

        <MudButton
            Color="Color.Primary"
            Variant="Variant.Filled"
            OnClick="@Submit"
            Disabled="@(_loading || string.IsNullOrWhiteSpace(CommentContent))"
        >
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <span>Add Comment</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject ITaskService TaskService

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int TaskId { get; set; }

    private string? CommentContent { get; set; }
    private MudForm _form = null!;
    private bool _loading;

    async Task Submit()
    {
        if (_loading || string.IsNullOrWhiteSpace(CommentContent))
        {
            return;
        }

        _loading = true;

        try
        {
            await TaskService.AddTaskComment(TaskId, CommentContent!, null, null, CancellationToken.None);
            MudDialog.Close(DialogResult.Ok(true));
            Snackbar.Add("Comment added successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding comment: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    void Cancel() => MudDialog.Cancel();
}
