@using Beacon.Core.Data.Enums
@using Beacon.Core.Models.DataSources
@using Beacon.Core.Models.Providers.CloudWatch
@using Beacon.Core.Services
@using Beacon.Core.Services.Providers
@using System.Text.Json
<MudDialog Class="pb-2">
    <TitleContent>
        <BeaconDialogHeader Variant="nodes"
            Eyebrow="DATA SOURCES"
            Prefix="Add a data"
            Emphasis="source"
            Suffix="."
            Sub="Connect a database, cloud service, or API as a Beacon data source." />
    </TitleContent>
    <DialogContent>
        <div class="pt-1">
            <BeaconSelect T="DataSourceType"
                          Label="Data Source Type"
                          @bind-Value="_selectedDataSourceType"
                          Required="true"
                          Items="@DataSourceTypeOptions"
                          ItemValueSelector="@(x => ((DataSourceTypeOption)x).Value)"
                          ItemTextSelector="@(x => ((DataSourceTypeOption)x).Text)" />

            @if (_selectedDataSourceType == DataSourceType.Database)
            {
                <BeaconSelect T="DatabaseEngineType"
                              Label="Database Engine Type"
                              @bind-Value="@_selectedDatabaseEngine"
                              Required="true"
                              Items="@(_registeredEngines.Select(x => (object)new DatabaseEngineOption(x.Key, x.Value)))"
                              ItemValueSelector="@(x => ((DatabaseEngineOption)x).Value)"
                              ItemTextSelector="@(x => ((DatabaseEngineOption)x).Text)" />

                <BeaconTextField @bind-Value="@DataSource.ConnectionString"
                                 Label="Connection string"
                                 Required="true"
                                 InputType="password" />
            }
            else if (_selectedDataSourceType == DataSourceType.CloudWatch)
            {
                <BeaconTextField @bind-Value="@_cloudWatchRegion"
                                 Label="AWS Region"
                                 Required="true"
                                 HelpText="e.g., us-east-1, eu-west-1" />

                <BeaconTextField @bind-Value="@_cloudWatchAccessKeyId"
                                 Label="AWS Access Key ID (optional)"
                                 HelpText="Leave empty to use IAM role or AWS profile" />

                <BeaconTextField @bind-Value="@_cloudWatchSecretAccessKey"
                                 Label="AWS Secret Access Key (optional)"
                                 InputType="password" />

                <BeaconTextField @bind-Value="@_cloudWatchLogGroups"
                                 Label="Log Groups (comma-separated)"
                                 Required="true"
                                 HelpText="e.g., /aws/lambda/function1, /aws/lambda/function2"
                                 Multiline="true"
                                 Rows="2" />

                <BeaconTextField @bind-Value="@_cloudWatchProfileName"
                                 Label="AWS Profile Name (optional)"
                                 HelpText="Use profile from ~/.aws/credentials" />
            }
            else if (_selectedDataSourceType == DataSourceType.Databricks)
            {
                <BeaconTextField @bind-Value="@_databricksHost"
                                 Label="Host"
                                 Required="true"
                                 HelpText="e.g., adb-1234567890123456.7.azuredatabricks.net" />

                <BeaconTextField @bind-Value="@_databricksHttpPath"
                                 Label="HTTP Path"
                                 Required="true"
                                 HelpText="e.g., /sql/1.0/warehouses/abc123def456" />

                <BeaconTextField @bind-Value="@_databricksToken"
                                 Label="Personal Access Token"
                                 Required="true"
                                 InputType="password" />

                <BeaconTextField @bind-Value="@_databricksCatalog"
                                 Label="Catalog (optional)"
                                 HelpText="Unity Catalog name" />

                <BeaconTextField @bind-Value="@_databricksSchema"
                                 Label="Schema (optional)"
                                 HelpText="Default schema" />
            }
            else if (_selectedDataSourceType == DataSourceType.BigQuery)
            {
                <BeaconTextField @bind-Value="@_bigQueryProjectId"
                                 Label="Project ID"
                                 Required="true"
                                 HelpText="Google Cloud project ID" />

                <BeaconTextField @bind-Value="@_bigQueryDatasetId"
                                 Label="Dataset ID (optional)"
                                 HelpText="Default dataset for queries" />

                <BeaconTextField @bind-Value="@_bigQueryLocation"
                                 Label="Location (optional)"
                                 HelpText="e.g., US, EU, us-central1" />

                <BeaconTextField @bind-Value="@_bigQueryServiceAccountJson"
                                 Label="Service Account JSON Key"
                                 Required="true"
                                 Multiline="true"
                                 Rows="4"
                                 HelpText="Paste the full JSON key file content" />
            }
            else if (_selectedDataSourceType == DataSourceType.Api)
            {
                <BeaconTextField @bind-Value="@_apiBaseUrl"
                                 Label="Base URL"
                                 Required="true"
                                 HelpText="e.g., https://api.example.com" />

                <BeaconTextField @bind-Value="@_apiSpecUrl"
                                 Label="OpenAPI Spec URL"
                                 Required="true"
                                 HelpText="e.g., https://api.example.com/swagger/v1/swagger.json" />

                <BeaconSelect T="string"
                              Label="Authentication"
                              @bind-Value="_apiAuthType"
                              Items="@_apiAuthTypeOptions"
                              ItemValueSelector="@(x => ((StringOption)x).Value)"
                              ItemTextSelector="@(x => ((StringOption)x).Text)" />

                @if (_apiAuthType == "apiKey")
                {
                    <BeaconTextField @bind-Value="@_apiKeyName"
                                     Label="Header / Parameter Name"
                                     Required="true"
                                     HelpText="e.g., X-Api-Key" />
                    <BeaconTextField @bind-Value="@_apiKeyValue"
                                     Label="API Key Value"
                                     Required="true"
                                     InputType="password" />
                    <BeaconSelect T="string"
                                  Label="Key Location"
                                  @bind-Value="_apiKeyLocation"
                                  Items="@_apiKeyLocationOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />
                }
                else if (_apiAuthType == "bearer")
                {
                    <BeaconTextField @bind-Value="@_apiBearerToken"
                                     Label="Bearer Token"
                                     Required="true"
                                     InputType="password" />
                }
                else if (_apiAuthType == "basic")
                {
                    <BeaconTextField @bind-Value="@_apiBasicUsername"
                                     Label="Username"
                                     Required="true" />
                    <BeaconTextField @bind-Value="@_apiBasicPassword"
                                     Label="Password"
                                     Required="true"
                                     InputType="password" />
                }

                <MudExpansionPanels Class="mb-4" Elevation="0">
                    <MudExpansionPanel Text="Endpoint Filter (optional)" IsInitiallyExpanded="false">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <BeaconTextField @bind-Value="_apiIncludePatterns"
                                                 Label="Include Path Patterns"
                                                 HelpText="Comma-separated (e.g., /api/v2/**)" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <BeaconTextField @bind-Value="_apiExcludePatterns"
                                                 Label="Exclude Path Patterns"
                                                 HelpText="Comma-separated (e.g., /api/internal/**)" />
                            </MudItem>
                        </MudGrid>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }

            @if (_selectedDataSourceType == DataSourceType.Database)
            {
                <MudExpansionPanels Class="mb-4" Elevation="0">
                    <MudExpansionPanel Text="Metadata Loading Options" IsInitiallyExpanded="false">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <BeaconSwitch @bind-Value="DataSource.MetadataLoadingEnabled"
                                              Label="Enable Metadata Loading" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <BeaconNumericField T="int"
                                                    @bind-Value="DataSource.MetadataMaxTables"
                                                    Label="Max Tables"
                                                    HelpText="0 = unlimited"
                                                    Min="0" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <BeaconNumericField T="int"
                                                    @bind-Value="DataSource.MetadataMaxColumnsPerTable"
                                                    Label="Max Columns Per Table"
                                                    HelpText="0 = unlimited"
                                                    Min="0" />
                            </MudItem>
                            <MudItem xs="12">
                                <BeaconSwitch @bind-Value="DataSource.MetadataLoadTableNamesOnly"
                                              Label="Load Table Names Only" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <BeaconTextField @bind-Value="_metadataExcludeSchemas"
                                                 Label="Exclude Schemas"
                                                 HelpText="Comma-separated (e.g., information_schema, pg_catalog)" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <BeaconTextField @bind-Value="_metadataIncludeSchemas"
                                                 Label="Include Schemas"
                                                 HelpText="Comma-separated. If set, only these schemas are loaded." />
                            </MudItem>
                        </MudGrid>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }

            <div class="d-flex align-center mb-4">
                <MudButton
                    Variant="Variant.Outlined"
                    Color="Color.Primary"
                    OnClick="TestConnection"
                    Disabled="@(_testingConnection || !CanTestConnection())"
                    StartIcon="@(_testingConnection ? null : Icons.Material.Filled.Cable)"
                    Class="mr-2">
                    @if (_testingConnection)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true"/>
                    }
                    <span>@(_testingConnection ? "Testing..." : "Test Connection")</span>
                </MudButton>

                @if (_connectionTested)
                {
                    <MudChip T="string"
                             Color="@(_connectionSuccess ? Color.Success : Color.Error)"
                             Icon="@(_connectionSuccess ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)"
                             Size="Size.Small">
                        @(_connectionSuccess ? "Connected" : "Failed")
                    </MudChip>
                }
            </div>

            @if (_connectionTested && !_connectionSuccess && !string.IsNullOrWhiteSpace(_connectionErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_connectionErrorMessage</MudAlert>
            }

            <BeaconTextField @bind-Value="@DataSource.Name"
                             Label="Name"
                             Required="true" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton
            Class="ml-4"
            OnClick="@Cancel"
            Variant="Variant.Filled"
        >
            Cancel
        </MudButton>

        <DialogSaveButton Disabled="@(!CanSubmit)" OnClick="@Submit"/>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IDataSourceService Service

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DataSourceData DataSource { get; set; }

    private bool _loading;
    private bool _testingConnection;
    private bool _connectionTested;
    private bool _connectionSuccess;
    private string _connectionErrorMessage = string.Empty;

    // Registered connectors (populated from ConnectorRegistry)
    private IReadOnlyDictionary<DatabaseEngineType, string> _registeredEngines = ConnectorRegistry.GetRegisteredDatabaseEngines();
    private IReadOnlyDictionary<DataSourceType, string> _registeredDataSourceTypes = ConnectorRegistry.GetRegisteredDataSourceTypes();

    // Data source type selection
    private DataSourceType _selectedDataSourceType = DataSourceType.Database;
    private DatabaseEngineType _selectedDatabaseEngine = ConnectorRegistry.GetRegisteredDatabaseEngines().Keys.FirstOrDefault();

    // CloudWatch fields
    private string? _cloudWatchRegion = "";
    private string? _cloudWatchAccessKeyId = "";
    private string? _cloudWatchSecretAccessKey = "";
    private string? _cloudWatchLogGroups = "";
    private string? _cloudWatchProfileName = "";

    // Databricks fields
    private string? _databricksHost = "";
    private string? _databricksHttpPath = "";
    private string? _databricksToken = "";
    private string? _databricksCatalog = "";
    private string? _databricksSchema = "";

    // BigQuery fields
    private string? _bigQueryProjectId = "";
    private string? _bigQueryDatasetId = "";
    private string? _bigQueryLocation = "";
    private string? _bigQueryServiceAccountJson = "";

    // API fields
    private string? _apiBaseUrl = "";
    private string? _apiSpecUrl = "";
    private string _apiAuthType = "none";
    private string? _apiKeyName = "";
    private string? _apiKeyValue = "";
    private string _apiKeyLocation = "header";
    private string? _apiBearerToken = "";
    private string? _apiBasicUsername = "";
    private string? _apiBasicPassword = "";
    private string? _apiIncludePatterns = "";
    private string? _apiExcludePatterns = "";

    // Metadata loading fields
    private string? _metadataExcludeSchemas = "";
    private string? _metadataIncludeSchemas = "";

    private record DataSourceTypeOption(DataSourceType Value, string Text);
    private record DatabaseEngineOption(DatabaseEngineType Value, string Text);
    private record StringOption(string Value, string Text);

    private List<object> DataSourceTypeOptions => BuildDataSourceTypeOptions();

    private List<object> BuildDataSourceTypeOptions()
    {
        var list = new List<object>();
        if (_registeredEngines.Any())
        {
            list.Add(new DataSourceTypeOption(DataSourceType.Database, $"Database ({string.Join(", ", _registeredEngines.Values)})"));
        }
        foreach (var dsType in _registeredDataSourceTypes)
        {
            list.Add(new DataSourceTypeOption(dsType.Key, dsType.Value));
        }
        return list;
    }

    private static readonly List<object> _apiAuthTypeOptions = new()
    {
        new StringOption("none", "None"),
        new StringOption("apiKey", "API Key"),
        new StringOption("bearer", "Bearer Token"),
        new StringOption("basic", "Basic Auth"),
    };

    private static readonly List<object> _apiKeyLocationOptions = new()
    {
        new StringOption("header", "Header"),
        new StringOption("query", "Query Parameter"),
    };

    private bool CanSubmit => !_loading
        && !string.IsNullOrWhiteSpace(DataSource?.Name)
        && CanTestConnection();

    bool CanTestConnection()
    {
        return _selectedDataSourceType switch
        {
            DataSourceType.Database => !string.IsNullOrWhiteSpace(DataSource.ConnectionString),
            DataSourceType.CloudWatch => !string.IsNullOrWhiteSpace(_cloudWatchRegion) && !string.IsNullOrWhiteSpace(_cloudWatchLogGroups),
            DataSourceType.Databricks => !string.IsNullOrWhiteSpace(_databricksHost) && !string.IsNullOrWhiteSpace(_databricksHttpPath) && !string.IsNullOrWhiteSpace(_databricksToken),
            DataSourceType.BigQuery => !string.IsNullOrWhiteSpace(_bigQueryProjectId) && !string.IsNullOrWhiteSpace(_bigQueryServiceAccountJson),
            DataSourceType.Api => !string.IsNullOrWhiteSpace(_apiBaseUrl) && !string.IsNullOrWhiteSpace(_apiSpecUrl),
            _ => false
        };
    }

    async Task TestConnection()
    {
        if (_testingConnection || !CanTestConnection())
        {
            return;
        }

        _testingConnection = true;
        _connectionTested = false;
        _connectionErrorMessage = string.Empty;

        try
        {
            // Build a temporary DataSourceData with the current form values for testing
            var testData = BuildDataSourceData();
            var response = await Service.TestConnectionAsync(testData, CancellationToken.None);

            _connectionTested = true;
            _connectionSuccess = response.Success;

            if (response.Success)
            {
                Snackbar.Add(response.Message, Severity.Success);
            }
            else
            {
                _connectionErrorMessage = response.Message;
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _connectionTested = true;
            _connectionSuccess = false;
            _connectionErrorMessage = ex.Message;
            Snackbar.Add($"Test failed: {ex.Message}", Severity.Error);
        }

        _testingConnection = false;
    }

    private DataSourceData BuildDataSourceData()
    {
        var data = new DataSourceData
        {
            DataSourceType = _selectedDataSourceType,
            Name = DataSource.Name ?? "test"
        };

        switch (_selectedDataSourceType)
        {
            case DataSourceType.Database:
                data.DatabaseEngineType = _selectedDatabaseEngine;
                data.ConnectionString = DataSource.ConnectionString;
                break;

            case DataSourceType.CloudWatch:
                data.ConnectionString = JsonSerializer.Serialize(new CloudWatchConfiguration
                {
                    Region = _cloudWatchRegion,
                    AccessKeyId = NullIfEmpty(_cloudWatchAccessKeyId),
                    SecretAccessKey = NullIfEmpty(_cloudWatchSecretAccessKey),
                    LogGroups = (_cloudWatchLogGroups ?? "").Split(',').Select(lg => lg.Trim()).Where(lg => !string.IsNullOrEmpty(lg)).ToList(),
                    ProfileName = NullIfEmpty(_cloudWatchProfileName),
                    QueryTimeoutSeconds = 300
                });
                break;

            case DataSourceType.Databricks:
                // Config class is in Beacon.Connector.Databricks (not referenced by UI)
                data.ConnectionString = JsonSerializer.Serialize(new
                {
                    Host = _databricksHost,
                    HttpPath = _databricksHttpPath,
                    Token = _databricksToken,
                    Catalog = NullIfEmpty(_databricksCatalog),
                    Schema = NullIfEmpty(_databricksSchema),
                    QueryTimeoutSeconds = 300
                });
                break;

            case DataSourceType.BigQuery:
                // Config class is in Beacon.Connector.BigQuery (not referenced by UI)
                data.ConnectionString = JsonSerializer.Serialize(new
                {
                    ProjectId = _bigQueryProjectId,
                    DatasetId = NullIfEmpty(_bigQueryDatasetId),
                    Location = NullIfEmpty(_bigQueryLocation),
                    ServiceAccountJson = _bigQueryServiceAccountJson,
                    QueryTimeoutSeconds = 300
                });
                break;

            case DataSourceType.Api:
                var auth = _apiAuthType switch
                {
                    "apiKey" => new { Type = "ApiKey", ApiKeyName = _apiKeyName, ApiKeyValue = _apiKeyValue, ApiKeyLocation = _apiKeyLocation, Token = (string?)null, Username = (string?)null, Password = (string?)null },
                    "bearer" => new { Type = "Bearer", ApiKeyName = (string?)null, ApiKeyValue = (string?)null, ApiKeyLocation = (string?)null, Token = _apiBearerToken, Username = (string?)null, Password = (string?)null },
                    "basic" => new { Type = "Basic", ApiKeyName = (string?)null, ApiKeyValue = (string?)null, ApiKeyLocation = (string?)null, Token = (string?)null, Username = _apiBasicUsername, Password = _apiBasicPassword },
                    _ => (object?)null
                };
                var includePatterns = ParseSchemaList(_apiIncludePatterns);
                var excludePatterns = ParseSchemaList(_apiExcludePatterns);
                data.ConnectionString = JsonSerializer.Serialize(new
                {
                    BaseUrl = _apiBaseUrl,
                    OpenApiSpecUrl = _apiSpecUrl,
                    Auth = auth,
                    EndpointFilter = (includePatterns.Count > 0 || excludePatterns.Count > 0)
                        ? new { IncludePathPatterns = includePatterns, ExcludePathPatterns = excludePatterns }
                        : null,
                    TimeoutSeconds = 30
                });
                break;
        }

        return data;
    }

    async Task Submit()
    {
        if (_loading || !CanSubmit)
        {
            return;
        }

        // Prepare data source based on type (reuse BuildDataSourceData for connection string serialization)
        var built = BuildDataSourceData();
        DataSource.DataSourceType = built.DataSourceType;
        DataSource.ConnectionString = built.ConnectionString ?? DataSource.ConnectionString;
        DataSource.DatabaseEngineType = built.DatabaseEngineType;

        if (_selectedDataSourceType == DataSourceType.Database)
        {
            DataSource.MetadataExcludeSchemas = ParseSchemaList(_metadataExcludeSchemas);
            DataSource.MetadataIncludeSchemas = ParseSchemaList(_metadataIncludeSchemas);
        }

        _loading = true;

        try
        {
            var response = await Service.CreateDataSource(DataSource, CancellationToken.None);

            if (response.Success)
            {
                MudDialog.Close(DialogResult.Ok(true));
                Snackbar.Add(response.Message, Severity.Success);
            }
            else
            {
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }

        _loading = false;
    }

    void Cancel() => MudDialog.Cancel();

    static string? NullIfEmpty(string? value) => string.IsNullOrWhiteSpace(value) ? null : value;

    static List<string> ParseSchemaList(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return new();
        return text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }
}
