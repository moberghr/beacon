@page "/"
@page "/dashboard"
@using Beacon.Core.Models.QueryExecutionHistory
@using Beacon.Core.Data.Enums
@using Beacon.UI.Helpers
@inherits BasePageComponent
@inject Beacon.Core.Services.INotificationService notificationService
@inject Beacon.Core.Services.IStatisticsService statisticsService

<BeaconPageTitle Title="Mission Control" />

<div class="@RootClass">
    <BeaconDashboardHero UserName="mirko"
                        HeadlinePrefix="Everything is"
                        HeadlineEmphasis="@HeadlineEmphasis">
        <Sub>
            <span>@FormatNumber(dashboardStatistics?.TotalQueriesExecuted ?? 0) queries executed in the last 30 days · </span>
            <span class="mono">@(dashboardStatistics?.AnomaliesLast24Hours ?? 0) anomal@((dashboardStatistics?.AnomaliesLast24Hours ?? 0) == 1 ? "y" : "ies") </span>
            <span>require attention.</span>
        </Sub>
        <Actions>
            <a href="data-migration" class="btn btn--ghost">
                <MudIcon Icon="@Icons.Material.Rounded.Download" Size="Size.Small" /> Export
            </a>
            <button class="btn" type="button" @onclick="RefreshDashboard">
                <MudIcon Icon="@Icons.Material.Rounded.Refresh" Size="Size.Small" /> Refresh
            </button>
            <a href="queries/add" class="btn btn--primary">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Size="Size.Small" /> New query
            </a>
        </Actions>
    </BeaconDashboardHero>

    <!-- Filter / range bar -->
    <div class="filter-bar">
        <div class="seg" role="tablist">
            @foreach (var r in new[] { "1H", "24H", "7D", "30D", "90D" })
            {
                var active = r == _selectedRange;
                <button class="seg__btn @(active ? "active" : "")" type="button" @onclick="() => _selectedRange = r">@r</button>
            }
        </div>
        <div class="divider-v"></div>
        <a class="chip" href="beacon/projects">
            <MudIcon Icon="@Icons.Material.Rounded.FilterList" Size="Size.Small" Style="font-size: 12px;" />
            All projects
        </a>
        <a class="chip chip--applied" href="data-sources">
            <MudIcon Icon="@Icons.Material.Rounded.Storage" Size="Size.Small" Style="font-size: 12px;" />
            @(dashboardStatistics?.TotalDataSources ?? 0) sources
        </a>
        <a class="chip" href="recipients">
            <MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Small" Style="font-size: 12px;" />
            All users
        </a>
        <div class="spacer"></div>
        <span class="mono subtle" style="font-size: 11.5px; padding-right: 6px;">@RangeLabel · UTC</span>
        <button class="icon-btn" title="Calendar" type="button">
            <MudIcon Icon="@Icons.Material.Rounded.CalendarToday" Size="Size.Small" />
        </button>
    </div>

    <!-- KPI grid -->
    <div class="kpi-grid">
        <KpiCard Dot="brand" Label="Active subscriptions"
                 Value="@((dashboardStatistics?.ActiveSubscriptions ?? 0).ToString())"
                 SubText="@($"of {dashboardStatistics?.TotalSubscriptions ?? 0} configured")"
                 SparkPoints="@_sparkA" SparkColor="var(--bx-brand-500)" />
        <KpiCard Dot="info" Label="Query executions"
                 Value="@FormatNumber(dashboardStatistics?.TotalQueriesExecuted ?? 0)"
                 SubText="@($"{dashboardStatistics?.TotalQueries ?? 0} queries configured")"
                 SparkPoints="@_sparkB" SparkColor="oklch(60% 0.13 240)" />
        <KpiCard Dot="warn" Label="Notifications sent"
                 Value="@FormatNumber(dashboardStatistics?.TotalNotificationsSent ?? 0)"
                 SubText="@($"{dashboardStatistics?.TotalRecipients ?? 0} recipients")"
                 SparkPoints="@_sparkC" SparkColor="oklch(70% 0.15 70)" />
        <KpiCard Dot="crit" Label="Anomalies detected"
                 Value="@((dashboardStatistics?.AnomaliesLast24Hours ?? 0).ToString())"
                 SparkPoints="@_sparkD" SparkColor="oklch(60% 0.19 25)">
            <Sub>
                @if ((dashboardStatistics?.AnomaliesLast24Hours ?? 0) > 0)
                {
                    <span class="pill pill--crit" style="margin-right: 6px;">@(dashboardStatistics?.AnomaliesLast24Hours ?? 0) open</span>
                }
                <span>@(dashboardStatistics?.TotalAnomaliesDetected ?? 0) total</span>
            </Sub>
        </KpiCard>
    </div>

    <!-- Performance KPIs -->
    <div class="row row--3-up">
        <KpiCard Dot="ok" Label="Avg execution"
                 Value="@FormatExecutionTime(dashboardStatistics?.AvgExecutionTimeMs ?? 0)"
                 SubText="across all queries" />
        <KpiCard Dot="ok" Label="Fastest query"
                 Value="@FormatExecutionTime(dashboardStatistics?.MinExecutionTimeMs ?? 0)"
                 SubText="best recorded" />
        <KpiCard Dot="@SlowestDot" Label="Slowest query"
                 Value="@FormatExecutionTime(dashboardStatistics?.MaxExecutionTimeMs ?? 0)"
                 SubText="needs review" />
    </div>

    <!-- Activity trends + system overview -->
    <div class="row row--7-3">
        <div class="card">
            <div class="card__head">
                <MudIcon Icon="@Icons.Material.Rounded.ShowChart" Size="Size.Small" Class="muted" />
                <h3 class="card__title">Activity trends</h3>
                <span class="card__sub">last 30 days</span>
                <div class="card__actions">
                    <div class="legend">
                        <span class="legend__item">
                            <span class="legend__sw" style="background: var(--bx-brand-500);"></span>Queries executed
                        </span>
                        <span class="legend__item">
                            <span class="legend__sw" style="background: oklch(70% 0.15 70);"></span>Notifications sent
                        </span>
                    </div>
                </div>
            </div>
            <div class="chart-wrap">
                @if (chartSeries.Any())
                {
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@chartSeries"
                              ChartLabels="@xAxisLabels"
                              Width="100%"
                              Height="320px"
                              ChartOptions="@chartOptions" />
                }
                else
                {
                    <div style="height: 320px; display: grid; place-items: center;" class="muted">
                        No activity yet — run a query to see it appear here.
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card__head">
                <MudIcon Icon="@Icons.Material.Rounded.Layers" Size="Size.Small" Class="muted" />
                <h3 class="card__title">System overview</h3>
                <div class="card__actions">
                    <span class="pill pill--ok">
                        <span style="width: 6px; height: 6px; border-radius: 99px; background: var(--bx-ok);"></span>
                        Healthy
                    </span>
                </div>
            </div>
            <div class="stat-list">
                <StatRow Icon="@Icons.Material.Rounded.Storage"
                         Label="Data sources"
                         Value="@((dashboardStatistics?.TotalDataSources ?? 0).ToString())"
                         Href="data-sources">
                    <Trail>
                        <span class="pill pill--ok">@((dashboardStatistics?.TotalDataSources ?? 0)) online</span>
                    </Trail>
                </StatRow>
                <StatRow Icon="@Icons.Material.Rounded.People"
                         Label="Recipients"
                         Value="@((dashboardStatistics?.TotalRecipients ?? 0).ToString())"
                         Href="recipients">
                    <Trail>
                        <span class="mono subtle">teams &amp; users</span>
                    </Trail>
                </StatRow>
                <StatRow Icon="@Icons.Material.Rounded.Task"
                         Label="Unresolved tasks"
                         Value="@((dashboardStatistics?.UnresolvedTasks ?? 0).ToString())"
                         Href="tasks">
                    <Trail>
                        @if ((dashboardStatistics?.UnresolvedTasks ?? 0) > 0)
                        {
                            <span class="pill pill--warn">action needed</span>
                        }
                        else
                        {
                            <span class="pill pill--ok">all clear</span>
                        }
                    </Trail>
                </StatRow>
                <StatRow Icon="@Icons.Material.Rounded.Notifications"
                         Label="Active anomaly detection"
                         Value="@((dashboardStatistics?.ActiveAnomalyConfigs ?? 0).ToString())"
                         Href="data-quality">
                    <Trail>
                        @if ((dashboardStatistics?.AnomaliesLast24Hours ?? 0) > 0)
                        {
                            <span class="pill pill--crit">action req.</span>
                        }
                        else
                        {
                            <span class="pill pill--ok">monitoring</span>
                        }
                    </Trail>
                </StatRow>
                <StatRow Icon="@Icons.Material.Rounded.Hub"
                         Label="Subscriptions"
                         Value="@((dashboardStatistics?.ActiveSubscriptions ?? 0).ToString())"
                         Href="subscriptions">
                    <Trail>
                        <span class="mono subtle">of @(dashboardStatistics?.TotalSubscriptions ?? 0)</span>
                    </Trail>
                </StatRow>
            </div>
        </div>
    </div>

    <!-- Query exec performance -->
    <div class="card">
        <div class="card__head">
            <MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="Size.Small" Class="muted" />
            <h3 class="card__title">Query execution performance</h3>
            <span class="card__sub">last 30 days · all sources</span>
            <div class="card__actions">
                <div class="seg">
                    @foreach (var p in new[] { "avg", "p50", "p95", "p99" })
                    {
                        var active = p == _perfMetric;
                        <button class="seg__btn @(active ? "active" : "")" type="button" @onclick="() => _perfMetric = p">@p</button>
                    }
                </div>
            </div>
        </div>
        <div class="chart-wrap">
            @if (executionTimeChartSeries.Any())
            {
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@executionTimeChartSeries"
                          ChartLabels="@executionTimeXAxisLabels"
                          Width="@ChartHelper.DefaultChartWidth"
                          Height="280px"
                          ChartOptions="@executionTimeChartOptions" />
            }
            else
            {
                <div style="height: 280px; display: grid; place-items: center;" class="muted">
                    No executions yet.
                </div>
            }
        </div>
        <div style="display: flex; gap: 16px; padding: 0 16px 14px; align-items: center; flex-wrap: wrap;">
            <span class="legend__item legend">
                <span class="legend__sw" style="background: var(--bx-brand-500);"></span>typical
            </span>
            <span class="legend__item legend">
                <span class="legend__sw" style="background: var(--bx-warn);"></span>p95 spike
            </span>
            <span class="legend__item legend">
                <span class="legend__sw" style="background: var(--bx-crit);"></span>p99 spike
            </span>
            <div class="spacer"></div>
            <span class="mono subtle" style="font-size: 12px;">
                @if ((dashboardStatistics?.MaxExecutionTimeMs ?? 0) > 1000)
                {
                    <span>review: <a href="query-execution-history/0" style="color: var(--bx-brand-600);">slowest →</a></span>
                }
            </span>
        </div>
    </div>

    <!-- Bottom: migration + tasks + activity -->
    <div class="row row--7-3">
        <div class="row" style="grid-template-rows: auto auto; gap: 16px;">
            <div class="card">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.SwapHoriz" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Data migration</h3>
                    <span class="card__sub">overview</span>
                    <div class="card__actions">
                        <a href="data-migration" style="font-size: 12.5px; color: var(--bx-brand-600); text-decoration: none; font-weight: 500;">Open jobs →</a>
                    </div>
                </div>
                <div class="card__body card__body--flush">
                    <div class="mini-grid">
                        <MiniMetric Label="Total jobs"
                                    Value="@((dashboardStatistics?.TotalMigrationJobs ?? 0).ToString())"
                                    Bar="100%"
                                    DotColor="var(--bx-info)" BarColor="var(--bx-info)" />
                        <MiniMetric Label="Enabled"
                                    Value="@((dashboardStatistics?.EnabledMigrationJobs ?? 0).ToString())"
                                    Bar="@PercentBar(dashboardStatistics?.EnabledMigrationJobs ?? 0, dashboardStatistics?.TotalMigrationJobs ?? 1)"
                                    DotColor="var(--bx-ok)" BarColor="var(--bx-ok)" />
                        <MiniMetric Label="Executions"
                                    Value="@FormatNumber(dashboardStatistics?.TotalMigrationExecutions ?? 0)"
                                    Bar="62%"
                                    DotColor="var(--bx-brand-500)" BarColor="var(--bx-brand-500)" />
                        <MiniMetric Label="Successful"
                                    Value="@FormatNumber(dashboardStatistics?.SuccessfulMigrationExecutions ?? 0)"
                                    Bar="@PercentBar(dashboardStatistics?.SuccessfulMigrationExecutions ?? 0, dashboardStatistics?.TotalMigrationExecutions ?? 1)"
                                    DotColor="var(--bx-ok)" BarColor="var(--bx-ok)" />
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.Check" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Task management</h3>
                    <span class="card__sub">@(dashboardStatistics?.UnresolvedTasks ?? 0) unresolved</span>
                    <div class="card__actions">
                        <a href="tasks" style="font-size: 12.5px; color: var(--bx-brand-600); text-decoration: none; font-weight: 500;">Open →</a>
                    </div>
                </div>
                <div class="card__body card__body--flush">
                    <div class="mini-grid mini-grid--3">
                        <MiniMetric Label="Total"
                                    Value="@((dashboardStatistics?.TotalTasks ?? 0).ToString())"
                                    Bar="100%"
                                    DotColor="var(--bx-text-muted)" BarColor="var(--bx-text-muted)" />
                        <MiniMetric Label="Open"
                                    Value="@((dashboardStatistics?.UnresolvedTasks ?? 0).ToString())"
                                    Bar="@PercentBar(dashboardStatistics?.UnresolvedTasks ?? 0, dashboardStatistics?.TotalTasks ?? 1)"
                                    DotColor="var(--bx-warn)" BarColor="var(--bx-warn)" />
                        <MiniMetric Label="Resolved"
                                    Value="@((dashboardStatistics?.ResolvedTasks ?? 0).ToString())"
                                    Bar="@PercentBar(dashboardStatistics?.ResolvedTasks ?? 0, dashboardStatistics?.TotalTasks ?? 1)"
                                    DotColor="var(--bx-ok)" BarColor="var(--bx-ok)" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card__head">
                <MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="Size.Small" Class="muted" />
                <h3 class="card__title">Recent activity</h3>
                <div class="card__actions">
                    <a href="notifications" style="font-size: 12.5px; color: var(--bx-brand-600); text-decoration: none; font-weight: 500;">View all →</a>
                </div>
            </div>
            <div class="feed">
                @if (dashboardStatistics?.RecentActivities?.Any() == true)
                {
                    @foreach (var activity in dashboardStatistics.RecentActivities.Take(6))
                    {
                        <FeedItem Tone="@ToneFor(activity)"
                                  Icon="@IconFor(activity)"
                                  Meta="@($"{activity.Type}{(string.IsNullOrEmpty(activity.Status) ? "" : $" · {activity.Status.ToLowerInvariant()}")}")"
                                  Time="@RelativeTime(activity.Timestamp)">
                            <Title>
                                @if (!string.IsNullOrEmpty(activity.Link))
                                {
                                    <a href="@activity.Link" style="color: inherit; text-decoration: none;">
                                        @activity.Description
                                    </a>
                                }
                                else
                                {
                                    @activity.Description
                                }
                            </Title>
                        </FeedItem>
                    }
                }
                else
                {
                    <div style="padding: 24px; text-align: center;" class="muted">
                        Quiet for now — recent runs and anomalies will show up here.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Footer info -->
    <div class="row-spread" style="padding-top: 4px;">
        <span class="mono subtle" style="font-size: 11.5px;">
            Beacon · region @_region · build @_build
        </span>
        <span class="mono subtle" style="font-size: 11.5px;">
            Press <span class="kbd">⌘</span> <span class="kbd">K</span> to search ·
            <span class="kbd">G</span> then <span class="kbd">H</span> for home
        </span>
    </div>
</div>

@code {

    private DashboardStatisticsData? dashboardStatistics;
    private List<ChartSeries<double>> chartSeries = new();
    private string[] xAxisLabels = Array.Empty<string>();
    private LineChartOptions chartOptions = new();

    private List<ChartSeries<double>> executionTimeChartSeries = new();
    private string[] executionTimeXAxisLabels = Array.Empty<string>();
    private LineChartOptions executionTimeChartOptions = new();

    private string _selectedRange = "30D";
    private string _perfMetric = "avg";
    private string _region = "eu-west";
    private string _build = $"{DateTime.UtcNow:yyyy.MM.dd}-r1";

    // Sample sparkline shapes — visual cue, not real micro-trends
    private readonly double[] _sparkA = { 3, 5, 4, 7, 6, 9, 8, 11, 10, 14, 13, 16, 15, 18 };
    private readonly double[] _sparkB = { 12, 11, 14, 13, 16, 18, 17, 20, 19, 22, 24, 23, 26, 28 };
    private readonly double[] _sparkC = { 2, 4, 3, 5, 8, 6, 9, 12, 10, 14, 11, 8, 6, 5 };
    private readonly double[] _sparkD = { 0, 0, 1, 0, 2, 1, 3, 2, 4, 3, 5, 4, 7, 5 };

    private string HeadlineEmphasis => (dashboardStatistics?.AnomaliesLast24Hours ?? 0) > 0 ? "watching" : "nominal";
    private string SlowestDot => (dashboardStatistics?.MaxExecutionTimeMs ?? 0) > 1000 ? "warn" : "ok";

    private string RangeLabel
    {
        get
        {
            var now = DateTime.UtcNow;
            return _selectedRange switch
            {
                "1H" => $"{now.AddHours(-1):MMM d HH:mm} → {now:HH:mm}",
                "24H" => $"{now.AddHours(-24):MMM d} → {now:MMM d}",
                "7D" => $"{now.AddDays(-7):MMM d} → {now:MMM d}",
                "90D" => $"{now.AddDays(-90):MMM d} → {now:MMM d}",
                _ => $"{now.AddDays(-30):MMM d} → {now:MMM d}"
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        var notificationStatisticsData = await notificationService.GetNotificationStatistics(CancellationToken.None);
        dashboardStatistics = await statisticsService.GetDashboardStatistics(CancellationToken.None);

        PrepareChartData(notificationStatisticsData);
        ConfigureChartOptions();
        PrepareExecutionTimeChart();
    }

    private async Task RefreshDashboard()
    {
        await LoadDashboardData();
        StateHasChanged();
    }

    private void PrepareChartData(NotificationStatisticsData? notificationStatisticsData)
    {
        if (notificationStatisticsData?.NotificationDateStatistics == null)
            return;

        var data = notificationStatisticsData.NotificationDateStatistics.OrderBy(x => x.Date).ToList();

        xAxisLabels = data.Select(x => x.Date.ToShortDateWithoutYear()).ToArray();

        chartSeries = new List<ChartSeries<double>>
        {
            new() { Name = "Queries executed", Data = data.Select(x => (double)x.TotalQueries).ToArray() },
            new() { Name = "Notifications sent", Data = data.Select(x => (double)x.NotificationsSent).ToArray() }
        };
    }

    private void ConfigureChartOptions()
    {
        chartOptions.YAxisTicks = 6;
        chartOptions.ChartPalette = new[] { "#0a8a87", "#c08a3e" };
        chartOptions.YAxisLines = true;
        chartOptions.XAxisLines = false;
        chartOptions.InterpolationOption = InterpolationOption.NaturalSpline;
        chartOptions.XAxisLabelRotation = 45;
        chartOptions.LineStrokeWidth = 2;
    }

    private void PrepareExecutionTimeChart()
    {
        if (dashboardStatistics?.ExecutionTimeHistory == null || !dashboardStatistics.ExecutionTimeHistory.Any())
            return;

        var chart = ChartHelper.BuildExecutionTimeChart(dashboardStatistics.ExecutionTimeHistory);
        executionTimeChartSeries = chart.Series;
        executionTimeXAxisLabels = chart.Labels;
        executionTimeChartOptions = chart.Options;
        executionTimeChartOptions.ChartPalette = new[] { "#0a8a87", "#c08a3e", "#c44545" };
        executionTimeChartOptions.LineStrokeWidth = 2;
        executionTimeChartOptions.InterpolationOption = InterpolationOption.NaturalSpline;
    }

    private string FormatNumber(int number)
    {
        if (number >= 1_000_000) return $"{number / 1_000_000.0:0.#}M";
        if (number >= 1_000) return $"{number / 1_000.0:0.#}K";
        return number.ToString("N0");
    }

    private string FormatExecutionTime(double milliseconds) => UiHelpers.FormatExecutionTime(milliseconds);

    private string PercentBar(int part, int total)
    {
        if (total <= 0) return "0%";
        var pct = Math.Min(100, (int)Math.Round(100.0 * part / total));
        return pct + "%";
    }

    private string ToneFor(RecentActivityItem activity) => activity.Type switch
    {
        "Anomaly Detected" => "crit",
        "Task Created" => "warn",
        "Migration" => "info",
        "Query Execution" => "ok",
        _ => "brand"
    };

    private string IconFor(RecentActivityItem activity) => activity.Icon switch
    {
        "Search" => Icons.Material.Rounded.Search,
        "Warning" => Icons.Material.Rounded.PriorityHigh,
        "Task" => Icons.Material.Rounded.Task,
        "Migration" => Icons.Material.Rounded.SwapHoriz,
        _ => activity.Type switch
        {
            "Anomaly Detected" => Icons.Material.Rounded.PriorityHigh,
            "Query Execution" => Icons.Material.Rounded.Check,
            "Task Created" => Icons.Material.Rounded.Task,
            _ => Icons.Material.Rounded.Bolt
        }
    };

    private string RelativeTime(DateTime ts)
    {
        var diff = DateTime.UtcNow - ts.ToUniversalTime();
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d";
        return ts.ToString("MMM d");
    }
}
