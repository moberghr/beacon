@page "/approvals"
@inherits BasePageComponent
@using MediatR
@using Beacon.Core.Data.Enums
@using Beacon.Core.Models.Queries
@using Beacon.Core.Handlers.Approvals
@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<BeaconPageTitle Title="Approvals"/>

<MudContainer Class="my-4 px-4" MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h3" Style="font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.Approval" Class="mr-2" />
                Pending Approvals
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Review and approve or reject pending query changes
            </MudText>
        </MudStack>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_approvals == null || !_approvals.Any())
    {
        <MudAlert Severity="Severity.Info">No pending approvals.</MudAlert>
    }
    else
    {
        <MudDataGrid T="ApprovalRequestSummary" Items="@_approvals" Dense="true" Hover="true" Bordered="true">
            <Columns>
                <PropertyColumn Property="x => x.QueryName" Title="Query" />
                <PropertyColumn Property="x => x.RequestedByUserName" Title="Submitted By" />
                <PropertyColumn Property="x => x.CreatedTime" Title="Submitted At" Format="g" />
                <PropertyColumn Property="x => x.ChangeSummary" Title="Change Summary" />
                <TemplateColumn Title="Actions">
                    <CellTemplate>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.RateReview"
                                   OnClick="@(() => ReviewApproval(context.Item))">
                            Review
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }
</MudContainer>

@code
{
    private List<ApprovalRequestSummary>? _approvals;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        _approvals = await Mediator.Send(new GetPendingApprovalsQuery());
        _loading = false;
    }

    private async Task ReviewApproval(ApprovalRequestSummary approval)
    {
        var parameters = new DialogParameters<ReviewApprovalDialog>
        {
            { x => x.ApprovalId, approval.Id }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ReviewApprovalDialog>("Review Approval", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await Load();
        }
    }
}
