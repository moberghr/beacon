@page "/data-migration/create"
@page "/data-migration/edit/{JobId:int}"
@inherits BasePageComponent
@using Beacon.Core.Models.DataMigration
@using Beacon.Core.Models.DataSources
@using Beacon.Core.Models.Queries
@using Beacon.Core.Services
@using Beacon.Core.Data.Enums
@using Beacon.UI.Components.Custom
@using QueryParameterValue = Beacon.Core.Models.Queries.ParameterValue

<BeaconPageTitle Title="@(IsEdit ? "Edit Migration Job" : "Create Migration Job")"/>

<MudContainer Class="my-4 px-4"  MaxWidth="MaxWidth.ExtraExtraLarge">
    <BeaconPageHeader Icon="@Icons.Material.Filled.SwapHoriz"
                        Title="@(IsEdit ? "Edit Migration Job" : "Create Migration Job")"
                        ButtonText="Back to List"
                        OnClick="@NavigateBack"/>

    <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Filled">
        <strong>Experimental Feature:</strong> Data Migration is currently in experimental phase. Please test thoroughly before using in production environments.
    </MudAlert>

    <MudForm @ref="_form" Model="_model" @onsubmit="SaveJob">
        <MudCard>
            <MudCardContent>
                <MudGrid>
                    <!-- Basic Information -->
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Name"
                                     Label="Job Name"
                                     Required="true"
                                     MaxLength="200" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Description"
                                     Label="Description"
                                     Required="true"
                                     Lines="3"
                                     MaxLength="1000" />
                    </MudItem>
                    
                    
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6" Class="mb-2">Source Query Configuration</MudText>
                        <MudText Typo="Typo.body2" Class="mb-4">Build your data extraction query using multiple steps across different data sources if needed.</MudText>
                        
                        <QueryStepBuilder Query="@_queryModel"
                                          AvailableProjects="@_availableProjects"
                                          OnQueryChanged="@OnQueryChanged"
                                          OnPreviewStep="@OnPreviewStep"
                                          OnPreviewStepWithParameters="@OnPreviewStepWithParameters"
                                          OnExecuteQuery="@OnExecuteQuery"
                                          OnSaveQuery="@(async () => {})" />
                    </MudItem>
                    
                    @if (_queryModel?.Steps?.Any() == true)
                    {
                        <MudItem xs="12">
                            <QueryFlowDiagram Query="@_queryModel" />
                        </MudItem>
                    }
                    
                    <!-- Destination Configuration -->
                    <MudItem xs="12" md="6">
                        <DataSourceSelect Value="@((int?)_model.DestinationDataSourceId)"
                                           ValueChanged="@(v => _model.DestinationDataSourceId = v ?? 0)"
                                           Label="Destination Data Source"
                                           Required="true"
                                           ShowEngineType="true"/>
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.DestinationTable" 
                                     Label="Destination Table" 
                                     Required="true" 
                                                                          HelperText="Table name in destination database" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_model.Mode" Label="Migration Mode" >
                            <MudSelectItem Value="MigrationMode.Insert">Insert Only</MudSelectItem>
                            <MudSelectItem Value="MigrationMode.Upsert">Insert or Update</MudSelectItem>
                            <MudSelectItem Value="MigrationMode.Truncate">Truncate & Insert</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    
                    <!-- Execution Options -->
                    <MudItem xs="12" md="6">
                        <CronExpressionField @bind-Value="_model.Schedule"
                                            Label="Schedule (Cron Expression)"
                                            Required="false"
                                            Placeholder="* * * * * (leave empty for manual execution only)" />
                    </MudItem>
                    
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_model.MaxRetries" 
                                        Label="Max Retries" 
                                                                                Min="0" Max="10" />
                    </MudItem>
                    
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_model.TimeoutMinutes" 
                                        Label="Timeout (Minutes)" 
                                                                                Min="1" Max="1440" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudCheckBox T="bool" @bind-Checked="_model.IsEnabled" 
                                    Label="Enable migration job" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudCheckBox T="bool" @bind-Checked="_model.ValidateBeforeExecution" 
                                    Label="Validate query before execution" />
                    </MudItem>
                    
                    <!-- Advanced Options -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.TransformationScript" 
                                     Label="Data Transformation Script" 
                                     Lines="5"
                                                                          HelperText="Optional: Use result1, result2 syntax for data transformation" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
            
            <MudCardActions>
                <MudButton ButtonType="ButtonType.Submit" 
                          Variant="Variant.Filled" 
                          Color="Color.Primary"
                          Disabled="@_loading"
                          OnClick="@SaveJob">
                    @if (_loading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">Saving...</MudText>
                    }
                    else
                    {
                        @(IsEdit ? "Update" : "Create")
                    }
                </MudButton>
                <MudButton OnClick="@NavigateBack" 
                          Variant="Variant.Text">
                    Cancel
                </MudButton>
                <MudButton OnClick="@ValidateOnly" 
                          Variant="Variant.Outlined"
                          Color="Color.Info"
                          Disabled="@_loading">
                    Validate
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudForm>

    @* Query Execution Results Preview *@
    @if (_currentQueryResult != null)
    {
        <QueryExecutionResultsPreview ExecutionResult="@_currentQueryResult"
                                      OnClose="@CloseResultsPreview" />
    }
</MudContainer>

@inject IMigrationService _migrationService
@inject IDataSourceService _dataSourceService
@inject IQueryExecutionPreviewService _previewService
@inject ISnackbar Snackbar

@code {
    [Parameter] public int? JobId { get; set; }
    
    private bool IsEdit => JobId.HasValue;
    private CreateMigrationJobRequest _model = new();
    private QueryData _queryModel = new() { Name = "", Description = "", Steps = new() };
    private List<DataSourceListData>? _dataSources;
    private Dictionary<int, QueryStepBuilder.ProjectInfo> _availableProjects = new();
    private bool _loading;
    private MudForm? _form;
    private QueryExecutionResult? _currentQueryResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataSources();
        
        if (IsEdit && JobId.HasValue)
        {
            await LoadMigrationJob();
        }
    }

    private async Task LoadDataSources()
    {
        try
        {
            _dataSources = await _dataSourceService.GetDataSources(null, CancellationToken.None);

            // Build available data sources dictionary for QueryStepBuilder
            // Only include database type data sources (migrations don't support CloudWatch, etc.)
            _availableProjects = _dataSources?
                .Where(x => x.DatabaseEngineType.HasValue)
                .ToDictionary(x => x.Id, x => new QueryStepBuilder.ProjectInfo
                {
                    Name = x.Name,
                    DatabaseEngine = x.DatabaseEngineType!.Value.ToString(),
                    DatabaseEngineType = x.DatabaseEngineType.Value
                }) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data sources: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadMigrationJob()
    {
        try
        {
            var job = await _migrationService.GetMigrationJob(JobId!.Value, CancellationToken.None);
            if (job == null)
            {
                Snackbar.Add("Migration job not found", Severity.Error);
                NavigateBack();
                return;
            }

            // Populate the model
            _model.Name = job.Name;
            _model.Description = job.Description;
            _model.DataSourceId = job.DataSourceId;
            _model.QueryText = job.QueryText;
            _model.DestinationDataSourceId = job.DestinationDataSourceId;
            _model.DestinationTable = job.DestinationTable;
            _model.Mode = job.Mode;
            _model.IsEnabled = job.IsEnabled;
            _model.Schedule = job.Schedule;
            _model.MaxRetries = job.MaxRetries;
            _model.TimeoutMinutes = job.TimeoutMinutes;
            _model.ValidateBeforeExecution = job.ValidateBeforeExecution;
            _model.TransformationScript = job.TransformationScript;

            // Parse and populate query steps from QueryText JSON
            if (!string.IsNullOrWhiteSpace(job.QueryText))
            {
                try
                {
                    var steps = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(job.QueryText);
                    if (steps != null)
                    {
                        _queryModel.Steps = steps.Select((step, index) =>
                        {
                            var dataSourceId = step.TryGetProperty("DataSourceId", out var dsId) ? dsId.GetInt32() : 0;
                            var dataSourceInfo = _availableProjects.ContainsKey(dataSourceId) ? _availableProjects[dataSourceId] : null;

                            return new QueryStepData
                            {
                                StepId = 0,
                                StepOrder = step.TryGetProperty("StepOrder", out var stepOrder) ? stepOrder.GetInt32() : index + 1,
                                Name = step.TryGetProperty("Name", out var name) ? name.GetString() ?? $"Step {index + 1}" : $"Step {index + 1}",
                                Description = step.TryGetProperty("Description", out var desc) ? desc.GetString() : null,
                                SqlValue = step.TryGetProperty("SqlValue", out var sql) ? sql.GetString() ?? "" : "",
                                DataSourceId = dataSourceId,
                                DataSourceName = dataSourceInfo?.Name ?? "Unknown Data Source",
                                DatabaseEngineType = dataSourceInfo?.DatabaseEngineType ?? DatabaseEngineType.PostgreSQL,
                                Parameters = new List<QueryStepParameterData>()
                            };
                        }).ToList();
                    }
                }
                catch (System.Text.Json.JsonException)
                {
                    // If JSON parsing fails, treat it as plain SQL (legacy format)
                    _queryModel.Steps = new List<QueryStepData>
                    {
                        new QueryStepData
                        {
                            StepId = 0,
                            StepOrder = 1,
                            Name = "Migration Query",
                            Description = "Data extraction query",
                            SqlValue = job.QueryText,
                            DataSourceId = job.DataSourceId,
                            DataSourceName = _availableProjects.ContainsKey(job.DataSourceId) ? _availableProjects[job.DataSourceId].Name : "Unknown Data Source",
                            DatabaseEngineType = _availableProjects.ContainsKey(job.DataSourceId) ? _availableProjects[job.DataSourceId].DatabaseEngineType : DatabaseEngineType.PostgreSQL,
                            Parameters = new List<QueryStepParameterData>()
                        }
                    };
                    Snackbar.Add("Loaded legacy SQL format - please re-save to update to new format", Severity.Info);
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error loading query steps: {ex.Message}", Severity.Error);
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading migration job: {ex.Message}", Severity.Error);
            NavigateBack();
        }
    }

    private async Task SaveJob()
    {
        // Ensure query model is synced with the migration model
        UpdateMigrationModelFromQuery();

        if (_form != null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                Snackbar.Add("Please fill in all required fields", Severity.Warning);
                return;
            }
        }

        // Additional validation
        if (string.IsNullOrWhiteSpace(_model.QueryText) || _model.DataSourceId == 0)
        {
            Snackbar.Add("Please add at least one query step", Severity.Warning);
            return;
        }

        if (_model.DestinationDataSourceId == 0)
        {
            Snackbar.Add("Please select a destination data source", Severity.Warning);
            return;
        }

        _loading = true;

        try
        {
            if (IsEdit && JobId.HasValue)
            {
                var response = await _migrationService.UpdateMigrationJob(JobId.Value, _model, CancellationToken.None);
                if (response.Success)
                {
                    Snackbar.Add("Migration job updated successfully", Severity.Success);
                    NavigateBack();
                }
                else
                {
                    Snackbar.Add($"Error updating migration job: {response.Message}", Severity.Error);
                }
            }
            else
            {
                var response = await _migrationService.CreateMigrationJob(_model, CancellationToken.None);
                if (response.Success)
                {
                    Snackbar.Add("Migration job created successfully", Severity.Success);
                    NavigateBack();
                }
                else
                {
                    Snackbar.Add($"Error creating migration job: {response.ErrorMessage}", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving migration job: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
    
    private async Task ValidateOnly()
    {
        // Simple validation - just check required fields
        var isValid = !string.IsNullOrWhiteSpace(_model.Name) &&
                     !string.IsNullOrWhiteSpace(_model.Description) &&
                     _queryModel?.Steps?.Any() == true &&
                     !string.IsNullOrWhiteSpace(_model.DestinationTable) &&
                     _model.DestinationDataSourceId > 0;

        if (isValid)
        {
            Snackbar.Add("Validation passed", Severity.Success);
        }
        else
        {
            Snackbar.Add("Please fill in all required fields and add at least one query step", Severity.Error);
        }
    }

    private void OnQueryChanged(QueryData updatedQuery)
    {
        _queryModel = updatedQuery;
        
        // Update the migration request model with query data
        UpdateMigrationModelFromQuery();
        
        StateHasChanged();
    }

    private void UpdateMigrationModelFromQuery()
    {
        if (_queryModel?.Steps?.Any() == true)
        {
            // Convert query steps to serialized format for migration job
            var queryStepsJson = System.Text.Json.JsonSerializer.Serialize(_queryModel.Steps.Select(s => new
            {
                StepOrder = s.StepOrder,
                Name = s.Name,
                Description = s.Description,
                SqlValue = s.SqlValue,
                DataSourceId = s.DataSourceId,
                DataSourceName = s.DataSourceName,
                Parameters = s.Parameters
            }));

            _model.QueryText = queryStepsJson;

            // Always set the primary data source ID from the first step
            _model.DataSourceId = _queryModel.Steps.OrderBy(s => s.StepOrder).First().DataSourceId;
        }
        else
        {
            _model.QueryText = "";
            _model.DataSourceId = 0;
        }
    }

    private async Task OnPreviewStep(int stepOrder)
    {
        await OnPreviewStepWithParameters((stepOrder, new List<QueryParameterValue>()));
    }

    private async Task OnPreviewStepWithParameters((int stepOrder, List<QueryParameterValue> parameters) args)
    {
        var step = _queryModel.Steps.FirstOrDefault(s => s.StepOrder == args.stepOrder);
        if (step == null)
        {
            Snackbar.Add($"Step {args.stepOrder} not found", Severity.Error);
            return;
        }

        // Validate SQL is not empty
        if (string.IsNullOrWhiteSpace(step.SqlValue))
        {
            Snackbar.Add($"Please enter SQL query for step {args.stepOrder}", Severity.Warning);
            return;
        }

        // Validate data source is selected
        if (step.DataSourceId <= 0)
        {
            Snackbar.Add($"Please select a data source for step {args.stepOrder}", Severity.Warning);
            return;
        }

        try
        {
            Snackbar.Add($"Executing step {args.stepOrder}...", Severity.Info);

            // Use the preview service to execute the temporary step
            var executionResult = await _previewService.ExecuteTemporaryStepPreview(_queryModel, args.stepOrder, args.parameters, CancellationToken.None);

            if (executionResult != null && executionResult.Success)
            {
                Snackbar.Add($"Step {args.stepOrder} executed successfully! Returned {executionResult.TotalRows} rows in {executionResult.ExecutionTimeMs:F0}ms", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Step {args.stepOrder} execution failed: {executionResult?.ErrorMessage ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing step {args.stepOrder}: {e.Message}", Severity.Error);
        }
    }

    private async Task OnExecuteQuery()
    {
        if (!_queryModel.Steps.Any())
        {
            Snackbar.Add("Add at least one step before executing the query", Severity.Warning);
            return;
        }

        try
        {
            Snackbar.Add("Executing full query...", Severity.Info);

            var executionResult = await _previewService.ExecuteTemporaryQueryPreview(_queryModel, CancellationToken.None);

            if (executionResult != null)
            {
                _currentQueryResult = executionResult;

                if (executionResult.Success)
                {
                    var message = executionResult.IsMultiStep
                        ? $"Query executed successfully! {executionResult.StepResults.Count} steps completed in {executionResult.TotalExecutionTimeMs:F0}ms"
                        : $"Query executed successfully! Returned {executionResult.FinalResult?.TotalRecords ?? 0} rows in {executionResult.TotalExecutionTimeMs:F0}ms";

                    Snackbar.Add(message, Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Query execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }

                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Query execution failed", Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing query: {e.Message}", Severity.Error);
        }
    }

    private void CloseResultsPreview()
    {
        _currentQueryResult = null;
        StateHasChanged();
    }

    private void NavigateBack()
    {
        NavManager.NavigateTo("data-migration");
    }
}