@using Beacon.Core.Data.Enums
@using Beacon.Core.Handlers.DataQuality.CreateDataContract
@using Beacon.Core.Handlers.DataQuality.UpdateDataContract
@using Beacon.Core.Handlers.DataQuality.GetDataContractDetail
@using Beacon.Core.Models.DataQuality
@using Beacon.Core.Models.Recipients
@using Beacon.Core.Services
@using MediatR
@inject IMediator Mediator
@inject IRecipientService RecipientService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                @* Contract Info *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Contract Information</MudText>
                    @if (!_isEdit)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.AutoFixHigh" Size="Size.Small"
                                   Variant="Variant.Text" Color="Color.Info" OnClick="LoadExample">
                            Load Example
                        </MudButton>
                    }
                </MudStack>

                <MudTextField @bind-Value="_name" Label="Contract Name" Required="true"
                              RequiredError="Name is required" MaxLength="200" Variant="Variant.Outlined"/>

                <MudTextField @bind-Value="_description" Label="Description" Lines="2"
                              MaxLength="1000" Variant="Variant.Outlined"/>

                <DataSourceSelect @bind-Value="_dataSourceId"
                                   Label="Data Source"
                                   Required="true"
                                   RequiredError="Data source is required"/>

                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_schemaName" Label="Schema Name" Required="true"
                                      RequiredError="Schema is required" MaxLength="200" Variant="Variant.Outlined"/>
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_tableName" Label="Table Name" Required="true"
                                      RequiredError="Table is required" MaxLength="200" Variant="Variant.Outlined"/>
                    </MudItem>
                </MudGrid>

                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_cronExpression" Label="Cron Expression" Required="true"
                                      RequiredError="Cron is required" MaxLength="100" Variant="Variant.Outlined"
                                      HelperText="e.g. 0 */6 * * * (every 6 hours)"/>
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="_failureThreshold" Label="Failure Threshold (%)"
                                         Min="0" Max="100" Variant="Variant.Outlined"/>
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Spacing="4">
                    <MudSwitch @bind-Value="_isEnabled" Color="Color.Success" Label="Enabled"/>
                    <MudSwitch @bind-Value="_alertOnFailure" Color="Color.Warning" Label="Alert on Failure"/>
                </MudStack>

                @* Recipients (visible when Alert on Failure is on) *@
                @if (_alertOnFailure)
                {
                    <MudSelect T="int" Label="Notification Recipients" MultiSelection="true"
                               @bind-SelectedValues="_selectedRecipientIds"
                               Variant="Variant.Outlined"
                               AdornmentIcon="@Icons.Material.Filled.NotificationsActive"
                               HelperText="Select recipients to notify when the score drops below the threshold">
                        @foreach (var recipient in _recipients)
                        {
                            <MudSelectItem T="int" Value="@recipient.RecipientId!.Value">
                                @recipient.Name (@recipient.NotificationType)
                            </MudSelectItem>
                        }
                    </MudSelect>
                }

                @* Rules *@
                <MudDivider Class="my-2"/>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Rules (@_rules.Count)</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                               Variant="Variant.Text" OnClick="AddRule">Add Rule</MudButton>
                </MudStack>

                @for (var i = 0; i < _rules.Count; i++)
                {
                    var index = i;
                    <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">Rule @(index + 1)</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => RemoveRule(index))"/>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="_rules[index].Name" Label="Rule Name" Required="true"
                                                  MaxLength="200" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudSelect T="DataContractRuleType" @bind-Value="_rules[index].RuleType"
                                               Label="Rule Type" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (DataContractRuleType rt in Enum.GetValues<DataContractRuleType>())
                                        {
                                            <MudSelectItem T="DataContractRuleType" Value="@rt">@rt</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>

                            <MudGrid Spacing="2">
                                <MudItem xs="4">
                                    <MudTextField @bind-Value="_rules[index].ColumnName" Label="Column (optional)"
                                                  MaxLength="200" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudSelect T="DataContractSeverity" @bind-Value="_rules[index].Severity"
                                               Label="Severity" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (DataContractSeverity s in Enum.GetValues<DataContractSeverity>())
                                        {
                                            <MudSelectItem T="DataContractSeverity" Value="@s">@s</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudNumericField @bind-Value="_rules[index].Weight" Label="Weight"
                                                     Min="0.1" Max="10.0" Step="0.1"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"/>
                                </MudItem>
                            </MudGrid>

                            <MudTextField @bind-Value="_rules[index].Configuration" Label="Configuration (JSON)"
                                          Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          HelperText="@GetConfigHint(_rules[index].RuleType)"/>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid || _submitting)">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Saving...</span>
            }
            else
            {
                <text>@(_isEdit ? "Update" : "Create")</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int? EditContractId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _submitting;
    private bool _isEdit;

    private string _name = string.Empty;
    private string? _description;
    private int? _dataSourceId;
    private string _schemaName = string.Empty;
    private string _tableName = string.Empty;
    private string _cronExpression = "0 */6 * * *";
    private bool _isEnabled = true;
    private bool _alertOnFailure = true;
    private int _failureThreshold = 80;

    private List<RuleEditModel> _rules = new();
    private List<RecipientData> _recipients = new();
    private IReadOnlyCollection<int> _selectedRecipientIds = new HashSet<int>();

    protected override async Task OnInitializedAsync()
    {
        _recipients = await RecipientService.GetRecipients(null, null, CancellationToken.None);

        if (EditContractId.HasValue)
        {
            _isEdit = true;
            var contract = await Mediator.Send(new GetDataContractDetailQuery(EditContractId.Value));
            _name = contract.Name;
            _description = contract.Description;
            _dataSourceId = contract.DataSourceId;
            _schemaName = contract.SchemaName;
            _tableName = contract.TableName;
            _cronExpression = contract.CronExpression;
            _isEnabled = contract.IsEnabled;
            _alertOnFailure = contract.AlertOnFailure;
            _failureThreshold = contract.FailureThresholdScore;
            _selectedRecipientIds = contract.Recipients.Select(r => r.Id).ToHashSet();
            _rules = contract.Rules.Select(r => new RuleEditModel
            {
                Name = r.Name,
                Description = r.Description,
                RuleType = r.RuleType,
                ColumnName = r.ColumnName,
                Configuration = r.Configuration,
                Severity = r.Severity,
                Weight = r.Weight,
                IsEnabled = r.IsEnabled
            }).ToList();
        }
    }

    private void LoadExample()
    {
        _name = "Orders Table Health Check";
        _description = "Ensures the orders table has fresh data, no null emails, valid row counts, and unique order IDs.";
        _schemaName = "public";
        _tableName = "orders";
        _cronExpression = "0 */6 * * *";
        _isEnabled = true;
        _alertOnFailure = true;
        _failureThreshold = 80;

        _rules = new List<RuleEditModel>
        {
            new()
            {
                Name = "Data freshness",
                RuleType = DataContractRuleType.Freshness,
                ColumnName = "created_at",
                Configuration = @"{""column"": ""created_at"", ""maxAgeMinutes"": 360}",
                Severity = DataContractSeverity.Critical,
                Weight = 2.0,
                IsEnabled = true
            },
            new()
            {
                Name = "Minimum row count",
                RuleType = DataContractRuleType.Volume,
                Configuration = @"{""minRows"": 1000}",
                Severity = DataContractSeverity.High,
                Weight = 1.5,
                IsEnabled = true
            },
            new()
            {
                Name = "Email not null",
                RuleType = DataContractRuleType.NullRate,
                ColumnName = "email",
                Configuration = @"{""column"": ""email"", ""maxNullPercent"": 5}",
                Severity = DataContractSeverity.Medium,
                Weight = 1.0,
                IsEnabled = true
            },
            new()
            {
                Name = "Unique order IDs",
                RuleType = DataContractRuleType.Uniqueness,
                ColumnName = "id",
                Configuration = @"{""column"": ""id""}",
                Severity = DataContractSeverity.Critical,
                Weight = 2.0,
                IsEnabled = true
            }
        };

        StateHasChanged();
    }

    private void AddRule()
    {
        _rules.Add(new RuleEditModel
        {
            Name = $"Rule {_rules.Count + 1}",
            RuleType = DataContractRuleType.Volume,
            Configuration = "{}",
            Severity = DataContractSeverity.Medium,
            Weight = 1.0,
            IsEnabled = true
        });
    }

    private void RemoveRule(int index)
    {
        _rules.RemoveAt(index);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (!_isValid || !_dataSourceId.HasValue) return;

        _submitting = true;
        try
        {
            var rulesData = _rules.Select(r => new DataContractRuleData
            {
                Name = r.Name,
                Description = r.Description,
                RuleType = r.RuleType,
                ColumnName = r.ColumnName,
                Configuration = r.Configuration,
                Severity = r.Severity,
                Weight = r.Weight,
                IsEnabled = r.IsEnabled
            }).ToList();

            var recipientIds = _alertOnFailure ? _selectedRecipientIds.ToList() : null;

            if (_isEdit)
            {
                await Mediator.Send(new UpdateDataContractCommand(
                    DataContractId: EditContractId!.Value,
                    DataSourceId: _dataSourceId.Value,
                    SchemaName: _schemaName,
                    TableName: _tableName,
                    Name: _name,
                    Description: _description,
                    CronExpression: _cronExpression,
                    IsEnabled: _isEnabled,
                    OwnerUserId: null,
                    AlertOnFailure: _alertOnFailure,
                    FailureThresholdScore: _failureThreshold,
                    Rules: rulesData,
                    RecipientIds: recipientIds
                ));
                MudDialog.Close(DialogResult.Ok(EditContractId.Value));
            }
            else
            {
                var result = await Mediator.Send(new CreateDataContractCommand(
                    DataSourceId: _dataSourceId.Value,
                    SchemaName: _schemaName,
                    TableName: _tableName,
                    Name: _name,
                    Description: _description,
                    CronExpression: _cronExpression,
                    IsEnabled: _isEnabled,
                    OwnerUserId: null,
                    AlertOnFailure: _alertOnFailure,
                    FailureThresholdScore: _failureThreshold,
                    Rules: rulesData,
                    RecipientIds: recipientIds
                ));
                MudDialog.Close(DialogResult.Ok(result.DataContractId));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string GetConfigHint(DataContractRuleType ruleType) => ruleType switch
    {
        DataContractRuleType.Freshness => @"{""column"": ""updated_at"", ""maxAgeMinutes"": 60}",
        DataContractRuleType.Volume => @"{""minRows"": 100, ""maxRows"": 1000000}",
        DataContractRuleType.NullRate => @"{""column"": ""email"", ""maxNullPercent"": 5}",
        DataContractRuleType.Uniqueness => @"{""column"": ""id""}",
        DataContractRuleType.Referential => @"{""column"": ""user_id"", ""referenceTable"": ""users"", ""referenceColumn"": ""id""}",
        DataContractRuleType.Range => @"{""column"": ""age"", ""min"": ""0"", ""max"": ""150""}",
        DataContractRuleType.Pattern => @"{""column"": ""email"", ""pattern"": ""^[^@]+@[^@]+$""}",
        DataContractRuleType.CustomSql => @"{""sql"": ""SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END AS passed FROM ...""}",
        _ => "{}"
    };

    private class RuleEditModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public DataContractRuleType RuleType { get; set; }
        public string? ColumnName { get; set; }
        public string Configuration { get; set; } = "{}";
        public DataContractSeverity Severity { get; set; } = DataContractSeverity.Medium;
        public double Weight { get; set; } = 1.0;
        public bool IsEnabled { get; set; } = true;
    }
}
