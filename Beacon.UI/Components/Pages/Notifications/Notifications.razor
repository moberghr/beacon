@page "/notifications"
@inherits BasePageComponent
@using Beacon.Core.Data.Enums
@using Beacon.Core.Models.QueryExecutionHistory
@using Beacon.Core.Services
@using SortDirection = MudBlazor.SortDirection

<BeaconPageTitle Title="Notifications" />

<div class="@RootClass">
    <BeaconPageHero Variant="signal"
                    Prefix="Sent"
                    Emphasis="notification"
                    Suffix="log.">
        <Eyebrow>
            <span>Beacon</span>
            <span class="page-hero__sep">/</span>
            <span>Notifications</span>
        </Eyebrow>
        <Sub>List of sent notifications.</Sub>
    </BeaconPageHero>
    <MudDataGrid @ref="_dataGrid" ServerData="ServerReload" T="QueryExecutionHistoryData" Filterable="false">
        <ToolBarContent>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.QueryExecutionHistoryId" Title="Id"/>
            
            <TemplateColumn Title="Details">
                <CellTemplate>
                    <MudStack Spacing="1">

                            <MudLink Href="@($"query-execution-history/{context.Item.QueryExecutionHistoryId}")">
                                View Details
                            </MudLink>

                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn InitialDirection="SortDirection.Descending" Property="x => x.CreatedTime"/>
            <TemplateColumn Title="Subscription">
                <CellTemplate>
                    <MudLink Href="@($"subscriptions/{context.Item?.SubscriptionId ?? 0}")">@context.Item?.QueryName</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Recipients">
                <CellTemplate>
                    <MudStack Spacing="1">
                        @foreach (var notification in context.Item.Notifications.Take(3))
                        {
                            <MudText>@notification.RecipientName</MudText>
                        }
                        @if (context.Item.Notifications.Count > 3)
                        {
                            <MudText Typo="Typo.caption">
                                and @(context.Item.Notifications.Count - 3) more...
                            </MudText>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ResultCount"/>
            <TemplateColumn Title="Status">
                <CellTemplate>
                    @{
                        var status = context.Item?.NotificationStatus;
                        var color = status switch
                        {
                            NotificationStatus.NotificationSent => Color.Success,
                            NotificationStatus.Timeout => Color.Error,
                            NotificationStatus.Failed => Color.Error,
                            NotificationStatus.NoResults => Color.Warning,
                            _ => Color.Default
                        };
                    }
                    <MudChip Color="@color" Size="Size.Small">@status</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Source" Sortable="false">
                <CellTemplate>
                    <SourceChip AiActorId="@context.Item.AiActorId" AiActorName="@context.Item.AiActorName" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ExecutionTimeMs" Title="Execution Time (ms)" Format="N2"/>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="QueryExecutionHistoryData" />
        </PagerContent>
    </MudDataGrid>
</div>

@inject Beacon.Core.Services.INotificationService service;

@code {

    private QueryExecutionHistoryListData List { get; set; }
    MudDataGrid<QueryExecutionHistoryData>? _dataGrid;
    //private bool _loading;
    private NotificationStatus? _notificationStatus;
    
    private async Task<GridData<QueryExecutionHistoryData>> ServerReload(GridState<QueryExecutionHistoryData> state, CancellationToken cancellationToken)
    {
        var request = DataGridHelper.BuildSortedRequest<GetQueryExecutionHistoryRequest, QueryExecutionHistoryData>(state);
        request.NotificationStatus = _notificationStatus;
        List = await service.GetQueryExecutionHistory(request, new CancellationToken());
        
        return new GridData<QueryExecutionHistoryData> 
        {
            TotalItems = List.TotalCount ?? List.Data.Count,
            Items = List.Data
        };
    }
    
    private void OnNotificationSent(NotificationStatus? value)
    {
        _notificationStatus = value;
        _dataGrid?.ReloadServerData();
    }
}