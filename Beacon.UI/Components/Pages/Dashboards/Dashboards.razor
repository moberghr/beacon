@page "/dashboards"
@using Beacon.Core.Handlers.Dashboards.GetDashboards
@using Beacon.Core.Handlers.Dashboards.CreateDashboard
@using Beacon.Core.Handlers.Dashboards.DeleteDashboard
@using Beacon.Core.Models.Dashboards
@using MediatR
@using Beacon.UI.Components.Custom
@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inherits BasePageComponent

<BeaconPageTitle Title="Dashboards"/>

<div class="@RootClass">
    <BeaconPageHero Prefix="Custom"
                    Emphasis="dashboard"
                    Suffix="library.">
        <Eyebrow>
            <span>Beacon</span>
            <span class="page-hero__sep">/</span>
            <span>Dashboards</span>
        </Eyebrow>
        <Sub>Create and manage personalized dashboards with custom widgets.</Sub>
        <Actions>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDashboardDialog">
                Create Dashboard
            </MudButton>
        </Actions>
    </BeaconPageHero>
    <MudStack Spacing="4">
        @* Dashboard Grid *@
        <MudDataGrid @ref="_dataGrid"
                     T="DashboardListData"
                     ServerData="ServerReload"
                     Dense="true"
                     Hover="true"
                     Striped="true"
                     FixedHeader="true"
                     Height="calc(100vh - 300px)">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name"/>

                <TemplateColumn Title="Description">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @(context.Item.Description ?? "-")
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Widgets">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Widgets">
                            @context.Item.WidgetCount
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Created By">
                    <CellTemplate>
                        @(context.Item.CreatedByUserName ?? "Unknown")
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Sharing">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1">
                            @if (context.Item.IsShared)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Share">
                                    Shared
                                </MudChip>
                            }
                            @if (context.Item.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Star">
                                    Default
                                </MudChip>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Created">
                    <CellTemplate>
                        @context.Item.CreatedTime.ToString("g")
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Actions" Sortable="false">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => ViewDashboard(context.Item.Id))"
                                           Title="View dashboard"/>
                            @if (context.Item.IsOwner)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Info"
                                               OnClick="@(() => EditDashboard(context.Item.Id))"
                                               Title="Edit dashboard"/>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           Color="Color.Secondary"
                                           OnClick="@(() => CloneDashboard(context.Item))"
                                           Title="Clone dashboard"/>
                            @if (context.Item.IsOwner)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteDashboard(context.Item))"
                                               Title="Delete dashboard"/>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>
                <MudDataGridPager T="DashboardListData"/>
            </PagerContent>
        </MudDataGrid>
    </MudStack>
</div>

@code {
    private MudDataGrid<DashboardListData>? _dataGrid;

    private async Task<GridData<DashboardListData>> ServerReload(GridState<DashboardListData> state, CancellationToken cancellationToken)
    {
        var request = new GetDashboardsRequest
        {
            Page = state.Page + 1,
            PageSize = state.PageSize
        };

        var result = await Mediator.Send(new GetDashboardsQuery(request));

        return new GridData<DashboardListData>
        {
            TotalItems = result.TotalCount ?? 0,
            Items = result.Data
        };
    }

    private async Task OpenCreateDashboardDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateDashboardDialog>("Create Dashboard");
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is int dashboardId)
        {
            Snackbar.Add("Dashboard created successfully", Severity.Success);
            await _dataGrid!.ReloadServerData();
            NavManager.NavigateTo($"/beacon/dashboards/builder/{dashboardId}");
        }
    }

    private void ViewDashboard(int dashboardId)
    {
        NavManager.NavigateTo($"/beacon/dashboards/view/{dashboardId}");
    }

    private void EditDashboard(int dashboardId)
    {
        NavManager.NavigateTo($"/beacon/dashboards/builder/{dashboardId}");
    }

    private async Task CloneDashboard(DashboardListData dashboard)
    {
        var parameters = new DialogParameters<CloneDashboardDialog>
        {
            { x => x.SourceDashboardId, dashboard.Id },
            { x => x.SourceDashboardName, dashboard.Name }
        };

        var dialog = await DialogService.ShowAsync<CloneDashboardDialog>("Clone Dashboard", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is int newDashboardId)
        {
            Snackbar.Add("Dashboard cloned successfully", Severity.Success);
            await _dataGrid!.ReloadServerData();
            NavManager.NavigateTo($"/beacon/dashboards/builder/{newDashboardId}");
        }
    }

    private async Task DeleteDashboard(DashboardListData dashboard)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Delete Dashboard",
            $"Are you sure you want to delete '{dashboard.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                await Mediator.Send(new DeleteDashboardCommand(dashboard.Id));
                Snackbar.Add("Dashboard deleted successfully", Severity.Success);
                await _dataGrid!.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting dashboard: {ex.Message}", Severity.Error);
            }
        }
    }
}
