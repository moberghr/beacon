@using Beacon.Core.Handlers.Dashboards.AddWidget
@using Beacon.Core.Data.Enums
@using Beacon.Core.Models.Dashboards
@using MediatR
@using System.Text.Json
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="nodes"
            Eyebrow="DASHBOARDS"
            Prefix="Add a"
            Emphasis="widget"
            Suffix="."
            Sub="Pin a query result or chart to this dashboard." />
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
                <BeaconSelect T="WidgetType"
                              @bind-Value="_widgetType"
                              Label="Widget Type"
                              Required="true"
                              Items="@_widgetTypeOptions"
                              ItemValueSelector="@(x => ((WidgetTypeOption)x).Value)"
                              ItemTextSelector="@(x => ((WidgetTypeOption)x).Text)" />

                <BeaconTextField @bind-Value="_title"
                                 Label="Widget Title"
                                 Required="true"
                                 MaxLength="200" />

                @* KPI Card Configuration *@
                @if (_widgetType == WidgetType.KpiCard)
                {
                    <BeaconSelect T="string"
                                  @bind-Value="_kpiMetric"
                                  Label="Metric"
                                  Required="true"
                                  Items="@_kpiMetricOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />

                    <BeaconSelect T="string"
                                  @bind-Value="_kpiColorClass"
                                  Label="Color"
                                  Items="@_kpiColorOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />
                }

                @* Chart Configuration *@
                @if (_widgetType == WidgetType.LineChart || _widgetType == WidgetType.BarChart)
                {
                    <BeaconSelect T="string"
                                  @bind-Value="_chartTimeRange"
                                  Label="Time Range"
                                  Items="@_chartTimeRangeOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />
                }

                @* Table Configuration *@
                @if (_widgetType == WidgetType.Table)
                {
                    <BeaconSelect T="string"
                                  @bind-Value="_tableType"
                                  Label="Table Type"
                                  Items="@_tableTypeOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />

                    <BeaconNumericField T="int"
                                        @bind-Value="_tableMaxRows"
                                        Label="Max Rows"
                                        Min="5"
                                        Max="50" />
                }

                @* Gauge Configuration *@
                @if (_widgetType == WidgetType.Gauge)
                {
                    <BeaconSelect T="string"
                                  @bind-Value="_gaugeMetric"
                                  Label="Metric"
                                  Required="true"
                                  Items="@_gaugeMetricOptions"
                                  ItemValueSelector="@(x => ((StringOption)x).Value)"
                                  ItemTextSelector="@(x => ((StringOption)x).Text)" />

                    <BeaconNumericField T="double"
                                        @bind-Value="_gaugeMin"
                                        Label="Min Value" />

                    <BeaconNumericField T="double"
                                        @bind-Value="_gaugeMax"
                                        Label="Max Value" />
                }
            </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="AddWidget"
                   Disabled="@(!CanSubmit)">
            @if (_isAdding)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Adding...</span>
            }
            else
            {
                <text>Add Widget</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int DashboardId { get; set; }

    private bool _isAdding;

    private record StringOption(string Value, string Text);
    private record WidgetTypeOption(WidgetType Value, string Text);

    private static readonly List<object> _widgetTypeOptions = new()
    {
        new WidgetTypeOption(WidgetType.KpiCard, "KPI Card"),
        new WidgetTypeOption(WidgetType.LineChart, "Line Chart"),
        new WidgetTypeOption(WidgetType.BarChart, "Bar Chart"),
        new WidgetTypeOption(WidgetType.Table, "Table"),
        new WidgetTypeOption(WidgetType.Gauge, "Gauge"),
    };

    private static readonly List<object> _kpiMetricOptions = new()
    {
        new StringOption("TotalSubscriptions", "Total Subscriptions"),
        new StringOption("ActiveSubscriptions", "Active Subscriptions"),
        new StringOption("TotalQueries", "Total Queries"),
        new StringOption("TotalNotificationsSent", "Notifications Sent"),
        new StringOption("UnresolvedTasks", "Unresolved Tasks"),
        new StringOption("TotalAnomalies", "Total Anomalies"),
    };

    private static readonly List<object> _kpiColorOptions = new()
    {
        new StringOption("hero-stat-card-primary", "Primary (Blue)"),
        new StringOption("hero-stat-card-success", "Success (Green)"),
        new StringOption("hero-stat-card-warning", "Warning (Orange)"),
        new StringOption("hero-stat-card-error", "Error (Red)"),
        new StringOption("hero-stat-card-info", "Info (Cyan)"),
    };

    private static readonly List<object> _chartTimeRangeOptions = new()
    {
        new StringOption("7days", "Last 7 Days"),
        new StringOption("30days", "Last 30 Days"),
        new StringOption("90days", "Last 90 Days"),
    };

    private static readonly List<object> _tableTypeOptions = new()
    {
        new StringOption("TopSubscriptions", "Top Subscriptions"),
    };

    private static readonly List<object> _gaugeMetricOptions = new()
    {
        new StringOption("TotalSubscriptions", "Total Subscriptions"),
        new StringOption("ActiveSubscriptions", "Active Subscriptions"),
        new StringOption("UnresolvedTasks", "Unresolved Tasks"),
    };

    private bool CanSubmit => !_isAdding
        && !string.IsNullOrWhiteSpace(_title);

    private WidgetType _widgetType = WidgetType.KpiCard;
    private string? _title = string.Empty;

    // KPI Card config
    private string _kpiMetric = "TotalSubscriptions";
    private string _kpiColorClass = "hero-stat-card-primary";

    // Chart config
    private string _chartTimeRange = "30days";

    // Table config
    private string _tableType = "TopSubscriptions";
    private int _tableMaxRows = 10;

    // Gauge config
    private string _gaugeMetric = "TotalSubscriptions";
    private double _gaugeMin = 0;
    private double _gaugeMax = 100;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task AddWidget()
    {
        if (!CanSubmit)
        {
            return;
        }

        _isAdding = true;

        try
        {
            var configJson = _widgetType switch
            {
                WidgetType.KpiCard => JsonSerializer.Serialize(new KpiCardWidgetConfiguration
                {
                    Metric = _kpiMetric,
                    ColorClass = _kpiColorClass,
                    Icon = Icons.Material.Filled.Dashboard,
                    Badge = "Live"
                }),
                WidgetType.LineChart or WidgetType.BarChart => JsonSerializer.Serialize(new ChartWidgetConfiguration
                {
                    ChartType = _widgetType == WidgetType.LineChart ? "Line" : "Bar",
                    TimeRange = _chartTimeRange,
                    Series = new List<string> { "Average" }
                }),
                WidgetType.Table => JsonSerializer.Serialize(new TableWidgetConfiguration
                {
                    TableType = _tableType,
                    MaxRows = _tableMaxRows
                }),
                WidgetType.Gauge => JsonSerializer.Serialize(new GaugeWidgetConfiguration
                {
                    Metric = _gaugeMetric,
                    MinValue = _gaugeMin,
                    MaxValue = _gaugeMax,
                    Thresholds = new List<GaugeThreshold>
                    {
                        new() { Value = 0, Color = "success", Label = "Good" },
                        new() { Value = 50, Color = "warning", Label = "Warning" },
                        new() { Value = 80, Color = "error", Label = "Critical" }
                    }
                }),
                _ => "{}"
            };

            var command = new AddWidgetCommand(
                DashboardId: DashboardId,
                Title: _title ?? string.Empty,
                WidgetType: _widgetType,
                ConfigurationJson: configJson,
                PositionX: null,
                PositionY: null,
                Width: _widgetType == WidgetType.Table ? 12 : 6,
                Height: _widgetType == WidgetType.KpiCard ? 1 : 2,
                RefreshIntervalSeconds: null
            );

            var result = await Mediator.Send(command);
            MudDialog.Close(DialogResult.Ok(result.WidgetId));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding widget: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAdding = false;
        }
    }
}
