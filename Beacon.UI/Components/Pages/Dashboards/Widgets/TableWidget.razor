@using Beacon.Core.Models.Dashboards
@using Beacon.Core.Models.QueryExecutionHistory
@using Beacon.Core.Services
@using System.Text.Json
@inject IStatisticsService StatisticsService

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">@Widget.Title</MudText>
        @if (_loading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px"/>
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_topSubscriptions.Any())
        {
            <MudTable T="TopSubscriptionItem" Items="@_topSubscriptions" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Subscription</MudTh>
                    <MudTh>Executions</MudTh>
                    <MudTh>Notifications</MudTh>
                    <MudTh>Last Executed</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudLink Href="@($"/beacon/subscriptions/{context.SubscriptionId}")">
                            @context.SubscriptionName
                        </MudLink>
                    </MudTd>
                    <MudTd>@context.ExecutionCount</MudTd>
                    <MudTd>@context.NotificationCount</MudTd>
                    <MudTd>@(context.LastExecuted?.ToLocalTime().ToString("g") ?? "Never")</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No data available</MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public DashboardWidgetData Widget { get; set; } = null!;

    private bool _loading = true;
    private string? _error;
    private TableWidgetConfiguration? _config;
    private List<TopSubscriptionItem> _topSubscriptions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _config = JsonSerializer.Deserialize<TableWidgetConfiguration>(Widget.ConfigurationJson);
            var statistics = await StatisticsService.GetDashboardStatistics(CancellationToken.None);

            if (_config?.TableType == "TopSubscriptions")
            {
                _topSubscriptions = statistics.TopSubscriptions.Take(_config.MaxRows).ToList();
            }
        }
        catch (Exception ex)
        {
            _error = $"Error loading widget: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}