@using Beacon.Core.Models.Dashboards
@using Beacon.Core.Models.QueryExecutionHistory
@using Beacon.Core.Services
@using System.Text.Json
@using Beacon.UI.Helpers
@inject IStatisticsService StatisticsService

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">@Widget.Title</MudText>
        @if (_loading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px"/>
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_config != null && _chartSeries.Any())
        {
            <MudChart ChartType="@GetChartType()"
                      ChartSeries="@_chartSeries"
                      XAxisLabels="@_xAxisLabels"
                      Width="@ChartHelper.DefaultChartWidth"
                      Height="@ChartHelper.DefaultChartHeight"
                      ChartOptions="@_chartOptions"/>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No data available</MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public DashboardWidgetData Widget { get; set; } = null!;

    private bool _loading = true;
    private string? _error;
    private ChartWidgetConfiguration? _config;
    private List<ChartSeries> _chartSeries = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private ChartOptions _chartOptions = ChartHelper.CreateDefaultChartOptions();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _config = JsonSerializer.Deserialize<ChartWidgetConfiguration>(Widget.ConfigurationJson);
            var statistics = await StatisticsService.GetDashboardStatistics(CancellationToken.None);

            if (_config != null && statistics.ExecutionTimeHistory.Any())
            {
                _xAxisLabels = statistics.ExecutionTimeHistory.Select(x => x.Date.ToString("MM/dd")).ToArray();

                _chartSeries = new List<ChartSeries>
                {
                    new()
                    {
                        Name = "Average",
                        Data = statistics.ExecutionTimeHistory.Select(x => x.AvgExecutionTimeMs).ToArray()
                    }
                };
            }
        }
        catch (Exception ex)
        {
            _error = $"Error loading widget: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private ChartType GetChartType()
    {
        return _config?.ChartType switch
        {
            "Line" => ChartType.Line,
            "Bar" => ChartType.Bar,
            "Pie" => ChartType.Pie,
            _ => ChartType.Line
        };
    }
}
