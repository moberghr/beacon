@using Beacon.Core.Handlers.Dashboards.UpdateDashboard
@using Beacon.Core.Handlers.Dashboards.DeleteDashboard
@using Beacon.Core.Models.Dashboards
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="nodes"
            Eyebrow="DASHBOARDS"
            Prefix="Dashboard"
            Emphasis="settings"
            Suffix="." />
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                <BeaconTextField @bind-Value="_name"
                                 Label="Dashboard Name"
                                 Required="true"
                                 MaxLength="200" />

                <BeaconTextField @bind-Value="_description"
                                 Label="Description"
                                 Multiline="true"
                                 Rows="3"
                                 MaxLength="1000" />

                <BeaconSwitch @bind-Value="_isShared"
                              Label="Share with all users" />

                <BeaconSwitch @bind-Value="_isDefault"
                              Label="Set as default dashboard" />

                <BeaconNumericField T="int?"
                                    @bind-Value="_refreshIntervalSeconds"
                                    Label="Auto-Refresh Interval (seconds)"
                                    Min="5"
                                    Max="3600"
                                    HelpText="Leave empty for no auto-refresh"/>

                <MudDivider Class="my-2"/>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="DeleteDashboard"
                           Disabled="@_isDeleting">
                    @if (_isDeleting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                        <span class="ml-2">Deleting...</span>
                    }
                    else
                    {
                        <text>Delete Dashboard</text>
                    }
                </MudButton>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@(!_isValid || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Saving...</span>
            }
            else
            {
                <text>Save Changes</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DashboardDetailsData Dashboard { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isSaving;
    private bool _isDeleting;

    private string? _name = string.Empty;
    private string? _description;
    private bool _isShared;
    private bool _isDefault;
    private int? _refreshIntervalSeconds;

    protected override void OnInitialized()
    {
        _name = Dashboard.Name;
        _description = Dashboard.Description;
        _isShared = Dashboard.IsShared;
        _isDefault = Dashboard.IsDefault;
        _refreshIntervalSeconds = Dashboard.RefreshIntervalSeconds;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        if (!_isValid)
        {
            return;
        }

        _isSaving = true;

        try
        {
            var command = new UpdateDashboardCommand(
                DashboardId: Dashboard.Id,
                Name: _name ?? string.Empty,
                Description: _description,
                IsShared: _isShared,
                IsDefault: _isDefault,
                RefreshIntervalSeconds: _refreshIntervalSeconds,
                LayoutConfiguration: null
            );

            await Mediator.Send(command);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteDashboard()
    {
        _isDeleting = true;

        try
        {
            var command = new DeleteDashboardCommand(Dashboard.Id);
            await Mediator.Send(command);

            Snackbar.Add("Dashboard deleted successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok("deleted"));

            // Navigate to dashboard list
            NavManager.NavigateTo("/beacon/dashboards");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
