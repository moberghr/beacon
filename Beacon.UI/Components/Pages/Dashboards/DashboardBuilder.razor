@page "/dashboards/builder/{DashboardId:int}"
@using Beacon.Core.Handlers.Dashboards.GetDashboard
@using Beacon.Core.Handlers.Dashboards.DeleteWidget
@using Beacon.Core.Models.Dashboards
@using Beacon.Core.Data.Enums
@using Beacon.UI.Components.Pages.Dashboards.Widgets
@using MediatR
@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inherits BasePageComponent

<BeaconPageTitle Title="@(_dashboard != null ? $"Edit {_dashboard.Name}" : "Dashboard Builder")"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large"/>
            <MudText Typo="Typo.h6">Loading dashboard...</MudText>
        </MudStack>
    }
    else if (_dashboard == null)
    {
        <MudAlert Severity="Severity.Error">Dashboard not found or you don't have permission to access it.</MudAlert>
    }
    else
    {
        <MudStack Spacing="4">
            <PageHeader Title="@_dashboard.Name"
                        Icon="@Icons.Material.Filled.Dashboard"
                        Subtitle="@_dashboard.Description">
                <Actions>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="OpenAddWidgetDialog">
                        Add Widget
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Share"
                               Color="Color.Tertiary"
                               OnClick="OpenShareDialog">
                        Share
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Settings"
                               Color="Color.Secondary"
                               OnClick="OpenSettingsDialog">
                        Settings
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Visibility"
                               Color="Color.Info"
                               Href="@($"/beacon/dashboards/view/{DashboardId}")">
                        Preview
                    </MudButton>
                </Actions>
            </PageHeader>

            @* Dashboard Content *@
            @if (!_dashboard.Widgets.Any())
            {
                <MudPaper Elevation="2" Class="pa-8" Style="min-height: 400px;">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" Style="min-height: 350px;">
                        <MudIcon Icon="@Icons.Material.Filled.Widgets" Size="Size.Large" Color="Color.Secondary"/>
                        <MudText Typo="Typo.h5" Color="Color.Secondary">No widgets yet</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            Add your first widget to start building your dashboard
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddWidgetDialog">
                            Add Widget
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var widget in _dashboard.Widgets.OrderBy(w => w.SortOrder))
                    {
                        <MudItem xs="12" sm="@widget.Width">
                            <div style="position: relative;">
                                @RenderWidget(widget)
                                <div style="position: absolute; top: 8px; right: 8px;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteWidget(widget))"
                                                   Title="Delete widget"
                                                   Style="background-color: rgba(255, 255, 255, 0.9);"/>
                                </div>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int DashboardId { get; set; }

    private MudDataGrid<DashboardListData>? _dataGrid;
    private DashboardDetailsData? _dashboard;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        _loading = true;
        try
        {
            _dashboard = await Mediator.Send(new GetDashboardQuery(DashboardId));
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddWidgetDialog()
    {
        var parameters = new DialogParameters<AddWidgetDialog>
        {
            { x => x.DashboardId, DashboardId }
        };

        var dialog = await DialogService.ShowAsync<AddWidgetDialog>("Add Widget", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Snackbar.Add("Widget added successfully", Severity.Success);
            await LoadDashboard();
        }
    }

    private async Task OpenSettingsDialog()
    {
        if (_dashboard == null) return;

        var parameters = new DialogParameters<DashboardSettingsDialog>
        {
            { x => x.Dashboard, _dashboard }
        };

        var dialog = await DialogService.ShowAsync<DashboardSettingsDialog>("Dashboard Settings", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            if (result.Data is string action && action == "deleted")
            {
                NavManager.NavigateTo("/beacon/dashboards");
            }
            else
            {
                await LoadDashboard();
            }
        }
    }

    private async Task OpenShareDialog()
    {
        if (_dashboard == null) return;

        var parameters = new DialogParameters<ShareDashboardDialog>
        {
            { x => x.DashboardId, DashboardId }
        };

        await DialogService.ShowAsync<ShareDashboardDialog>("Share Dashboard", parameters);
    }

    private async Task DeleteWidget(DashboardWidgetData widget)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Delete Widget",
            $"Are you sure you want to delete widget '{widget.Title}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                await Mediator.Send(new DeleteWidgetCommand(widget.Id));
                Snackbar.Add("Widget deleted successfully", Severity.Success);
                await LoadDashboard();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting widget: {ex.Message}", Severity.Error);
            }
        }
    }

    private RenderFragment RenderWidget(DashboardWidgetData widget) => builder =>
    {
        switch (widget.WidgetType)
        {
            case WidgetType.KpiCard:
                builder.OpenComponent<KpiCardWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.AddAttribute(2, "DashboardRefreshInterval", _dashboard?.RefreshIntervalSeconds);
                builder.CloseComponent();
                break;

            case WidgetType.LineChart:
            case WidgetType.BarChart:
                builder.OpenComponent<ChartWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            case WidgetType.Table:
                builder.OpenComponent<TableWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            case WidgetType.Gauge:
                builder.OpenComponent<GaugeWidget>(0);
                builder.AddAttribute(1, "Widget", widget);
                builder.CloseComponent();
                break;

            default:
                builder.OpenElement(0, "div");
                builder.AddContent(1, $"Widget type {widget.WidgetType} not yet implemented");
                builder.CloseElement();
                break;
        }
    };
}
