@using Beacon.Core.Handlers.Dashboards.CreateDashboard
@using MediatR
@using MudBlazor
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="nodes"
            Eyebrow="DASHBOARDS"
            Prefix="Create a"
            Emphasis="dashboard"
            Suffix="."
            Sub="Pin queries side-by-side and keep them live during incidents." />
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                <BeaconTextField @bind-Value="_name"
                                 Label="Dashboard Name"
                                 Required="true"
                                 MaxLength="200" />

                <BeaconTextField @bind-Value="_description"
                                 Label="Description"
                                 Multiline="true"
                                 Rows="3"
                                 MaxLength="1000" />

                <BeaconSwitch @bind-Value="_isShared"
                              Label="Share with all users" />

                <BeaconNumericField T="int?"
                                    @bind-Value="_refreshIntervalSeconds"
                                    Label="Auto-Refresh Interval (seconds)"
                                    Min="5"
                                    Max="3600"
                                    HelpText="Leave empty for no auto-refresh"/>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Create"
                   Disabled="@(!_isValid || _isCreating)">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Creating...</span>
            }
            else
            {
                <text>Create</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isCreating;

    private string? _name = string.Empty;
    private string? _description;
    private bool _isShared;
    private int? _refreshIntervalSeconds;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Create()
    {
        if (!_isValid)
        {
            return;
        }

        _isCreating = true;

        try
        {
            var command = new CreateDashboardCommand(
                Name: _name ?? string.Empty,
                Description: _description,
                IsShared: _isShared,
                RefreshIntervalSeconds: _refreshIntervalSeconds
            );

            var result = await Mediator.Send(command);
            MudDialog.Close(DialogResult.Ok(result.DashboardId));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCreating = false;
        }
    }
}
