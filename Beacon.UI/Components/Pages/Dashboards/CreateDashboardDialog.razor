@using Beacon.Core.Handlers.Dashboards.CreateDashboard
@using MediatR
@using MudBlazor
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Dashboard Name"
                              Required="true"
                              RequiredError="Name is required"
                              MaxLength="200"
                              Variant="Variant.Outlined"/>

                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Lines="3"
                              MaxLength="1000"
                              Variant="Variant.Outlined"/>

                <MudSwitch @bind-Value="_isShared"
                           Color="Color.Info"
                           Label="Share with all users"/>

                <MudNumericField @bind-Value="_refreshIntervalSeconds"
                                 Label="Auto-Refresh Interval (seconds)"
                                 Min="5"
                                 Max="3600"
                                 Variant="Variant.Outlined"
                                 HelpText="Leave empty for no auto-refresh"/>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Create"
                   Disabled="@(!_isValid || _isCreating)">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Creating...</span>
            }
            else
            {
                <text>Create</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isCreating;

    private string _name = string.Empty;
    private string? _description;
    private bool _isShared;
    private int? _refreshIntervalSeconds;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Create()
    {
        if (!_isValid)
        {
            return;
        }

        _isCreating = true;

        try
        {
            var command = new CreateDashboardCommand(
                Name: _name,
                Description: _description,
                IsShared: _isShared,
                RefreshIntervalSeconds: _refreshIntervalSeconds
            );

            var result = await Mediator.Send(command);
            MudDialog.Close(DialogResult.Ok(result.DashboardId));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCreating = false;
        }
    }
}
