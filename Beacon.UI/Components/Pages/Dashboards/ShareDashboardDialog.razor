@using Beacon.Core.Handlers.Dashboards.ShareDashboard
@using Beacon.Core.Handlers.Dashboards.GetDashboardPermissions
@using Beacon.Core.Handlers.Dashboards.RevokeDashboardPermission
@using Beacon.Core.Data.Enums
@using Beacon.Core.Services
@using MediatR
@inject IMediator Mediator
@inject IUserManagementService UserManagementService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Share Dashboard</MudText>

            @* Add User Section *@
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1">Grant Access</MudText>
                    <MudAutocomplete T="string"
                                     @bind-Value="_selectedUserId"
                                     Label="Select User"
                                     SearchFunc="SearchUsers"
                                     Variant="Variant.Outlined"
                                     ToStringFunc="@(userId => _userCache.GetValueOrDefault(userId, userId))"/>

                    <MudSelect @bind-Value="_selectedPermissionLevel"
                               Label="Permission Level"
                               Variant="Variant.Outlined"
                               T="DashboardPermissionLevel">
                        <MudSelectItem Value="@DashboardPermissionLevel.View">View (Read-only)</MudSelectItem>
                        <MudSelectItem Value="@DashboardPermissionLevel.Edit">Edit (Can modify widgets)</MudSelectItem>
                        <MudSelectItem Value="@DashboardPermissionLevel.Admin">Admin (Full control)</MudSelectItem>
                    </MudSelect>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Share"
                               OnClick="GrantAccess"
                               Disabled="@(string.IsNullOrEmpty(_selectedUserId) || _isGranting)">
                        @if (_isGranting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                            <span class="ml-2">Granting...</span>
                        }
                        else
                        {
                            <text>Grant Access</text>
                        }
                    </MudButton>
                </MudStack>
            </MudPaper>

            @* Current Permissions *@
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1">Current Permissions</MudText>
                    @if (_loading)
                    {
                        <MudProgressLinear Indeterminate="true"/>
                    }
                    else if (_permissions.Any())
                    {
                        <MudList T="string" Dense="true">
                            @foreach (var permission in _permissions)
                            {
                                <MudListItem T="string">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1">@permission.UserName</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Granted @permission.GrantedAt.ToString("g")
                                            </MudText>
                                        </MudStack>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Color="@GetPermissionColor(permission.PermissionLevel)">
                                                @permission.PermissionLevel
                                            </MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="@(() => RevokeAccess(permission))"
                                                           Title="Revoke access"/>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No explicit permissions granted</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int DashboardId { get; set; }

    private bool _loading = true;
    private bool _isGranting;
    private List<DashboardPermissionData> _permissions = new();
    private Dictionary<string, string> _userCache = new();

    private string? _selectedUserId;
    private DashboardPermissionLevel _selectedPermissionLevel = DashboardPermissionLevel.View;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        _loading = true;
        try
        {
            _permissions = await Mediator.Send(new GetDashboardPermissionsQuery(DashboardId));
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IEnumerable<string>> SearchUsers(string searchText, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(searchText) || searchText.Length < 2)
        {
            return Array.Empty<string>();
        }

        var users = await UserManagementService.GetUsersAsync(searchText, cancellationToken);

        // Cache user names for display
        foreach (var user in users)
        {
            _userCache[user.ExternalId] = user.DisplayName ?? user.UserName;
        }

        return users.Select(u => u.ExternalId).ToList();
    }

    private async Task GrantAccess()
    {
        if (string.IsNullOrEmpty(_selectedUserId))
        {
            return;
        }

        _isGranting = true;

        try
        {
            var command = new ShareDashboardCommand(
                DashboardId: DashboardId,
                UserId: _selectedUserId,
                PermissionLevel: _selectedPermissionLevel
            );

            await Mediator.Send(command);
            Snackbar.Add("Access granted successfully", Severity.Success);

            _selectedUserId = null;
            await LoadPermissions();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error granting access: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isGranting = false;
        }
    }

    private async Task RevokeAccess(DashboardPermissionData permission)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Revoke Access",
            $"Revoke {permission.PermissionLevel} access for {permission.UserName}?",
            yesText: "Revoke",
            cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                await Mediator.Send(new RevokeDashboardPermissionCommand(permission.Id));
                Snackbar.Add("Access revoked successfully", Severity.Success);
                await LoadPermissions();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error revoking access: {ex.Message}", Severity.Error);
            }
        }
    }

    private static Color GetPermissionColor(DashboardPermissionLevel level)
    {
        return level switch
        {
            DashboardPermissionLevel.View => Color.Info,
            DashboardPermissionLevel.Edit => Color.Warning,
            DashboardPermissionLevel.Admin => Color.Error,
            _ => Color.Default
        };
    }

    private void Close()
    {
        MudDialog.Close();
    }
}
