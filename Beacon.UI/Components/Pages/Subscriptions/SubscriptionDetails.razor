@page "/subscriptions/{id:int}"
@inherits BasePageComponent
@using Beacon.Core.Models.QueryExecutionHistory
@using Beacon.Core.Models.Subscriptions
@using Beacon.Core.Models.Recipients
@using Beacon.Core.Models.Anomaly
@using Beacon.Core.Data.Enums
@using Beacon.Core.Services
@using Beacon.Core.Worker
@using Beacon.UI.Helpers
@using SortDirection = MudBlazor.SortDirection

<BeaconPageTitle Title="Subscription Details"/>

<div class="beacon-aq">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (Model != null)
    {
        <BeaconPageHero Variant="signal" Emphasis="@Model.QueryName">
            <Eyebrow>
                <a href="/subscriptions" class="mono" style="color:inherit;text-decoration:none;">Subscriptions</a>
                <span class="page-hero__sep">/</span>
                <span class="mono">#@Model.SubscriptionId</span>
                <span class="page-hero__sep">·</span>
                @if (isSubscriptionActive)
                {
                    <span class="pill pill--ok" style="display:inline-flex;align-items:center;gap:4px;">
                        <span style="width:6px;height:6px;border-radius:50%;background:var(--ok);"></span>ACTIVE
                    </span>
                }
                else
                {
                    <span class="pill pill--neutral" style="display:inline-flex;align-items:center;gap:4px;">
                        <span style="width:6px;height:6px;border-radius:50%;background:var(--text-muted);"></span>ARCHIVED
                    </span>
                }
                @if (Model.AiActorId.HasValue)
                {
                    <span class="page-hero__sep">·</span>
                    <span class="pill pill--info mono" style="font-size:10px;">AI</span>
                }
            </Eyebrow>
            <Sub>
                @if (!string.IsNullOrEmpty(_cronDescription))
                {
                    <span>@_cronDescription</span>
                }
                @if (!string.IsNullOrEmpty(_cronNextAt))
                {
                    <span style="opacity:0.5;">·</span>
                    <span>next </span><span class="mono">@_cronNextAt</span>
                }
            </Sub>
            <Actions>
                <button class="btn btn--primary" @onclick="TestSubscription" disabled="@(!_canWrite)">
                    <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:13px;margin-right:3px;" />Test now
                </button>
                <button class="btn" @onclick="ArchiveSubscription" disabled="@(!_isAdmin || !isSubscriptionActive)">
                    <MudIcon Icon="@Icons.Material.Rounded.Archive" Style="font-size:13px;margin-right:3px;" />Archive
                </button>
            </Actions>
        </BeaconPageHero>

        <!-- KPI row -->
        <div class="kpi-grid">
            <KpiCard Dot="info" Label="Total executions" Value="@GetTotalExecutions().ToString()"
                     SubText="@(GetTotalExecutions() == 0 ? "never run" : "to date")" />
            <KpiCard Dot="brand" Label="Notifications sent" Value="@GetTotalNotifications().ToString()"
                     SubText="@(GetTotalNotifications() == 0 ? "none yet" : "delivered")" />
            <KpiCard Dot="ok" Label="Recipients" Value="@Model.Recipients.Count.ToString()"
                     SubText="@(Model.Recipients.Count == 0 ? "none configured" : "configured")" />
            @if (Model.AnomalyConfig?.Enabled == true)
            {
                <KpiCard Dot="warn" Label="Anomaly detection" Value="ON"
                         SubText="@($"{Model.AnomalyConfig.Sensitivity.ToString().ToLower()} sensitivity")" />
            }
            else
            {
                <KpiCard Dot="warn" Label="Latest results" Value="@GetLatestResultCount().ToString()"
                         SubText="@(GetTotalExecutions() == 0 ? "no executions yet" : "last run")" />
            }
        </div>

        <!-- Main Content Tabs -->
        <MudPaper Elevation="2" Class="pa-0" Style="border-radius: 12px; overflow: hidden;">
            <MudTabs Elevation="0"
                     Rounded="false"
                     PanelClass="tab-panel-content"
                     ApplyEffectsToContainer="true"
                     Color="Color.Primary"
                     SliderColor="Color.Primary">

                <!-- Overview Tab -->
                <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
                    <div class="row row--2-up" style="align-items:start;">
                        <div class="q-section">
                            <!-- Query configuration -->
                            <div class="card">
                                <div class="card__head">
                                    <MudIcon Icon="@Icons.Material.Rounded.Code" Style="font-size:15px;color:var(--text-muted);" />
                                    <h3 class="card__title">Query configuration</h3>
                                </div>
                                <div class="card__body">
                                    <div class="kv">
                                        <div class="kv__row">
                                            <span class="kv__label">Query</span>
                                            <span class="kv__value">
                                                <a href="@($"queries/{Model.QueryId}")" class="mono" style="color:var(--brand-500);">@Model.QueryName</a>
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Schedule</span>
                                            <span class="kv__value">
                                                <span>@_cronDescription</span>
                                                <span class="pill pill--neutral mono" style="font-size:10px;margin-left:6px;">@Model.CronExpression</span>
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Result limit</span>
                                            <span class="kv__value mono">
                                                @(Model.MaxRows.HasValue ? Model.MaxRows + " rows" : "no limit")
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Min row threshold</span>
                                            <span class="kv__value">
                                                @if (Model.MinimumRowCount.HasValue)
                                                {
                                                    <span class="mono">≥ @Model.MinimumRowCount rows</span>
                                                    <span class="pill pill--warn mono" style="font-size:10px;margin-left:6px;">active</span>
                                                }
                                                else
                                                {
                                                    <span class="mono" style="color:var(--text-muted);">none</span>
                                                }
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Query timeout</span>
                                            <span class="kv__value mono">
                                                @(Model.TimeoutSeconds.HasValue ? Model.TimeoutSeconds + " seconds" : "no timeout")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Parameters.ToJson()) && Model.Parameters.ToJson() != "{}" && Model.Parameters.ToJson() != "[]")
                            {
                                <div class="card">
                                    <div class="card__head">
                                        <MudIcon Icon="@Icons.Material.Rounded.DataObject" Style="font-size:15px;color:var(--text-muted);" />
                                        <h3 class="card__title">Query parameters</h3>
                                    </div>
                                    <div class="card__body">
                                        <pre class="mono" style="margin:0;font-size:12px;color:var(--text);white-space:pre-wrap;">@Model.Parameters.ToJson()</pre>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="q-section">
                            <!-- Notification settings -->
                            <div class="card">
                                <div class="card__head">
                                    <MudIcon Icon="@Icons.Material.Rounded.Settings" Style="font-size:15px;color:var(--text-muted);" />
                                    <h3 class="card__title">Notification settings</h3>
                                </div>
                                <div class="card__body">
                                    <div class="kv">
                                        <div class="kv__row">
                                            <span class="kv__label">Send notification</span>
                                            <span class="kv__value">
                                                <span class="pill pill--info mono" style="font-size:10px;">@GetNotificationTriggerLabel()</span>
                                                <span style="margin-left:8px;color:var(--text-muted);">@GetNotificationTriggerDescription()</span>
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Include attachment</span>
                                            <span class="kv__value">
                                                @if (Model.IncludeAttachment)
                                                {
                                                    <span class="pill pill--ok mono" style="font-size:10px;">enabled</span>
                                                    <span class="mono" style="margin-left:6px;color:var(--text-muted);">@Model.ResultAttachmentType</span>
                                                }
                                                else
                                                {
                                                    <span class="pill pill--neutral mono" style="font-size:10px;">disabled</span>
                                                }
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Show query</span>
                                            <span class="kv__value">
                                                <span class="pill @(Model.ShowQuery ? "pill--ok" : "pill--neutral") mono" style="font-size:10px;">
                                                    @(Model.ShowQuery ? "enabled" : "disabled")
                                                </span>
                                                <span style="margin-left:8px;color:var(--text-muted);">SQL in notifications</span>
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Store results</span>
                                            <span class="kv__value">
                                                <span class="pill @(Model.StoreResults ? "pill--ok" : "pill--neutral") mono" style="font-size:10px;">
                                                    @(Model.StoreResults ? "enabled" : "disabled")
                                                </span>
                                                <span style="margin-left:8px;color:var(--text-muted);">persist query results</span>
                                            </span>
                                        </div>
                                        <div class="kv__row">
                                            <span class="kv__label">Create tasks</span>
                                            <span class="kv__value">
                                                <span class="pill @(Model.CreateTasks ? "pill--ok" : "pill--neutral") mono" style="font-size:10px;">
                                                    @(Model.CreateTasks ? "enabled" : "disabled")
                                                </span>
                                                <span style="margin-left:8px;color:var(--text-muted);">auto-create tracking tasks</span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </MudTabPanel>

                <!-- Recipients Tab -->
                <MudTabPanel Text="Recipients" Icon="@Icons.Material.Filled.Group" BadgeData="@Model.Recipients.Count" BadgeColor="Color.Primary">
                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                Notification Recipients (@Model.Recipients.Count)
                            </MudText>
                            <BeaconButton Variant="primary"
                                          Icon="@Icons.Material.Filled.Add"
                                          OnClick="@AddRecipientsAsync"
                                          Disabled="@(!_canWrite)">
                                Add Recipient
                            </BeaconButton>
                        </MudStack>

                        <MudGrid Spacing="3">
                            @foreach (var recipient in Model.Recipients)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudPaper Elevation="0" Class="recipient-card pa-4">
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudChip T="string"
                                                         Size="Size.Small"
                                                         Color="Color.Primary"
                                                         Icon="@GetNotificationIcon(recipient.NotificationType)">
                                                    @recipient.NotificationType
                                                </MudChip>
                                                <BeaconIconButton Icon="@Icons.Material.Filled.Delete"
                                                                  Variant="danger"
                                                                  Size="sm"
                                                                  Disabled="@(!_isAdmin || Model.Recipients.Count <= 1)"
                                                                  OnClick="@(() => RemoveRecipientAsync(recipient))" />
                                            </MudStack>

                                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@recipient.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="word-break: break-all;">
                                                @UiHelpers.FormatRecipientDestination(recipient)
                                            </MudText>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudStack>
                </MudTabPanel>

                <!-- Anomaly Detection Tab -->
                @if (Model.AnomalyConfig?.Enabled == true)
                {
                    <MudTabPanel Text="Anomaly Detection" Icon="@Icons.Material.Filled.BubbleChart">
                        <MudStack Spacing="4">
                            <!-- Configuration Summary -->
                            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.BubbleChart">
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">Anomaly Detection Active</MudText>
                                <MudText Typo="Typo.body2">
                                    This subscription monitors result counts using @Model.AnomalyConfig.DetectionMethod with @Model.AnomalyConfig.Sensitivity.ToString().ToLower() sensitivity.
                                </MudText>
                            </MudAlert>

                            <MudGrid Spacing="3">
                                <MudItem xs="12" sm="6" md="3">
                                    <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid var(--mud-palette-primary); border-radius: 12px;">
                                        <MudStack Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Science" Color="Color.Primary" />
                                            <div class="config-label">Detection Method</div>
                                            <div class="config-value">@Model.AnomalyConfig.DetectionMethod</div>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid var(--mud-palette-warning); border-radius: 12px;">
                                        <MudStack Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Warning" />
                                            <div class="config-label">Sensitivity</div>
                                            <div class="config-value">@Model.AnomalyConfig.Sensitivity</div>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid var(--mud-palette-info); border-radius: 12px;">
                                        <MudStack Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info" />
                                            <div class="config-label">Lookback Period</div>
                                            <div class="config-value">@Model.AnomalyConfig.LookbackDays days</div>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid var(--mud-palette-success); border-radius: 12px;">
                                        <MudStack Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.DataArray" Color="Color.Success" />
                                            <div class="config-label">Min Data Points</div>
                                            <div class="config-value">@Model.AnomalyConfig.MinimumDataPoints</div>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudPaper Elevation="0" Class="pa-4" Style="background: rgba(76, 175, 80, 0.1); border-radius: 12px;">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Large" />
                                            <div>
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Alert on Increase</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    @(Model.AnomalyConfig.AlertOnIncrease ? "Enabled - Alerts when results spike above threshold" : "Disabled")
                                                </MudText>
                                            </div>
                                            <MudSpacer />
                                            <MudChip T="string" Color="@(Model.AnomalyConfig.AlertOnIncrease ? Color.Success : Color.Default)">
                                                @(Model.AnomalyConfig.AlertOnIncrease ? "ON" : "OFF")
                                            </MudChip>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudPaper Elevation="0" Class="pa-4" Style="background: rgba(244, 67, 54, 0.1); border-radius: 12px;">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Large" />
                                            <div>
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Alert on Decrease</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    @(Model.AnomalyConfig.AlertOnDecrease ? "Enabled - Alerts when results drop below threshold" : "Disabled")
                                                </MudText>
                                            </div>
                                            <MudSpacer />
                                            <MudChip T="string" Color="@(Model.AnomalyConfig.AlertOnDecrease ? Color.Error : Color.Default)">
                                                @(Model.AnomalyConfig.AlertOnDecrease ? "ON" : "OFF")
                                            </MudChip>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>

                            <!-- Anomaly Chart -->
                            @if (_anomalyChartData?.HasAnomalyDetection == true && _anomalyChartData.DataPoints.Any())
                            {
                                <div class="chart-container">
                                    <MudStack Spacing="3">
                                        <div class="section-header">
                                            <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                                <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="mr-2" Style="vertical-align: middle;" />
                                                Result Count Trends & Thresholds
                                            </MudText>
                                        </div>

                                        @if (_anomalyChartData.BaselineMean.HasValue)
                                        {
                                            <MudPaper Elevation="0" Class="pa-3" Style="background: white; border-radius: 8px;">
                                                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
                                                    <div>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">BASELINE</MudText>
                                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">@_anomalyChartData.BaselineMean.Value.ToString("N0")</MudText>
                                                    </div>

                                                    @if (_anomalyChartData.LowerThreshold.HasValue)
                                                    {
                                                        <MudDivider Vertical="true" FlexItem="true" />
                                                        <div>
                                                            <MudText Typo="Typo.caption" Color="Color.Error">LOWER THRESHOLD</MudText>
                                                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: var(--mud-palette-error);">
                                                                @_anomalyChartData.LowerThreshold.Value.ToString("N0")
                                                            </MudText>
                                                        </div>
                                                    }

                                                    @if (_anomalyChartData.UpperThreshold.HasValue)
                                                    {
                                                        <MudDivider Vertical="true" FlexItem="true" />
                                                        <div>
                                                            <MudText Typo="Typo.caption" Color="Color.Warning">UPPER THRESHOLD</MudText>
                                                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: var(--mud-palette-warning);">
                                                                @_anomalyChartData.UpperThreshold.Value.ToString("N0")
                                                            </MudText>
                                                        </div>
                                                    }
                                                </MudStack>
                                            </MudPaper>
                                        }

                                        <MudChart ChartType="ChartType.Line"
                                                  ChartSeries="@_anomalyChartSeries"
                                                  ChartLabels="@_anomalyXAxisLabels"
                                                  Width="@ChartHelper.DefaultChartWidth"
                                                  Height="@ChartHelper.DefaultChartHeight"
                                                  ChartOptions="@_anomalyChartOptions" />

                                        @if (_anomalyChartData.DataPoints.Any(x => x.IsAnomaly || x.NotificationSent))
                                        {
                                            <div>
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; margin-bottom: 12px;">Recent Detection Events</MudText>
                                                <MudStack Row="true" Spacing="2" Style="flex-wrap: wrap;">
                                                    @foreach (var point in _anomalyChartData.DataPoints.Where(x => x.IsAnomaly || x.NotificationSent).OrderByDescending(x => x.DateTime).Take(10))
                                                    {
                                                        <MudPaper Elevation="0" Class="pa-2" Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                                @if (point.IsAnomaly)
                                                                {
                                                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                                                                }
                                                                @if (point.NotificationSent)
                                                                {
                                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Success" Size="Size.Small" />
                                                                }
                                                                <div>
                                                                    <MudText Typo="Typo.caption" Style="font-weight: 600;">@point.DateTime.ToString("MMM dd HH:mm")</MudText>
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@point.ResultCount results</MudText>
                                                                </div>
                                                                @if (!string.IsNullOrEmpty(point.AnomalySeverity))
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">@point.AnomalySeverity</MudChip>
                                                                }
                                                            </MudStack>
                                                        </MudPaper>
                                                    }
                                                </MudStack>
                                            </div>
                                        }
                                    </MudStack>
                                </div>
                            }
                        </MudStack>
                    </MudTabPanel>
                }

                <!-- Execution History Tab -->
                <MudTabPanel Text="Execution History" Icon="@Icons.Material.Filled.History">
                    <MudDataGrid @ref="_notificationsDataGrid"
                                 ServerData="NotificationsServerReload"
                                 T="QueryExecutionHistoryData"
                                 Hover="true"
                                 Filterable="false"
                                 Elevation="0"
                                 Style="border-radius: 8px;">
                        <Columns>
                            <TemplateColumn Title="Execution" Sortable="false">
                                <CellTemplate>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            <MudLink Href="@($"query-execution-history/{context.Item.QueryExecutionHistoryId}")">
                                                #@context.Item.QueryExecutionHistoryId
                                            </MudLink>
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @context.Item.CreatedTime.ToString("MMM dd, yyyy HH:mm:ss")
                                        </MudText>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>

                            <TemplateColumn Title="Recipients" Sortable="false">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Group">
                                        @context.Item.Notifications.Count recipient(s)
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>

                            <TemplateColumn Title="Results" Sortable="false">
                                <CellTemplate>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.DataArray" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Item.ResultCount</MudText>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>

                            <TemplateColumn Title="Status" Sortable="false">
                                <CellTemplate>
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@GetNotificationStatusColor(context.Item.NotificationStatus)"
                                             Icon="@GetNotificationStatusIcon(context.Item.NotificationStatus)">
                                        @context.Item.NotificationStatus
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="QueryExecutionHistoryData" />
                        </PagerContent>
                    </MudDataGrid>
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    }
</div>

@inject ISubscriptionService Service
@inject IQueryService QueryService
@inject IJobService JobService
@inject INotificationService NotificationsService
@inject IAnomalyDetectionService AnomalyDetectionService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject Beacon.Core.Authorization.IBeaconAuthorizationProvider AuthorizationProvider
@inject Beacon.Core.Authorization.IBeaconUserContext UserContext

@code
{
    [Parameter]
    public int Id { get; set; }

    public SubscriptionDetailsData? Model;

    private bool _loading;

    private QueryExecutionHistoryListData List { get; set; } = new();

    MudDataGrid<QueryExecutionHistoryData>? _notificationsDataGrid;

    private bool isSubscriptionActive;
    private bool _canWrite;
    private bool _isAdmin;

    private string? _cronDescription;
    private string? _cronNextAt;

    // Anomaly chart data
    private AnomalyChartData? _anomalyChartData;
    private List<ChartSeries<double>> _anomalyChartSeries = new();
    private string[] _anomalyXAxisLabels = Array.Empty<string>();
    private LineChartOptions _anomalyChartOptions = new();

    private async Task<GridData<QueryExecutionHistoryData>> NotificationsServerReload(GridState<QueryExecutionHistoryData> state, CancellationToken cancellationToken)
    {
        var gridRequest = DataGridHelper.BuildSortedRequest<GetQueryExecutionHistoryRequest, QueryExecutionHistoryData>(state);

        gridRequest.SubscriptionId = Id;

        List = await NotificationsService.GetQueryExecutionHistory(gridRequest, CancellationToken.None);

        return new GridData<QueryExecutionHistoryData> {
            TotalItems = List.Data.Count,
            Items = List.Data
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _canWrite = await AuthorizationProvider.HasWritePermissionAsync();
        _isAdmin = UserContext.HasClaim("role", "Admin") ||
                   UserContext.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", "Admin") ||
                   UserContext.HasClaim("beacon:role", "Admin");
        await Load();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _cronDescription = Model?.CronExpression?.GetCronDescription();

        var cronNextAt = Model?.CronExpression?.GetCronNextAt();
        var localNextAt = await JSRuntime.InvokeAsync<string>("toLocalTime", cronNextAt);

        _cronNextAt = $"{localNextAt}";

    }

    private async Task Load()
    {
        _loading = true;

        Model = await Service.GetSubscriptionDetails(Id, CancellationToken.None);

        isSubscriptionActive = Model?.Status == "Active";

        // Load anomaly chart data if anomaly detection is enabled
        if (Model?.AnomalyConfig?.Enabled == true)
        {
            _anomalyChartData = await AnomalyDetectionService.GetAnomalyChartDataAsync(Id, 30, CancellationToken.None);
            PrepareAnomalyChart();
        }

        // Only reload grid if it's been initialized
        if (_notificationsDataGrid != null)
        {
            await _notificationsDataGrid.ReloadServerData();
        }

        _loading = false;
    }

    private void PrepareAnomalyChart()
    {
        if (_anomalyChartData == null || !_anomalyChartData.DataPoints.Any())
            return;

        var orderedPoints = _anomalyChartData.DataPoints.OrderBy(x => x.DateTime).ToList();

        _anomalyXAxisLabels = orderedPoints.Select(x => x.DateTime.ToString("MM/dd HH:mm")).ToArray();

        _anomalyChartSeries = new List<ChartSeries<double>>
        {
            new()
            {
                Name = "Result Count",
                Data = orderedPoints.Select(x => (double)x.ResultCount).ToArray()
            }
        };

        // Use rolling baseline if available (shows baseline evolution), otherwise use static baseline
        if (_anomalyChartData.RollingBaseline != null && _anomalyChartData.RollingBaseline.Any())
        {
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Rolling Baseline",
                Data = _anomalyChartData.RollingBaseline.Select(x => (double)x).ToArray()
            });
        }
        else if (_anomalyChartData.BaselineMean.HasValue)
        {
            var baselineValue = (double)_anomalyChartData.BaselineMean.Value;
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Baseline",
                Data = Enumerable.Repeat(baselineValue, orderedPoints.Count).ToArray()
            });
        }

        // Use rolling upper threshold if available
        if (_anomalyChartData.RollingUpperThreshold != null && _anomalyChartData.RollingUpperThreshold.Any())
        {
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Upper Threshold",
                Data = _anomalyChartData.RollingUpperThreshold.Select(x => (double)x).ToArray()
            });
        }
        else if (_anomalyChartData.UpperThreshold.HasValue)
        {
            var upperValue = (double)_anomalyChartData.UpperThreshold.Value;
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Upper Threshold",
                Data = Enumerable.Repeat(upperValue, orderedPoints.Count).ToArray()
            });
        }

        // Use rolling lower threshold if available
        if (_anomalyChartData.RollingLowerThreshold != null && _anomalyChartData.RollingLowerThreshold.Any())
        {
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Lower Threshold",
                Data = _anomalyChartData.RollingLowerThreshold.Select(x => (double)x).ToArray()
            });
        }
        else if (_anomalyChartData.LowerThreshold.HasValue)
        {
            var lowerValue = (double)_anomalyChartData.LowerThreshold.Value;
            _anomalyChartSeries.Add(new ChartSeries<double>
            {
                Name = "Lower Threshold",
                Data = Enumerable.Repeat(lowerValue, orderedPoints.Count).ToArray()
            });
        }

        _anomalyChartOptions = ChartHelper.CreateAnomalyChartOptions();
    }

    private async Task ArchiveSubscription()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning",
            "Do you want to archive this subscription?",
            yesText: "Yes",
            cancelText: "No");

        if (result == null || !result.Value)
        {
            return;
        }

        await Service.DeleteSubscription(Id, CancellationToken.None);

        await Load();
    }

    private async Task TestSubscription()
    {
        await JobService.ExecuteQuery(Id);

        await Load();
    }

    private async Task AddRecipientsAsync()
    {
        var parameters = new DialogParameters<AddRecipientsDialog> { { x => x.Subscription, Model }};

        var dialog = await DialogService.ShowAsync<AddRecipientsDialog>("", parameters);
        var result = await dialog.Result;

        if (!result?.Canceled ?? false)
        {
            await Load();
        }
    }

    private async Task RemoveRecipientAsync(RecipientData recipientData)
    {
        await Service.RemoveRecipient(Model!.SubscriptionId, recipientData!.RecipientId!.Value, CancellationToken.None);

        await Load();
    }

    private string GetHeaderSubtitle()
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(_cronDescription))
            parts.Add(_cronDescription);
        if (!string.IsNullOrEmpty(_cronNextAt))
            parts.Add($"Next: {_cronNextAt}");

        return string.Join("  ·  ", parts);
    }

    // Helper methods for UI
    private int GetTotalExecutions()
    {
        return List?.Data?.Count ?? 0;
    }

    private int GetTotalNotifications()
    {
        return List?.Data?.Sum(x => x.Notifications.Count) ?? 0;
    }

    private int GetLatestResultCount()
    {
        return List?.Data?.OrderByDescending(x => x.CreatedTime).FirstOrDefault()?.ResultCount ?? 0;
    }

    private string GetNotificationIcon(NotificationType type)
    {
        return type switch
        {
            NotificationType.Email => Icons.Material.Filled.Email,
            NotificationType.Teams => Icons.Material.Filled.Groups,
            NotificationType.Slack => Icons.Material.Filled.Chat,
            NotificationType.Jira => Icons.Material.Filled.BugReport,
            _ => Icons.Material.Filled.Notifications
        };
    }

    private Color GetNotificationStatusColor(NotificationStatus status)
    {
        return status switch
        {
            NotificationStatus.NotificationSent => Color.Success,
            NotificationStatus.NoResults => Color.Info,
            NotificationStatus.Timeout => Color.Error,
            NotificationStatus.Failed => Color.Error,
            NotificationStatus.NotificationSilenced => Color.Warning,
            _ => Color.Default
        };
    }

    private string GetNotificationStatusIcon(NotificationStatus status)
    {
        return status switch
        {
            NotificationStatus.NotificationSent => Icons.Material.Filled.CheckCircle,
            NotificationStatus.NoResults => Icons.Material.Filled.Info,
            NotificationStatus.Timeout => Icons.Material.Filled.Error,
            NotificationStatus.Failed => Icons.Material.Filled.Error,
            NotificationStatus.NotificationSilenced => Icons.Material.Filled.NotificationsOff,
            _ => Icons.Material.Filled.Circle
        };
    }

    private string GetNotificationTriggerLabel()
    {
        return Model?.NotificationTrigger switch
        {
            NotificationTrigger.OnResultCountChange => "On Change",
            NotificationTrigger.Always => "Always",
            NotificationTrigger.OnResultCountIncrease => "On Increase",
            _ => "Unknown"
        };
    }

    private string GetNotificationTriggerDescription()
    {
        return Model?.NotificationTrigger switch
        {
            NotificationTrigger.OnResultCountChange => "When result count changes",
            NotificationTrigger.Always => "Every execution",
            NotificationTrigger.OnResultCountIncrease => "When result count increases",
            _ => "Unknown trigger"
        };
    }
