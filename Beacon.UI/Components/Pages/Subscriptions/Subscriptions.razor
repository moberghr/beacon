@page "/subscriptions"
@inherits BasePageComponent 
@using Beacon.Core.Models.Subscriptions
@using Beacon.Core.Services
@inject ISubscriptionService service

<BeaconPageTitle Title="Subscriptions"/>

<div class="@RootClass">
    <BeaconPageHero Variant="signal"
                    Prefix="Active"
                    Emphasis="subscription"
                    Suffix="monitor.">
        <Eyebrow>
            <span>Beacon</span>
            <span class="page-hero__sep">/</span>
            <span>Subscriptions</span>
        </Eyebrow>
        <Sub>List of defined subscriptions. Click on a subscription to view more.</Sub>
    </BeaconPageHero>
    <MudDataGrid @ref="_dataGrid" ServerData="ServerReload" T="SubscriptionData" RowClick="OnRowClick" Hover="true" Filterable="false">
        <ToolBarContent>
            <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Placeholder="Search by query name..." Adornment="Adornment.Start"
                          Immediate="true"
                          DebounceInterval="300"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0">
            </MudTextField>

        </ToolBarContent>

        <Columns>
            <PropertyColumn Property="x => x.SubscriptionId" Title="Subscription Id" />
            <PropertyColumn Property="x => x.QueryId" Title="Query Id" />
            <PropertyColumn Property="x => x.QueryName" Title="Query Name" />
            <TemplateColumn Title="Recipients">
                <CellTemplate>
                        @($"[{context.Item.Recipients.Count}] {string.Join(", ", context.Item.Recipients.Select(y => y.Name).ToList()).GetSubstring(30)}")
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.CronExpression" Title="Cron Expression"/>
            <TemplateColumn Title="Source" Sortable="false">
                <CellTemplate>
                    <SourceChip AiActorId="@context.Item.AiActorId" AiActorName="@context.Item.AiActorName" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="SubscriptionData"/>
        </PagerContent>
    </MudDataGrid>
</div>

@code {

    private List<SubscriptionData> SubscriptionsList { get; set; } = new();
    MudDataGrid<SubscriptionData>? _dataGrid;
    private bool _loading;
    private string _searchString;

    private async Task<GridData<SubscriptionData>> ServerReload(GridState
        <SubscriptionData> state, CancellationToken cancellationToken)
    {
        SubscriptionsList = await service.GetSubscriptions(null, null, null, _searchString, CancellationToken.None);

        return new GridData<SubscriptionData>
        {
            TotalItems = SubscriptionsList.Count(),
            Items = SubscriptionsList
        };
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        _dataGrid?.ReloadServerData();
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<SubscriptionData> args)
    {
        NavManager.NavigateTo($"subscriptions/{args.Item.SubscriptionId}");
    }

    private void NewSubscription()
    {
        NavManager.NavigateTo("subscriptions/create");
    }

}