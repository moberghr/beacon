@page "/beacon/projects"
@inherits BasePageComponent
@using MediatR
@using Beacon.Core.Handlers.Projects
@inject IMediator Mediator

<BeaconPageTitle Title="Projects"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <MudStack Spacing="4">
        @* Page Header *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">Projects</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Manage multi-source projects with data quality tracking and repository scanning
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateProjectDialog">
                Create Project
            </MudButton>
        </MudStack>

        @* Loading State *@
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
        }
        @* Empty State *@
        else if (_projects.Count == 0)
        {
            <MudPaper Elevation="0" Class="pa-8 text-center" Style="border: 2px dashed var(--mud-palette-lines-default); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Size="Size.Large" Color="Color.Secondary" Class="mb-3"/>
                <MudText Typo="Typo.h6" Color="Color.Secondary">No projects yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Create your first project to start tracking data quality and code references across multiple sources.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateProjectDialog">
                    Create First Project
                </MudButton>
            </MudPaper>
        }
        @* Project Cards *@
        else
        {
            <MudGrid Spacing="3">
                @foreach (var project in _projects)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" Style="border-radius: 12px; cursor: pointer;" @onclick="@(() => NavigateToProject(project.Id))">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.FolderSpecial"/>
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@project.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@project.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetHealthColor(project.QualityScore)"
                                             Variant="Variant.Filled">
                                        @(project.QualityScore.HasValue ? $"{project.QualityScore:F0}%" : "N/A")
                                    </MudChip>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (!string.IsNullOrWhiteSpace(project.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3" Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @project.Description
                                    </MudText>
                                }
                                <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Color="Color.Secondary"/>
                                        <MudText Typo="Typo.caption">@project.DataSourceCount data sources</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Secondary"/>
                                        <MudText Typo="Typo.caption">@project.RepositoryCount repos</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="px-2 pb-1">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetScanStatusColor(project.LastScanStatus)"
                                             Variant="Variant.Outlined"
                                             Icon="@GetScanStatusIcon(project.LastScanStatus)">
                                        @(project.LastScanStatus ?? "Never scanned")
                                    </MudChip>
                                    @if (project.LastScanAt.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @project.LastScanAt.Value.ToString("MMM dd HH:mm")
                                        </MudText>
                                    }
                                </MudStack>
                                <MudSpacer/>
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => NavigateToProject(project.Id))"/>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudStack>
</MudContainer>

@inject ISnackbar Snackbar
@inject IDialogService DialogService

@code {
    private List<ProjectSummaryEntry> _projects = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new GetProjectsQuery());
            _projects = result.Entries;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load projects: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateProjectDialog()
    {
        var options = await CreateResponsiveDialogOptions(MaxWidth.Medium);
        var dialog = await DialogService.ShowAsync<CreateProjectDialog>("Create Project", options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadProjects();
            Snackbar.Add("Project created successfully", Severity.Success);
        }
    }

    private void NavigateToProject(int projectId)
    {
        NavManager.NavigateTo($"beacon/projects/{projectId}");
    }

    private static Color GetHealthColor(double? score) => score switch
    {
        >= 90 => Color.Success,
        >= 70 => Color.Warning,
        < 70 => Color.Error,
        _ => Color.Default
    };

    private static Color GetScanStatusColor(string? status) => status switch
    {
        "Completed" => Color.Success,
        "InProgress" => Color.Info,
        "Failed" => Color.Error,
        _ => Color.Default
    };

    private static string GetScanStatusIcon(string? status) => status switch
    {
        "Completed" => Icons.Material.Filled.CheckCircle,
        "InProgress" => Icons.Material.Filled.Sync,
        "Failed" => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.HelpOutline
    };
}
