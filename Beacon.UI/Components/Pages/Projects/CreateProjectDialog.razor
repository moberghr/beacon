@using MediatR
@using Beacon.Core.Handlers.Projects
@inject IMediator Mediator

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="nodes"
            Eyebrow="WORKSPACE &nbsp;/&nbsp; PROJECTS"
            Prefix="Create a new"
            Emphasis="project"
            Suffix="."
            Sub="Group queries, data sources, and repos together so dashboards and alerts have shared context." />
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <BeaconTextField @bind-Value="_name"
                                 Label="Project Name"
                                 Required="true"
                                 MaxLength="200" />

                <BeaconTextField @bind-Value="_description"
                                 Label="Description"
                                 Multiline="true"
                                 Rows="3"
                                 MaxLength="1000"
                                 HelpText="Briefly describe what this project tracks" />

                @* Data Sources *@
                <MudDivider Class="my-1"/>
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Data Sources</MudText>
                <DataSourceSelect Label="Link Data Sources"
                                   MultiSelection="true"
                                   SelectedValues="_selectedDataSourceIds"
                                   SelectedValuesChanged="@(ids => _selectedDataSourceIds = ids)"
                                   HelperText="Select existing data sources to include in this project"/>

                @* Repositories *@
                <MudDivider Class="my-1"/>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Repositories (@_repoUrls.Count)</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Color="Color.Primary"
                               Variant="Variant.Text"
                               OnClick="AddRepoField">
                        Add Repo
                    </MudButton>
                </MudStack>

                <BeaconTextField @bind-Value="_accessToken"
                                 Label="GitHub Access Token"
                                 Placeholder="ghp_..."
                                 InputType="password"
                                 HelpText="Required for private repositories. Token is encrypted at rest." />

                @if (_repoUrls.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No repositories added. Click "Add Repo" to link a GitHub repository.
                    </MudText>
                }
                else
                {
                    @for (var i = 0; i < _repoUrls.Count; i++)
                    {
                        var index = i;
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <div style="flex: 1;">
                                <BeaconTextField Value="@_repoUrls[index]"
                                                 ValueChanged="@(v => _repoUrls[index] = v ?? string.Empty)"
                                                 Label="@($"Repository URL {index + 1}")"
                                                 Placeholder="https://github.com/org/repo" />
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveRepo(index))"/>
                        </MudStack>
                    }
                }
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _submitting)">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                <span class="ml-2">Creating...</span>
            }
            else
            {
                <text>Create Project</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _submitting;

    private string? _name = string.Empty;
    private string? _description;
    private IReadOnlyCollection<int> _selectedDataSourceIds = [];
    private List<string> _repoUrls = new();
    private string? _accessToken;

    private void AddRepoField()
    {
        _repoUrls.Add(string.Empty);
    }

    private void RemoveRepo(int index)
    {
        _repoUrls.RemoveAt(index);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _submitting = true;
        try
        {
            await Mediator.Send(new CreateProjectCommand(
                _name ?? string.Empty,
                _description,
                _selectedDataSourceIds.ToList(),
                _repoUrls,
                _accessToken));

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
