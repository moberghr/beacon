@page "/admin/settings"
@inherits BasePageComponent
@using Beacon.Core
@using Beacon.Core.Authorization
@using Beacon.Core.Data.Enums
@using Beacon.Core.Models.Settings
@using Beacon.Core.Services
@using Beacon.Core.Data.Entities

<BeaconPageTitle Title="Admin Settings"/>

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-4 px-4">
    <PageHeader Icon="@Icons.Material.Filled.AdminPanelSettings" Title="Admin Settings"/>

    @if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Error" Class="my-4">You do not have permission to access this page.</MudAlert>
        return;
    }

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-4" />
        return;
    }

    @if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="my-4">@_error</MudAlert>
    }

    <MudTabs Elevation="2" Rounded="true" Class="my-4" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Settings">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_settings.BaseUrl"
                                  Label="Base URL"
                                  HelperText="Base URL of the Beacon admin UI (e.g., https://your-domain.com/beacon). Used for notification links."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="AI Configuration" Icon="@Icons.Material.Filled.Psychology">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_selectedProvider"
                               Label="Provider"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        @foreach (var provider in Enum.GetValues<AiProvider>())
                        {
                            <MudSelectItem Value="@((AiProvider?)provider)">@provider</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmModel"
                                  Label="Model"
                                  HelperText="e.g., gpt-4o, claude-sonnet-4-20250514"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmApiKey"
                                  Label="API Key"
                                  InputType="@(_showApiKey ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showApiKey = !_showApiKey)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmFastModel"
                                  Label="Fast Model (optional)"
                                  HelperText="For simple operations. Falls back to main model if empty."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmEndpoint"
                                  Label="Endpoint"
                                  HelperText="Required for Azure OpenAI"
                                  InputType="@(_showEndpoint ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showEndpoint ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showEndpoint = !_showEndpoint)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmRegion"
                                  Label="Region"
                                  HelperText="AWS Region for Bedrock (e.g., us-east-1)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.LlmSessionToken"
                                  Label="Session Token"
                                  HelperText="AWS temporary credentials"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Rate Limits &amp; Budget</MudText>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_settings.LlmMaxConcurrentRequests"
                                     Label="Max Concurrent Requests"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="1" Max="500" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_settings.LlmTokensPerMinute"
                                     Label="Tokens/Minute"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="1000" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_settings.LlmRequestsPerMinute"
                                     Label="Requests/Minute"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="1" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_settings.LlmMonthlyBudget"
                                     Label="Monthly Budget ($)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0m" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Change History" Icon="@Icons.Material.Filled.History">
            @if (_history == null)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_history.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No changes recorded yet.</MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Setting</th>
                            <th>Old Value</th>
                            <th>New Value</th>
                            <th>Changed By</th>
                            <th>Changed At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in _history)
                        {
                            <tr>
                                <td><MudText Typo="Typo.body2"><code>@h.SettingKey</code></MudText></td>
                                <td><MudText Typo="Typo.body2">@(h.OldValue ?? "—")</MudText></td>
                                <td><MudText Typo="Typo.body2">@(h.NewValue ?? "—")</MudText></td>
                                <td><MudText Typo="Typo.body2">@(h.ChangedByUserId ?? "System")</MudText></td>
                                <td><MudText Typo="Typo.body2">@h.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</MudText></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>
    </MudTabs>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@_saving"
                   OnClick="SaveSettings"
                   StartIcon="@Icons.Material.Filled.Save">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <text>Saving...</text>
            }
            else
            {
                <text>Save Settings</text>
            }
        </MudButton>
    </MudStack>
</MudContainer>

@inject IAppSettingsService SettingsService
@inject IBeaconUserContext UserContext
@inject BeaconConfiguration Configuration
@inject ISnackbar Snackbar

@code {
    private AppSettingsData _settings = new();
    private List<AppSettingHistory>? _history;
    private bool _loading = true;
    private bool _saving;
    private bool _isAdmin;
    private string? _error;
    private bool _showApiKey;
    private bool _showEndpoint;

    private AiProvider? _selectedProvider;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = UserContext.HasClaim("role", "Admin") ||
                   UserContext.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", "Admin");

        if (!_isAdmin)
        {
            _loading = false;
            return;
        }

        try
        {
            _settings = await SettingsService.GetSettingsAsync();
            _selectedProvider = _settings.LlmProvider;
            _history = await SettingsService.GetHistoryAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveSettings()
    {
        _saving = true;
        _error = null;

        try
        {
            // Sync UI fields back to DTO
            _settings.LlmProvider = _selectedProvider;

            await SettingsService.SaveSettingsAsync(_settings, UserContext.UserId);
            _history = await SettingsService.GetHistoryAsync();
            Snackbar.Add("Settings saved successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = $"Failed to save settings: {ex.Message}";
            Snackbar.Add("Failed to save settings.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

}
