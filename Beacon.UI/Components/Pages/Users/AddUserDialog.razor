@using Beacon.Core
@using Beacon.Core.Authorization
@using Beacon.Core.Helpers
@using Beacon.Core.Models.UserManagement
@using Beacon.Core.Services

<MudDialog Class="pb-2">
    <TitleContent>
        <BeaconDialogHeader Variant="grid"
            Eyebrow="USERS"
            Prefix="Add a"
            Emphasis="user"
            Suffix="." />
    </TitleContent>
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="_activeTab" ApplyEffectsToContainer="true" Elevation="0" Rounded="true" PanelClass="pa-4">
            @if (_configuration.UserManagement.AllowInternalUsers)
            {
                <MudTabPanel Text="Internal User" Icon="@Icons.Material.Filled.Lock">
                    <BeaconTextField @bind-Value="_internalRequest.UserName"
                                     Label="Username"
                                     Required="true" />

                    <BeaconTextField @bind-Value="_internalRequest.Email"
                                     Label="Email (optional)"
                                     InputType="email" />

                    <BeaconTextField @bind-Value="_internalRequest.DisplayName"
                                     Label="Display Name (optional)" />

                    <BeaconTextField @bind-Value="_internalRequest.Password"
                                     Label="Password"
                                     Required="true"
                                     InputType="@(_showInternalPassword ? "text" : "password")"
                                     AdornmentIcon="@(_showInternalPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                     OnAdornmentClick="@(() => _showInternalPassword = !_showInternalPassword)"
                                     ErrorText="@_passwordError" />

                    <BeaconSelect T="int"
                                  Label="Roles"
                                  MultiSelection="true"
                                  @bind-SelectedValues="_selectedInternalRoleIds"
                                  Items="@(_roles.Cast<object>())"
                                  ItemValueSelector="@(x => ((BeaconRoleData)x).Id)"
                                  ItemTextSelector="@(x => $"{((BeaconRoleData)x).Name} - {((BeaconRoleData)x).Description}")" />

                    <MudAlert Severity="Severity.Info" Dense="true">
                        <MudText Typo="Typo.caption">
                            Internal users authenticate with a password stored in Beacon.
                        </MudText>
                    </MudAlert>
                </MudTabPanel>
            }

            <MudTabPanel Text="External User" Icon="@Icons.Material.Filled.VpnKey">
                <BeaconTextField @bind-Value="_externalRequest.ExternalId"
                                 Label="External ID"
                                 HelpText="Must match the 'sub' claim from JWT/OAuth"
                                 Required="true" />

                <BeaconTextField @bind-Value="_externalRequest.UserName"
                                 Label="Username"
                                 Required="true" />

                <BeaconTextField @bind-Value="_externalRequest.Email"
                                 Label="Email (optional)"
                                 InputType="email" />

                <BeaconTextField @bind-Value="_externalRequest.DisplayName"
                                 Label="Display Name (optional)" />

                <BeaconSelect T="int"
                              Label="Roles"
                              MultiSelection="true"
                              @bind-SelectedValues="_selectedExternalRoleIds"
                              Items="@(_roles.Cast<object>())"
                              ItemValueSelector="@(x => ((BeaconRoleData)x).Id)"
                              ItemTextSelector="@(x => $"{((BeaconRoleData)x).Name} - {((BeaconRoleData)x).Description}")" />

                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        External users are pre-registered and authenticate via JWT/OAuth.
                        The External ID must match the 'sub' claim from the authentication token.
                    </MudText>
                </MudAlert>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
        <DialogSaveButton Text="Create User" Disabled="@(!CanSubmit)" OnClick="Submit" />
    </DialogActions>
</MudDialog>

@inject IUserManagementService UserService
@inject IRoleService RoleService
@inject ISnackbar Snackbar
@inject BeaconConfiguration _configuration

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private int _activeTab = 0;
    private bool _loading;
    private bool _showInternalPassword;
    private string? _passwordError;

    private CreateInternalUserRequest _internalRequest = new();
    private CreateExternalUserRequest _externalRequest = new();
    private List<BeaconRoleData> _roles = new();
    private IEnumerable<int> _selectedInternalRoleIds = new List<int>();
    private IEnumerable<int> _selectedExternalRoleIds = new List<int>();

    private bool CanSubmit
    {
        get
        {
            if (_loading) return false;
            if (_configuration.UserManagement.AllowInternalUsers && _activeTab == 0)
            {
                return !string.IsNullOrWhiteSpace(_internalRequest.UserName)
                    && !string.IsNullOrWhiteSpace(_internalRequest.Password);
            }
            return !string.IsNullOrWhiteSpace(_externalRequest.ExternalId)
                && !string.IsNullOrWhiteSpace(_externalRequest.UserName);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _roles = await RoleService.GetRolesAsync();
    }

    private string? ValidatePassword(string password)
    {
        if (string.IsNullOrEmpty(password))
            return null;

        if (password.Length < _configuration.UserManagement.MinimumPasswordLength)
            return $"Password must be at least {_configuration.UserManagement.MinimumPasswordLength} characters";

        if (_configuration.UserManagement.RequirePasswordComplexity)
        {
            if (!password.Any(char.IsUpper))
                return "Password must contain at least one uppercase letter";
            if (!password.Any(char.IsLower))
                return "Password must contain at least one lowercase letter";
            if (!password.Any(char.IsDigit))
                return "Password must contain at least one digit";
            if (!password.Any(c => !char.IsLetterOrDigit(c)))
                return "Password must contain at least one special character";
        }

        return null;
    }

    private async Task Submit()
    {
        if (_loading) return;

        _loading = true;

        try
        {
            BaseResponse response;

            if (_configuration.UserManagement.AllowInternalUsers && _activeTab == 0)
            {
                _passwordError = ValidatePassword(_internalRequest.Password ?? string.Empty);
                if (_passwordError != null)
                {
                    _loading = false;
                    return;
                }

                _internalRequest.RoleIds = _selectedInternalRoleIds.ToList();
                response = await UserService.CreateInternalUserAsync(_internalRequest);
            }
            else
            {
                _externalRequest.RoleIds = _selectedExternalRoleIds.ToList();
                response = await UserService.CreateExternalUserAsync(_externalRequest);
            }

            if (response.Success)
            {
                Snackbar.Add(response.Message, Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
