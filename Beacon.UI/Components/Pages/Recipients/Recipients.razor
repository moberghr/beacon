@page "/recipients"
@inherits BasePageComponent 
@using Beacon.Core.Models.Recipients
@using Beacon.Core.Services
@using SortDirection = MudBlazor.SortDirection
@inject IRecipientService service
@inject IDialogService DialogService
@inject Beacon.Core.Authorization.IBeaconAuthorizationProvider AuthorizationProvider

<BeaconPageTitle Title="Recipients"/>

<MudContainer Class="my-4 px-4"  MaxWidth="MaxWidth.ExtraExtraLarge">
    <BeaconPageHeader Icon="@Icons.Material.Filled.QueryBuilder" Title="Recipients" ButtonText="New recipient" OnClick="@NewRecipient" ButtonDisabled="@(!_canWrite)" />
    <BeaconPageAlert Text="List of recipients. recipients need to be defined and then added to a subscription to receive notifications. Create new or click on row and edit recipient."/>
    <MudDataGrid @ref="_dataGrid" ServerData="ServerReload" T="RecipientData" RowClick="OnRowClick" Hover="true" Filterable="false" >
        <ToolBarContent>
            <MudTextField T="string" ValueChanged="@(s=>OnSearch(s))" Placeholder="Search" Adornment="Adornment.Start"
                          Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.RecipientId" Title="Id"/>
            <PropertyColumn InitialDirection="SortDirection.Ascending"  Property="x => x.Name" Title="Name"/>
            <TemplateColumn Title="Destination">
                <CellTemplate>
                    @UiHelpers.FormatRecipientDestination(context.Item)
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.NotificationType" Title="Notification Type" />
            <PropertyColumn Property="x => x.Description" Title="Description" />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="RecipientData"/>
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<RecipientData> RecipientList { get; set; } = new();
    MudDataGrid<RecipientData>? _dataGrid;
    private bool _loading;
    private string _searchString;
    private bool _canWrite;

    protected override async Task OnInitializedAsync()
    {
        _canWrite = await AuthorizationProvider.HasWritePermissionAsync();
    }

    private async Task<GridData<RecipientData>> ServerReload(GridState
        <RecipientData> state, CancellationToken cancellationToken)
    {
        RecipientList = await service.GetRecipients(null, _searchString, CancellationToken.None);

        return new GridData<RecipientData>
        {
            TotalItems = RecipientList.Count(),
            Items = RecipientList
        };
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        _dataGrid?.ReloadServerData();
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<RecipientData> args)
    {
        var options = await CreateResponsiveDialogOptions();
        var parameters = new DialogParameters<UpdateRecipientDialog> { { x => x.Recipient, args.Item } };

        var dialog = await DialogService.ShowAsync<UpdateRecipientDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result!.Canceled)
        {
            return;
        }

        await _dataGrid?.ReloadServerData();
    }

    private async Task NewRecipient()
    {
        var options = await CreateResponsiveDialogOptions();
        var recipient = new RecipientData();
        var parameters = new DialogParameters<AddRecipientDialog> { { x => x.Recipient, recipient } };

        var dialog = await DialogService.ShowAsync<AddRecipientDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result!.Canceled)
        {
            return;
        }

        await _dataGrid?.ReloadServerData();
    }
}