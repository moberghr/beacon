@page "/beacon/data-catalog"
@inherits BasePageComponent
@using MediatR
@using Beacon.Core.Data.Enums
@using Beacon.Core.Handlers.DataCatalog
@inject IMediator Mediator

<BeaconPageTitle Title="Data Catalog"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <MudStack Spacing="4">
        <PageHeader Title="Data Catalog"
                    Icon="@Icons.Material.Filled.LibraryBooks"
                    Subtitle="Browse and search all tables across your connected data sources">
            <Badges>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                    @_filteredEntries.Count tables
                </MudChip>
            </Badges>
        </PageHeader>

        @* Search + Filters *@
        <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 12px;">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="_searchTerm"
                                  Label="Search tables"
                                  Placeholder="Search by table name, schema, or column..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  DebounceInterval="300"
                                  OnDebounceIntervalElapsed="ApplyFilters"
                                  Clearable="true"
                                  OnClearButtonClick="ClearSearch"/>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string"
                               @bind-Value="_selectedDataSource"
                               @bind-Value:after="ApplyFilters"
                               Label="Data Source"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@null">All Data Sources</MudSelectItem>
                        @foreach (var ds in _dataSources)
                        {
                            <MudSelectItem T="string" Value="@ds">@ds</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="string"
                               @bind-Value="_selectedSchema"
                               @bind-Value:after="ApplyFilters"
                               Label="Schema"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@null">All Schemas</MudSelectItem>
                        @foreach (var schema in _schemas)
                        {
                            <MudSelectItem T="string" Value="@schema">@schema</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="string"
                               @bind-Value="_qualityFilter"
                               @bind-Value:after="ApplyFilters"
                               Label="Quality"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@((string?)null)">Any Score</MudSelectItem>
                        <MudSelectItem T="string" Value="@("high")">High (90%+)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("medium")">Medium (70-89%)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("low")">Low (under 70%)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("unrated")">Not rated</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Loading *@
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
        }
        @* Empty *@
        else if (_filteredEntries.Count == 0)
        {
            <MudPaper Elevation="0" Class="pa-8 text-center"
                      Style="border: 2px dashed var(--mud-palette-lines-default); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" Class="mb-3"/>
                <MudText Typo="Typo.h6" Color="Color.Secondary">No tables found</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Try adjusting your search term or filters.
                </MudText>
            </MudPaper>
        }
        @* Results Grid *@
        else
        {
            <MudGrid Spacing="3">
                @foreach (var entry in _filteredEntries.Take(100))
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" Style="border-radius: 12px; cursor: pointer; height: 100%;"
                                 @onclick="@(() => NavigateToTable(entry))">
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@entry.SchemaName</MudText>
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@entry.TableName</MudText>
                                        </MudStack>
                                        @if (entry.QualityScore.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@GetScoreColor(entry.QualityScore)"
                                                     Variant="Variant.Filled">
                                                @($"{entry.QualityScore:F0}%")
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">N/A</MudChip>
                                        }
                                    </MudStack>

                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudChip T="string" Size="Size.Small" Icon="@(entry.DataSourceType == DataSourceType.Api ? Icons.Material.Filled.Api : Icons.Material.Filled.Storage)">
                                            @entry.DataSourceName
                                        </MudChip>
                                        @if (entry.DataSourceType == DataSourceType.Api)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">API</MudChip>
                                        }
                                    </MudStack>

                                    <MudDivider/>

                                    <MudStack Row="true" Spacing="3">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@entry.ColumnCount</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Columns</MudText>
                                        </MudStack>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.h6" Style="font-weight: 700;" Color="Color.Info">@entry.CodeReferenceCount</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Code Refs</MudText>
                                        </MudStack>
                                    </MudStack>

                                    @if (!string.IsNullOrWhiteSpace(entry.Description))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @entry.Description
                                        </MudText>
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>

            @if (_filteredEntries.Count > 100)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2">
                    Showing first 100 of @_filteredEntries.Count results. Refine your search to see more specific results.
                </MudAlert>
            }
        }
    </MudStack>
</MudContainer>

@code {
    private List<DataCatalogEntry> _allEntries = new();
    private List<DataCatalogEntry> _filteredEntries = new();
    private List<string> _dataSources = new();
    private List<string> _schemas = new();

    private string _searchTerm = string.Empty;
    private string? _selectedDataSource;
    private string? _selectedSchema;
    private string? _qualityFilter;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalog();
    }

    private async Task LoadCatalog()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new GetDataCatalogQuery());
            _allEntries = result.Entries;
            _dataSources = _allEntries.Select(e => e.DataSourceName).Distinct().OrderBy(x => x).ToList();
            _schemas = _allEntries.Select(e => e.SchemaName).Distinct().OrderBy(x => x).ToList();
            _filteredEntries = _allEntries;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        var result = _allEntries.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var term = _searchTerm.Trim().ToLowerInvariant();
            result = result.Where(e =>
                e.TableName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                e.SchemaName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                e.DataSourceName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (e.Description ?? string.Empty).Contains(term, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_selectedDataSource))
            result = result.Where(e => e.DataSourceName == _selectedDataSource);

        if (!string.IsNullOrWhiteSpace(_selectedSchema))
            result = result.Where(e => e.SchemaName == _selectedSchema);

        if (!string.IsNullOrWhiteSpace(_qualityFilter))
        {
            result = _qualityFilter switch
            {
                "high" => result.Where(e => e.QualityScore >= 90),
                "medium" => result.Where(e => e.QualityScore is >= 70 and < 90),
                "low" => result.Where(e => e.QualityScore is < 70),
                "unrated" => result.Where(e => !e.QualityScore.HasValue),
                _ => result
            };
        }

        _filteredEntries = result.ToList();
        StateHasChanged();
    }

    private void ClearSearch()
    {
        _searchTerm = string.Empty;
        ApplyFilters();
    }

    private void NavigateToTable(DataCatalogEntry entry)
    {
        NavManager.NavigateTo($"data-sources");
    }

    private static Color GetScoreColor(double? score) => score switch
    {
        >= 90 => Color.Success,
        >= 70 => Color.Warning,
        < 70 => Color.Error,
        _ => Color.Default
    };
}
