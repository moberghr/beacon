@page "/beacon/settings/mcp-learning"
@namespace Beacon.UI.Components.Pages.McpLearning
@inherits BasePageComponent
@using MediatR
@using Beacon.Core.Data.Enums
@using Beacon.Core.Handlers.McpLearning
@inject IMediator Mediator
@inject ISnackbar Snackbar

<BeaconPageTitle Title="MCP Learning"/>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">MCP Learning</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                The MCP server learns from every query. Review what it has learned, approve patterns, and manage documentation improvements.
            </MudText>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
        }
        else
        {
            @* Stats Cards *@
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Signals (7d / 30d)</MudText>
                            <MudText Typo="Typo.h5">@_stats.Signals7d / @_stats.Signals30d</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Success Rate</MudText>
                            <MudText Typo="Typo.h5" Color="@(_stats.SuccessRate >= 0.8 ? Color.Success : _stats.SuccessRate >= 0.5 ? Color.Warning : Color.Error)">
                                @_stats.SuccessRate.ToString("P0")
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Patterns Learned</MudText>
                            <MudText Typo="Typo.h5">@_stats.PatternsApproved</MudText>
                            @if (_stats.PatternsPending > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Warning">@_stats.PatternsPending pending</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Doc Patches</MudText>
                            <MudText Typo="Typo.h5">@_stats.PatchesApplied applied</MudText>
                            @if (_stats.PatchesProposed > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Info">@_stats.PatchesProposed proposed</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                @* Tab 1: Learned Patterns *@
                <MudTabPanel Text="Learned Patterns" Icon="@Icons.Material.Filled.Lightbulb" BadgeData="@(_stats.PatternsPending > 0 ? _stats.PatternsPending : null)" BadgeColor="Color.Warning">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudSelect T="McpPatternStatus?" @bind-Value="_patternStatusFilter" Label="Status" Variant="Variant.Outlined" Dense="true" Clearable="true" Style="max-width: 200px;">
                                <MudSelectItem T="McpPatternStatus?" Value="McpPatternStatus.Pending">Pending</MudSelectItem>
                                <MudSelectItem T="McpPatternStatus?" Value="McpPatternStatus.AutoApproved">Auto-Approved</MudSelectItem>
                                <MudSelectItem T="McpPatternStatus?" Value="McpPatternStatus.Approved">Approved</MudSelectItem>
                                <MudSelectItem T="McpPatternStatus?" Value="McpPatternStatus.Rejected">Rejected</MudSelectItem>
                            </MudSelect>
                            <MudSelect T="McpPatternType?" @bind-Value="_patternTypeFilter" Label="Type" Variant="Variant.Outlined" Dense="true" Clearable="true" Style="max-width: 200px;">
                                @foreach (var t in Enum.GetValues<McpPatternType>())
                                {
                                    <MudSelectItem T="McpPatternType?" Value="t">@t</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadPatterns" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                        </MudStack>

                        <MudDataGrid Items="@FilteredPatterns" Dense="true" Hover="true" Bordered="true" Striped="true">
                            <Columns>
                                <PropertyColumn Property="x => x.PatternType" Title="Type"/>
                                <PropertyColumn Property="x => x.TableName" Title="Table"/>
                                <PropertyColumn Property="x => x.ColumnName" Title="Column"/>
                                <TemplateColumn Title="Content" SortBy="x => x.PatternContent">
                                    <CellTemplate>
                                        <MudTooltip Text="@context.Item.PatternContent">
                                            <MudText Typo="Typo.body2" Style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                @context.Item.PatternContent
                                            </MudText>
                                        </MudTooltip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Confidence" Title="Conf." Format="P0"/>
                                <PropertyColumn Property="x => x.SignalCount" Title="Signals"/>
                                <TemplateColumn Title="Status">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.Status == McpPatternStatus.AutoApproved || context.Item.Status == McpPatternStatus.Approved ? Color.Success : context.Item.Status == McpPatternStatus.Pending ? Color.Warning : Color.Error)">
                                            @context.Item.Status
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" StickyRight="true">
                                    <CellTemplate>
                                        @if (context.Item.Status == McpPatternStatus.Pending)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                                           OnClick="() => UpdatePatternStatus(context.Item.Id, McpPatternStatus.Approved)"/>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                                           OnClick="() => UpdatePatternStatus(context.Item.Id, McpPatternStatus.Rejected)"/>
                                        }
                                        @if (context.Item.Status == McpPatternStatus.AutoApproved)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                                           OnClick="() => UpdatePatternStatus(context.Item.Id, McpPatternStatus.Rejected)"
                                                           Title="Reject"/>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudStack>
                </MudTabPanel>

                @* Tab 2: Documentation Patches *@
                <MudTabPanel Text="Doc Patches" Icon="@Icons.Material.Filled.Description" BadgeData="@(_stats.PatchesProposed > 0 ? _stats.PatchesProposed : null)" BadgeColor="Color.Info">
                    <MudDataGrid Items="@_patches" Dense="true" Hover="true" Bordered="true" Striped="true">
                        <Columns>
                            <PropertyColumn Property="x => x.TargetType" Title="Target"/>
                            <PropertyColumn Property="x => x.TargetIdentifier" Title="Identifier"/>
                            <TemplateColumn Title="Current">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2" Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @(context.Item.CurrentContent ?? "—")
                                    </MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Proposed">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2" Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @context.Item.ProposedContent
                                    </MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.SupportingSignalCount" Title="Signals"/>
                            <TemplateColumn Title="Status">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.Item.Status == McpDocPatchStatus.Applied ? Color.Success : context.Item.Status == McpDocPatchStatus.Proposed ? Color.Info : Color.Error)">
                                        @context.Item.Status
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Actions" StickyRight="true">
                                <CellTemplate>
                                    @if (context.Item.Status == McpDocPatchStatus.Proposed)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                                       OnClick="() => ApplyPatch(context.Item.Id)"/>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                                       OnClick="() => RejectPatch(context.Item.Id)"/>
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudTabPanel>

                @* Tab 3: Problem Tables *@
                <MudTabPanel Text="Problem Tables" Icon="@Icons.Material.Filled.Warning">
                    @if (_stats.ProblemTables.Count == 0)
                    {
                        <MudAlert Severity="Severity.Success">No tables with high error rates detected.</MudAlert>
                    }
                    else
                    {
                        <MudDataGrid Items="@_stats.ProblemTables" Dense="true" Hover="true" Bordered="true">
                            <Columns>
                                <PropertyColumn Property="x => x.TablesUsed" Title="Tables"/>
                                <PropertyColumn Property="x => x.TotalQueries" Title="Total Queries"/>
                                <PropertyColumn Property="x => x.ErrorCount" Title="Errors"/>
                                <TemplateColumn Title="Error Rate">
                                    <CellTemplate>
                                        <MudText Color="@(context.Item.ErrorRate >= 0.5 ? Color.Error : Color.Warning)">
                                            @context.Item.ErrorRate.ToString("P0")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    }
                </MudTabPanel>
            </MudTabs>
        }
    </MudStack>
</MudContainer>

@code {
    private bool _loading = true;
    private LearningStatsResult _stats = new();
    private List<LearnedPatternEntry> _patterns = [];
    private List<DocumentationPatchEntry> _patches = [];
    private McpPatternStatus? _patternStatusFilter;
    private McpPatternType? _patternTypeFilter;

    private IEnumerable<LearnedPatternEntry> FilteredPatterns => _patterns
        .Where(p => _patternStatusFilter == null || p.Status == _patternStatusFilter)
        .Where(p => _patternTypeFilter == null || p.PatternType == _patternTypeFilter);

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true;
        try
        {
            var statsTask = Mediator.Send(new GetLearningStatsQuery());
            var patternsTask = LoadPatterns();
            var patchesTask = Mediator.Send(new GetDocumentationPatchesQuery());

            await Task.WhenAll(statsTask, patternsTask, patchesTask);

            _stats = statsTask.Result;
            _patches = patchesTask.Result.Patches;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPatterns()
    {
        var result = await Mediator.Send(new GetLearnedPatternsQuery());
        _patterns = result.Patterns;
    }

    private async Task UpdatePatternStatus(int patternId, McpPatternStatus newStatus)
    {
        await Mediator.Send(new UpdatePatternStatusCommand
        {
            PatternId = patternId,
            NewStatus = newStatus
        });

        Snackbar.Add($"Pattern {(newStatus == McpPatternStatus.Approved ? "approved" : "rejected")}.", Severity.Success);
        await LoadAll();
    }

    private async Task ApplyPatch(int patchId)
    {
        await Mediator.Send(new ApplyDocumentationPatchCommand { PatchId = patchId });
        Snackbar.Add("Patch applied to documentation.", Severity.Success);
        await LoadAll();
    }

    private async Task RejectPatch(int patchId)
    {
        await Mediator.Send(new RejectDocumentationPatchCommand { PatchId = patchId });
        Snackbar.Add("Patch rejected.", Severity.Info);
        await LoadAll();
    }
}
