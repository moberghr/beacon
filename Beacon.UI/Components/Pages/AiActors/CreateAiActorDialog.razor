@using Beacon.Core.Handlers.Ai.AiActor
@using MediatR

<MudDialog Class="pb-2">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-1 mb-n1" />
            Create AI Actor
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_creating)
        {
            <div class="d-flex flex-column align-center py-8">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.body1" Class="mt-4">Creating AI Actor...</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">This will also run the initial setup</MudText>
            </div>
        }
        else if (_result != null)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                AI Actor created successfully!
            </MudAlert>
            <MudPaper Elevation="0" Class="pa-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Actor ID</MudText>
                <MudText Typo="Typo.h6">@_result.ActorId</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Status</MudText>
                <MudText Typo="Typo.body1">@_result.Status.ToString()</MudText>
            </MudPaper>
        }
        else
        {
            <MudForm @ref="@_form" Class="pt-1" @bind-IsValid="_isFormValid">
                <MudTextField
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Class="mb-3"
                    @bind-Value="@_name"
                    T="String"
                    Label="Actor Name"
                    Required="true"
                    RequiredError="Name is required"
                />

                <MudTextField
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Class="mb-3"
                    @bind-Value="@_instructions"
                    T="String"
                    Label="Monitoring Instructions"
                    Required="true"
                    RequiredError="Instructions are required"
                    Lines="5"
                    HelperText="Describe what you want to monitor (e.g., 'Monitor transactions for unusual activity, failed payments, or sudden spikes in volume')"
                />

                <MudTextField
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Class="mb-3"
                    @bind-Value="@_additionalContext"
                    T="String"
                    Label="Additional Context (Optional)"
                    Lines="3"
                    HelperText="Any additional context about the data source, business rules, or specific requirements"
                />

                <MudExpansionPanels Class="mt-4">
                    <MudExpansionPanel Text="Advanced Options">
                        <MudNumericField
                            Margin="Margin.Dense"
                            Variant="Variant.Outlined"
                            @bind-Value="@_maxQueries"
                            T="int"
                            Label="Max Queries"
                            Min="1"
                            Max="50"
                            HelperText="Maximum number of queries the actor can create"
                        />

                        <MudNumericField
                            Margin="Margin.Dense"
                            Variant="Variant.Outlined"
                            Class="mt-3"
                            @bind-Value="@_maxSubscriptionsPerQuery"
                            T="int"
                            Label="Max Subscriptions per Query"
                            Min="1"
                            Max="10"
                            HelperText="Maximum subscriptions per query"
                        />

                        <MudSwitch
                            @bind-Checked="@_activateImmediately"
                            T="bool"
                            Color="Color.Primary"
                            Label="Activate Immediately"
                            Class="mt-3"
                        />
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
                    The actor will analyze the data source schema and create initial monitoring queries based on your instructions.
                </MudAlert>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        @if (_result != null)
        {
            <MudButton OnClick="@Close" Variant="Variant.Filled" Color="Color.Primary">
                Close
            </MudButton>
        }
        else
        {
            <MudButton Class="ml-4" OnClick="@Cancel" Variant="Variant.Filled" Disabled="@_creating">
                Cancel
            </MudButton>
            <MudButton
                OnClick="@Create"
                Variant="Variant.Filled"
                Color="Color.Primary"
                Disabled="@(!_isFormValid || _creating)"
                StartIcon="@Icons.Material.Filled.RocketLaunch"
            >
                @(_creating ? "Creating..." : "Create Actor")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject ISnackbar Snackbar
@inject IMediator Mediator

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int DataSourceId { get; set; }

    private MudForm _form;
    private bool _creating;
    private bool _isFormValid;
    private CreateAiActorResult? _result;

    private string _name = "";
    private string _instructions = "";
    private string? _additionalContext;
    private int _maxQueries = 10;
    private int _maxSubscriptionsPerQuery = 3;
    private bool _activateImmediately = true;

    async Task Create()
    {
        if (_creating) return;

        await _form.Validate();
        if (!_form.IsValid) return;

        _creating = true;
        StateHasChanged();

        try
        {
            var command = new CreateAiActorCommand
            {
                Name = _name,
                Instructions = _instructions,
                DataSourceId = DataSourceId,
                AdditionalContext = _additionalContext,
                MaxQueries = _maxQueries,
                MaxSubscriptionsPerQuery = _maxSubscriptionsPerQuery,
                ActivateImmediately = _activateImmediately
            };

            _result = await Mediator.Send(command);
            Snackbar.Add($"AI Actor '{_result.Name}' created successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create actor: {ex.Message}", Severity.Error);
        }
        finally
        {
            _creating = false;
            StateHasChanged();
        }
    }

    void Cancel() => MudDialog.Cancel();
    void Close() => MudDialog.Close(DialogResult.Ok(_result));
}
