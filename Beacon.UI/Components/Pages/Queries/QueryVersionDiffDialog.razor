@using Beacon.Core.Models.Queries

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="grid"
            Eyebrow="QUERIES &nbsp;/&nbsp; VERSION HISTORY"
            Prefix="Version"
            Emphasis="diff"
            Suffix="." />
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Version @Diff.VersionA.VersionNumber
                        <MudChip T="string" Size="Size.Small">@Diff.VersionA.Status</MudChip>
                    </MudText>
                    <MudText Typo="Typo.caption">@Diff.VersionA.CreatedTime.ToString("g")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Version @Diff.VersionB.VersionNumber
                        <MudChip T="string" Size="Size.Small">@Diff.VersionB.Status</MudChip>
                    </MudText>
                    <MudText Typo="Typo.caption">@Diff.VersionB.CreatedTime.ToString("g")</MudText>
                </MudItem>
            </MudGrid>

            @if (Diff.NameChanged)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Name changed: "@Diff.VersionA.Name" -> "@Diff.VersionB.Name"</MudAlert>
            }

            @if (Diff.FinalQueryChanged)
            {
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Final Query Changed</MudText>
                <MudGrid>
                    <MudItem xs="6">
                        <MudPaper Class="pa-2" Style="background-color: #fff3f3; border-radius: 8px; overflow-x: auto;">
                            <pre style="margin: 0; white-space: pre-wrap;">@(Diff.VersionA.FinalQuery ?? "(none)")</pre>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="pa-2" Style="background-color: #f3fff3; border-radius: 8px; overflow-x: auto;">
                            <pre style="margin: 0; white-space: pre-wrap;">@(Diff.VersionB.FinalQuery ?? "(none)")</pre>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }

            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Steps</MudText>
            @foreach (var stepDiff in Diff.StepDiffs)
            {
                <MudCard Outlined="true" Class="pa-3">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.subtitle2">Step @stepDiff.StepOrder</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetDiffColor(stepDiff.DiffType)">
                                @stepDiff.DiffType
                            </MudChip>
                        </MudStack>

                        @if (stepDiff.DiffType == StepDiffType.Modified)
                        {
                            <MudGrid>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(stepDiff.StepA?.DataSourceName)</MudText>
                                    <MudPaper Class="pa-2" Style="background-color: #fff3f3; border-radius: 8px; overflow-x: auto;">
                                        <pre style="margin: 0; white-space: pre-wrap;">@(stepDiff.StepA?.SqlValue)</pre>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(stepDiff.StepB?.DataSourceName)</MudText>
                                    <MudPaper Class="pa-2" Style="background-color: #f3fff3; border-radius: 8px; overflow-x: auto;">
                                        <pre style="margin: 0; white-space: pre-wrap;">@(stepDiff.StepB?.SqlValue)</pre>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        }
                        else if (stepDiff.DiffType == StepDiffType.Added)
                        {
                            <MudPaper Class="pa-2" Style="background-color: #f3fff3; border-radius: 8px; overflow-x: auto;">
                                <pre style="margin: 0; white-space: pre-wrap;">@(stepDiff.StepB?.SqlValue)</pre>
                            </MudPaper>
                        }
                        else if (stepDiff.DiffType == StepDiffType.Removed)
                        {
                            <MudPaper Class="pa-2" Style="background-color: #fff3f3; border-radius: 8px; overflow-x: auto;">
                                <pre style="margin: 0; white-space: pre-wrap;">@(stepDiff.StepA?.SqlValue)</pre>
                            </MudPaper>
                        }
                        else
                        {
                            <MudPaper Class="pa-2" Style="background-color: #f5f5f5; border-radius: 8px; overflow-x: auto;">
                                <pre style="margin: 0; white-space: pre-wrap;">@(stepDiff.StepA?.SqlValue)</pre>
                            </MudPaper>
                        }
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled">Close</MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public QueryVersionDiff Diff { get; set; } = null!;

    private void Close() => MudDialog.Close();

    private Color GetDiffColor(StepDiffType diffType) => diffType switch
    {
        StepDiffType.Added => Color.Success,
        StepDiffType.Removed => Color.Error,
        StepDiffType.Modified => Color.Warning,
        StepDiffType.Unchanged => Color.Default,
        _ => Color.Default
    };
}
