@using Beacon.Core.Models.Queries

<MudDialog>
    <TitleContent>
        <BeaconDialogHeader Variant="grid"
            Eyebrow="QUERIES &nbsp;/&nbsp; VERSION HISTORY"
            Prefix="Version"
            Emphasis="detail"
            Suffix="." />
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor()">@Version.Status</MudChip>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                    <MudText>@Version.CreatedTime.ToString("g")</MudText>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(Version.Description))
            {
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                    <MudText>@Version.Description</MudText>
                </div>
            }

            @if (!string.IsNullOrEmpty(Version.ChangeReason))
            {
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Change Reason</MudText>
                    <MudText>@Version.ChangeReason</MudText>
                </div>
            }

            @if (!string.IsNullOrEmpty(Version.FinalQuery))
            {
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Final Query</MudText>
                    <MudPaper Class="pa-2" Style="background-color: #f5f5f5; border-radius: 8px; overflow-x: auto;">
                        <pre style="margin: 0; white-space: pre-wrap;">@Version.FinalQuery</pre>
                    </MudPaper>
                </div>
            }

            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Steps (@Version.Steps.Count)</MudText>
            @foreach (var step in Version.Steps.OrderBy(s => s.StepOrder))
            {
                <MudCard Outlined="true" Class="pa-3">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">Step @step.StepOrder</MudChip>
                            <MudText Typo="Typo.subtitle2">@(step.Name ?? $"Step {step.StepOrder}")</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@step.DataSourceName</MudText>
                        </MudStack>
                        <MudPaper Class="pa-2" Style="background-color: #f5f5f5; border-radius: 8px; overflow-x: auto;">
                            <pre style="margin: 0; white-space: pre-wrap;">@step.SqlValue</pre>
                        </MudPaper>
                        @if (step.Parameters.Any())
                        {
                            <MudText Typo="Typo.caption">Parameters: @string.Join(", ", step.Parameters.Select(p => $"{p.Name} ({p.Type})"))</MudText>
                        }
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled">Close</MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public QueryVersionDetail Version { get; set; } = null!;

    private void Close() => MudDialog.Close();

    private Color GetStatusColor() => Version.Status switch
    {
        Beacon.Core.Data.Enums.QueryVersionStatus.Active => Color.Success,
        Beacon.Core.Data.Enums.QueryVersionStatus.Archived => Color.Default,
        Beacon.Core.Data.Enums.QueryVersionStatus.PendingApproval => Color.Warning,
        Beacon.Core.Data.Enums.QueryVersionStatus.Rejected => Color.Error,
        _ => Color.Default
    };
}
