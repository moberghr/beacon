@using Beacon.Core.Data.Enums
@using Beacon.Core.Handlers.Queries
@using MediatR

<MudPaper Elevation="0" Class="pa-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.subtitle1">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1 mb-n1" />
            Change History
        </MudText>
        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@LoadHistoryAsync" StartIcon="@Icons.Material.Filled.Refresh">
            Refresh
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_history == null || !_history.Changes.Any())
    {
        <MudAlert Severity="Severity.Info" Dense="true">No change history recorded for this query.</MudAlert>
    }
    else
    {
        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
            @foreach (var change in _history.Changes)
            {
                <MudTimelineItem Color="@GetChangeSourceColor(change.ChangeSource)" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @change.ChangedAt.ToString("g")
                        </MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudPaper Elevation="1" Class="pa-3 mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                                <MudChip T="string" Size="Size.Small" Color="@GetChangeSourceColor(change.ChangeSource)" Variant="Variant.Filled">
                                    @change.ChangeSource.ToString()
                                </MudChip>
                                @if (!string.IsNullOrEmpty(change.QueryStepName))
                                {
                                    <MudText Typo="Typo.caption">@change.QueryStepName</MudText>
                                }
                                @if (!string.IsNullOrEmpty(change.AiActorName))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                                        AI: @change.AiActorName
                                    </MudChip>
                                }
                            </MudStack>

                            @if (!string.IsNullOrEmpty(change.ChangeReason))
                            {
                                <MudText Typo="Typo.body2" Class="mb-2">@change.ChangeReason</MudText>
                            }

                            <MudExpansionPanels Elevation="0">
                                <MudExpansionPanel Text="View Changes" Dense="true">
                                    <MudGrid>
                                        <MudItem xs="12" md="6">
                                            <MudText Typo="Typo.caption" Color="Color.Error">Previous SQL:</MudText>
                                            <MudPaper Elevation="0" Class="pa-2" Style="background: var(--mud-palette-error-lighten); max-height: 200px; overflow: auto;">
                                                <pre style="margin: 0; font-size: 11px;">@change.PreviousSql</pre>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudText Typo="Typo.caption" Color="Color.Success">New SQL:</MudText>
                                            <MudPaper Elevation="0" Class="pa-2" Style="background: var(--mud-palette-success-lighten); max-height: 200px; overflow: auto;">
                                                <pre style="margin: 0; font-size: 11px;">@change.NewSql</pre>
                                            </MudPaper>
                                        </MudItem>
                                    </MudGrid>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudPaper>

@inject IMediator Mediator
@inject ISnackbar Snackbar

@code {
    [Parameter]
    public int QueryId { get; set; }

    [Parameter]
    public int? StepId { get; set; }

    private GetQueryChangeHistoryResult? _history;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var query = new GetQueryChangeHistoryQuery
            {
                QueryId = QueryId,
                StepId = StepId,
                MaxResults = 50
            };

            _history = await Mediator.Send(query);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load history: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private Color GetChangeSourceColor(ChangeSource source) => source switch
    {
        ChangeSource.User => Color.Primary,
        ChangeSource.AiActor => Color.Info,
        ChangeSource.Import => Color.Secondary,
        _ => Color.Default
    };
}
