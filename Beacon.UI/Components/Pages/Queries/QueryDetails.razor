@page "/queries/{id:int}"
@inherits BasePageComponent
@using Beacon.Core.Models.Subscriptions
@using Beacon.Core.Services
@using Beacon.UI.Components.Custom
@using Beacon.UI.Components.Pages.Subscriptions
@using Beacon.Core.Models.Queries
@using Beacon.Core.Data.Enums
@using Beacon.Core.Adapters
@using Beacon.UI.Helpers
@inject IQueryService Service
@inject IQueryExecutionPreviewService PreviewService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Beacon.Core.Handlers.Approvals
@inject Beacon.Core.Authorization.IBeaconAuthorizationProvider AuthorizationProvider
@inject MediatR.IMediator Mediator
@inject Beacon.Core.BeaconConfiguration BeaconConfig

<BeaconPageTitle Title="Query" />

<div class="beacon-aq">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (Model != null)
    {
        <BeaconPageHero Variant="signal" Prefix="Editing" Emphasis="@Model.Name">
            <Eyebrow>
                <a href="/queries" class="mono" style="color:inherit;text-decoration:none;">Queries</a>
                <span class="page-hero__sep">/</span>
                <span class="mono">#@Model.Id</span>
                <span class="page-hero__sep">·</span>
                <span class="pill pill--ok" style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--ok);"></span>ACTIVE
                </span>
                <span class="page-hero__sep">·</span>
                @if (Model.IsMultiStep)
                {
                    <span class="pill pill--neutral mono" style="font-size:10px;">MULTI-STEP</span>
                }
                else
                {
                    <span class="pill pill--neutral mono" style="font-size:10px;">SINGLE-STEP</span>
                }
                @if (Model.AiActorId.HasValue)
                {
                    <span class="pill pill--info mono" style="font-size:10px;margin-left:2px;">AI</span>
                }
            </Eyebrow>
            <Sub>
                @if (Model.DataSourceNames?.Any() == true)
                {
                    <span class="mono">@string.Join(", ", Model.DataSourceNames)</span>
                    <span style="opacity:0.5;">·</span>
                }
                <span>created </span><span class="mono">@Model.CreatedTime.ToString("dd MMM yyyy · HH:mm")</span>
                <span style="opacity:0.5;">·</span>
                <span>@Model.TotalExecutions run@(Model.TotalExecutions != 1 ? "s" : "") to date</span>
            </Sub>
            <Actions>
                <button class="btn" @onclick="AddSubscription" disabled="@(!_canWrite)">
                    <MudIcon Icon="@Icons.Material.Rounded.Add" Style="font-size:13px;margin-right:3px;" />Add subscription
                </button>
                <button class="btn btn--primary" @onclick="ExecuteQuery" disabled="@(!_canWrite)">
                    <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:13px;margin-right:3px;" />Execute query
                </button>
            </Actions>
        </BeaconPageHero>

        @if (_hasPendingApproval)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="false">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText>This query has pending changes awaiting approval.</MudText>
                    @* TODO: Beacon migration — MudButton uses Href= (link-style); BeaconButton doesn't support Href. *@
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Href="@($"approvals")">
                        Review Changes
                    </MudButton>
                </MudStack>
            </MudAlert>
        }

        <!-- KPI row -->
        <div class="kpi-grid">
            <KpiCard Dot="info" Label="Executions" Value="@(Model.TotalExecutions.ToString())"
                     SubText="@(Model.TotalExecutions == 0 ? "never run" : "total")" />
            <KpiCard Dot="brand" Label="Results rate" Value="@GetResultsRate()"
                     SubText="@(Model.TotalExecutions == 0 ? "run to populate" : "of executions")" />
            <KpiCard Dot="ok" Label="Subscriptions" Value="@((Model.Subscriptions?.Count ?? 0).ToString())"
                     SubText="@(Model.Subscriptions?.Count == 0 ? "not yet subscribed" : "active")" />
            <KpiCard Dot="warn" Label="Query steps" Value="@((Model.Steps?.Count ?? 0).ToString())"
                     SubText="@(Model.IsMultiStep ? "multi-step" : "single-step")" />
        </div>

        <!-- Perf row -->
        <div class="row row--3-up" style="margin-top:12px;">
            <KpiCard Dot="ok" Label="Avg execution" Value="@FormatExecutionTime(Model.AvgExecutionTimeMs)" Unit="ms"
                     SubText="@(Model.TotalExecutions == 0 ? "no samples yet" : null)" />
            <KpiCard Dot="ok" Label="Fastest" Value="@FormatExecutionTime(Model.MinExecutionTimeMs)" Unit="ms"
                     SubText="@(Model.TotalExecutions == 0 ? "no samples yet" : null)" />
            <KpiCard Dot="warn" Label="Slowest" Value="@FormatExecutionTime(Model.MaxExecutionTimeMs)" Unit="ms"
                     SubText="@(Model.TotalExecutions == 0 ? "no samples yet" : null)" />
        </div>

        <!-- Two-column layout -->
        <div class="q-layout">
            <div class="q-section">

                <!-- Query information -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.Info" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Query information</h3>
                        <div class="card__actions">
                            <SourceChip AiActorId="@Model.AiActorId" AiActorName="@Model.AiActorName" Compact="false" />
                        </div>
                    </div>
                    <div class="card__body">
                        <div class="kv">
                            <div class="kv__row">
                                <span class="kv__label">Query ID</span>
                                <span class="kv__value mono">#@Model.Id</span>
                            </div>
                            <div class="kv__row">
                                <span class="kv__label">Query type</span>
                                <span class="kv__value" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                    @if (Model.IsMultiStep)
                                    {
                                        <span class="pill pill--info mono" style="font-size:10px;">MULTI-STEP</span>
                                    }
                                    else
                                    {
                                        <span class="pill pill--neutral mono" style="font-size:10px;">SINGLE-STEP</span>
                                    }
                                    @if (Model.IsCrossDataSource)
                                    {
                                        <span class="pill pill--warn mono" style="font-size:10px;">CROSS-SOURCE</span>
                                    }
                                    @if (Model.IsCrossDatabase)
                                    {
                                        <span class="pill pill--crit mono" style="font-size:10px;">CROSS-DB</span>
                                    }
                                </span>
                            </div>
                            <div class="kv__row">
                                <span class="kv__label">Created</span>
                                <span class="kv__value mono">@Model.CreatedTime.ToString("dd MMM yyyy · HH:mm") UTC</span>
                            </div>
                            <div class="kv__row">
                                <span class="kv__label">Data sources</span>
                                <span class="kv__value" style="display:flex;flex-wrap:wrap;gap:6px;">
                                    @if (Model.DataSourceNames?.Any() == true)
                                    {
                                        @foreach (var ds in Model.DataSourceNames)
                                        {
                                            <span class="mono" style="display:inline-flex;align-items:center;gap:5px;">
                                                <span style="width:6px;height:6px;border-radius:50%;background:var(--ok);flex-shrink:0;"></span>@ds
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="mono" style="color:var(--text-muted);">—</span>
                                    }
                                </span>
                            </div>
                            @if (Model.DatabaseEngines?.Any() == true)
                            {
                                <div class="kv__row">
                                    <span class="kv__label">DB engine</span>
                                    <span class="kv__value mono">@string.Join(", ", Model.DatabaseEngines.Distinct())</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Model.FinalQuery))
                            {
                                <div class="kv__row">
                                    <span class="kv__label">Final query</span>
                                    <span class="kv__value">
                                        <span class="pill pill--info mono" style="font-size:10px;">Uses @("@")result refs</span>
                                    </span>
                                </div>
                            }
                            @if (Model.IsLocked)
                            {
                                <div class="kv__row">
                                    <span class="kv__label">Status</span>
                                    <span class="kv__value">
                                        <span class="pill pill--warn" style="display:inline-flex;align-items:center;gap:4px;">
                                            <MudIcon Icon="@Icons.Material.Rounded.Lock" Style="font-size:10px;" />LOCKED
                                        </span>
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Query steps -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.AccountTree" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Query steps</h3>
                        <span class="card__sub">@(Model.Steps?.Count ?? 0) step@(Model.Steps?.Count != 1 ? "s" : "") · @(Model.Steps?.Sum(s => s.Parameters?.Count ?? 0) ?? 0) params</span>
                        <div class="card__actions">
                            <button class="btn btn--primary" @onclick="ExecuteQuery" disabled="@(!_canWrite)">
                                <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:13px;margin-right:3px;" />Execute query
                            </button>
                        </div>
                    </div>
                    <div class="card__body" style="display:flex;flex-direction:column;gap:12px;">
                        @if (Model.Steps?.Any() == true)
                        {
                            @foreach (var step in Model.Steps.OrderBy(s => s.StepOrder))
                            {
                                <div class="step-card">
                                    <div class="step-card__head">
                                        <span class="step-num">@step.StepOrder.ToString("D2")</span>
                                        <span class="step-name">@(string.IsNullOrEmpty(step.Name) ? $"Step {step.StepOrder}" : step.Name)</span>
                                        @if (!string.IsNullOrEmpty(step.DataSourceName))
                                        {
                                            <span class="pill pill--neutral mono" style="font-size:10px;">@step.DataSourceName · @step.DatabaseEngineDescription</span>
                                        }
                                        <div style="margin-left:auto;display:flex;gap:4px;">
                                            <button class="icon-btn" title="@(_editingStepId == step.StepId ? "View only" : "Edit SQL")"
                                                    @onclick="@(() => ToggleStepEdit(step.StepId))"
                                                    disabled="@(!_canWrite)">
                                                <MudIcon Icon="@(_editingStepId == step.StepId ? Icons.Material.Rounded.Visibility : Icons.Material.Rounded.Edit)" Style="font-size:14px;" />
                                            </button>
                                            <button class="icon-btn" title="Execute step"
                                                    @onclick="@(() => ExecuteStep(step.StepOrder))"
                                                    disabled="@(!_canWrite)">
                                                <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:14px;" />
                                            </button>
                                        </div>
                                    </div>
                                    <div class="step-card__body">
                                        @if (_editingStepId == step.StepId)
                                        {
                                            <SqlEditor Value="@step.SqlValue"
                                                       ValueChanged="@((v) => { step.SqlValue = v; })"
                                                       DataSourceId="@step.DataSourceId"
                                                       Height="300px"
                                                       EditorId="@($"sql-editor-step-{step.StepId}")" />
                                        }
                                        else
                                        {
                                            <MudPaper Class="pa-2" Style="border-radius:6px;overflow:hidden;">
                                                <CodeHiglight Code="@step.SqlValue" />
                                            </MudPaper>
                                        }
                                        @if (step.Parameters?.Any() == true)
                                        {
                                            <div class="params">
                                                <div class="params__head">
                                                    <span class="q-label">
                                                        Parameters
                                                        <span class="pill pill--neutral mono" style="font-size:10px;">@step.Parameters.Count detected</span>
                                                    </span>
                                                    <button class="btn btn--ghost" @onclick="@(() => ToggleParameterDetails(step.StepId))">
                                                        @(_showParametersDetails.GetValueOrDefault(step.StepId, false) ? "Hide" : "Show") details
                                                    </button>
                                                </div>
                                                <div class="params__chips">
                                                    @foreach (var param in step.Parameters)
                                                    {
                                                        <span class="pill pill--info mono" style="font-size:11px;">@param.Name (@param.Type)</span>
                                                    }
                                                </div>
                                                @if (_showParametersDetails.GetValueOrDefault(step.StepId, false))
                                                {
                                                    <MudTable T="QueryStepParameterData" Items="@step.Parameters" Dense="true" Hover="true" Class="mt-2">
                                                        <HeaderContent>
                                                            <MudTh>Name</MudTh><MudTh>Type</MudTh><MudTh>Description</MudTh><MudTh>Placeholder</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd>@context.Name</MudTd><MudTd>@context.Type</MudTd>
                                                            <MudTd>@(context.Description ?? "—")</MudTd><MudTd>@(context.Placeholder ?? "—")</MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Final query (multi-step only) -->
                @if (!string.IsNullOrEmpty(Model.FinalQuery))
                {
                    <div class="card">
                        <div class="card__head">
                            <MudIcon Icon="@Icons.Material.Rounded.TableChart" Style="font-size:15px;color:var(--text-muted);" />
                            <h3 class="card__title">Final query</h3>
                            <span class="pill pill--info mono" style="font-size:10px;">@("@")result refs</span>
                            <div class="card__actions">
                                <button class="btn btn--ghost" @onclick="@(() => _editingFinalQuery = !_editingFinalQuery)" disabled="@(!_canWrite)">
                                    <MudIcon Icon="@(_editingFinalQuery ? Icons.Material.Rounded.Visibility : Icons.Material.Rounded.Edit)" Style="font-size:13px;margin-right:3px;" />
                                    @(_editingFinalQuery ? "View only" : "Edit")
                                </button>
                            </div>
                        </div>
                        <div class="card__body">
                            <p style="font-size:12.5px;color:var(--text-muted);margin:0 0 12px;">
                                Executes against in-memory SQLite containing all step results.
                                Use <code class="mono">@("@")result1</code>, <code class="mono">@("@")result2</code>, etc. to reference prior steps.
                            </p>
                            @if (Model.FinalQueryDataSourceId.HasValue)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    Target data source ID @Model.FinalQueryDataSourceId used for SQL dialect compatibility.
                                </MudAlert>
                            }
                            @if (_editingFinalQuery)
                            {
                                <FinalQueryEditor Value="@Model.FinalQuery"
                                                 ValueChanged="@((v) => { Model.FinalQuery = v; })"
                                                 Query="@ConvertToQueryData()"
                                                 Height="300px"
                                                 EditorId="final-query-editor-details" />
                            }
                            else
                            {
                                <MudPaper Class="pa-2" Style="border-radius:6px;overflow:hidden;border-left:3px solid var(--brand-500);">
                                    <CodeHiglight Code="@Model.FinalQuery" />
                                </MudPaper>
                            }
                        </div>
                    </div>
                }

                <!-- Flow diagram -->
                @if (Model.Steps?.Any() == true)
                {
                    <div class="card">
                        <div class="card__head">
                            <MudIcon Icon="@Icons.Material.Rounded.AccountTree" Style="font-size:15px;color:var(--text-muted);" />
                            <h3 class="card__title">Query flow diagram</h3>
                        </div>
                        <div class="card__body" style="padding:0;">
                            <QueryFlowDiagram Query="@ConvertToQueryData()" />
                        </div>
                    </div>
                }

                <!-- Version history -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.History" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Version history</h3>
                    </div>
                    <div class="card__body" style="padding:0;">
                        <QueryVersionHistory QueryId="@Id" OnVersionRestored="@Load" />
                    </div>
                </div>

                <!-- Subscriptions -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.Subscriptions" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Subscriptions</h3>
                        <span class="card__sub">@(Model.Subscriptions?.Count ?? 0) attached</span>
                        <div class="card__actions">
                            <button class="btn btn--primary" @onclick="AddSubscription" disabled="@(!_canWrite)">
                                <MudIcon Icon="@Icons.Material.Rounded.Add" Style="font-size:13px;margin-right:3px;" />Add subscription
                            </button>
                        </div>
                    </div>
                    <div class="card__body card__body--flush">
                        @if (Model.Subscriptions?.Any() == true)
                        {
                            <div class="tbl">
                                <div class="tbl__head">
                                    <div>Subscription ID</div>
                                    <div>Name</div>
                                    <div>Created</div>
                                    <div>Subscribers</div>
                                    <div>Cron expression</div>
                                    <div></div>
                                </div>
                                @foreach (var sub in Model.Subscriptions)
                                {
                                    <div class="tbl__row" @onclick="@(() => NavManager.NavigateTo($"subscriptions/{sub.SubscriptionId}"))">
                                        <div class="mono" style="font-size:12px;">#@sub.SubscriptionId</div>
                                        <div>@sub.Name</div>
                                        <div class="mono" style="font-size:12px;">@sub.CreatedTime.ToString("dd MMM yy")</div>
                                        <div class="mono">@sub.Subscribers</div>
                                        <div><span class="pill pill--neutral mono" style="font-size:10px;">@sub.CronExpression</span></div>
                                        <div><MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Style="font-size:16px;color:var(--text-subtle);" /></div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="padding:16px;">
                                <div class="empty-state">
                                    <div class="empty-state__icon">
                                        <MudIcon Icon="@Icons.Material.Rounded.Inbox" Style="font-size:16px;" />
                                    </div>
                                    <div>
                                        <div class="empty-state__title">No subscriptions yet</div>
                                        <div class="empty-state__sub">Add a subscription to schedule this query and notify recipients.</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Execution analytics (only when data exists) -->
                @if (Model.NotificationHistory?.Any() == true || Model.ExecutionTimeHistory?.Any() == true)
                {
                    <div class="card">
                        <div class="card__head">
                            <MudIcon Icon="@Icons.Material.Rounded.Analytics" Style="font-size:15px;color:var(--text-muted);" />
                            <h3 class="card__title">Execution analytics</h3>
                            <span class="card__sub">last 30 days</span>
                        </div>
                        <div class="card__body">
                            @if (Model.NotificationHistory?.Any() == true)
                            {
                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;" Class="mb-3">Results Rate Over Time</MudText>
                                        <MudChart ChartType="ChartType.Line"
                                                  ChartSeries="@_successRateSeriesData"
                                                  ChartLabels="@_chartLabels"
                                                  Width="100%" Height="260px"
                                                  ChartOptions="@_successRateOptions" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;" Class="mb-3">Daily Executions</MudText>
                                        <MudChart ChartType="ChartType.Bar"
                                                  ChartSeries="@_executionSeriesData"
                                                  ChartLabels="@_chartLabels"
                                                  Width="100%" Height="260px"
                                                  ChartOptions="@_executionOptions" />
                                    </MudItem>
                                </MudGrid>
                            }
                            @if (Model.ExecutionTimeHistory?.Any() == true)
                            {
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;" Class="@(Model.NotificationHistory?.Any() == true ? "mt-4 mb-3" : "mb-3")">Execution Time Performance</MudText>
                                <MudChart ChartType="ChartType.Line"
                                          ChartSeries="@_executionTimeChartSeries"
                                          ChartLabels="@_executionTimeXAxisLabels"
                                          Width="@ChartHelper.DefaultChartWidth"
                                          Height="@ChartHelper.DefaultChartHeight"
                                          ChartOptions="@_executionTimeChartOptions" />
                            }
                        </div>
                    </div>
                }

            </div>

            <!-- Right aside -->
            <aside class="q-aside">

                <!-- Run history -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.Timeline" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Run history</h3>
                        <span class="card__sub">last 30d</span>
                    </div>
                    <div class="card__body" style="@(Model.NotificationHistory?.Any() == true ? "padding:0;" : "")">
                        @if (Model.NotificationHistory?.Any() == true)
                        {
                            <div class="feed">
                                @foreach (var entry in Model.NotificationHistory.TakeLast(7).Reverse())
                                {
                                    <FeedItem Tone="@(entry.SuccessfulNotifications > 0 ? "ok" : "warn")"
                                              Icon="@(entry.SuccessfulNotifications > 0 ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Warning)"
                                              Meta="@($"{entry.SuccessfulNotifications}/{entry.TotalExecutions} with results")"
                                              Time="@entry.Date.ToString("dd MMM")">
                                        <Title>@entry.TotalExecutions run@(entry.TotalExecutions != 1 ? "s" : "")</Title>
                                    </FeedItem>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state" style="padding:12px;gap:10px;">
                                <div class="empty-state__icon" style="width:28px;height:28px;">
                                    <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:14px;" />
                                </div>
                                <div>
                                    <div class="empty-state__title" style="font-size:12.5px;">Never executed</div>
                                    <div class="empty-state__sub" style="font-size:11.5px;">Hit Execute query to populate metrics.</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Recipients -->
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.People" Style="font-size:15px;color:var(--text-muted);" />
                        <h3 class="card__title">Recipients</h3>
                        <span class="card__sub">@(Model.Subscriptions?.Count ?? 0) attached</span>
                    </div>
                    <div class="card__body" style="font-size:12.5px;color:var(--text-muted);">
                        @if (Model.Subscriptions?.Any() == true)
                        {
                            var subCount = Model.Subscriptions.Count;
                            <span>@subCount subscription@(subCount != 1 ? "s" : "") active. Add recipients via each subscription.</span>
                        }
                        else
                        {
                            <span>Add a subscription to route results to recipients via email, Slack, or webhook.</span>
                        }
                    </div>
                </div>

                <!-- Tip callout -->
                <div class="callout">
                    <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Style="font-size:16px;flex-shrink:0;margin-top:2px;" Class="callout__icon" />
                    <div>
                        <div class="callout__title">Tip · faster iteration</div>
                        <div class="callout__sub">Click Edit on any step, then use <span class="kbd">⌘</span> <span class="kbd">↵</span> in the SQL editor to run just that step without saving.</div>
                    </div>
                </div>

            </aside>
        </div>

        <!-- Save bar -->
        <div class="save-bar">
            <span class="save-bar__hint">
                <span class="pill pill--ok" style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--ok);"></span>ACTIVE
                </span>
                <span class="mono" style="color:var(--text);">@Model.TotalExecutions</span>
                <span>run@(Model.TotalExecutions != 1 ? "s" : "") to date</span>
            </span>
            <span class="spacer"></span>
            <span class="save-bar__hint">
                <span>Press</span>
                <span class="kbd">⌘</span><span class="kbd">↵</span>
                <span>to execute in editor</span>
            </span>
            <button class="btn" @onclick="AddSubscription" disabled="@(!_canWrite)">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Style="font-size:13px;margin-right:3px;" />Add subscription
            </button>
            <button class="btn btn--primary" @onclick="ExecuteQuery" disabled="@(!_canWrite)">
                <MudIcon Icon="@Icons.Material.Rounded.PlayArrow" Style="font-size:13px;margin-right:3px;" />Execute query
            </button>
        </div>

        <!-- Execution result overlays -->
        @if (_currentQueryResult != null)
        {
            <QueryExecutionResultsPreview ExecutionResult="@_currentQueryResult" OnClose="@CloseResultsPreview" />
        }

        @if (_currentStepResult != null)
        {
            <QueryResultsPreview Results="@_currentStepResult.PreviewResults"
                                 TotalRows="@_currentStepResult.TotalRows"
                                 ExecutionTimeMs="@_currentStepResult.ExecutionTimeMs"
                                 Success="@_currentStepResult.Success"
                                 ErrorMessage="@_currentStepResult.ErrorMessage"
                                 IsStepResult="true"
                                 StepOrder="@_currentStepResult.StepOrder"
                                 OnClose="@CloseStepResultsPreview" />
        }
    }
    else
    {
        <div style="padding:24px 0;">
            <div class="empty-state">
                <div class="empty-state__icon">
                    <MudIcon Icon="@Icons.Material.Rounded.SearchOff" Style="font-size:16px;" />
                </div>
                <div>
                    <div class="empty-state__title">Query not found</div>
                    <div class="empty-state__sub">Query #@Id could not be loaded.</div>
                </div>
            </div>
        </div>
    }
</div>

@code
{
    [Parameter]
    public int Id { get; set; }

    public QueryDetailsData? Model;

    private bool _loading;
    private Dictionary<int, bool> _showParametersDetails = new();
    private QueryExecutionResult? _currentQueryResult;
    private QueryStepResult? _currentStepResult;
    private int? _editingStepId;
    private bool _editingFinalQuery;
    private bool _canWrite;
    private bool _hasPendingApproval;

    // Chart data
    private List<ChartSeries<double>> _successRateSeriesData = new();
    private List<ChartSeries<double>> _executionSeriesData = new();
    private string[] _chartLabels = Array.Empty<string>();
    private LineChartOptions _successRateOptions = new();
    private BarChartOptions _executionOptions = new();

    // Execution time chart fields
    private List<ChartSeries<double>> _executionTimeChartSeries = new();
    private string[] _executionTimeXAxisLabels = Array.Empty<string>();
    private LineChartOptions _executionTimeChartOptions = new();

    protected override async Task OnInitializedAsync()
    {
        _canWrite = await AuthorizationProvider.HasWritePermissionAsync();
        await Load();
        await CheckPendingApproval();
    }

    private async Task Load()
    {
        _loading = true;

        Model = await Service.GetQueryDetails(Id, new CancellationToken());

        if (Model?.NotificationHistory?.Any() == true)
        {
            PrepareChartData();
        }

        if (Model?.ExecutionTimeHistory?.Any() == true)
        {
            PrepareExecutionTimeChart();
        }

        _loading = false;
    }

    private void PrepareChartData()
    {
        if (Model?.NotificationHistory == null || !Model.NotificationHistory.Any()) return;

        _chartLabels = Model.NotificationHistory
            .Select(x => x.Date.ToString("MM/dd"))
            .ToArray();

        _successRateSeriesData = new List<ChartSeries<double>>
        {
            new() {
                Name = "Results Rate (%)",
                Data = Model.NotificationHistory.Select(x => x.SuccessRate).ToArray()
            }
        };

        _executionSeriesData = new List<ChartSeries<double>>
        {
            new() {
                Name = "With Results",
                Data = Model.NotificationHistory.Select(x => (double)x.SuccessfulNotifications).ToArray()
            },
            new() {
                Name = "No Results",
                Data = Model.NotificationHistory.Select(x => (double)x.FailedExecutions).ToArray()
            }
        };

        _successRateOptions = new LineChartOptions
        {
            YAxisTicks = 10,
            MaxNumYAxisTicks = 10,
            YAxisFormat = "0'%'",
            XAxisLabelRotation = 45,
            LineStrokeWidth = 3,
            ChartPalette = new[] { Colors.Green.Default }
        };

        _executionOptions = new BarChartOptions
        {
            YAxisTicks = 10,
            MaxNumYAxisTicks = 10,
            XAxisLabelRotation = 45,
            ChartPalette = new[] { Colors.Green.Default, Colors.Gray.Default }
        };
    }

    private void ToggleParameterDetails(int stepId)
    {
        _showParametersDetails[stepId] = !_showParametersDetails.GetValueOrDefault(stepId, false);
    }

    private void ToggleStepEdit(int stepId)
    {
        _editingStepId = _editingStepId == stepId ? null : stepId;
    }

    private async Task ExecuteQuery()
    {
        if (Model?.Id == null) return;

        try
        {
            _currentStepResult = null;

            Snackbar.Add("Executing full query...", Severity.Info);
            var result = await PreviewService.ExecuteQueryPreview(Model.Id, CancellationToken.None);

            if (result != null)
            {
                _currentQueryResult = result;

                if (result.Success)
                {
                    var message = result.IsMultiStep
                        ? $"Query executed successfully! {result.StepResults.Count} steps completed in {result.TotalExecutionTimeMs:F0}ms"
                        : $"Query executed successfully! Returned {result.FinalResult?.TotalRecords ?? 0} rows in {result.TotalExecutionTimeMs:F0}ms";

                    Snackbar.Add(message, Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Query execution failed: {result.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add("Query execution failed", Severity.Error);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error executing query: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExecuteStep(int stepOrder)
    {
        if (Model?.Id == null) return;

        try
        {
            _currentQueryResult = null;

            var step = Model.Steps.FirstOrDefault(s => s.StepOrder == stepOrder);
            List<Beacon.Core.Models.Queries.ParameterValue>? parameterValues = null;

            if (step?.Parameters?.Any() == true)
            {
                var options = await CreateResponsiveDialogOptions();

                var parameters = new DialogParameters<ExecuteStepParametersDialog>
                {
                    { x => x.Parameters, step.Parameters }
                };

                var dialog = await DialogService.ShowAsync<ExecuteStepParametersDialog>("", parameters, options);
                var result = await dialog.Result;

                if (result.Canceled)
                {
                    return;
                }

                parameterValues = result.Data as List<Beacon.Core.Models.Queries.ParameterValue>;
            }

            Snackbar.Add($"Executing step {stepOrder}...", Severity.Info);
            var executionResult = await PreviewService.ExecuteStepPreview(Model.Id, stepOrder, parameterValues, CancellationToken.None);

            if (executionResult != null)
            {
                _currentStepResult = executionResult;

                if (executionResult.Success)
                {
                    Snackbar.Add($"Step {stepOrder} executed successfully! Returned {executionResult.TotalRows} rows in {executionResult.ExecutionTimeMs:F0}ms", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Step {stepOrder} execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add($"Step {stepOrder} execution failed", Severity.Error);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error executing step {stepOrder}: {ex.Message}", Severity.Error);
        }
    }

    private void AddSubscription()
    {
        NavManager.NavigateTo($"subscriptions/add/{Id}");
    }

    private void CloseResultsPreview()
    {
        _currentQueryResult = null;
        StateHasChanged();
    }

    private void CloseStepResultsPreview()
    {
        _currentStepResult = null;
        StateHasChanged();
    }

    private QueryData ConvertToQueryData()
    {
        if (Model == null) return new QueryData();

        return new QueryData
        {
            QueryId = Model.Id,
            Name = Model.Name,
            Description = Model.Description,
            CreatedTime = Model.CreatedTime,
            Steps = Model.Steps,
            FinalQuery = Model.FinalQuery,
            FinalQueryDataSourceId = Model.FinalQueryDataSourceId
        };
    }

    private void PrepareExecutionTimeChart()
    {
        if (Model?.ExecutionTimeHistory == null || !Model.ExecutionTimeHistory.Any())
            return;

        var chart = ChartHelper.BuildExecutionTimeChart(Model.ExecutionTimeHistory);
        _executionTimeChartSeries = chart.Series;
        _executionTimeXAxisLabels = chart.Labels;
        _executionTimeChartOptions = chart.Options;
    }

    private string GetResultsRate()
    {
        if (Model?.TotalExecutions > 0)
        {
            var rate = (double)(Model?.SentNotifications ?? 0) / (Model?.TotalExecutions ?? 1) * 100;
            return $"{rate:F0}%";
        }
        return "N/A";
    }

    private string FormatExecutionTime(double milliseconds) => UiHelpers.FormatExecutionTime(milliseconds);

    private async Task CheckPendingApproval()
    {
        if (BeaconConfig?.ApprovalWorkflow.Enabled != true) return;
        var pending = await Mediator.Send(new GetPendingApprovalsQuery { QueryId = Id });
        _hasPendingApproval = pending.Any();
    }
}
