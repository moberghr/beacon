@page "/queries/add"
@inherits BasePageComponent
@using Beacon.Core.Models.Queries
@using Beacon.Core.Services
@using Beacon.UI.Components.Custom
@using Beacon.Core.Data.Enums
@using Beacon.Core.Adapters
@using QueryParameterValue = Beacon.Core.Models.Queries.ParameterValue

<div class="@RootClass">
    <BeaconPageHero Variant="signal"
                    Prefix="Compose a"
                    Emphasis="cross-source"
                    Suffix="query.">
        <Eyebrow>
            <a href="queries" style="color: inherit; text-decoration: none;">Queries</a>
            <span class="page-hero__sep">/</span>
            <span>NEW</span>
            <span class="page-hero__sep">·</span>
            <span class="pill pill--neutral mono" style="font-size: 10px;">DRAFT</span>
        </Eyebrow>
        <Sub>
            Chain SQL steps across data sources, pipe results between steps using
            <span class="mono">@@result1</span>, and parameterize with
            <span class="mono">{name}</span>.
        </Sub>
        <Actions>
            <button class="btn" @onclick="GoBack" type="button">
                <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small" /> Back
            </button>
            <button class="btn" @onclick="OnExecuteQuery" disabled="@(!HasSteps)" type="button">
                <MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="Size.Small" /> Run
            </button>
            <button class="btn btn--primary" @onclick="Submit" disabled="@(!IsFormValid || _loading)" type="button">
                <MudIcon Icon="@Icons.Material.Rounded.Check" Size="Size.Small" /> Save query
            </button>
        </Actions>
    </BeaconPageHero>

    <div class="q-layout">
        <div class="q-section">
            <!-- Query details card -->
            <div class="card">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.Info" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Query details</h3>
                    <div class="card__actions">
                        <span class="pill pill--neutral mono" style="font-size: 10px;">@(IsFormValid ? "READY" : "UNSAVED")</span>
                    </div>
                </div>
                <div class="card__body">
                    <div class="q-meta-grid">
                        <div class="q-field q-field--full">
                            <label class="q-label">
                                Query name <span class="q-label__req">*</span>
                            </label>
                            <input class="q-input"
                                   placeholder="e.g. EU signups vs revenue — daily"
                                   value="@Query.Name"
                                   @oninput="@(e => Query.Name = e.Value?.ToString() ?? string.Empty)" />
                            <span class="q-help">A short, descriptive name. Shown in lists and notifications.</span>
                        </div>
                        <div class="q-field q-field--full">
                            <label class="q-label">
                                Description <span class="q-label__req">*</span>
                            </label>
                            <textarea class="q-textarea"
                                      placeholder="What does this query measure, and why? Include thresholds and audience."
                                      @oninput="@(e => Query.Description = e.Value?.ToString() ?? string.Empty)">@Query.Description</textarea>
                            <span class="q-help">@(Query.Description?.Length ?? 0)/280 · supports markdown links.</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Builder card (wraps the existing MudBlazor QueryStepBuilder) -->
            <div class="card builder-host">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.AccountTree" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Cross-data-source query builder</h3>
                    <span class="card__sub">@StepCount step@(StepCount == 1 ? "" : "s") · @ParamCount param@(ParamCount == 1 ? "" : "s")</span>
                </div>
                <div class="card__body card__body--flush">
                    <QueryStepBuilder Query="@Query"
                                      AvailableProjects="@_availableProjects"
                                      OnQueryChanged="@OnQueryChanged"
                                      OnPreviewStep="@OnPreviewStep"
                                      OnPreviewStepWithParameters="@OnPreviewStepWithParameters"
                                      OnExecuteQuery="@OnExecuteQuery"
                                      OnSaveQuery="@OnSaveQuery" />
                </div>
            </div>

            <!-- Query flow diagram -->
            @if (HasSteps)
            {
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.AltRoute" Size="Size.Small" Class="muted" />
                        <h3 class="card__title">Query flow</h3>
                        <span class="card__sub">step graph</span>
                    </div>
                    <div class="flow">
                        @foreach (var step in Query.Steps.OrderBy(s => s.StepOrder))
                        {
                            <div class="flow__node flow__node--db">
                                <div class="flow__node-title">STEP @step.StepOrder · @(string.IsNullOrWhiteSpace(step.Name) ? $"Step {step.StepOrder}" : step.Name.ToUpperInvariant())</div>
                                <div class="flow__node-sub">@(string.IsNullOrEmpty(step.DataSourceName) ? "—" : step.DataSourceName) · @(step.DatabaseEngineType?.ToString().ToLowerInvariant() ?? "?")</div>
                            </div>
                            @if (step.StepOrder < Query.Steps.Count)
                            {
                                <div class="flow__edge"></div>
                                <div class="flow__node flow__node--result">
                                    <div class="flow__node-title">@@result@step.StepOrder</div>
                                    <div class="flow__node-sub">intermediate result</div>
                                </div>
                                <div class="flow__edge"></div>
                            }
                        }
                    </div>
                </div>
            }

            @if (_currentQueryResult != null)
            {
                <div class="card">
                    <div class="card__head">
                        <MudIcon Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small" Class="muted" />
                        <h3 class="card__title">Execution result</h3>
                        <div class="card__actions">
                            <button class="btn btn--ghost" @onclick="ClosePreview" type="button">Close</button>
                        </div>
                    </div>
                    <div class="card__body">
                        <QueryExecutionResultsPreview ExecutionResult="@_currentQueryResult"
                                                      OnClose="@ClosePreview" />
                    </div>
                </div>
            }
        </div>

        <!-- Sticky right rail -->
        <aside class="q-aside">
            <div class="card">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.Info" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Query info</h3>
                </div>
                <div class="card__body" style="display: flex; flex-direction: column; gap: 10px;">
                    <InfoRow Label="Steps" Value="@StepCount.ToString()" />
                    <InfoRow Label="Sources used" Value="@SourceCount.ToString()" Detail="@SourceDetail" />
                    <InfoRow Label="Parameters" Value="@ParamCount.ToString()" Detail="@ParamDetail" />
                    <InfoRow Label="Estimated cost" Value="—" Detail="run to estimate" />
                    <InfoRow Label="Owner" Value="you" />
                    <InfoRow Label="Last edited" Value="just now" />
                    @if (Query.IsCrossDataSource)
                    {
                        <span class="pill pill--info" style="align-self: flex-start;">cross-data-source</span>
                    }
                    @if (Query.IsCrossDatabase)
                    {
                        <span class="pill pill--warn" style="align-self: flex-start;">cross-database</span>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card__head">
                    <MudIcon Icon="@Icons.Material.Rounded.Check" Size="Size.Small" Class="muted" />
                    <h3 class="card__title">Pre-flight checks</h3>
                    <div class="card__actions">
                        @if (FailingChecks > 0)
                        {
                            <span class="pill pill--warn">@FailingChecks to fix</span>
                        }
                        else
                        {
                            <span class="pill pill--ok">all clear</span>
                        }
                    </div>
                </div>
                <div class="checks">
                    <CheckItem Tone="@(HasName ? "ok" : "warn")"
                               Title="Query name"
                               Detail="@(HasName ? "looks good" : "add a descriptive name")" />
                    <CheckItem Tone="@(HasDescription ? "ok" : "warn")"
                               Title="Description"
                               Detail="@(HasDescription ? "described" : "explain what this measures")" />
                    <CheckItem Tone="@(HasSteps ? "ok" : "warn")"
                               Title="At least one step"
                               Detail="@(HasSteps ? $"{StepCount} step(s) defined" : "add a step to begin")" />
                    <CheckItem Tone="@(AllStepsHaveSql ? "ok" : "warn")"
                               Title="Every step has SQL"
                               Detail="@(AllStepsHaveSql ? "all steps populated" : "some steps are missing SQL")" />
                    <CheckItem Tone="@(AllStepsHaveSource ? "ok" : "warn")"
                               Title="Every step has a target source"
                               Detail="@(AllStepsHaveSource ? "sources assigned" : "select a target database")" />
                    <CheckItem Tone="pending"
                               Title="Run to validate output"
                               Detail="dry-run not executed yet" />
                </div>
            </div>

            <div class="callout">
                <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="Size.Small" Class="callout__icon" />
                <div>
                    <div class="callout__title">Tip · pipe results</div>
                    <div class="callout__sub">
                        Reference a previous step using <span class="mono">@@result1</span> in your
                        <span class="mono">FROM</span> clause to chain across sources.
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <div class="save-bar">
        <span class="save-bar__hint">
            <span class="pill pill--neutral mono" style="font-size: 10px;">DRAFT</span>
            <span>Unsaved changes — save to publish to your workspace.</span>
        </span>
        <span class="save-bar__spacer"></span>
        <span class="save-bar__hint">
            <span>Press</span>
            <span class="kbd">⌘</span><span class="kbd">↵</span>
            <span>to run ·</span>
            <span class="kbd">⌘</span><span class="kbd">S</span>
            <span>to save</span>
        </span>
        <button class="btn" @onclick="OnExecuteQuery" disabled="@(!HasSteps)" type="button">
            <MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="Size.Small" /> Run
        </button>
        <button class="btn btn--primary" @onclick="Submit" disabled="@(!IsFormValid || _loading)" type="button">
            <MudIcon Icon="@Icons.Material.Rounded.Check" Size="Size.Small" /> Save query
        </button>
    </div>
</div>

@inject ISnackbar Snackbar
@inject IQueryService QueryService
@inject IQueryExecutionPreviewService PreviewService
@inject IDataSourceService DataSourceService
@inject NavigationManager NavigationManager

@code
{
    public QueryData Query { get; set; } = new();

    private Dictionary<int, QueryStepBuilder.ProjectInfo> _availableProjects { get; set; } = [];
    private bool _loading;
    private QueryExecutionResult? _currentQueryResult;

    private bool HasName => !string.IsNullOrWhiteSpace(Query.Name);
    private bool HasDescription => !string.IsNullOrWhiteSpace(Query.Description);
    private bool HasSteps => Query.Steps?.Any() == true;
    private int StepCount => Query.Steps?.Count ?? 0;
    private bool AllStepsHaveSql => HasSteps && Query.Steps.All(s => !string.IsNullOrWhiteSpace(s.SqlValue));
    private bool AllStepsHaveSource => HasSteps && Query.Steps.All(s => s.DataSourceId > 0);

    private int SourceCount => HasSteps
        ? Query.Steps.Select(s => s.DataSourceId).Where(id => id > 0).Distinct().Count()
        : 0;
    private string SourceDetail => HasSteps
        ? string.Join(", ", Query.Steps.Select(s => s.DataSourceName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct())
        : string.Empty;

    private int ParamCount => HasSteps
        ? Query.Steps.SelectMany(s => s.Parameters ?? new()).Select(p => p.Name).Distinct().Count()
        : 0;
    private string ParamDetail => HasSteps
        ? string.Join(", ", Query.Steps.SelectMany(s => s.Parameters ?? new()).Select(p => "{" + p.Name + "}").Distinct().Take(4))
        : string.Empty;

    private int FailingChecks
    {
        get
        {
            var n = 0;
            if (!HasName) n++;
            if (!HasDescription) n++;
            if (!HasSteps) n++;
            if (!AllStepsHaveSql) n++;
            if (!AllStepsHaveSource) n++;
            return n;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var dataSources = await DataSourceService.GetDataSources(null, default);

        _availableProjects = dataSources
            .Where(x => x.DatabaseEngineType.HasValue)
            .ToDictionary(x => x.Id, x => new QueryStepBuilder.ProjectInfo
            {
                Name = x.Name,
                DatabaseEngine = x.DatabaseEngineType!.Value.ToString(),
                DatabaseEngineType = x.DatabaseEngineType.Value
            });

        Query = new QueryData { Name = "", Description = "", Steps = new() };
    }

    private async Task Submit()
    {
        if (_loading || !IsFormValid)
        {
            return;
        }

        _loading = true;

        try
        {
            var response = await QueryService.CreateQuery(Query, CancellationToken.None);

            if (response.Success)
            {
                Snackbar.Add(response.Message, Severity.Success);
                NavigationManager.NavigateTo("queries");
            }
            else
            {
                Snackbar.Add(response.Message, Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }

        _loading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("queries");
    }

    private bool IsFormValid =>
        HasName &&
        HasDescription &&
        HasSteps &&
        AllStepsHaveSql &&
        AllStepsHaveSource;

    private void OnQueryChanged(QueryData updatedQuery)
    {
        Query = updatedQuery;
        StateHasChanged();
    }

    private async Task OnPreviewStep(int stepOrder)
    {
        await OnPreviewStepWithParameters((stepOrder, new List<QueryParameterValue>()));
    }

    private async Task OnPreviewStepWithParameters((int stepOrder, List<QueryParameterValue> parameters) args)
    {
        var step = Query.Steps.FirstOrDefault(s => s.StepOrder == args.stepOrder);
        if (step == null)
        {
            Snackbar.Add($"Step {args.stepOrder} not found", Severity.Error);
            return;
        }

        try
        {
            Snackbar.Add($"Executing step {args.stepOrder}...", Severity.Info);

            var executionResult = await PreviewService.ExecuteTemporaryStepPreview(Query, args.stepOrder, args.parameters, CancellationToken.None);

            if (executionResult != null)
            {
                _currentQueryResult = new QueryExecutionResult
                {
                    Success = executionResult.Success,
                    ErrorMessage = executionResult.ErrorMessage,
                    TotalExecutionTimeMs = executionResult.ExecutionTimeMs,
                    IsMultiStep = Query.Steps.Count > 1,
                    IsCrossDataSource = Query.Steps.Select(s => s.DataSourceId).Distinct().Count() > 1,
                    IsCrossDatabase = Query.Steps.Where(s => s.DatabaseEngineType.HasValue).Select(s => s.DatabaseEngineType!.Value).Distinct().Count() > 1,
                    DataSourcesInvolved = Query.Steps.Select(s => s.DataSourceName).Distinct().ToList(),
                    DatabaseEnginesUsed = Query.Steps.Where(s => s.DatabaseEngineType.HasValue).Select(s => s.DatabaseEngineType!.Value).Distinct().ToList(),
                    StepResults = new List<QueryStepResult> { executionResult },
                    FinalResult = executionResult.Success && executionResult.PreviewResults != null ? new QueryResult
                    {
                        QueryResults = "Step preview results",
                        TotalRecords = executionResult.TotalRows,
                        DataSourceName = executionResult.DataSourceName,
                        SqlQuery = executionResult.StepName,
                        SubscriptionName = "Step Preview",
                        SubscriptionId = null,
                        ExecutionTimeMs = executionResult.ExecutionTimeMs,
                        AllRecords = executionResult.PreviewResults,
                        TopRecords = executionResult.PreviewResults?.Take(20).ToList() ?? new()
                    } : null
                };

                if (executionResult.Success)
                {
                    Snackbar.Add($"Step {args.stepOrder} executed successfully! Returned {executionResult.TotalRows} rows in {executionResult.ExecutionTimeMs:F0}ms", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Step {args.stepOrder} execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add($"Step {args.stepOrder} execution failed", Severity.Error);
            }

            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing step {args.stepOrder}: {e.Message}", Severity.Error);
        }
    }

    private void ClosePreview()
    {
        _currentQueryResult = null;
        StateHasChanged();
    }

    private async Task OnExecuteQuery()
    {
        if (!HasSteps)
        {
            Snackbar.Add("Add at least one step before executing the query", Severity.Warning);
            return;
        }

        try
        {
            Snackbar.Add("Executing full query...", Severity.Info);

            var executionResult = await PreviewService.ExecuteTemporaryQueryPreview(Query, CancellationToken.None);

            if (executionResult != null)
            {
                _currentQueryResult = executionResult;

                if (executionResult.Success)
                {
                    var message = executionResult.IsMultiStep
                        ? $"Query executed successfully! {executionResult.StepResults.Count} steps completed in {executionResult.TotalExecutionTimeMs:F0}ms"
                        : $"Query executed successfully! Returned {executionResult.FinalResult?.TotalRecords ?? 0} rows in {executionResult.TotalExecutionTimeMs:F0}ms";

                    Snackbar.Add(message, Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Query execution failed: {executionResult.ErrorMessage}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add("Query execution failed", Severity.Error);
            }

            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add($"Error executing query: {e.Message}", Severity.Error);
        }
    }

    private async Task OnSaveQuery()
    {
        await Submit();
    }
}
