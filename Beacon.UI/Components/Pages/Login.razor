@page "/login"
@rendermode InteractiveServer
@layout LoginLayout
@using Beacon.Core
@using Beacon.Core.Authorization

<BeaconPageTitle Title="Login" />

<div class="login-card-wrapper">
    <div class="login-card-glow"></div>
    <MudPaper Class="login-card pa-8 pa-sm-10" Elevation="0">
        <MudStack Spacing="5" AlignItems="AlignItems.Center">
            <!-- Logo and Title -->
            <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                <div class="login-logo-container">
                    <img src="../_content/Beacon.UI/favicon.svg" alt="Beacon" class="login-logo" />
                </div>
                <MudText Typo="Typo.h4" Class="login-title">Beacon</MudText>
                <MudText Typo="Typo.body2" Class="login-subtitle">Sign in to your workspace</MudText>
            </MudStack>

            <!-- Error Alert -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true"
                          Class="login-alert" Icon="@Icons.Material.Rounded.ErrorOutline">
                    @_errorMessage
                </MudAlert>
            }

            <!-- Single sign-on -->
            <div style="width: 100%;">
                <SsoLoginButton Disabled="@_isLoading" />
            </div>

            <!-- Login Form -->
            <MudForm @ref="_form" Style="width: 100%;">
                <MudStack Spacing="4">
                    <MudTextField @bind-Value="_username"
                                  Label="Username"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Text"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Rounded.PersonOutline"
                                  Disabled="@_isLoading"
                                  Required="true"
                                  RequiredError="Username is required"
                                  Immediate="true"
                                  Class="login-field" />

                    <MudTextField @bind-Value="_password"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                  OnAdornmentClick="TogglePasswordVisibility"
                                  Disabled="@_isLoading"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Immediate="true"
                                  OnKeyUp="HandleKeyUp"
                                  Class="login-field" />

                    @if (_configuration.Authentication.EnableRememberMe)
                    {
                        <MudCheckBox @bind-Value="_rememberMe"
                                     Label="Remember me"
                                     Color="Color.Primary"
                                     Disabled="@_isLoading"
                                     Dense="true"
                                     Class="login-checkbox" />
                    }

                    <MudButton FullWidth="true"
                               Size="Size.Large"
                               Disabled="@_isLoading"
                               OnClick="HandleLoginAsync"
                               Class="login-submit-btn">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Style="color: white;" />
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Rounded.ArrowForward" Class="mr-2" />
                            <span>Sign In</span>
                        }
                    </MudButton>
                </MudStack>
            </MudForm>
        </MudStack>
    </MudPaper>
</div>

<style>
    .login-card-wrapper {
        position: relative;
        max-width: 440px;
        width: 100%;
    }

    .login-card-glow {
        position: absolute;
        inset: -1px;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.4), rgba(99, 102, 241, 0.3), rgba(168, 85, 247, 0.4));
        opacity: 0.5;
        filter: blur(1px);
        z-index: 0;
        transition: opacity 0.3s ease;
    }

    .login-card-wrapper:hover .login-card-glow {
        opacity: 0.7;
    }

    .login-card {
        position: relative;
        z-index: 1;
        border-radius: 20px !important;
        background: rgba(15, 20, 35, 0.85) !important;
        backdrop-filter: blur(40px) saturate(1.5);
        -webkit-backdrop-filter: blur(40px) saturate(1.5);
        border: 1px solid rgba(255, 255, 255, 0.06) !important;
    }

    .login-logo-container {
        width: 72px;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.15);
        margin-bottom: 4px;
    }

    .login-logo {
        width: 48px;
        height: 48px;
        filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
    }

    .login-title {
        font-weight: 700 !important;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, #e2e8f0 0%, #f8fafc 50%, #cbd5e1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .login-subtitle {
        color: rgba(148, 163, 184, 0.8) !important;
        font-size: 0.9rem !important;
    }

    .login-alert {
        width: 100%;
        border-radius: 10px !important;
    }

    .login-field .mud-input-outlined .mud-input-outlined-border {
        border-radius: 10px !important;
        border-color: rgba(148, 163, 184, 0.15) !important;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .login-field .mud-input-outlined:hover .mud-input-outlined-border {
        border-color: rgba(99, 102, 241, 0.4) !important;
    }

    .login-field .mud-input-outlined.mud-input-focused .mud-input-outlined-border {
        border-color: rgba(99, 102, 241, 0.6) !important;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .login-field .mud-input-adornment svg {
        color: rgba(148, 163, 184, 0.5);
    }

    .login-checkbox .mud-typography {
        font-size: 0.85rem;
        color: rgba(148, 163, 184, 0.7);
    }

    .login-submit-btn {
        background: linear-gradient(135deg, #06b6d4 0%, #6366f1 50%, #a855f7 100%) !important;
        color: white !important;
        font-weight: 600 !important;
        font-size: 0.95rem !important;
        letter-spacing: 0.3px;
        border-radius: 10px !important;
        height: 48px !important;
        text-transform: none !important;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3) !important;
        transition: all 0.3s ease !important;
    }

    .login-submit-btn:hover {
        box-shadow: 0 6px 25px rgba(99, 102, 241, 0.45) !important;
        transform: translateY(-1px);
    }

    .login-submit-btn:disabled {
        opacity: 0.6 !important;
        box-shadow: none !important;
        transform: none !important;
    }
</style>

@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject BeaconConfiguration _configuration
@inject IBeaconUserContext UserContext

@code {
    private MudForm _form = null!;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private bool _rememberMe;
    private bool _isLoading;
    private bool _showPassword;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        // If already authenticated, redirect to dashboard
        if (UserContext.IsAuthenticated)
        {
            NavigateToDashboard();
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.ContainsKey("ssoError"))
        {
            _errorMessage = "Single sign-on failed. Please try again or sign in with username and password.";
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLoginAsync();
        }
    }

    private async Task HandleLoginAsync()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            // Build the API URL
            var baseUri = new Uri(NavigationManager.BaseUri);
            var apiUrl = $"{baseUri.AbsolutePath.TrimEnd('/')}/api/auth/login";

            // Call the login API via JavaScript (so browser receives the cookie)
            var result = await JS.InvokeAsync<LoginResult>("beaconLogin", apiUrl, _username, _password, _rememberMe);

            if (result.Success && !string.IsNullOrEmpty(result.RedirectUrl))
            {
                // Navigate with force reload to apply the new cookie
                NavigationManager.NavigateTo(result.RedirectUrl, forceLoad: true);
            }
            else
            {
                _errorMessage = result.Error ?? "Invalid username or password.";
                _isLoading = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An error occurred during login. Please try again.";
            Console.WriteLine($"Login error: {ex.Message}");
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void NavigateToDashboard()
    {
        var redirectPath = _configuration.Authentication.LoginRedirectPath;
        var baseUri = new Uri(NavigationManager.BaseUri);
        var path = baseUri.AbsolutePath.TrimEnd('/');
        NavigationManager.NavigateTo($"{path}{redirectPath}", forceLoad: true);
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private class LoginResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public string? RedirectUrl { get; set; }
    }
}
