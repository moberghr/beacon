@* Reusable Beacon-styled text field. Matches the q-field design used on AddQuery,
   but with unscoped .bx-field classes so it works in both pages and dialogs.

   Usage:
       <BeaconTextField @bind-Value="_name"
                        Label="Folder name"
                        Required="true"
                        Placeholder="e.g. Customer KPIs"
                        HelpText="Shown in lists and notifications." />

       <BeaconTextField @bind-Value="_description"
                        Label="Description"
                        Multiline="true"
                        Rows="3"
                        HelpText="Optional." /> *@

<div class="bx-field @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bx-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bx-label__req">*</span>
            }
        </label>
    }

    @if (Multiline)
    {
        <textarea id="@_id"
                  class="bx-textarea @(HasError ? "bx-textarea--error" : "")"
                  style="@(Rows > 0 ? $"min-height: {Rows * 22 + 16}px;" : "")"
                  placeholder="@Placeholder"
                  maxlength="@(MaxLength > 0 ? MaxLength.ToString() : null)"
                  disabled="@Disabled"
                  readonly="@ReadOnly"
                  @oninput="OnInput"
                  @onchange="OnChange"
                  @onblur="OnBlurInternal">@Value</textarea>
    }
    else if (!string.IsNullOrEmpty(AdornmentIcon))
    {
        <div class="bx-input-wrap @(AdornmentPosition == "start" ? "bx-input-wrap--start" : "bx-input-wrap--end")">
            <input id="@_id"
                   class="bx-input @(HasError ? "bx-input--error" : "")"
                   type="@InputType"
                   placeholder="@Placeholder"
                   maxlength="@(MaxLength > 0 ? MaxLength.ToString() : null)"
                   disabled="@Disabled"
                   readonly="@ReadOnly"
                   value="@Value"
                   @oninput="OnInput"
                   @onchange="OnChange"
                   @onblur="OnBlurInternal" />
            <button type="button"
                    class="bx-input__adornment"
                    tabindex="-1"
                    disabled="@Disabled"
                    @onclick="OnAdornmentClickInternal">
                <MudIcon Icon="@AdornmentIcon" Size="Size.Small" />
            </button>
        </div>
    }
    else
    {
        <input id="@_id"
               class="bx-input @(HasError ? "bx-input--error" : "")"
               type="@InputType"
               placeholder="@Placeholder"
               maxlength="@(MaxLength > 0 ? MaxLength.ToString() : null)"
               disabled="@Disabled"
               readonly="@ReadOnly"
               value="@Value"
               @oninput="OnInput"
               @onchange="OnChange"
               @onblur="OnBlurInternal" />
    }

    @if (HasError)
    {
        <span class="bx-help bx-help--error">@ErrorText</span>
    }
    else if (!string.IsNullOrEmpty(HelpText))
    {
        <span class="bx-help">@HelpText</span>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public string? ErrorText { get; set; }

    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Multiline { get; set; }

    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public int MaxLength { get; set; }

    /// <summary>Input type: text, email, password, number, url, tel, search.</summary>
    [Parameter] public string InputType { get; set; } = "text";

    /// <summary>Fire ValueChanged on every keystroke. Default true (matches MudTextField Immediate).</summary>
    [Parameter] public bool Immediate { get; set; } = true;

    /// <summary>Extra class on the wrapper (e.g. "bx-field--full" for full-width grid cell).</summary>
    [Parameter] public string? CssClass { get; set; }

    /// <summary>MudBlazor icon string (e.g. Icons.Material.Rounded.Visibility). When set, renders an adornment button.</summary>
    [Parameter] public string? AdornmentIcon { get; set; }

    /// <summary>"start" or "end" (default).</summary>
    [Parameter] public string AdornmentPosition { get; set; } = "end";

    [Parameter] public EventCallback OnAdornmentClick { get; set; }

    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }

    private readonly string _id = $"bxf-{Guid.NewGuid().ToString("N")[..8]}";

    private bool HasError => !string.IsNullOrEmpty(ErrorText);

    private async Task OnInput(ChangeEventArgs e)
    {
        if (!Immediate) return;
        var newValue = e.Value?.ToString();
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task OnChange(ChangeEventArgs e)
    {
        if (Immediate) return;
        var newValue = e.Value?.ToString();
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task OnBlurInternal(FocusEventArgs e)
    {
        if (OnBlur.HasDelegate)
        {
            await OnBlur.InvokeAsync(e);
        }
    }

    private async Task OnAdornmentClickInternal()
    {
        if (OnAdornmentClick.HasDelegate)
        {
            await OnAdornmentClick.InvokeAsync();
        }
    }
}
