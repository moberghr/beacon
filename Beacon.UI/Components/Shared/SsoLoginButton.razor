@using Microsoft.Extensions.Options
@using Beacon.Core.Authentication
@inject IOptions<OidcAuthenticationOptions> OidcOptions
@inject NavigationManager Nav

@if (OidcOptions.Value.Enabled)
{
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               FullWidth="true"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.VpnKey"
               Disabled="@Disabled"
               OnClick="HandleSsoClick">
        Sign in with @OidcOptions.Value.DisplayName
    </MudButton>

    <MudDivider Class="my-3" />

    <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
        or sign in with username and password
    </MudText>
}

@code {
    [Parameter] public bool Disabled { get; set; }

    private void HandleSsoClick()
    {
        var baseUri = new Uri(Nav.BaseUri);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        var returnUrl = Uri.EscapeDataString($"{basePath}/");
        Nav.NavigateTo($"{basePath}/api/auth/sso/challenge?returnUrl={returnUrl}", forceLoad: true);
    }
}
