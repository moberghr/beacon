@* Dropdown / multi-select — Beacon visual language. Generic over T (the value type).

   Three usage modes:

   1) Enum (auto-populated from Enum.GetNames):
       <BeaconSelect T="DataSourceType" @bind-Value="_type" Label="Type" Required="true" />

   2) Item list with selectors:
       <BeaconSelect T="int"
                     Items="_projects"
                     ItemValueSelector="@(x => ((Project)x).Id)"
                     ItemTextSelector="@(x => ((Project)x).Name)"
                     @bind-Value="_projectId" />

   3) Multi-select:
       <BeaconSelect T="int" MultiSelection="true"
                     Items="_projects"
                     ItemValueSelector="@(x => ((Project)x).Id)"
                     ItemTextSelector="@(x => ((Project)x).Name)"
                     @bind-SelectedValues="_projectIds" />

   For static option lists, prefer enum or pre-build a List of a small record type. *@

@typeparam T
@using System.Linq

<div class="bx-field @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bx-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bx-label__req">*</span>
            }
        </label>
    }

    <div class="bx-select-wrap">
        @if (MultiSelection)
        {
            <select id="@_id"
                    class="bx-select @(HasError ? "bx-select--error" : "")"
                    multiple
                    disabled="@Disabled"
                    @onchange="OnMultiChange">
                @foreach (var (value, text) in EnumerateOptions())
                {
                    var sel = SelectedValues != null && SelectedValues.Contains(value);
                    <option value="@FormatValue(value)" selected="@sel">@text</option>
                }
            </select>
        }
        else
        {
            <select id="@_id"
                    class="bx-select @(HasError ? "bx-select--error" : "")"
                    disabled="@Disabled"
                    @onchange="OnSingleChange">
                @if (Clearable || HasNoSelection())
                {
                    <option value="" selected="@HasNoSelection()">@(Placeholder ?? "")</option>
                }
                @foreach (var (value, text) in EnumerateOptions())
                {
                    var sel = Value != null && EqualityComparer<T>.Default.Equals(Value, value);
                    <option value="@FormatValue(value)" selected="@sel">@text</option>
                }
            </select>
            @if (Clearable && Value != null && !Disabled)
            {
                <button type="button"
                        class="bx-select__clear"
                        tabindex="-1"
                        @onclick="ClearSingle"
                        title="Clear">
                    <MudIcon Icon="@Icons.Material.Rounded.Close" Size="Size.Small" />
                </button>
            }
        }
    </div>

    @if (HasError)
    {
        <span class="bx-help bx-help--error">@ErrorText</span>
    }
    else if (!string.IsNullOrEmpty(HelpText))
    {
        <span class="bx-help">@HelpText</span>
    }
</div>

@code {
    // Single-select
    [Parameter] public T? Value { get; set; }
    [Parameter] public EventCallback<T?> ValueChanged { get; set; }

    // Multi-select
    [Parameter] public IEnumerable<T>? SelectedValues { get; set; }
    [Parameter] public EventCallback<IEnumerable<T>> SelectedValuesChanged { get; set; }
    [Parameter] public bool MultiSelection { get; set; }

    // Items (object-based; cast in selectors)
    [Parameter] public IEnumerable<object>? Items { get; set; }
    [Parameter] public Func<object, T>? ItemValueSelector { get; set; }
    [Parameter] public Func<object, string>? ItemTextSelector { get; set; }

    // Display
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? CssClass { get; set; }

    // State
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Clearable { get; set; }

    private readonly string _id = $"bxs-{Guid.NewGuid().ToString("N")[..8]}";

    private bool HasError => !string.IsNullOrEmpty(ErrorText);

    private bool HasNoSelection() => Value == null;

    private IEnumerable<(T Value, string Text)> EnumerateOptions()
    {
        if (Items != null && ItemValueSelector != null && ItemTextSelector != null)
        {
            foreach (var item in Items)
            {
                yield return (ItemValueSelector(item), ItemTextSelector(item));
            }
            yield break;
        }

        var underlying = Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T);
        if (underlying.IsEnum)
        {
            foreach (var name in Enum.GetNames(underlying))
            {
                var enumValue = Enum.Parse(underlying, name);
                yield return ((T)enumValue, name);
            }
        }
    }

    private static string FormatValue(T value) =>
        value is null ? "" : Convert.ToString(value, System.Globalization.CultureInfo.InvariantCulture) ?? "";

    private static T? ParseValue(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return default;
        var underlying = Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T);
        try
        {
            if (underlying.IsEnum)
            {
                return (T)Enum.Parse(underlying, raw);
            }
            return (T?)Convert.ChangeType(raw, underlying, System.Globalization.CultureInfo.InvariantCulture);
        }
        catch
        {
            return default;
        }
    }

    private async Task OnSingleChange(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        var parsed = ParseValue(raw);
        Value = parsed;
        await ValueChanged.InvokeAsync(parsed);
    }

    private async Task OnMultiChange(ChangeEventArgs e)
    {
        if (e.Value is not string[] arr)
        {
            await SelectedValuesChanged.InvokeAsync(Enumerable.Empty<T>());
            return;
        }

        var parsed = arr
            .Select(ParseValue)
            .Where(x => x != null)
            .Cast<T>()
            .ToList();

        SelectedValues = parsed;
        await SelectedValuesChanged.InvokeAsync(parsed);
    }

    private async Task ClearSingle()
    {
        Value = default;
        await ValueChanged.InvokeAsync(default);
    }
}
