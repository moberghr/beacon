@* Button — Beacon visual language. Uses canonical .btn / .btn--primary etc. *@

<button type="@ButtonType"
        class="btn @VariantClass @SizeClass @CssClass"
        disabled="@(Disabled || Loading)"
        @onclick="OnClickInternal"
        @onclick:stopPropagation="@StopPropagation"
        title="@Title">
    @if (Loading)
    {
        <span class="btn__spinner" aria-hidden="true"></span>
    }
    else if (!string.IsNullOrEmpty(Icon))
    {
        <MudIcon Icon="@Icon" Class="btn__icon" Size="MudBlazor.Size.Small" />
    }
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else if (!string.IsNullOrEmpty(Text))
    {
        @Text
    }
</button>

@code {
    /// <summary>"default" (outlined neutral), "primary", "ghost", "danger", "subtle".</summary>
    [Parameter] public string Variant { get; set; } = "default";

    /// <summary>"sm", "md" (default), "lg".</summary>
    [Parameter] public string Size { get; set; } = "md";

    /// <summary>MudBlazor icon string (e.g. Icons.Material.Rounded.Check).</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Inline text. Prefer ChildContent; this is a shortcut for the icon-+-text case.</summary>
    [Parameter] public string? Text { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool StopPropagation { get; set; }

    /// <summary>"button" (default), "submit", "reset".</summary>
    [Parameter] public string ButtonType { get; set; } = "button";

    [Parameter] public string? Title { get; set; }
    [Parameter] public string? CssClass { get; set; }

    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string VariantClass => Variant switch
    {
        "primary" => "btn--primary",
        "ghost"   => "btn--ghost",
        "danger"  => "btn--danger",
        "subtle"  => "btn--subtle",
        _         => ""
    };

    private string SizeClass => Size switch
    {
        "sm" => "btn--sm",
        "lg" => "btn--lg",
        _    => ""
    };

    private async Task OnClickInternal(MouseEventArgs e)
    {
        if (Loading || Disabled) return;
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(e);
        }
    }
}
