@if (AiActorId.HasValue)
{
    @if (Compact)
    {
        <MudTooltip Text="@($"AI Managed by {AiActorName}")">
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Class="mr-1"/>AI
            </MudChip>
        </MudTooltip>
    }
    else
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Class="mr-1" />
            AI Managed
        </MudChip>
        @if (!string.IsNullOrEmpty(AiActorName))
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                @AiActorName
            </MudChip>
        }
    }
}
else
{
    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1"/>@(Compact ? "User" : "User Defined")
    </MudChip>
}

@code
{
    [Parameter]
    public int? AiActorId { get; set; }

    [Parameter]
    public string? AiActorName { get; set; }

    [Parameter]
    public bool Compact { get; set; } = true;
}
