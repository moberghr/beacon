<MudButton
    Class="@Class"
    OnClick="@HandleClick"
    Variant="Variant.Filled"
    Disabled="@(Disabled || _isSubmitting)"
    Style="@($"color: white; background: {Colors.Green.Default};")"
>
    @Text
</MudButton>

@code
{
    [Parameter]
    public string Text { get; set; } = "Save";

    [Parameter]
    public string Class { get; set; } = "mr-4";

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private bool _isSubmitting;

    private async Task HandleClick()
    {
        _isSubmitting = true;
        await OnClick.InvokeAsync();
        _isSubmitting = false;
    }
}
